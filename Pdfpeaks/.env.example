# ============================================================
# Pdfpeaks Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# SQL Server connection string (required in Production)
DB_CONNECTION_STRING=Server=localhost;Database=Pdfpeaks;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=true;

# ── Redis ────────────────────────────────────────────────────
REDIS_CONNECTION_STRING=localhost:6379

# ── JWT Authentication ───────────────────────────────────────
# Must be at least 32 characters. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# ── Azure OpenAI (optional) ──────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# ── Azure Blob Storage (optional) ───────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# ── Stripe Payments (optional) ──────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Python AI Service ────────────────────────────────────────
AI_API_KEY=your-ai-service-api-key

# ── Qdrant Vector DB (optional) ─────────────────────────────
QDRANT_API_KEY=your-qdrant-api-key
