{
  "ConnectionStrings": {
    "DefaultConnection": "${DB_CONNECTION_STRING}",
    "Redis": "${REDIS_CONNECTION_STRING:-localhost:6379}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true,
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  
  "Redis": {
    "InstanceName": "pdfpeaks",
    "ConnectionString": "${REDIS_CONNECTION_STRING:-localhost:6379}"
  },
  
  "Jwt": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "Pdfpeaks",
    "Audience": "PdfpeaksUsers",
    "ExpiryHours": 24
  },
  
  "RateLimit": {
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      }
    ],
    "ClientWhitelist": []
  },
  
  "IpRateLimit": {
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 200
      }
    ],
    "EndpointWhitelist": [
      "/health",
      "/healthz"
    ],
    "ClientWhitelist": []
  },
  
  "AzureStorage": {
    "ConnectionString": "${AZURE_STORAGE_CONNECTION_STRING}",
    "BlobContainer": "pdfpeaks-files"
  },
  
  "Stripe": {
    "SecretKey": "${STRIPE_SECRET_KEY}",
    "PublishableKey": "${STRIPE_PUBLISHABLE_KEY}",
    "WebhookSecret": "${STRIPE_WEBHOOK_SECRET}"
  },
  
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/pdfpeaks-.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  },
  
  "ReactApp": {
    "Url": "http://localhost:3000"
  },
  
  "Features": {
    "EnableAIAnalysis": true,
    "EnableRealTimeUpdates": true,
    "EnableRateLimiting": true,
    "EnableMetrics": true
  },
  
  "AIService": {
    "Enabled": true,
    "Url": "http://localhost:8000",
    "ApiKey": "${AI_API_KEY}"
  },

  "Conversion": {
    "PdfToWordPrimaryEngine": "pdf2docx",
    "PythonScriptTimeoutSeconds": 180
  }
}
