@{
    ViewData["Title"] = "Compress PDF - PdfPeaks";
}

@Html.AntiForgeryToken()

<div class="tool-wrap py-5">
    <div class="container">
        <div class="text-center mb-4">
            <h1 class="fw-bold mb-2">Compress PDF</h1>
            <p class="text-muted mb-0">Reduce file size while balancing output quality</p>
        </div>

        <input type="file" id="fileInput" accept=".pdf,application/pdf" style="display:none;" />

        <div class="row g-4 justify-content-center">
            <div class="col-lg-8">
                <div id="uploadZone" class="upload-zone card shadow-sm border-0">
                    <div class="card-body p-5 text-center">
                        <div class="upload-icon mb-3">
                            <i class="fas fa-file-zipper"></i>
                        </div>
                        <h5 class="mb-2">Drop PDF here</h5>
                        <p class="text-muted mb-3">or select a file from your device</p>
                        <button type="button" class="btn btn-primary px-4" id="selectFileBtn">
                            <i class="fas fa-folder-open me-2"></i>Select PDF
                        </button>
                        <p class="small text-muted mt-3 mb-0">Supported: .pdf</p>
                    </div>
                </div>

                <div id="configCard" class="card shadow-sm border-0 mt-3 d-none">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <div class="fw-semibold" id="fileName">-</div>
                                <div class="small text-muted" id="fileMeta">-</div>
                            </div>
                            <button type="button" class="btn-close" id="clearFile" aria-label="Clear"></button>
                        </div>
                        <hr />

                        <label class="form-label fw-semibold">Compression Level</label>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="quality-card selected" data-quality="80">
                                    <div class="fw-semibold">Low Compression</div>
                                    <div class="small text-muted">Best quality, larger file</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="quality-card" data-quality="50">
                                    <div class="fw-semibold">Balanced</div>
                                    <div class="small text-muted">Recommended overall output</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="quality-card" data-quality="20">
                                    <div class="fw-semibold">High Compression</div>
                                    <div class="small text-muted">Smaller file, lower detail</div>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="button" class="btn btn-success btn-lg" id="compressBtn">
                                <i class="fas fa-compress me-2"></i>Compress PDF
                            </button>
                        </div>
                    </div>
                </div>

                <div id="resultCard" class="card shadow-sm border-0 mt-3 d-none">
                    <div class="card-body text-center py-5">
                        <div class="mb-3 text-success result-icon"><i class="fas fa-circle-check"></i></div>
                        <h4 class="mb-2">Compression Completed</h4>
                        <p class="text-muted mb-4" id="resultMessage">Your compressed PDF is ready.</p>
                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            <a id="downloadBtn" href="#" class="btn btn-success btn-lg">
                                <i class="fas fa-download me-2"></i>Download PDF
                            </a>
                            <button type="button" class="btn btn-outline-secondary btn-lg" id="compressAnotherBtn">
                                <i class="fas fa-rotate me-2"></i>Compress Another File
                            </button>
                        </div>
                    </div>
                </div>

                <div id="loading" class="text-center mt-3 d-none">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <div class="mt-2 text-muted">Compressing PDF...</div>
                </div>

                <div id="errorAlert" class="alert alert-danger mt-3 d-none" role="alert"></div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 info-card">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3"><i class="fas fa-circle-info me-2"></i>Compression Notes</h6>
                        <div class="small text-muted">
                            <div class="mb-2">Low compression keeps the best readability.</div>
                            <div class="mb-2">Balanced mode is good for general sharing.</div>
                            <div class="mb-2">High compression is useful for strict size limits.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .tool-wrap {
            background:
                radial-gradient(circle at 10% 20%, rgba(13, 110, 253, 0.11), transparent 40%),
                radial-gradient(circle at 90% 18%, rgba(25, 135, 84, 0.08), transparent 36%),
                #f8f9fb;
        }

        .upload-zone {
            border: 2px dashed #e2e6ea;
            transition: all 0.2s ease;
            cursor: pointer;
            background: #fff;
        }

        .upload-zone:hover,
        .upload-zone.dragover {
            border-color: #0d6efd;
            transform: translateY(-1px);
        }

        .upload-icon {
            font-size: 3rem;
            color: #0d6efd;
        }

        .quality-card {
            border: 2px solid #e9ecef;
            border-radius: 10px;
            padding: 0.8rem;
            background: #fff;
            cursor: pointer;
            transition: all 0.2s ease;
            height: 100%;
        }

        .quality-card:hover {
            border-color: #0d6efd;
        }

        .quality-card.selected {
            border-color: #0d6efd;
            background: #eef5ff;
        }

        .info-card {
            position: sticky;
            top: 88px;
        }

        .result-icon {
            font-size: 3rem;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const fileInput = document.getElementById('fileInput');
            const uploadZone = document.getElementById('uploadZone');
            const selectFileBtn = document.getElementById('selectFileBtn');
            const configCard = document.getElementById('configCard');
            const resultCard = document.getElementById('resultCard');
            const clearFile = document.getElementById('clearFile');
            const compressBtn = document.getElementById('compressBtn');
            const compressAnotherBtn = document.getElementById('compressAnotherBtn');
            const loading = document.getElementById('loading');
            const errorAlert = document.getElementById('errorAlert');
            const fileName = document.getElementById('fileName');
            const fileMeta = document.getElementById('fileMeta');
            const resultMessage = document.getElementById('resultMessage');
            const downloadBtn = document.getElementById('downloadBtn');

            let currentFile = null;
            let selectedQuality = 80;

            function parseJsonSafe(text) {
                if (!text || !text.trim()) return {};
                try { return JSON.parse(text); } catch { return {}; }
            }

            function formatBytes(bytes) {
                if (!bytes) return '0 B';
                const units = ['B', 'KB', 'MB', 'GB'];
                let value = bytes;
                let i = 0;
                while (value >= 1024 && i < units.length - 1) {
                    value /= 1024;
                    i++;
                }
                return `${value.toFixed(value >= 100 ? 0 : 2)} ${units[i]}`;
            }

            function showError(message) {
                errorAlert.textContent = message;
                errorAlert.classList.remove('d-none');
            }

            function hideError() {
                errorAlert.classList.add('d-none');
                errorAlert.textContent = '';
            }

            function reset() {
                currentFile = null;
                fileInput.value = '';
                uploadZone.classList.remove('d-none');
                configCard.classList.add('d-none');
                resultCard.classList.add('d-none');
                loading.classList.add('d-none');
                compressBtn.disabled = false;
                compressBtn.innerHTML = '<i class="fas fa-compress me-2"></i>Compress PDF';
                hideError();
            }

            function setFile(file) {
                hideError();
                if (!file || !file.name.toLowerCase().endsWith('.pdf')) {
                    showError('Please select a valid PDF file.');
                    return;
                }
                currentFile = file;
                fileName.textContent = file.name;
                fileMeta.textContent = `Size: ${formatBytes(file.size)}`;
                uploadZone.classList.add('d-none');
                resultCard.classList.add('d-none');
                configCard.classList.remove('d-none');
            }

            function postWithXhr(url, formData) {
                return new Promise((resolve, reject) => {
                    const xhr = new XMLHttpRequest();
                    xhr.open('POST', url, true);
                    xhr.withCredentials = true;
                    xhr.onreadystatechange = function () {
                        if (xhr.readyState !== 4) return;
                        resolve({
                            ok: xhr.status >= 200 && xhr.status < 300,
                            status: xhr.status,
                            text: xhr.responseText || ''
                        });
                    };
                    xhr.onerror = function () {
                        reject(new Error('Network transport failed (XHR).'));
                    };
                    xhr.send(formData);
                });
            }

            document.querySelectorAll('.quality-card').forEach(card => {
                card.addEventListener('click', function () {
                    document.querySelectorAll('.quality-card').forEach(c => c.classList.remove('selected'));
                    card.classList.add('selected');
                    selectedQuality = Number(card.dataset.quality || '80');
                });
            });

            selectFileBtn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                fileInput.click();
            });

            uploadZone.addEventListener('click', function () {
                fileInput.click();
            });

            fileInput.addEventListener('change', function (e) {
                if (e.target.files && e.target.files.length > 0) {
                    setFile(e.target.files[0]);
                }
            });

            uploadZone.addEventListener('dragover', function (e) {
                e.preventDefault();
                uploadZone.classList.add('dragover');
            });

            uploadZone.addEventListener('dragleave', function () {
                uploadZone.classList.remove('dragover');
            });

            uploadZone.addEventListener('drop', function (e) {
                e.preventDefault();
                uploadZone.classList.remove('dragover');
                const file = e.dataTransfer?.files?.[0];
                if (file) setFile(file);
            });

            clearFile.addEventListener('click', reset);
            compressAnotherBtn.addEventListener('click', reset);

            compressBtn.addEventListener('click', async function () {
                if (!currentFile) return;

                hideError();
                compressBtn.disabled = true;
                compressBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Compressing...';
                loading.classList.remove('d-none');

                try {
                    const fd = new FormData();
                    fd.append('file', currentFile);
                    fd.append('quality', String(selectedQuality));

                    let res;
                    try {
                        const fetchRes = await fetch('/Pdf/Compress', { method: 'POST', body: fd });
                        res = { ok: fetchRes.ok, status: fetchRes.status, text: await fetchRes.text() };
                    } catch {
                        res = await postWithXhr('/Pdf/Compress', fd);
                    }

                    const result = parseJsonSafe(res.text);
                    if (result.success && result.downloadUrl) {
                        resultMessage.textContent = result.message || 'Compression completed successfully.';
                        downloadBtn.href = result.downloadUrl;
                        downloadBtn.setAttribute('download', result.fileName || 'compressed.pdf');
                        configCard.classList.add('d-none');
                        resultCard.classList.remove('d-none');
                    } else {
                        const statusText = !res.ok ? ` (HTTP ${res.status})` : '';
                        showError(result.message || `Compression failed${statusText}.`);
                    }
                } catch (err) {
                    showError('Error while compressing PDF: ' + (err.message || 'Unknown error'));
                } finally {
                    loading.classList.add('d-none');
                    compressBtn.disabled = false;
                    compressBtn.innerHTML = '<i class="fas fa-compress me-2"></i>Compress PDF';
                }
            });
        });
    </script>
}
