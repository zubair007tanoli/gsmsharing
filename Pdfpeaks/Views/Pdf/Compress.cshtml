@{
    ViewData["Title"] = "Compress PDF - PdfPeaks";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header -->
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold text-primary">
                    <i class="bi bi-file-earmark-zip"></i> Compress PDF
                </h1>
                <p class="lead text-muted">Reduce PDF file size while maintaining quality</p>
            </div>

            <!-- Drop Zone -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div id="dropZone" class="drop-zone border-2 border-dashed rounded-4 p-5 text-center bg-light" style="position: relative;">
                        <div class="mb-3">
                            <i class="bi bi-cloud-upload display-1 text-primary"></i>
                        </div>
                        <h4 class="mb-2">Drop your PDF file here</h4>
                        <p class="text-muted mb-3">or</p>
                        <label class="btn btn-primary btn-lg" style="position: relative; z-index: 1;">
                            <i class="bi bi-folder-plus"></i> Select PDF File
                            <input type="file" id="fileInput" accept=".pdf" multiple style="position: absolute; opacity: 0; width: 100%; height: 100%; top: 0; left: 0; cursor: pointer; z-index: 2;">
                        </label>
                        <p class="text-muted mt-3 mb-0">
                            <small>Maximum file size: 100MB</small>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Compression Options -->
            <div id="compressOptions" class="card shadow-sm mb-4 d-none">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="bi bi-sliders"></i> Compression Options
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <label class="form-label fw-bold">Compression Level:</label>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="form-check card h-100 p-3" onclick="selectCompression('low')">
                                    <input class="form-check-input" type="radio" name="compressionLevel" id="lowQuality" value="low">
                                    <label class="form-check-label w-100" for="lowQuality">
                                        <i class="bi bi-gem text-success fs-3 d-block mb-2"></i>
                                        <strong>Low Compression</strong>
                                        <small class="text-muted d-block">Best quality, larger file</small>
                                        <span class="badge bg-success mt-2">Recommended</span>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check card h-100 p-3" onclick="selectCompression('medium')">
                                    <input class="form-check-input" type="radio" name="compressionLevel" id="mediumQuality" value="medium" checked>
                                    <label class="form-check-label w-100" for="mediumQuality">
                                        <i class="bi bi-balance text-warning fs-3 d-block mb-2"></i>
                                        <strong>Medium</strong>
                                        <small class="text-muted d-block">Balanced quality/size</small>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check card h-100 p-3" onclick="selectCompression('high')">
                                    <input class="form-check-input" type="radio" name="compressionLevel" id="highQuality" value="high">
                                    <label class="form-check-label w-100" for="highQuality">
                                        <i class="bi bi-lightning text-danger fs-3 d-block mb-2"></i>
                                        <strong>High Compression</strong>
                                        <small class="text-muted d-block">Smaller file, lower quality</small>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- File Info -->
                    <div id="fileInfo" class="alert alert-info">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong id="fileName">document.pdf</strong>
                                <span class="ms-3 text-muted" id="fileSize">0 MB</span>
                            </div>
                            <i class="bi bi-file-earmark-pdf text-danger fs-4"></i>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <button id="compressBtn" class="btn btn-success btn-lg w-100">
                        <i class="bi bi-file-earmark-zip"></i> Compress PDF
                    </button>
                </div>
            </div>

            <!-- Success Result -->
            <div id="resultContainer" class="card shadow-sm mb-4" style="display: none;">
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success display-1"></i>
                    </div>
                    <h3 class="card-title" id="successMessage">PDF Compressed Successfully!</h3>
                    
                    <div class="row justify-content-center mt-4">
                        <div class="col-md-8">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <div class="row text-center">
                                        <div class="col-4">
                                            <small class="text-muted">Original Size</small>
                                            <div class="fw-bold" id="originalSize">-</div>
                                        </div>
                                        <div class="col-4">
                                            <i class="bi bi-arrow-right text-primary fs-4"></i>
                                            <div class="text-success fw-bold" id="reduction">-</div>
                                            <small class="text-muted">Reduction</small>
                                        </div>
                                        <div class="col-4">
                                            <small class="text-muted">Compressed</small>
                                            <div class="fw-bold" id="compressedSize">-</div>
                                        </div>
                                    </div>
                                    
                                    <!-- Progress bar showing compression -->
                                    <div class="progress mt-3" style="height: 8px;">
                                        <div class="progress-bar bg-success" id="reductionBar" role="progressbar" style="width: 0%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a id="downloadBtn" href="#" class="btn btn-primary btn-lg">
                            <i class="bi bi-download"></i> Download Compressed PDF
                        </a>
                        <button id="compressAnotherBtn" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-arrow-repeat"></i> Compress Another File
                        </button>
                    </div>
                </div>
            </div>

            <!-- Error Alert -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="loading-overlay d-none">
    <div class="spinner-container">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h4 class="mt-3 text-white">Compressing your PDF...</h4>
        <p class="text-white-50">This may take a few moments depending on file size</p>
    </div>
</div>

@section Styles {
    <style>
        .drop-zone {
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .drop-zone:hover {
            background-color: #e3f2fd !important;
            border-color: #0d6efd !important;
        }
        
        .form-check-input:checked + label {
            background-color: #e7f1ff;
            border-color: #0d6efd !important;
        }
        
        .form-check-label {
            cursor: pointer;
        }
        
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }
        
        .loading-overlay .spinner-container {
            text-align: center;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const dropZone = document.getElementById('dropZone');
            const fileInput = document.getElementById('fileInput');
            const compressOptions = document.getElementById('compressOptions');
            const compressBtn = document.getElementById('compressBtn');
            const loadingOverlay = document.getElementById('loadingOverlay');
            
            let selectedFile = null;
            
            // Drop zone events
            dropZone.addEventListener('dragover', function(e) {
                e.preventDefault();
                dropZone.classList.add('bg-primary', 'text-white');
            });
            
            dropZone.addEventListener('dragleave', function(e) {
                e.preventDefault();
                dropZone.classList.remove('bg-primary', 'text-white');
            });
            
            dropZone.addEventListener('drop', function(e) {
                e.preventDefault();
                dropZone.classList.remove('bg-primary', 'text-white');
                
                const file = e.dataTransfer.files[0];
                if (file && (file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf'))) {
                    handleFile(file);
                } else {
                    alert('Please select a PDF file.');
                }
            });
            
            fileInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) handleFile(file);
            });
            
            dropZone.addEventListener('click', function() {
                fileInput.click();
            });
            
            // Handle file
            function handleFile(file) {
                selectedFile = file;
                
                document.getElementById('fileName').textContent = file.name;
                document.getElementById('fileSize').textContent = formatSize(file.size);
                
                compressOptions.classList.remove('d-none');
            }
            
            // Format size
            function formatSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }
            
            // Select compression level
            window.selectCompression = function(level) {
                document.getElementById('lowQuality').checked = (level === 'low');
                document.getElementById('mediumQuality').checked = (level === 'medium');
                document.getElementById('highQuality').checked = (level === 'high');
            };
            
            // Compress button
            compressBtn.addEventListener('click', async function() {
                if (!selectedFile) return;
                
                const quality = document.querySelector('input[name="compressionLevel"]:checked').value;
                
                const formData = new FormData();
                formData.append('file', selectedFile);
                formData.append('quality', quality);
                
                loadingOverlay.classList.remove('d-none');
                compressBtn.disabled = true;
                
                try {
                    const response = await fetch('@Url.Action("Compress")', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    
                    loadingOverlay.classList.add('d-none');
                    
                    if (result.success) {
                        console.log('Compression successful:', result);
                        
                        // Show result section
                        document.getElementById('dropZone').closest('.card').style.display = 'none';
                        document.getElementById('compressOptions').style.display = 'none';
                        document.getElementById('resultContainer').style.display = 'block';
                        
                        // Update result info
                        document.getElementById('successMessage').textContent = result.message || 'PDF Compressed Successfully!';
                        document.getElementById('originalSize').textContent = result.originalSize;
                        document.getElementById('compressedSize').textContent = result.compressedSize;
                        document.getElementById('reduction').textContent = result.reduction;
                        document.getElementById('reductionBar').style.width = result.reduction;
                        
                        // Setup download button
                        const downloadBtn = document.getElementById('downloadBtn');
                        downloadBtn.href = result.downloadUrl;
                        
                        // Manual download with visual feedback
                        downloadBtn.onclick = function(e) {
                            e.preventDefault();
                            console.log('Manual download clicked, URL:', result.downloadUrl);
                            
                            // Create a temporary anchor and click it
                            const tempLink = document.createElement('a');
                            tempLink.href = result.downloadUrl;
                            tempLink.target = '_blank';
                            document.body.appendChild(tempLink);
                            tempLink.click();
                            document.body.removeChild(tempLink);
                        };
                        
                        // Try automatic download
                        setTimeout(() => {
                            console.log('Attempting auto-download...');
                            downloadBtn.click();
                        }, 500);
                        
                        compressBtn.disabled = false;
                    } else {
                        console.error('Compression failed:', result);
                        alert(result.message || 'An error occurred while compressing the PDF.');
                        compressBtn.disabled = false;
                    }
                } catch (error) {
                    console.error('Error:', error);
                    loadingOverlay.classList.add('d-none');
                    alert('An error occurred while compressing the PDF: ' + error.message);
                    compressBtn.disabled = false;
                }
            });
            
            // Compress another button
            document.getElementById('compressAnotherBtn').addEventListener('click', function() {
                location.reload();
            });
        });
    </script>
}
