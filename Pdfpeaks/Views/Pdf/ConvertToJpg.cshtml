@{
    ViewData["Title"] = "PDF to JPG - Convert PDF to Images";
}
<div class="tool-page py-5">
    <div class="container">
        <div class="tool-header text-center mb-4">
            <h1 class="tool-title fw-bold">PDF to JPG</h1>
            <p class="tool-description text-muted">Convert PDF pages to JPG images</p>
        </div>
        <input type="file" id="fileInput" accept=".pdf" style="display: none;" />
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div id="uploadZone" class="upload-zone border border-3 border-dashed rounded-4 p-5 text-center bg-white cursor-pointer">
                    <i class="fas fa-cloud-upload-alt fa-4x text-primary mb-3"></i>
                    <p class="mb-0">Drag & drop your PDF here or click to browse</p>
                </div>
                <div id="fileSection" class="d-none mt-3">
                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded-3 mb-3">
                        <span id="fileNameDisplay" class="fw-bold"></span>
                        <button type="button" class="btn-close" id="clearFile" aria-label="Clear"></button>
                    </div>
                    <button type="button" class="btn btn-primary btn-lg w-100" id="convertBtn">
                        <i class="fas fa-image me-2"></i> Convert to JPG
                    </button>
                </div>
                <div id="loadingState" class="d-none mt-3 text-center">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2 mb-0">Converting...</p>
                </div>
                <div id="resultsSection" class="d-none mt-3"></div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script>
(function() {
    const fileInput = document.getElementById('fileInput');
    const uploadZone = document.getElementById('uploadZone');
    const fileSection = document.getElementById('fileSection');
    const fileNameDisplay = document.getElementById('fileNameDisplay');
    const convertBtn = document.getElementById('convertBtn');
    const loadingState = document.getElementById('loadingState');
    const resultsSection = document.getElementById('resultsSection');
    const clearFile = document.getElementById('clearFile');
    let currentFile = null;

    uploadZone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', e => { if (e.target.files.length) setFile(e.target.files[0]); });
    uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('border-primary'); });
    uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('border-primary'));
    uploadZone.addEventListener('drop', e => { e.preventDefault(); uploadZone.classList.remove('border-primary'); if (e.dataTransfer.files.length) setFile(e.dataTransfer.files[0]); });
    clearFile.addEventListener('click', () => { currentFile = null; fileSection.classList.add('d-none'); uploadZone.classList.remove('d-none'); fileInput.value = ''; resultsSection.classList.add('d-none'); });

    function setFile(file) {
        if (!file.name.toLowerCase().endsWith('.pdf')) { alert('Please select a PDF file.'); return; }
        currentFile = file;
        fileNameDisplay.textContent = file.name;
        uploadZone.classList.add('d-none');
        fileSection.classList.remove('d-none');
    }

    convertBtn.addEventListener('click', async () => {
        if (!currentFile) return;
        convertBtn.disabled = true;
        loadingState.classList.remove('d-none');
        resultsSection.classList.add('d-none');
        const fd = new FormData();
        fd.append('file', currentFile);
        try {
            const res = await fetch('/Pdf/ConvertToJpg', { method: 'POST', body: fd });
            const result = await res.json();
            loadingState.classList.add('d-none');
            convertBtn.disabled = false;
            if (result.success && result.files && result.files.length > 0) {
                resultsSection.innerHTML = '<p class="fw-bold">Download images:</p><div class="list-group"></div>';
                const list = resultsSection.querySelector('.list-group');
                result.files.forEach(function(f) {
                    const a = document.createElement('a');
                    a.href = f.url;
                    a.className = 'list-group-item list-group-item-action';
                    a.textContent = f.fileName;
                    a.target = '_blank';
                    list.appendChild(a);
                });
                resultsSection.classList.remove('d-none');
                if (result.files.length === 1) { window.location.href = result.files[0].url; }
            } else if (result.success && result.downloadUrl) {
                window.location.href = result.downloadUrl;
            } else {
                alert(result.message || 'Conversion failed');
            }
        } catch (e) {
            loadingState.classList.add('d-none');
            convertBtn.disabled = false;
            alert('Error: ' + e.message);
        }
    });
})();
</script>
}
