@{
    ViewData["Title"] = "PDF to PowerPoint - Convert PDF to PPTX";
}
<div class="tool-page" style="padding: 2rem 0;">
    <div class="container">
        <div class="tool-header" style="text-align: center; margin-bottom: 2rem;">
            <h1 class="tool-title" style="font-size: 2rem; font-weight: 700; color: var(--text-dark); margin-bottom: 0.5rem;">PDF to PowerPoint</h1>
            <p class="tool-description" style="color: var(--text-light); font-size: 1.1rem;">Convert your PDF files to editable PowerPoint presentations</p>
        </div>
        <div class="upload-zone" style="border: 3px dashed #d0d0d0; border-radius: 20px; padding: 3rem; text-align: center; background: #fff;">
            <i class="fas fa-cloud-upload-alt" style="font-size: 4rem; color: #d24726; margin-bottom: 1rem;"></i>
            <p style="font-size: 1.2rem; color: var(--text-dark); margin-bottom: 0.5rem;">Drag & drop your PDF file here</p>
            <p style="color: var(--text-light); font-size: 0.9rem;">or click to browse</p>
        </div>
        <div class="action-buttons" style="display: flex; gap: 1rem; justify-content: center; margin-top: 2rem;">
            <button class="btn-tool btn-primary" style="padding: 1rem 2rem; border-radius: 12px; font-weight: 600; border: none; background: linear-gradient(135deg, #d24726 0%, #aa1d11 100%); color: #fff; cursor: pointer;">
                <i class="fas fa-exchange-alt"></i> Convert to PowerPoint
            </button>
        </div>
    </div>
</div>
