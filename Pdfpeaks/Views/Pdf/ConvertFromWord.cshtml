@{
    ViewData["Title"] = "Word to PDF - Convert DOCX to PDF";
}
<div class="tool-page py-5">
    <div class="container">
        <div class="tool-header text-center mb-4">
            <h1 class="tool-title fw-bold">Word to PDF</h1>
            <p class="tool-description text-muted">Convert your Word documents to PDF format</p>
        </div>
        <input type="file" id="fileInput" accept=".doc,.docx" style="display: none;" />
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div id="uploadZone" class="upload-zone border border-3 border-dashed rounded-4 p-5 text-center bg-white cursor-pointer">
                    <i class="fas fa-file-word fa-4x text-primary mb-3"></i>
                    <p class="mb-1">Drag & drop your Word file here or click to browse</p>
                    <p class="small text-muted mb-0">.doc, .docx</p>
                </div>
                <div id="fileSection" class="d-none mt-3">
                    <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded-3 mb-3">
                        <span id="fileNameDisplay" class="fw-bold"></span>
                        <button type="button" class="btn-close" id="clearFile" aria-label="Clear"></button>
                    </div>
                    <button type="button" class="btn btn-primary btn-lg w-100" id="convertBtn">
                        <i class="fas fa-file-pdf me-2"></i> Convert to PDF
                    </button>
                </div>
                <div id="loadingState" class="d-none mt-3 text-center">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2 mb-0">Converting...</p>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script>
(function() {
    const fileInput = document.getElementById('fileInput');
    const uploadZone = document.getElementById('uploadZone');
    const fileSection = document.getElementById('fileSection');
    const fileNameDisplay = document.getElementById('fileNameDisplay');
    const convertBtn = document.getElementById('convertBtn');
    const loadingState = document.getElementById('loadingState');
    const clearFile = document.getElementById('clearFile');
    let currentFile = null;

    uploadZone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', e => { if (e.target.files.length) setFile(e.target.files[0]); });
    uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('border-primary'); });
    uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('border-primary'));
    uploadZone.addEventListener('drop', e => { e.preventDefault(); uploadZone.classList.remove('border-primary'); if (e.dataTransfer.files.length) setFile(e.dataTransfer.files[0]); });
    clearFile.addEventListener('click', () => { currentFile = null; fileSection.classList.add('d-none'); uploadZone.classList.remove('d-none'); fileInput.value = ''; });

    function setFile(file) {
        var ext = (file.name || '').toLowerCase();
        if (!ext.endsWith('.doc') && !ext.endsWith('.docx')) { alert('Please select a Word document (.doc or .docx).'); return; }
        currentFile = file;
        fileNameDisplay.textContent = file.name;
        uploadZone.classList.add('d-none');
        fileSection.classList.remove('d-none');
    }

    async function uploadFileForJob(file) {
        const formData = new FormData();
        formData.append('file', file);
        formData.append('operation', 'word2pdf');

        const response = await fetch('/api/files/upload', { method: 'POST', body: formData });
        if (!response.ok) {
            const text = await response.text();
            throw new Error('Upload failed: ' + text);
        }

        const result = await response.json();
        if (!result.success || !result.fileName) {
            throw new Error(result.message || 'Upload failed.');
        }
        return result.fileName;
    }

    async function enqueueWordToPdfJob(tempFileName) {
        const formData = new FormData();
        formData.append('fileName', tempFileName);

        const outputName = (currentFile?.name || 'converted.docx')
            .replace(/\.docx$/i, '.pdf')
            .replace(/\.doc$/i, '.pdf');

        formData.append('outputFileName', outputName);

        const response = await fetch('/api/jobs/pdf/from-word', { method: 'POST', body: formData });
        if (!response.ok) {
            const text = await response.text();
            throw new Error('Failed to queue conversion: ' + text);
        }

        const result = await response.json();
        if (!result.success || !result.jobId) {
            throw new Error(result.message || 'Failed to queue conversion.');
        }

        return { jobId: result.jobId, outputFileName: result.outputFileName || outputName };
    }

    async function pollJobStatus(jobId, outputFileName) {
        let attempts = 0;
        const maxAttempts = 120; // ~4 minutes at 2s intervals

        while (attempts < maxAttempts) {
            attempts++;
            const response = await fetch(`/api/jobs/${encodeURIComponent(jobId)}`);
            if (!response.ok) {
                throw new Error('Status check failed with HTTP ' + response.status);
            }

            const status = await response.json();
            if (!status.success) {
                throw new Error(status.message || 'Unknown job error.');
            }

            const state = (status.status || '').toLowerCase();
            if (state === 'succeeded') {
                const fileName = status.outputFileName || outputFileName;
                const downloadUrl = `/api/files/download/${encodeURIComponent(fileName)}`;
                window.location.href = downloadUrl;
                return;
            }

            if (state === 'failed') {
                throw new Error(status.message || 'Conversion failed.');
            }

            await new Promise(r => setTimeout(r, 2000));
        }

        throw new Error('Conversion is taking longer than expected. Please try again later.');
    }

    convertBtn.addEventListener('click', async () => {
        if (!currentFile) return;
        convertBtn.disabled = true;
        loadingState.classList.remove('d-none');

        try {
            const tempFileName = await uploadFileForJob(currentFile);
            const { jobId, outputFileName } = await enqueueWordToPdfJob(tempFileName);
            await pollJobStatus(jobId, outputFileName);
        } catch (e) {
            alert('Conversion failed: ' + (e.message || 'Unknown error'));
        } finally {
            loadingState.classList.add('d-none');
            convertBtn.disabled = false;
        }
    });
})();
</script>
}
