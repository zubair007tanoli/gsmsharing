@{
    ViewData["Title"] = "Word to PDF - Convert DOCX to PDF";
}
<div class="tool-page" style="padding: 2rem 0;">
    <div class="container">
        <div class="tool-header" style="text-align: center; margin-bottom: 2rem;">
            <h1 class="tool-title" style="font-size: 2rem; font-weight: 700; color: var(--text-dark); margin-bottom: 0.5rem;">Word to PDF</h1>
            <p class="tool-description" style="color: var(--text-light); font-size: 1.1rem;">Convert your Word documents to PDF format</p>
        </div>
        <div class="upload-zone" style="border: 3px dashed #d0d0d0; border-radius: 20px; padding: 3rem; text-align: center; background: #fff;">
            <i class="fas fa-cloud-upload-alt" style="font-size: 4rem; color: #2b579a; margin-bottom: 1rem;"></i>
            <p style="font-size: 1.2rem; color: var(--text-dark); margin-bottom: 0.5rem;">Drag & drop your Word file here</p>
            <p style="color: var(--text-light); font-size: 0.9rem;">.doc, .docx</p>
        </div>
        <div class="action-buttons" style="display: flex; gap: 1rem; justify-content: center; margin-top: 2rem;">
            <button class="btn-tool btn-primary" style="padding: 1rem 2rem; border-radius: 12px; font-weight: 600; border: none; background: linear-gradient(135deg, #2b579a 0%, #1e3c72 100%); color: #fff; cursor: pointer;">
                <i class="fas fa-file-pdf"></i> Convert to PDF
            </button>
        </div>
    </div>
</div>
