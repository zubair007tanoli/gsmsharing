@{
    ViewData["Title"] = "PowerPoint to PDF - Convert PPT/PPTX to PDF";
}

<div class="tool-wrap py-5">
    <div class="container">
        <div class="text-center mb-4">
            <h1 class="fw-bold mb-2">PowerPoint to PDF</h1>
            <p class="text-muted mb-0">Convert presentations to reliable, print-friendly PDF output</p>
        </div>

        <input type="file" id="fileInput" accept=".ppt,.pptx,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation" style="display:none;" />

        <div class="row g-4 justify-content-center">
            <div class="col-lg-8">
                <div id="uploadZone" class="upload-zone card shadow-sm border-0">
                    <div class="card-body p-5 text-center">
                        <div class="upload-icon mb-3">
                            <i class="fas fa-file-powerpoint"></i>
                        </div>
                        <h5 class="mb-2">Drop PPT/PPTX here</h5>
                        <p class="text-muted mb-3">or select presentation file</p>
                        <button type="button" class="btn btn-warning px-4 text-dark fw-semibold" id="selectFileBtn">
                            <i class="fas fa-folder-open me-2"></i>Select PowerPoint
                        </button>
                        <p class="small text-muted mt-3 mb-0">Supported: .ppt, .pptx</p>
                    </div>
                </div>

                <div id="fileCard" class="card shadow-sm border-0 mt-3 d-none">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <div class="fw-semibold" id="fileName">-</div>
                                <div class="small text-muted" id="fileMeta">-</div>
                                <div class="small text-muted">Output: searchable PDF when source text is embedded in slides.</div>
                            </div>
                            <button type="button" class="btn-close" id="clearFile" aria-label="Clear"></button>
                        </div>
                        <div class="d-grid mt-4">
                            <button type="button" class="btn btn-warning btn-lg text-dark fw-semibold" id="convertBtn">
                                <i class="fas fa-file-pdf me-2"></i>Convert to PDF
                            </button>
                        </div>
                    </div>
                </div>

                <div id="loading" class="text-center mt-3 d-none">
                    <div class="spinner-border text-warning" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <div class="mt-2 text-muted">Converting PowerPoint to PDF...</div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 info-card">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3"><i class="fas fa-wand-magic-sparkles me-2"></i>Conversion Notes</h6>
                        <div class="small text-muted">
                            <div class="mb-2">Fonts and slide design are preserved using LibreOffice conversion.</div>
                            <div class="mb-2">For best results, embed fonts in source presentation.</div>
                            <div class="mb-2">Complex animations are not rendered in PDF output.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .tool-wrap {
            background:
                radial-gradient(circle at 10% 20%, rgba(255, 193, 7, 0.13), transparent 38%),
                radial-gradient(circle at 88% 18%, rgba(220, 53, 69, 0.09), transparent 36%),
                #f8f9fb;
        }

        .upload-zone {
            border: 2px dashed #e2e6ea;
            transition: all 0.2s ease;
            cursor: pointer;
            background: #fff;
        }

        .upload-zone:hover,
        .upload-zone.dragover {
            border-color: #ffc107;
            transform: translateY(-1px);
        }

        .upload-icon {
            font-size: 3rem;
            color: #d24726;
        }

        .info-card {
            position: sticky;
            top: 88px;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const fileInput = document.getElementById('fileInput');
            const uploadZone = document.getElementById('uploadZone');
            const selectFileBtn = document.getElementById('selectFileBtn');
            const fileCard = document.getElementById('fileCard');
            const fileName = document.getElementById('fileName');
            const fileMeta = document.getElementById('fileMeta');
            const clearFile = document.getElementById('clearFile');
            const convertBtn = document.getElementById('convertBtn');
            const loading = document.getElementById('loading');

            let currentFile = null;

            function isPowerPoint(name) {
                const lower = (name || '').toLowerCase();
                return lower.endsWith('.ppt') || lower.endsWith('.pptx');
            }

            function formatBytes(bytes) {
                if (!bytes) return '0 B';
                const units = ['B', 'KB', 'MB', 'GB'];
                let size = bytes;
                let idx = 0;
                while (size >= 1024 && idx < units.length - 1) {
                    size /= 1024;
                    idx++;
                }
                return `${size.toFixed(size >= 100 ? 0 : 2)} ${units[idx]}`;
            }

            function parseJsonSafe(text) {
                if (!text || !text.trim()) return {};
                try { return JSON.parse(text); } catch { return {}; }
            }

            function reset() {
                currentFile = null;
                fileInput.value = '';
                uploadZone.classList.remove('d-none');
                fileCard.classList.add('d-none');
                loading.classList.add('d-none');
                convertBtn.disabled = false;
                convertBtn.innerHTML = '<i class="fas fa-file-pdf me-2"></i>Convert to PDF';
            }

            function setFile(file) {
                if (!file || !isPowerPoint(file.name)) {
                    alert('Please select a PowerPoint file (.ppt or .pptx).');
                    return;
                }
                currentFile = file;
                fileName.textContent = file.name;
                fileMeta.textContent = `Size: ${formatBytes(file.size)}`;
                uploadZone.classList.add('d-none');
                fileCard.classList.remove('d-none');
            }

            selectFileBtn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                fileInput.click();
            });

            uploadZone.addEventListener('click', function () {
                fileInput.click();
            });

            fileInput.addEventListener('change', function (e) {
                if (e.target.files && e.target.files.length > 0) {
                    setFile(e.target.files[0]);
                }
            });

            uploadZone.addEventListener('dragover', function (e) {
                e.preventDefault();
                uploadZone.classList.add('dragover');
            });

            uploadZone.addEventListener('dragleave', function () {
                uploadZone.classList.remove('dragover');
            });

            uploadZone.addEventListener('drop', function (e) {
                e.preventDefault();
                uploadZone.classList.remove('dragover');
                const file = e.dataTransfer?.files?.[0];
                if (file) setFile(file);
            });

            clearFile.addEventListener('click', reset);

            convertBtn.addEventListener('click', async function () {
                if (!currentFile) return;

                convertBtn.disabled = true;
                convertBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Converting...';
                loading.classList.remove('d-none');

                try {
                    const fd = new FormData();
                    fd.append('file', currentFile);

                    const response = await fetch('/Pdf/ConvertFromPowerPoint', { method: 'POST', body: fd });
                    const result = parseJsonSafe(await response.text());

                    if (result.success && result.downloadUrl) {
                        window.location.href = result.downloadUrl;
                    } else {
                        const statusText = !response.ok ? ` (HTTP ${response.status})` : '';
                        alert(result.message || `Conversion failed${statusText}.`);
                    }
                } catch (err) {
                    alert('Error: ' + (err.message || 'Unknown error'));
                } finally {
                    loading.classList.add('d-none');
                    convertBtn.disabled = false;
                    convertBtn.innerHTML = '<i class="fas fa-file-pdf me-2"></i>Convert to PDF';
                }
            });
        });
    </script>
}
