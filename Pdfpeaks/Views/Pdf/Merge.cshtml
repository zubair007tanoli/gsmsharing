@{
    ViewData["Title"] = "Merge PDF Files - PdfPeaks";
}

@Html.AntiForgeryToken()

<div class="tool-wrap py-5">
    <div class="container">
        <div class="text-center mb-4">
            <h1 class="fw-bold mb-2">Merge PDF Files</h1>
            <p class="text-muted mb-0">Combine multiple PDFs into a single document in your preferred order</p>
        </div>

        <input type="file" id="fileInput" accept=".pdf,application/pdf" multiple style="display:none;" />

        <div class="row g-4 justify-content-center">
            <div class="col-lg-8">
                <div id="uploadCard" class="upload-zone card shadow-sm border-0">
                    <div class="card-body p-5 text-center">
                        <div class="upload-icon mb-3">
                            <i class="fas fa-file-circle-plus"></i>
                        </div>
                        <h5 class="mb-2">Drop PDF files here</h5>
                        <p class="text-muted mb-3">or select files from your device</p>
                        <button type="button" class="btn btn-primary px-4" id="selectFileBtn">
                            <i class="fas fa-folder-open me-2"></i>Select PDF Files
                        </button>
                        <p class="small text-muted mt-3 mb-0">Minimum 2 files, maximum 100MB per file</p>
                    </div>
                </div>

                <div id="queueCard" class="card shadow-sm border-0 mt-3 d-none">
                    <div class="card-header bg-white border-0 pt-3">
                        <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                            <h6 class="mb-0">Merge Queue (<span id="fileCount">0</span>)</h6>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-primary btn-sm" id="addMoreBtn">
                                    <i class="fas fa-plus me-1"></i>Add Files
                                </button>
                                <button type="button" class="btn btn-outline-danger btn-sm" id="clearAllBtn">
                                    <i class="fas fa-trash me-1"></i>Clear All
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="card-body pt-2">
                        <div id="fileList" class="file-list"></div>
                        <div class="text-muted small mt-3">Drag to reorder. Files are merged top to bottom.</div>
                        <div class="d-grid mt-4">
                            <button type="button" class="btn btn-success btn-lg" id="mergeBtn" disabled>
                                <i class="fas fa-object-group me-2"></i>Merge PDF Files
                            </button>
                        </div>
                    </div>
                </div>

                <div id="resultCard" class="card shadow-sm border-0 mt-3 d-none">
                    <div class="card-body text-center py-5">
                        <div class="mb-3 text-success result-icon"><i class="fas fa-circle-check"></i></div>
                        <h4 class="mb-2">Merge Completed</h4>
                        <p class="text-muted mb-4" id="resultMessage">Your merged PDF is ready.</p>
                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            <a id="downloadBtn" href="#" class="btn btn-success btn-lg">
                                <i class="fas fa-download me-2"></i>Download PDF
                            </a>
                            <button type="button" class="btn btn-outline-secondary btn-lg" id="mergeAnotherBtn">
                                <i class="fas fa-rotate me-2"></i>Merge More Files
                            </button>
                        </div>
                    </div>
                </div>

                <div id="loading" class="text-center mt-3 d-none">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <div class="mt-2 text-muted">Merging files...</div>
                </div>

                <div id="errorAlert" class="alert alert-danger mt-3 d-none" role="alert"></div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 info-card">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3"><i class="fas fa-circle-info me-2"></i>Merge Notes</h6>
                        <div class="small text-muted">
                            <div class="mb-2">Upload at least two PDF files.</div>
                            <div class="mb-2">Use drag-and-drop to set final page order.</div>
                            <div class="mb-2">Output quality and searchable text are preserved.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .tool-wrap {
            background:
                radial-gradient(circle at 10% 20%, rgba(13, 110, 253, 0.11), transparent 40%),
                radial-gradient(circle at 90% 18%, rgba(25, 135, 84, 0.08), transparent 36%),
                #f8f9fb;
        }

        .upload-zone {
            border: 2px dashed #e2e6ea;
            transition: all 0.2s ease;
            cursor: pointer;
            background: #fff;
        }

        .upload-zone:hover,
        .upload-zone.dragover {
            border-color: #0d6efd;
            transform: translateY(-1px);
        }

        .upload-icon {
            font-size: 3rem;
            color: #0d6efd;
        }

        .info-card {
            position: sticky;
            top: 88px;
        }

        .file-list {
            display: flex;
            flex-direction: column;
            gap: 0.65rem;
            max-height: 420px;
            overflow-y: auto;
            padding-right: 0.25rem;
        }

        .file-item {
            display: grid;
            grid-template-columns: 28px 1fr auto;
            gap: 0.7rem;
            align-items: center;
            border: 1px solid #e9ecef;
            border-radius: 10px;
            padding: 0.65rem 0.75rem;
            background: #fff;
        }

        .file-item.dragging {
            opacity: 0.65;
        }

        .file-item.dragover {
            border-color: #0d6efd;
            box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.15);
        }

        .drag-handle {
            color: #adb5bd;
            cursor: grab;
            text-align: center;
        }

        .file-name {
            font-weight: 600;
            word-break: break-word;
        }

        .file-meta {
            font-size: 0.8rem;
            color: #6c757d;
        }

        .result-icon {
            font-size: 3rem;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const fileInput = document.getElementById('fileInput');
            const selectFileBtn = document.getElementById('selectFileBtn');
            const addMoreBtn = document.getElementById('addMoreBtn');
            const clearAllBtn = document.getElementById('clearAllBtn');
            const mergeBtn = document.getElementById('mergeBtn');
            const mergeAnotherBtn = document.getElementById('mergeAnotherBtn');
            const uploadCard = document.getElementById('uploadCard');
            const queueCard = document.getElementById('queueCard');
            const resultCard = document.getElementById('resultCard');
            const loading = document.getElementById('loading');
            const errorAlert = document.getElementById('errorAlert');
            const fileList = document.getElementById('fileList');
            const fileCount = document.getElementById('fileCount');
            const downloadBtn = document.getElementById('downloadBtn');
            const resultMessage = document.getElementById('resultMessage');

            let selectedFiles = [];
            let dragId = null;

            function parseJsonSafe(text) {
                if (!text || !text.trim()) return {};
                try { return JSON.parse(text); } catch { return {}; }
            }

            function formatBytes(bytes) {
                if (!bytes) return '0 B';
                const units = ['B', 'KB', 'MB', 'GB'];
                let value = bytes;
                let i = 0;
                while (value >= 1024 && i < units.length - 1) {
                    value /= 1024;
                    i++;
                }
                return `${value.toFixed(value >= 100 ? 0 : 2)} ${units[i]}`;
            }

            function showError(message) {
                errorAlert.textContent = message;
                errorAlert.classList.remove('d-none');
            }

            function hideError() {
                errorAlert.classList.add('d-none');
                errorAlert.textContent = '';
            }

            function resetState() {
                selectedFiles = [];
                dragId = null;
                fileInput.value = '';
                fileList.innerHTML = '';
                fileCount.textContent = '0';
                mergeBtn.disabled = true;
                mergeBtn.innerHTML = '<i class="fas fa-object-group me-2"></i>Merge PDF Files';
                uploadCard.classList.remove('d-none');
                queueCard.classList.add('d-none');
                resultCard.classList.add('d-none');
                loading.classList.add('d-none');
                hideError();
            }

            function renderQueue() {
                fileList.innerHTML = '';
                fileCount.textContent = String(selectedFiles.length);
                mergeBtn.disabled = selectedFiles.length < 2;

                if (selectedFiles.length === 0) {
                    uploadCard.classList.remove('d-none');
                    queueCard.classList.add('d-none');
                    return;
                }

                uploadCard.classList.add('d-none');
                queueCard.classList.remove('d-none');
                resultCard.classList.add('d-none');

                selectedFiles.forEach((item, idx) => {
                    const row = document.createElement('div');
                    row.className = 'file-item';
                    row.draggable = true;
                    row.dataset.id = item.id;
                    row.innerHTML = `
                        <div class="drag-handle"><i class="fas fa-grip-vertical"></i></div>
                        <div>
                            <div class="file-name">${escapeHtml(item.file.name)}</div>
                            <div class="file-meta">${formatBytes(item.file.size)} - Position ${idx + 1}</div>
                        </div>
                        <button type="button" class="btn btn-outline-danger btn-sm remove-btn" title="Remove">
                            <i class="fas fa-xmark"></i>
                        </button>
                    `;

                    row.querySelector('.remove-btn').addEventListener('click', function () {
                        selectedFiles = selectedFiles.filter(f => f.id !== item.id);
                        renderQueue();
                    });

                    row.addEventListener('dragstart', function (e) {
                        dragId = item.id;
                        row.classList.add('dragging');
                        if (e.dataTransfer) {
                            e.dataTransfer.effectAllowed = 'move';
                            e.dataTransfer.setData('text/plain', String(item.id));
                        }
                    });

                    row.addEventListener('dragend', function () {
                        row.classList.remove('dragging');
                        fileList.querySelectorAll('.dragover').forEach(el => el.classList.remove('dragover'));
                        dragId = null;
                    });

                    row.addEventListener('dragover', function (e) {
                        e.preventDefault();
                        if (dragId !== item.id) row.classList.add('dragover');
                    });

                    row.addEventListener('dragleave', function () {
                        row.classList.remove('dragover');
                    });

                    row.addEventListener('drop', function (e) {
                        e.preventDefault();
                        row.classList.remove('dragover');
                        reorderByDrag(dragId, item.id);
                    });

                    fileList.appendChild(row);
                });
            }

            function reorderByDrag(sourceId, targetId) {
                if (!sourceId || sourceId === targetId) return;
                const sourceIndex = selectedFiles.findIndex(f => f.id === sourceId);
                const targetIndex = selectedFiles.findIndex(f => f.id === targetId);
                if (sourceIndex < 0 || targetIndex < 0) return;
                const [moved] = selectedFiles.splice(sourceIndex, 1);
                const insertIndex = sourceIndex < targetIndex ? targetIndex - 1 : targetIndex;
                selectedFiles.splice(insertIndex, 0, moved);
                renderQueue();
            }

            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function addFiles(fileListInput) {
                hideError();
                if (!fileListInput || fileListInput.length === 0) return;

                for (const file of fileListInput) {
                    const lower = (file.name || '').toLowerCase();
                    if (!lower.endsWith('.pdf')) continue;
                    selectedFiles.push({
                        id: `${Date.now()}-${Math.random()}`,
                        file
                    });
                }

                renderQueue();
            }

            function postWithXhr(url, formData) {
                return new Promise((resolve, reject) => {
                    const xhr = new XMLHttpRequest();
                    xhr.open('POST', url, true);
                    xhr.withCredentials = true;
                    xhr.onreadystatechange = function () {
                        if (xhr.readyState !== 4) return;
                        resolve({
                            ok: xhr.status >= 200 && xhr.status < 300,
                            status: xhr.status,
                            text: xhr.responseText || ''
                        });
                    };
                    xhr.onerror = function () {
                        reject(new Error('Network transport failed (XHR).'));
                    };
                    xhr.send(formData);
                });
            }

            fileInput.addEventListener('change', function (e) {
                addFiles(e.target.files);
                fileInput.value = '';
            });

            selectFileBtn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                fileInput.click();
            });

            addMoreBtn.addEventListener('click', function () {
                fileInput.click();
            });

            uploadCard.addEventListener('click', function () {
                fileInput.click();
            });

            uploadCard.addEventListener('dragover', function (e) {
                e.preventDefault();
                uploadCard.classList.add('dragover');
            });

            uploadCard.addEventListener('dragleave', function () {
                uploadCard.classList.remove('dragover');
            });

            uploadCard.addEventListener('drop', function (e) {
                e.preventDefault();
                uploadCard.classList.remove('dragover');
                addFiles(e.dataTransfer?.files);
            });

            clearAllBtn.addEventListener('click', resetState);
            mergeAnotherBtn.addEventListener('click', resetState);

            mergeBtn.addEventListener('click', async function () {
                hideError();
                if (selectedFiles.length < 2) {
                    showError('Please select at least 2 PDF files to merge.');
                    return;
                }

                mergeBtn.disabled = true;
                mergeBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Merging...';
                loading.classList.remove('d-none');

                try {
                    const fd = new FormData();
                    selectedFiles.forEach(item => fd.append('files', item.file));
                    fd.append('sortOrder', JSON.stringify(selectedFiles.map((_, i) => i)));

                    let res;
                    try {
                        const fetchRes = await fetch('/Pdf/Merge', { method: 'POST', body: fd });
                        res = { ok: fetchRes.ok, status: fetchRes.status, text: await fetchRes.text() };
                    } catch {
                        res = await postWithXhr('/Pdf/Merge', fd);
                    }

                    const result = parseJsonSafe(res.text);
                    if (result.success && result.downloadUrl) {
                        resultMessage.textContent = result.message || 'Your merged PDF is ready.';
                        downloadBtn.href = result.downloadUrl;
                        downloadBtn.setAttribute('download', result.fileName || 'merged.pdf');
                        queueCard.classList.add('d-none');
                        resultCard.classList.remove('d-none');
                    } else {
                        const statusText = !res.ok ? ` (HTTP ${res.status})` : '';
                        showError(result.message || `Merge failed${statusText}.`);
                    }
                } catch (err) {
                    showError('Error while merging PDFs: ' + (err.message || 'Unknown error'));
                } finally {
                    loading.classList.add('d-none');
                    mergeBtn.disabled = selectedFiles.length < 2;
                    mergeBtn.innerHTML = '<i class="fas fa-object-group me-2"></i>Merge PDF Files';
                }
            });
        });
    </script>
}
