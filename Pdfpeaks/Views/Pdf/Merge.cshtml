@{
    ViewData["Title"] = "Merge PDF Files - PdfPeaks";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <!-- Header -->
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold text-primary">
                    <i class="bi bi-files"></i> Merge PDF Files
                </h1>
                <p class="lead text-muted">Combine multiple PDF files into one document</p>
            </div>

            <!-- Drop Zone -->
            <div class="card shadow-sm mb-4" id="uploadSection">
                <div class="card-body">
                    <div class="border-2 border-dashed rounded-4 p-5 text-center bg-light">
                        <div class="mb-3">
                            <i class="bi bi-cloud-upload display-1 text-primary"></i>
                        </div>
                        <h4 class="mb-2">Drag & Drop PDF files here</h4>
                        <p class="text-muted mb-3">or</p>
                        <label class="btn btn-primary btn-lg" style="cursor: pointer;">
                            <i class="bi bi-folder-plus"></i> Select PDF Files
                            <input type="file" id="fileInput" accept=".pdf" multiple style="display: none;">
                        </label>
                        <p class="text-muted mt-3 mb-0">
                            <small>Maximum file size: 100MB per file</small>
                        </p>
                    </div>
                </div>
            </div>

            <!-- File List -->
            <div class="card shadow-sm mb-4" id="fileListCard" style="display: none;">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-check"></i> Selected Files
                        <span id="fileCount" class="badge bg-secondary ms-2">0</span>
                    </h5>
                    <div>
                        <button type="button" id="clearAllBtn" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-trash"></i> Clear All
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div id="fileList" class="file-list">
                        <!-- Files will be added here -->
                    </div>
                    <div id="emptyState" class="text-center py-4 text-muted">
                        <i class="bi bi-file-earmark-pdf display-4"></i>
                        <p class="mt-2">No files selected yet</p>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <span class="text-muted">Files will be merged in the order shown above</span>
                        <button type="button" id="mergeBtn" class="btn btn-success btn-lg" disabled>
                            <i class="bi bi-union"></i> Merge PDF Files
                        </button>
                    </div>
                </div>
            </div>

            <!-- Progress Section -->
            <div class="card shadow-sm mb-4" id="progressSection" style="display: none;">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                    <h4 class="card-title mb-2">Merging Your PDFs</h4>
                    <p class="card-text text-muted" id="progressMessage">Please wait while we merge your files...</p>
                    <div class="progress mt-3" style="height: 10px; max-width: 400px; margin: 0 auto;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" id="progressBar" style="width: 100%"></div>
                    </div>
                </div>
            </div>

            <!-- Success/Download Section -->
            <div class="card shadow-sm mb-4" id="downloadSection" style="display: none;">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success display-1"></i>
                    </div>
                    <h3 class="card-title mb-3">PDF Merged Successfully!</h3>
                    <p class="card-text text-muted mb-4" id="successMessage"></p>
                    
                    <!-- Download Button -->
                    <a id="downloadBtn" href="#" class="btn btn-success btn-lg mb-3" download>
                        <i class="bi bi-download"></i> Download Merged PDF
                    </a>
                    
                    <div class="mt-3">
                        <button type="button" id="mergeAnotherBtn" class="btn btn-outline-primary">
                            <i class="bi bi-plus-circle"></i> Merge More Files
                        </button>
                    </div>
                </div>
            </div>

            <!-- Error Alert -->
            <div id="errorAlert" class="alert alert-danger alert-dismissible fade show" role="alert" style="display: none;">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <span id="errorMessage"></span>
                <button type="button" class="btn-close" onclick="document.getElementById('errorAlert').style.display='none'"></button>
            </div>

            <!-- Server-side Error Display -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .file-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .file-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 8px;
        border: 1px solid #e9ecef;
    }
    
    .file-item:hover {
        background: #e9ecef;
    }
    
    .file-item .drag-handle {
        cursor: grab;
        color: #adb5bd;
        font-size: 1.2rem;
    }
    
    .file-item .file-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #e94057 0%, #f27121 100%);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.2rem;
    }
    
    .file-item .file-info {
        flex: 1;
    }
    
    .file-item .file-name {
        font-weight: 600;
        color: #2d2d3f;
        margin-bottom: 0.25rem;
        word-break: break-all;
    }
    
    .file-item .file-meta {
        font-size: 0.85rem;
        color: #6c757d;
    }
    
    .file-item .file-actions {
        display: flex;
        gap: 0.5rem;
    }
    
    .file-item .file-actions button {
        padding: 0.5rem;
        border: none;
        background: transparent;
        color: #6c757d;
        cursor: pointer;
        border-radius: 4px;
    }
    
    .file-item .file-actions button:hover {
        background: #e9ecef;
        color: #0d6efd;
    }
    
    .file-item .file-actions button.delete:hover {
        color: #dc3545;
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const fileInput = document.getElementById('fileInput');
            const uploadSection = document.getElementById('uploadSection');
            const fileListCard = document.getElementById('fileListCard');
            const progressSection = document.getElementById('progressSection');
            const downloadSection = document.getElementById('downloadSection');
            const fileList = document.getElementById('fileList');
            const emptyState = document.getElementById('emptyState');
            const fileCount = document.getElementById('fileCount');
            const clearAllBtn = document.getElementById('clearAllBtn');
            const mergeBtn = document.getElementById('mergeBtn');
            const mergeAnotherBtn = document.getElementById('mergeAnotherBtn');
            const errorAlert = document.getElementById('errorAlert');
            const downloadBtn = document.getElementById('downloadBtn');
            const successMessage = document.getElementById('successMessage');
            
            let selectedFiles = [];
            
            // File input change handler
            fileInput.addEventListener('change', function(e) {
                handleFiles(e.target.files);
                fileInput.value = ''; // Reset to allow selecting same files
            });
            
            function handleFiles(files) {
                if (!files || files.length === 0) return;
                
                for (let i = 0; i < files.length; i++) {
                    const file = files[i];
                    if (file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf')) {
                        selectedFiles.push({
                            id: Date.now() + Math.random(),
                            file: file,
                            name: file.name,
                            size: file.size
                        });
                    }
                }
                
                renderFileList();
            }
            
            function renderFileList() {
                hideError();
                
                if (selectedFiles.length === 0) {
                    uploadSection.style.display = 'block';
                    fileListCard.style.display = 'none';
                    progressSection.style.display = 'none';
                    downloadSection.style.display = 'none';
                    return;
                }
                
                uploadSection.style.display = 'none';
                fileListCard.style.display = 'block';
                progressSection.style.display = 'none';
                downloadSection.style.display = 'none';
                
                fileCount.textContent = selectedFiles.length;
                mergeBtn.disabled = selectedFiles.length < 2;
                
                if (selectedFiles.length === 0) {
                    emptyState.style.display = 'block';
                    fileList.innerHTML = '';
                } else {
                    emptyState.style.display = 'none';
                    renderFileItems();
                }
            }
            
            function renderFileItems() {
                fileList.innerHTML = '';
                
                selectedFiles.forEach((fileData, index) => {
                    const fileItem = document.createElement('div');
                    fileItem.className = 'file-item';
                    fileItem.dataset.id = fileData.id;
                    
                    fileItem.innerHTML = `
                        <div class="drag-handle"><i class="bi bi-grip-vertical"></i></div>
                        <div class="file-icon"><i class="bi bi-file-earmark-pdf"></i></div>
                        <div class="file-info">
                            <div class="file-name">${fileData.name}</div>
                            <div class="file-meta">${formatSize(fileData.size)} - Position ${index + 1} of ${selectedFiles.length}</div>
                        </div>
                        <div class="file-actions">
                            <button type="button" class="move-up" title="Move up"><i class="bi bi-arrow-up"></i></button>
                            <button type="button" class="move-down" title="Move down"><i class="bi bi-arrow-down"></i></button>
                            <button type="button" class="delete" title="Remove"><i class="bi bi-x"></i></button>
                        </div>
                    `;
                    
                    fileItem.querySelector('.move-up').addEventListener('click', () => moveFile(fileData.id, -1));
                    fileItem.querySelector('.move-down').addEventListener('click', () => moveFile(fileData.id, 1));
                    fileItem.querySelector('.delete').addEventListener('click', () => removeFile(fileData.id));
                    
                    fileList.appendChild(fileItem);
                });
            }
            
            function moveFile(id, direction) {
                const index = selectedFiles.findIndex(f => f.id === id);
                if (index < 0) return;
                
                const newIndex = index + direction;
                if (newIndex < 0 || newIndex >= selectedFiles.length) return;
                
                [selectedFiles[index], selectedFiles[newIndex]] = [selectedFiles[newIndex], selectedFiles[index]];
                renderFileItems();
            }
            
            function removeFile(id) {
                selectedFiles = selectedFiles.filter(f => f.id !== id);
                renderFileList();
            }
            
            function formatSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }
            
            function showError(message) {
                errorAlert.style.display = 'block';
                document.getElementById('errorMessage').textContent = message;
            }
            
            function hideError() {
                errorAlert.style.display = 'none';
            }
            
            clearAllBtn.addEventListener('click', function() {
                selectedFiles = [];
                renderFileList();
            });
            
            // Merge Another button
            mergeAnotherBtn.addEventListener('click', function() {
                selectedFiles = [];
                renderFileList();
            });
            
            // Merge button - Submit via AJAX and redirect to download page
            mergeBtn.addEventListener('click', async function() {
                if (selectedFiles.length < 2) {
                    showError('Please select at least 2 PDF files to merge.');
                    return;
                }
                
                mergeBtn.disabled = true;
                mergeBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Merging...';
                
                // Show progress section
                uploadSection.style.display = 'none';
                fileListCard.style.display = 'none';
                progressSection.style.display = 'block';
                
                try {
                    const formData = new FormData();
                    
                    for (let i = 0; i < selectedFiles.length; i++) {
                        formData.append('files', selectedFiles[i].file);
                    }
                    
                    const sortOrder = selectedFiles.map((_, i) => i);
                    formData.append('sortOrder', JSON.stringify(sortOrder));
                    
                    const response = await fetch('/Pdf/Merge', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    
                    // Hide progress section
                    progressSection.style.display = 'none';
                    
                    if (result.success) {
                        console.log('Merge successful:', result);
                        
                        // Show download section
                        uploadSection.style.display = 'none';
                        fileListCard.style.display = 'none';
                        downloadSection.style.display = 'block';
                        
                        // Update download button with direct download URL
                        const downloadUrl = result.downloadUrl;
                        downloadBtn.href = downloadUrl;
                        downloadBtn.download = result.fileName;
                        
                        // Update success message
                        successMessage.textContent = result.message || 'Your merged PDF is ready!';
                        
                        // Manual download with visual feedback
                        downloadBtn.onclick = function(e) {
                            e.preventDefault();
                            console.log('Manual download clicked, URL:', downloadUrl);
                            
                            // Create a temporary anchor and click it
                            const tempLink = document.createElement('a');
                            tempLink.href = downloadUrl;
                            tempLink.download = result.fileName;
                            tempLink.target = '_blank';
                            document.body.appendChild(tempLink);
                            tempLink.click();
                            document.body.removeChild(tempLink);
                        };
                        
                        // Try automatic download first
                        setTimeout(() => {
                            console.log('Attempting auto-download...');
                            downloadBtn.click();
                        }, 500);
                        
                        // Reset merge button
                        mergeBtn.disabled = false;
                        mergeBtn.innerHTML = '<i class="bi bi-union"></i> Merge PDF Files';
                    } else {
                        console.error('Merge failed:', result);
                        showError(result.message || 'An error occurred during merging.');
                        mergeBtn.disabled = false;
                        mergeBtn.innerHTML = '<i class="bi bi-union"></i> Merge PDF Files';
                    }
                } catch (error) {
                    console.error('Error:', error);
                    progressSection.style.display = 'none';
                    showError('An error occurred while merging: ' + error.message);
                    mergeBtn.disabled = false;
                    mergeBtn.innerHTML = '<i class="bi bi-union"></i> Merge PDF Files';
                }
            });
        });
    </script>
}
