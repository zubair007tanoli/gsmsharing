@{
    ViewData["Title"] = "Merge PDF Files - PdfPeaks";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header -->
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold text-primary">
                    <i class="bi bi-files"></i> Merge PDF Files
                </h1>
                <p class="lead text-muted">Combine multiple PDF files into one document</p>
            </div>

            <!-- Drop Zone -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div id="dropZone" class="drop-zone border-2 border-dashed rounded-4 p-5 text-center bg-light transition-all">
                        <div class="mb-3">
                            <i class="bi bi-cloud-upload display-1 text-primary"></i>
                        </div>
                        <h4 class="mb-2">Drag & Drop PDF files here</h4>
                        <p class="text-muted mb-3">or</p>
                        <label class="btn btn-primary btn-lg">
                            <i class="bi bi-folder-plus"></i> Select PDF Files
                            <input type="file" id="fileInput" multiple accept=".pdf" style="display: none;">
                        </label>
                        <p class="text-muted mt-3 mb-0">
                            <small>Maximum file size: 100MB per file</small>
                        </p>
                    </div>
                </div>
            </div>

            <!-- File List with Reorder -->
            <div id="fileListContainer" class="card shadow-sm mb-4 @(TempData["Success"] != null ? "d-none" : "")">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-check"></i> Selected Files
                        <span id="fileCount" class="badge bg-secondary ms-2">0</span>
                    </h5>
                    <div>
                        <button id="clearAllBtn" class="btn btn-outline-danger btn-sm" disabled>
                            <i class="bi bi-trash"></i> Clear All
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <ul id="fileList" class="list-group list-group-flush file-list">
                        <!-- Files will be added here dynamically -->
                    </ul>
                    <div id="emptyState" class="text-center py-4 text-muted">
                        <i class="bi bi-file-earmark-pdf display-4"></i>
                        <p class="mt-2">No files selected yet</p>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <button id="mergeBtn" class="btn btn-success btn-lg w-100" disabled>
                        <i class="bi bi-union"></i> Merge PDF Files
                    </button>
                </div>
            </div>

            <!-- Success Result -->
            @if (TempData["Success"] != null)
            {
                <div id="resultContainer" class="card shadow-sm mb-4">
                    <div class="card-body text-center">
                        <div class="mb-4">
                            <i class="bi bi-check-circle-fill text-success display-1"></i>
                        </div>
                        <h3 class="card-title">@TempData["Success"]</h3>
                        <p class="text-muted">@TempData["Info"]</p>
                        
                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <a href="@TempData["DownloadUrl"]" class="btn btn-primary btn-lg">
                                <i class="bi bi-download"></i> Download Merged PDF
                            </a>
                            <a asp-action="Merge" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-repeat"></i> Merge More Files
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- Error Alert -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="loading-overlay d-none">
    <div class="spinner-container">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h4 class="mt-3 text-white">Processing your files...</h4>
        <p class="text-white-50">This may take a few moments</p>
    </div>
</div>

@section Styles {
    <style>
        .drop-zone {
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .drop-zone:hover,
        .drop-zone.drag-over {
            background-color: #e3f2fd !important;
            border-color: #0d6efd !important;
        }
        
        .drop-zone .transition-all {
            transition: all 0.3s ease;
        }
        
        .file-item {
            cursor: grab;
            transition: all 0.2s ease;
            user-select: none;
        }
        
        .file-item:hover {
            background-color: #f8f9fa;
        }
        
        .file-item.dragging {
            opacity: 0.5;
            transform: scale(1.02);
        }
        
        .file-item .drag-handle {
            cursor: grab;
            color: #adb5bd;
        }
        
        .file-item .drag-handle:hover {
            color: #0d6efd;
        }
        
        .file-item .file-info {
            flex: 1;
            min-width: 0;
        }
        
        .file-item .file-name {
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        .file-item .file-size {
            font-size: 0.875rem;
            color: #6c757d;
        }
        
        .file-item .remove-btn {
            opacity: 0;
            transition: opacity 0.2s;
        }
        
        .file-item:hover .remove-btn {
            opacity: 1;
        }
        
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }
        
        .loading-overlay .spinner-container {
            text-align: center;
        }
        
        .sortable-ghost {
            opacity: 0.4;
        }
        
        .sortable-drag {
            cursor: grabbing !important;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const dropZone = document.getElementById('dropZone');
            const fileInput = document.getElementById('fileInput');
            const fileList = document.getElementById('fileList');
            const fileCount = document.getElementById('fileCount');
            const emptyState = document.getElementById('emptyState');
            const clearAllBtn = document.getElementById('clearAllBtn');
            const mergeBtn = document.getElementById('mergeBtn');
            const loadingOverlay = document.getElementById('loadingOverlay');
            
            let files = [];
            let sortable;
            
            // Initialize Sortable
            function initSortable() {
                if (sortable) {
                    sortable.destroy();
                }
                
                sortable = new Sortable(fileList, {
                    animation: 150,
                    handle: '.drag-handle',
                    ghostClass: 'sortable-ghost',
                    dragClass: 'sortable-drag',
                    onEnd: function(evt) {
                        // Reorder files array
                        const movedFile = files.splice(evt.oldIndex, 1)[0];
                        files.splice(evt.newIndex, 0, movedFile);
                        updateFileIndices();
                    }
                });
            }
            
            // Update file indices in data attributes
            function updateFileIndices() {
                const items = fileList.querySelectorAll('.file-item');
                items.forEach((item, index) => {
                    item.dataset.index = index;
                });
            }
            
            // Format file size
            function formatSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }
            
            // Add file to list
            function addFile(file) {
                const id = Date.now() + Math.random().toString(36).substr(2, 9);
                const fileData = {
                    id: id,
                    file: file,
                    name: file.name,
                    size: file.size
                };
                files.push(fileData);
                
                const li = document.createElement('li');
                li.className = 'list-group-item file-item d-flex align-items-center gap-3 py-3';
                li.dataset.id = id;
                li.dataset.index = files.length - 1;
                
                li.innerHTML = `
                    <div class="drag-handle">
                        <i class="bi bi-grip-vertical fs-4"></i>
                    </div>
                    <div class="file-icon text-danger">
                        <i class="bi bi-file-earmark-pdf-fill fs-3"></i>
                    </div>
                    <div class="file-info">
                        <div class="file-name" title="${file.name}">${file.name}</div>
                        <div class="file-size">${formatSize(file.size)}</div>
                    </div>
                    <button type="button" class="btn btn-link remove-btn text-danger" onclick="removeFile('${id}')">
                        <i class="bi bi-x-circle fs-5"></i>
                    </button>
                `;
                
                fileList.appendChild(li);
                updateUI();
                initSortable();
            }
            
            // Remove file
            window.removeFile = function(id) {
                files = files.filter(f => f.id !== id);
                const li = fileList.querySelector(`[data-id="${id}"]`);
                if (li) li.remove();
                updateUI();
            };
            
            // Update UI state
            function updateUI() {
                const count = files.length;
                fileCount.textContent = count;
                
                if (count > 0) {
                    emptyState.classList.add('d-none');
                    fileList.classList.remove('d-none');
                    clearAllBtn.disabled = false;
                    mergeBtn.disabled = count < 2;
                } else {
                    emptyState.classList.remove('d-none');
                    fileList.classList.add('d-none');
                    clearAllBtn.disabled = true;
                    mergeBtn.disabled = true;
                }
            }
            
            // Clear all files
            clearAllBtn.addEventListener('click', function() {
                files = [];
                fileList.innerHTML = '';
                fileInput.value = '';
                updateUI();
            });
            
            // Drop zone events
            dropZone.addEventListener('dragover', function(e) {
                e.preventDefault();
                e.stopPropagation();
                dropZone.classList.add('drag-over');
            });
            
            dropZone.addEventListener('dragleave', function(e) {
                e.preventDefault();
                e.stopPropagation();
                dropZone.classList.remove('drag-over');
            });
            
            dropZone.addEventListener('drop', function(e) {
                e.preventDefault();
                e.stopPropagation();
                dropZone.classList.remove('drag-over');
                
                const droppedFiles = e.dataTransfer.files;
                handleFiles(droppedFiles);
            });
            
            // File input change
            fileInput.addEventListener('change', function(e) {
                handleFiles(e.target.files);
                fileInput.value = '';
            });
            
            // Handle files
            function handleFiles(fileList) {
                for (let file of fileList) {
                    if (file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf')) {
                        addFile(file);
                    } else {
                        alert(`Invalid file: ${file.name}. Please select PDF files only.`);
                    }
                }
            }
            
            // Click on drop zone
            dropZone.addEventListener('click', function() {
                fileInput.click();
            });
            
            // Merge button
            mergeBtn.addEventListener('click', async function() {
                if (files.length < 2) return;
                
                const formData = new FormData();
                
                // Add files in current order
                files.forEach((f, index) => {
                    formData.append('files', f.file);
                });
                
                // Add sort order
                const sortOrder = files.map((_, index) => index);
                formData.append('sortOrder', JSON.stringify(sortOrder));
                
                // Show loading
                loadingOverlay.classList.remove('d-none');
                
                try {
                    const response = await fetch('@Url.Action("Merge")', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    
                    if (result.success || response.redirected) {
                        window.location.reload();
                    } else {
                        alert(result.error || 'An error occurred while merging files.');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred while processing your files.');
                } finally {
                    loadingOverlay.classList.add('d-none');
                }
            });
            
            // Prevent default drag behavior on document
            document.addEventListener('dragover', function(e) {
                e.preventDefault();
            });
            
            document.addEventListener('drop', function(e) {
                e.preventDefault();
            });
        });
    </script>
}
