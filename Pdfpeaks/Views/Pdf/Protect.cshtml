@{
    ViewData["Title"] = "Protect PDF - Add Password Security";
}
<div class="tool-page py-5">
    <div class="container">
        <div class="tool-header text-center mb-4">
            <h1 class="tool-title fw-bold">Protect PDF</h1>
            <p class="tool-description text-muted">Add password protection to your PDF</p>
        </div>
        <input type="file" id="fileInput" accept=".pdf" style="display: none;" />
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div id="uploadZone" class="upload-zone border border-3 border-dashed rounded-4 p-5 text-center bg-white cursor-pointer">
                    <i class="fas fa-lock fa-4x text-primary mb-3"></i>
                    <p class="mb-0">Drag & drop your PDF here or click to browse</p>
                </div>
                <div id="formSection" class="d-none mt-3">
                    <div class="mb-3 d-flex align-items-center justify-content-between p-3 bg-light rounded-3">
                        <span id="fileNameDisplay" class="fw-bold text-truncate"></span>
                        <button type="button" class="btn-close" id="clearFile" aria-label="Clear"></button>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">User password (to open the PDF)</label>
                        <input type="password" id="userPassword" class="form-control" placeholder="Optional" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Owner password (to change permissions)</label>
                        <input type="password" id="ownerPassword" class="form-control" placeholder="Optional" />
                    </div>
                    <p class="small text-muted">Enter at least one password.</p>
                    <button type="button" class="btn btn-primary btn-lg w-100" id="protectBtn">
                        <i class="fas fa-shield-alt me-2"></i> Protect PDF
                    </button>
                </div>
                <div id="loadingState" class="d-none mt-3 text-center">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2 mb-0">Adding protection...</p>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script>
(function() {
    const fileInput = document.getElementById('fileInput');
    const uploadZone = document.getElementById('uploadZone');
    const formSection = document.getElementById('formSection');
    const fileNameDisplay = document.getElementById('fileNameDisplay');
    const userPassword = document.getElementById('userPassword');
    const ownerPassword = document.getElementById('ownerPassword');
    const protectBtn = document.getElementById('protectBtn');
    const loadingState = document.getElementById('loadingState');
    const clearFile = document.getElementById('clearFile');
    let currentFile = null;

    uploadZone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', e => { if (e.target.files.length) { currentFile = e.target.files[0]; fileNameDisplay.textContent = currentFile.name; uploadZone.classList.add('d-none'); formSection.classList.remove('d-none'); } });
    uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('border-primary'); });
    uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('border-primary'));
    uploadZone.addEventListener('drop', e => { e.preventDefault(); uploadZone.classList.remove('border-primary'); if (e.dataTransfer.files.length) { currentFile = e.dataTransfer.files[0]; fileNameDisplay.textContent = currentFile.name; uploadZone.classList.add('d-none'); formSection.classList.remove('d-none'); } });
    clearFile.addEventListener('click', () => { currentFile = null; formSection.classList.add('d-none'); uploadZone.classList.remove('d-none'); fileInput.value = ''; });

    protectBtn.addEventListener('click', async () => {
        if (!currentFile) return;
        if (!userPassword.value.trim() && !ownerPassword.value.trim()) { alert('Please enter at least one password (user and/or owner).'); return; }
        protectBtn.disabled = true;
        loadingState.classList.remove('d-none');
        const fd = new FormData();
        fd.append('file', currentFile);
        fd.append('userPassword', userPassword.value);
        fd.append('ownerPassword', ownerPassword.value);
        try {
            const res = await fetch('/Pdf/Protect', { method: 'POST', body: fd });
            const result = await res.json();
            loadingState.classList.add('d-none');
            protectBtn.disabled = false;
            if (result.success && result.downloadUrl) { window.location.href = result.downloadUrl; }
            else { alert(result.message || 'Protect failed'); }
        } catch (e) {
            loadingState.classList.add('d-none');
            protectBtn.disabled = false;
            alert('Error: ' + e.message);
        }
    });
})();
</script>
}
