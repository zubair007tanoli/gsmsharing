@{
    ViewData["Title"] = "PDF to Excel - Convert PDF to Excel";
}

<style>
    .tool-page { padding: 2rem 0; }
    .tool-header { text-align: center; margin-bottom: 2rem; }
    .tool-title { font-size: 2rem; font-weight: 700; color: var(--text-dark); margin-bottom: 0.5rem; }
    .tool-description { color: var(--text-light); font-size: 1.1rem; }
    .upload-zone { border: 3px dashed #d0d0d0; border-radius: 20px; padding: 3rem; text-align: center; background: #fff; transition: all 0.3s ease; cursor: pointer; margin-bottom: 2rem; }
    .upload-zone:hover { border-color: #217346; background: rgba(33, 115, 70, 0.02); }
    .upload-icon { font-size: 4rem; color: #217346; margin-bottom: 1rem; }
    .action-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .btn-tool { padding: 1rem 2rem; border-radius: 12px; font-weight: 600; font-size: 1rem; border: none; cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; gap: 0.5rem; }
    .btn-primary { background: linear-gradient(135deg, #217346 0%, #185c37 100%); color: #fff; }
    .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(33, 115, 70, 0.3); }
    .btn-secondary { background: #fff; color: var(--text-dark); border: 2px solid #e0e0e0; }
</style>

<div class="tool-page">
    <div class="container">
        <div class="tool-header">
            <h1 class="tool-title">PDF to Excel</h1>
            <p class="tool-description">Convert your PDF files to editable Excel spreadsheets</p>
        </div>
        <div class="upload-zone" id="uploadZone" style="position: relative;">
            <div class="upload-icon"><i class="fas fa-cloud-upload-alt"></i></div>
            <p class="upload-text">Drag & drop your PDF file here</p>
            <p class="upload-hint">or click to browse</p>
            <input type="file" id="fileInput" accept=".pdf" style="position: absolute; opacity: 0; width: 100%; height: 100%; top: 0; left: 0; cursor: pointer;">
        </div>
        <div class="action-buttons">
            <button type="button" class="btn-tool btn-primary" id="convertBtn" disabled>
                <i class="fas fa-exchange-alt"></i> Convert to Excel
            </button>
            <button type="button" class="btn-tool btn-secondary" id="clearBtn">
                <i class="fas fa-trash-alt"></i> Clear
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const uploadZone = document.getElementById('uploadZone');
            const fileInput = document.getElementById('fileInput');
            const convertBtn = document.getElementById('convertBtn');
            const clearBtn = document.getElementById('clearBtn');
            let currentFile = null;

            uploadZone.addEventListener('click', () => fileInput.click());
            fileInput.addEventListener('change', (e) => {
                if (e.target.files.length > 0) {
                    currentFile = e.target.files[0];
                    if (!currentFile.name.toLowerCase().endsWith('.pdf')) { alert('Please select a PDF file.'); return; }
                    convertBtn.disabled = false;
                }
            });
            clearBtn.addEventListener('click', () => { convertBtn.disabled = true; fileInput.value = ''; currentFile = null; });

            convertBtn.addEventListener('click', async () => {
                if (!currentFile) return;
                convertBtn.disabled = true;
                try {
                    const fd = new FormData();
                    fd.append('file', currentFile);
                    const res = await fetch('/Pdf/ConvertToExcel', { method: 'POST', body: fd });
                    const result = await res.json();
                    convertBtn.disabled = false;
                    if (result.success && result.downloadUrl) { window.location.href = result.downloadUrl; }
                    else { alert(result.message || 'Conversion failed'); }
                } catch (e) {
                    convertBtn.disabled = false;
                    alert('Error: ' + e.message);
                }
            });
        });
    </script>
}
