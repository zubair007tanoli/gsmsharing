@{
    ViewData["Title"] = "Organize PDF - Reorder PDF Pages";
}
<div class="tool-page py-5">
    <div class="container">
        <div class="tool-header text-center mb-4">
            <h1 class="tool-title fw-bold">Organize PDF</h1>
            <p class="tool-description text-muted">Reorder or remove pages (enter page numbers in the new order)</p>
        </div>
        <input type="file" id="fileInput" accept=".pdf" style="display: none;" />
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div id="uploadZone" class="upload-zone border border-3 border-dashed rounded-4 p-5 text-center bg-white cursor-pointer">
                    <i class="fas fa-sort fa-4x text-primary mb-3"></i>
                    <p class="mb-0">Drag & drop your PDF here or click to browse</p>
                </div>
                <div id="formSection" class="d-none mt-3">
                    <div class="mb-3 d-flex align-items-center justify-content-between p-3 bg-light rounded-3">
                        <span id="fileNameDisplay" class="fw-bold"></span>
                        <span class="badge bg-primary" id="pageCountBadge"></span>
                        <button type="button" class="btn-close" id="clearFile" aria-label="Clear"></button>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">New page order (comma-separated page numbers, e.g. 3,1,2 to put page 3 first, then 1, then 2; omit a number to remove that page)</label>
                        <input type="text" id="pageOrder" class="form-control" placeholder="e.g. 3, 1, 2" />
                    </div>
                    <button type="button" class="btn btn-primary btn-lg w-100" id="organizeBtn">
                        <i class="fas fa-check me-2"></i> Organize PDF
                    </button>
                </div>
                <div id="loadingState" class="d-none mt-3 text-center">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2 mb-0">Organizing...</p>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script>
(function() {
    const fileInput = document.getElementById('fileInput');
    const uploadZone = document.getElementById('uploadZone');
    const formSection = document.getElementById('formSection');
    const fileNameDisplay = document.getElementById('fileNameDisplay');
    const pageCountBadge = document.getElementById('pageCountBadge');
    const pageOrder = document.getElementById('pageOrder');
    const organizeBtn = document.getElementById('organizeBtn');
    const loadingState = document.getElementById('loadingState');
    const clearFile = document.getElementById('clearFile');
    let currentFile = null;
    let pageCount = 0;

    uploadZone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', e => { if (e.target.files.length) handleFile(e.target.files[0]); });
    uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('border-primary'); });
    uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('border-primary'));
    uploadZone.addEventListener('drop', e => { e.preventDefault(); uploadZone.classList.remove('border-primary'); if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]); });
    clearFile.addEventListener('click', () => { currentFile = null; formSection.classList.add('d-none'); uploadZone.classList.remove('d-none'); fileInput.value = ''; });

    function handleFile(file) {
        if (!file.name.toLowerCase().endsWith('.pdf')) { alert('Please select a PDF.'); return; }
        currentFile = file;
        fileNameDisplay.textContent = file.name;
        const fd = new FormData();
        fd.append('file', file);
        fetch('/Pdf/GetPdfInfo', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    pageCount = data.pageCount || 0;
                    pageCountBadge.textContent = pageCount + ' page(s)';
                    pageOrder.placeholder = 'e.g. 1,2,3 or 3,1,2';
                    uploadZone.classList.add('d-none');
                    formSection.classList.remove('d-none');
                } else { alert(data.message || 'Could not read PDF'); }
            })
            .catch(() => alert('Failed to read PDF'));
    }

    organizeBtn.addEventListener('click', async () => {
        if (!currentFile) return;
        const raw = pageOrder.value.trim().replace(/\s+/g, '');
        const order = raw ? raw.split(',').map(s => parseInt(s, 10)).filter(n => !isNaN(n) && n >= 1 && n <= pageCount) : [];
        if (order.length === 0) { alert('Enter at least one page number (e.g. 1,2,3 or 3,1,2).'); return; }
        organizeBtn.disabled = true;
        loadingState.classList.remove('d-none');
        const fd = new FormData();
        fd.append('file', currentFile);
        fd.append('pageOrder', JSON.stringify(order));
        try {
            const res = await fetch('/Pdf/Organize', { method: 'POST', body: fd });
            const result = await res.json();
            loadingState.classList.add('d-none');
            organizeBtn.disabled = false;
            if (result.success && result.downloadUrl) { window.location.href = result.downloadUrl; }
            else { alert(result.message || 'Organize failed'); }
        } catch (e) {
            loadingState.classList.add('d-none');
            organizeBtn.disabled = false;
            alert('Error: ' + e.message);
        }
    });
})();
</script>
}
