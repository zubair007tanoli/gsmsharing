@{
    ViewData["Title"] = "PDF to Word - Convert PDF to DOCX";
}

<style>
    .tool-page {
        padding: 2rem 0;
    }

    .tool-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .tool-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.5rem;
    }

    .tool-description {
        color: var(--text-light);
        font-size: 1.1rem;
    }

    .upload-zone {
        border: 3px dashed #d0d0d0;
        border-radius: 20px;
        padding: 3rem;
        text-align: center;
        background: #fff;
        transition: all 0.3s ease;
        cursor: pointer;
        margin-bottom: 2rem;
    }

    .upload-zone:hover, .upload-zone.dragover {
        border-color: #2b579a;
        background: rgba(43, 87, 154, 0.02);
    }

    .upload-icon {
        font-size: 4rem;
        color: #2b579a;
        margin-bottom: 1rem;
    }

    .upload-text {
        font-size: 1.2rem;
        color: var(--text-dark);
        margin-bottom: 0.5rem;
    }

    .upload-hint {
        color: var(--text-light);
        font-size: 0.9rem;
    }

    .conversion-options {
        background: #fff;
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: var(--card-shadow);
    }

    .options-title {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--text-dark);
    }

    .option-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem;
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        margin-bottom: 0.5rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .option-item:hover {
        border-color: #2b579a;
    }

    .option-item.selected {
        border-color: #2b579a;
        background: rgba(43, 87, 154, 0.05);
    }

    .option-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .option-icon {
        width: 40px;
        height: 40px;
        background: #2b579a;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
    }

    .option-text h5 {
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 0.2rem;
    }

    .option-text span {
        font-size: 0.85rem;
        color: var(--text-light);
    }

    .file-info-card {
        background: #fff;
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: var(--card-shadow);
    }

    .file-info-header {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .file-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #2b579a 0%, #1e3c72 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.5rem;
    }

    .file-details h4 {
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 0.25rem;
    }

    .file-details span {
        color: var(--text-light);
        font-size: 0.9rem;
    }

    .output-preview {
        display: none;
        background: linear-gradient(135deg, rgba(43, 87, 154, 0.1) 0%, rgba(30, 60, 114, 0.1) 100%);
        border-radius: 12px;
        padding: 1.5rem;
        margin-top: 1rem;
    }

    .output-preview.active {
        display: block;
    }

    .output-info {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
    }

    .output-icon {
        width: 50px;
        height: 50px;
        background: #2b579a;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.3rem;
    }

    .output-text h5 {
        font-weight: 600;
        color: var(--text-dark);
    }

    .output-text span {
        color: var(--text-light);
        font-size: 0.9rem;
    }

    .action-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-tool {
        padding: 1rem 2rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: linear-gradient(135deg, #2b579a 0%, #1e3c72 100%);
        color: #fff;
    }

    .btn-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(43, 87, 154, 0.3);
    }

    .btn-success {
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
        color: #fff;
    }

    .btn-success:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(67, 233, 123, 0.3);
    }

    .btn-secondary {
        background: #fff;
        color: var(--text-dark);
        border: 2px solid #e0e0e0;
    }

    .btn-secondary:hover {
        border-color: #2b579a;
        color: #2b579a;
    }

    .processing-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.95);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .processing-overlay.active {
        display: flex;
    }

    .processing-content {
        text-align: center;
    }

    .spinner {
        width: 60px;
        height: 60px;
        border: 4px solid #f0f0f0;
        border-top-color: #2b579a;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 0 auto 1rem;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .processing-text {
        font-size: 1.2rem;
        color: var(--text-dark);
        font-weight: 500;
    }
</style>

<div class="tool-page">
    <div class="container">
        <!-- Tool Header -->
        <div class="tool-header">
            <h1 class="tool-title">PDF to Word</h1>
            <p class="tool-description">Convert your PDF files to editable Word documents (.docx)</p>
        </div>

        <!-- Upload Zone -->
        <div class="upload-zone" id="uploadZone">
            <div class="upload-icon">
                <i class="fas fa-cloud-upload-alt"></i>
            </div>
            <p class="upload-text">Drag & drop your PDF file here</p>
            <p class="upload-hint">or click to browse</p>
            <input type="file" id="fileInput" accept=".pdf" style="display: none;">
        </div>

        <!-- Conversion Options -->
        <div class="conversion-options">
            <h3 class="options-title">Output Format</h3>
            <div class="option-item selected" data-format="docx">
                <div class="option-info">
                    <div class="option-icon">
                        <i class="fas fa-file-word"></i>
                    </div>
                    <div class="option-text">
                        <h5>Word Document (.docx)</h5>
                        <span>Editable Word format - recommended</span>
                    </div>
                </div>
                <i class="fas fa-check-circle" style="color: #2b579a;"></i>
            </div>
            <div class="option-item" data-format="doc">
                <div class="option-info">
                    <div class="option-icon">
                        <i class="fas fa-file-word"></i>
                    </div>
                    <div class="option-text">
                        <h5>Word 97-2003 (.doc)</h5>
                        <span>Legacy Word format</span>
                    </div>
                </div>
                <i class="fas fa-circle" style="color: #ccc;"></i>
            </div>
        </div>

        <!-- File Info Card -->
        <div class="file-info-card" id="fileInfoCard" style="display: none;">
            <div class="file-info-header">
                <div class="file-icon">
                    <i class="fas fa-file-pdf"></i>
                </div>
                <div class="file-details">
                    <h4 id="fileName">document.pdf</h4>
                    <span id="fileSize">2.5 MB</span>
                </div>
            </div>
            <div class="output-preview" id="outputPreview">
                <div class="output-info">
                    <div class="output-icon">
                        <i class="fas fa-file-word"></i>
                    </div>
                    <div class="output-text">
                        <h5>Output: document.docx</h5>
                        <span>Ready for download after conversion</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons">
            <button type="button" class="btn-tool btn-primary" id="convertBtn" disabled>
                <i class="fas fa-exchange-alt"></i>
                Convert to Word
            </button>
            <button type="button" class="btn-tool btn-success" id="downloadBtn" style="display: none;">
                <i class="fas fa-download"></i>
                Download
            </button>
            <button type="button" class="btn-tool btn-secondary" id="clearBtn">
                <i class="fas fa-trash-alt"></i>
                Clear
            </button>
        </div>
    </div>

    <!-- Processing Overlay -->
    <div class="processing-overlay" id="processingOverlay">
        <div class="processing-content">
            <div class="spinner"></div>
            <p class="processing-text">Converting PDF to Word...</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const uploadZone = document.getElementById('uploadZone');
            const fileInput = document.getElementById('fileInput');
            const fileInfoCard = document.getElementById('fileInfoCard');
            const outputPreview = document.getElementById('outputPreview');
            const convertBtn = document.getElementById('convertBtn');
            const downloadBtn = document.getElementById('downloadBtn');
            const clearBtn = document.getElementById('clearBtn');
            const processingOverlay = document.getElementById('processingOverlay');
            const optionItems = document.querySelectorAll('.option-item');
            
            let currentFile = null;
            let outputFormat = 'docx';

            uploadZone.addEventListener('click', () => fileInput.click());

            fileInput.addEventListener('change', (e) => {
                if (e.target.files.length > 0) {
                    handleFile(e.target.files[0]);
                }
                fileInput.value = '';
            });

            uploadZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadZone.classList.add('dragover');
            });

            uploadZone.addEventListener('dragleave', () => {
                uploadZone.classList.remove('dragover');
            });

            uploadZone.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadZone.classList.remove('dragover');
                if (e.dataTransfer.files.length > 0) {
                    handleFile(e.dataTransfer.files[0]);
                }
            });

            function handleFile(file) {
                if (file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf')) {
                    currentFile = file;
                    document.getElementById('fileName').textContent = file.name;
                    document.getElementById('fileSize').textContent = formatFileSize(file.size);
                    
                    fileInfoCard.style.display = 'block';
                    outputPreview.classList.remove('active');
                    convertBtn.disabled = false;
                    downloadBtn.style.display = 'none';
                }
            }

            function formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }

            // Format selection
            optionItems.forEach(item => {
                item.addEventListener('click', () => {
                    optionItems.forEach(i => {
                        i.classList.remove('selected');
                        i.querySelector('.fa-check-circle')?.classList.replace('fa-check-circle', 'fa-circle');
                        i.querySelector('.fa-check-circle')?.style.color = '#ccc';
                    });
                    item.classList.add('selected');
                    const icon = item.querySelector('.fa-circle');
                    if (icon) {
                        icon.classList.replace('fa-circle', 'fa-check-circle');
                        icon.style.color = '#2b579a';
                    }
                    outputFormat = item.dataset.format;
                });
            });

            clearBtn.addEventListener('click', () => {
                currentFile = null;
                fileInfoCard.style.display = 'none';
                convertBtn.disabled = true;
                downloadBtn.style.display = 'none';
            });

            convertBtn.addEventListener('click', () => {
                if (!currentFile) return;

                processingOverlay.classList.add('active');

                setTimeout(() => {
                    processingOverlay.classList.remove('active');
                    outputPreview.classList.add('active');
                    downloadBtn.style.display = 'flex';
                }, 2500);
            });

            downloadBtn.addEventListener('click', () => {
                alert(`Download ${outputFormat.toUpperCase()} file functionality would be implemented here.`);
            });
        });
    </script>
}
