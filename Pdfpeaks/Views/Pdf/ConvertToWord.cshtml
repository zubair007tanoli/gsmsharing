@{
    ViewData["Title"] = "PDF to Word - AI-Powered Conversion";
}

<div class="tool-page py-5">
    <div class="container">
        <div class="tool-header text-center mb-5">
            <h1 class="tool-title fw-bold text-dark display-5">PDF to Word</h1>
            <p class="tool-description text-muted fs-5">Utilizing hybrid AI reconstruction to convert PDFs into fully editable Word documents.</p>
        </div>

        <input type="file" id="fileInput" accept=".pdf" style="display: none;" />

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div id="uploadZone" class="upload-zone p-5 text-center border border-3 border-dashed rounded-4 bg-white shadow-sm cursor-pointer position-relative" style="transition: all 0.3s ease; min-height: 300px; display: flex; flex-direction: column; justify-content: center; align-items: center;">
                    <div id="dropPrompt">
                        <div class="upload-icon mb-3">
                            <i class="fas fa-file-word fa-4x text-primary"></i>
                        </div>
                        <h3 class="fs-4 mb-2 fw-bold">Select PDF File</h3>
                        <p class="text-muted">Drag & drop your PDF here or click to browse</p>
                        <span class="badge bg-light text-primary border border-primary px-3 py-2 mt-2">Free & No Limits</span>
                    </div>

                    <div id="selectedFileInfo" class="mt-3 d-none w-100">
                        <div class="d-flex align-items-center justify-content-center p-3 border rounded-3 bg-light">
                            <i class="fas fa-file-pdf fs-3 text-danger me-3"></i>
                            <div class="text-start">
                                <div id="fileNameDisplay" class="fw-bold text-truncate" style="max-width: 250px;"></div>
                                <div id="fileSizeDisplay" class="small text-muted"></div>
                            </div>
                            <button type="button" class="btn-close ms-auto" id="removeFile" aria-label="Close"></button>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <div id="actionArea" class="text-center">
                        <button id="convertBtn" class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow d-none w-100">
                            <i class="fas fa-magic me-2"></i> Start Conversion
                        </button>
                    </div>

                    <div id="loadingState" class="d-none mt-3">
                        <div class="progress mb-3" style="height: 10px;">
                            <div id="conversionProgress" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%"></div>
                        </div>
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="text-primary fw-bold"><i class="fas fa-brain me-2"></i> Running Hybrid AI Reconstruction...</span>
                            <span class="text-muted small">This may take 10-30 seconds</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .upload-zone:hover { border-color: #0d6efd !important; background-color: #fbfcfe !important; transform: scale(1.01); }
    .cursor-pointer { cursor: pointer; }
    .upload-zone.drag-active { background-color: #e9f7fe !important; border-color: #0d6efd !important; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const fileInput = document.getElementById('fileInput');
            const uploadZone = document.getElementById('uploadZone');
            const dropPrompt = document.getElementById('dropPrompt');
            const selectedFileInfo = document.getElementById('selectedFileInfo');
            const fileNameDisplay = document.getElementById('fileNameDisplay');
            const fileSizeDisplay = document.getElementById('fileSizeDisplay');
            const removeFile = document.getElementById('removeFile');
            const convertBtn = document.getElementById('convertBtn');
            const actionArea = document.getElementById('actionArea');
            const loadingState = document.getElementById('loadingState');
            
            let currentFile = null;

            // Click on upload zone to trigger file input
            uploadZone.addEventListener('click', () => {
                if (!currentFile) {
                    fileInput.click();
                }
            });

            // File input change
            fileInput.addEventListener('change', (e) => {
                if (e.target.files.length > 0) {
                    handleFile(e.target.files[0]);
                }
                fileInput.value = '';
            });

            // Drag and drop events
            uploadZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadZone.classList.add('drag-active');
            });

            uploadZone.addEventListener('dragleave', () => {
                uploadZone.classList.remove('drag-active');
            });

            uploadZone.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadZone.classList.remove('drag-active');
                if (e.dataTransfer.files.length > 0) {
                    handleFile(e.dataTransfer.files[0]);
                }
            });

            // Remove file button
            removeFile.addEventListener('click', (e) => {
                e.stopPropagation();
                clearFile();
            });

            function handleFile(file) {
                if (file.type !== 'application/pdf' && !file.name.toLowerCase().endsWith('.pdf')) {
                    alert('Please select a PDF file.');
                    return;
                }

                currentFile = file;
                fileNameDisplay.textContent = file.name;
                fileSizeDisplay.textContent = formatFileSize(file.size);
                
                dropPrompt.classList.add('d-none');
                selectedFileInfo.classList.remove('d-none');
                convertBtn.classList.remove('d-none');
                loadingState.classList.add('d-none');
            }

            function clearFile() {
                currentFile = null;
                dropPrompt.classList.remove('d-none');
                selectedFileInfo.classList.add('d-none');
                convertBtn.classList.add('d-none');
                loadingState.classList.add('d-none');
            }

            function formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }

            // Convert button click
            convertBtn.addEventListener('click', async () => {
                if (!currentFile) return;

                convertBtn.classList.add('d-none');
                loadingState.classList.remove('d-none');
                console.log('[PDF2Word] Starting conversion for:', currentFile.name, '(' + currentFile.size + ' bytes)');

                try {
                    const formData = new FormData();
                    formData.append('file', currentFile);

                    const response = await fetch('/Pdf/ConvertToWord', {
                        method: 'POST',
                        body: formData
                    });

                    console.log('[PDF2Word] Response status:', response.status, response.statusText);
                    const contentType = response.headers.get('content-type') || '';
                    const isJson = contentType.includes('application/json');

                    if (!isJson) {
                        const text = await response.text();
                        console.error('[PDF2Word] Non-JSON response:', text.substring(0, 500));
                        loadingState.classList.add('d-none');
                        convertBtn.classList.remove('d-none');
                        alert('Server error (status ' + response.status + '). Check console for details.');
                        return;
                    }

                    const result = await response.json();
                    console.log('[PDF2Word] Result:', result);

                    loadingState.classList.add('d-none');

                    if (result.success) {
                        if (result.downloadUrl) {
                            window.location.href = result.downloadUrl;
                            clearFile();
                        } else {
                            console.error('[PDF2Word] Success but no downloadUrl:', result);
                            convertBtn.classList.remove('d-none');
                            alert('Conversion succeeded but no download link was returned.');
                        }
                    } else {
                        console.warn('[PDF2Word] Conversion failed:', result.message);
                        alert('Conversion failed: ' + (result.message || 'Unknown error'));
                        convertBtn.classList.remove('d-none');
                    }
                } catch (error) {
                    loadingState.classList.add('d-none');
                    console.error('[PDF2Word] Exception:', error);
                    alert('An error occurred: ' + error.message);
                    convertBtn.classList.remove('d-none');
                }
            });
        });
    </script>
}
