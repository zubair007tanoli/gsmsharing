@{
    ViewData["Title"] = "Split PDF Files - PdfPeaks";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header -->
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold text-primary">
                    <i class="bi bi-scissors"></i> Split PDF Files
                </h1>
                <p class="lead text-muted">Extract pages or split your PDF into multiple files</p>
            </div>

            <!-- Upload Section -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div id="dropZone" class="drop-zone border-2 border-dashed rounded-4 p-5 text-center bg-light">
                        <div class="mb-3">
                            <i class="bi bi-cloud-upload display-1 text-primary"></i>
                        </div>
                        <h4 class="mb-2">Drop your PDF file here</h4>
                        <p class="text-muted mb-3">or</p>
                        <label class="btn btn-primary btn-lg">
                            <i class="bi bi-folder-plus"></i> Select PDF File
                            <input type="file" id="fileInput" accept=".pdf" style="display: none;">
                        </label>
                        <p class="text-muted mt-3 mb-0">
                            <small>Maximum file size: 100MB</small>
                        </p>
                    </div>
                </div>
            </div>

            <!-- PDF Info and Split Options -->
            <div id="pdfInfoContainer" class="card shadow-sm mb-4 d-none">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="bi bi-file-earmark-pdf"></i> <span id="pdfFileName">Document.pdf</span>
                        <small class="text-muted"> - <span id="pdfPageCount">0</span> pages</small>
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Split Mode Selection -->
                    <div class="mb-4">
                        <label class="form-label fw-bold">Choose split mode:</label>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="form-check card h-100 p-3" onclick="selectSplitMode('range')">
                                    <input class="form-check-input" type="radio" name="splitMode" id="modeRange" value="range">
                                    <label class="form-check-label w-100" for="modeRange">
                                        <i class="bi bi-list-columns text-primary fs-3 d-block mb-2"></i>
                                        <strong>Extract Pages</strong>
                                        <small class="text-muted d-block">Select a specific range of pages</small>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check card h-100 p-3" onclick="selectSplitMode('every')">
                                    <input class="form-check-input" type="radio" name="splitMode" id="modeEvery" value="every">
                                    <label class="form-check-label w-100" for="modeEvery">
                                        <i class="bi bi-layout-split text-primary fs-3 d-block mb-2"></i>
                                        <strong>Split Every Page</strong>
                                        <small class="text-muted d-block">Create a separate file for each page</small>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check card h-100 p-3" onclick="selectSplitMode('remove')">
                                    <input class="form-check-input" type="radio" name="splitMode" id="modeRemove" value="remove">
                                    <label class="form-check-label w-100" for="modeRemove">
                                        <i class="bi bi bi-x-circle text-primary fs-3 d-block mb-2"></i>
                                        <strong>Remove Pages</strong>
                                        <small class="text-muted d-block">Delete specific pages from PDF</small>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Range Selection -->
                    <div id="rangeOptions" class="mb-4 d-none">
                        <label class="form-label fw-bold">Select page range:</label>
                        <div class="row g-3 align-items-end">
                            <div class="col-auto">
                                <label class="form-label">From page</label>
                                <input type="number" id="startPage" class="form-control" min="1" value="1" style="width: 100px;">
                            </div>
                            <div class="col-auto">
                                <label class="form-label">to page</label>
                                <input type="number" id="endPage" class="form-control" min="1" value="1" style="width: 100px;">
                            </div>
                            <div class="col-auto">
                                <button type="button" id="previewRangeBtn" class="btn btn-outline-primary">
                                    <i class="bi bi-eye"></i> Preview Selection
                                </button>
                            </div>
                        </div>
                        <small class="text-muted">Example: 1-3 will extract pages 1, 2, and 3</small>
                    </div>

                    <!-- Individual Page Selection -->
                    <div id="pageSelection" class="d-none">
                        <label class="form-label fw-bold">Select pages to keep or remove:</label>
                        <div class="page-selector mb-3">
                            <div id="pageList" class="d-flex flex-wrap gap-2">
                                <!-- Pages will be rendered here -->
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="button" id="selectAllBtn" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-check-square"></i> Select All
                            </button>
                            <button type="button" id="deselectAllBtn" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-x-square"></i> Deselect All
                            </button>
                            <button type="button" id="invertSelectionBtn" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-arrow-repeat"></i> Invert Selection
                            </button>
                        </div>
                    </div>

                    <!-- Preview -->
                    <div id="previewContainer" class="mt-4 d-none">
                        <label class="form-label fw-bold">Selection Preview:</label>
                        <div class="alert alert-info">
                            <strong>Selected:</strong> <span id="selectedSummary">No pages selected</span>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <button id="splitBtn" class="btn btn-success btn-lg w-100" disabled>
                        <i class="bi bi-scissors"></i> Split PDF
                    </button>
                </div>
            </div>

            <!-- Success Result -->
            @if (TempData["Success"] != null)
            {
                <div id="resultContainer" class="card shadow-sm mb-4">
                    <div class="card-body text-center">
                        <div class="mb-4">
                            <i class="bi bi-check-circle-fill text-success display-1"></i>
                        </div>
                        <h3 class="card-title">@TempData["Success"]</h3>
                        <p class="text-muted">@TempData["Info"]</p>
                        
                        @if (TempData["MultipleFiles"] != null && (bool)TempData["MultipleFiles"])
                        {
                            <div class="alert alert-success mt-4">
                                <h5><i class="bi bi-box-seam"></i> Split Files Generated</h5>
                                <p>Your PDF has been split into multiple files.</p>
                            </div>
                        }
                        
                        <div class="d-flex justify-content-center gap-3 mt-4">
                            @if (TempData["MultipleFiles"] != null && (bool)TempData["MultipleFiles"])
                            {
                                <span class="btn btn-primary btn-lg disabled">
                                    <i class="bi bi-download"></i> Download All Files
                                </span>
                            }
                            else
                            {
                                <a href="@TempData["DownloadUrl"]" class="btn btn-primary btn-lg">
                                    <i class="bi bi-download"></i> Download
                                </a>
                            }
                            <a asp-action="Split" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-repeat"></i> Split Another File
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- Error Alert -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triagram"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="loading-overlay d-none">
    <div class="spinner-container">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h4 class="mt-3 text-white">Processing your file...</h4>
    </div>
</div>

@if (TempData["PageCount"] != null)
{
    <input type="hidden" id="existingPageCount" value="@TempData["PageCount"]">
}

@section Styles {
    <style>
        .drop-zone {
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .drop-zone:hover {
            background-color: #e3f2fd !important;
            border-color: #0d6efd !important;
        }
        
        .form-check-input:checked + label {
            background-color: #e7f1ff;
            border-color: #0d6efd;
        }
        
        .form-check-label {
            cursor: pointer;
        }
        
        .page-item {
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        .page-item.selected {
            background-color: #0d6efd !important;
            border-color: #0d6efd !important;
            color: white !important;
        }
        
        .page-number {
            min-width: 40px;
            text-align: center;
        }
        
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }
        
        .loading-overlay .spinner-container {
            text-align: center;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const dropZone = document.getElementById('dropZone');
            const fileInput = document.getElementById('fileInput');
            const pdfInfoContainer = document.getElementById('pdfInfoContainer');
            const pdfFileName = document.getElementById('pdfFileName');
            const pdfPageCount = document.getElementById('pdfPageCount');
            const splitBtn = document.getElementById('splitBtn');
            const loadingOverlay = document.getElementById('loadingOverlay');
            const previewContainer = document.getElementById('previewContainer');
            const selectedSummary = document.getElementById('selectedSummary');
            
            let selectedFile = null;
            let currentSplitMode = '';
            let selectedPages = new Set();
            let totalPages = 0;
            
            // Check if there are existing page count
            const existingPageCountInput = document.getElementById('existingPageCount');
            if (existingPageCountInput) {
                totalPages = parseInt(existingPageCountInput.value);
                pdfPageCount.textContent = totalPages;
                pdfInfoContainer.classList.remove('d-none');
                updateSplitButton();
            }
            
            // Drop zone events
            dropZone.addEventListener('dragover', function(e) {
                e.preventDefault();
                dropZone.classList.add('bg-primary', 'text-white');
            });
            
            dropZone.addEventListener('dragleave', function(e) {
                e.preventDefault();
                dropZone.classList.remove('bg-primary', 'text-white');
            });
            
            dropZone.addEventListener('drop', function(e) {
                e.preventDefault();
                dropZone.classList.remove('bg-primary', 'text-white');
                
                const file = e.dataTransfer.files[0];
                if (file && file.type === 'application/pdf') {
                    handleFile(file);
                } else {
                    alert('Please select a PDF file.');
                }
            });
            
            fileInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    handleFile(file);
                }
            });
            
            dropZone.addEventListener('click', function() {
                fileInput.click();
            });
            
            // Handle file
            async function handleFile(file) {
                selectedFile = file;
                pdfFileName.textContent = file.name;
                
                // Show loading
                loadingOverlay.classList.remove('d-none');
                
                try {
                    const formData = new FormData();
                    formData.append('file', file);
                    
                    const response = await fetch('@Url.Action("GetPdfInfo")', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        totalPages = result.pageCount;
                        pdfPageCount.textContent = totalPages;
                        pdfInfoContainer.classList.remove('d-none');
                        
                        // Initialize page selection
                        initPageSelection();
                        updateSplitButton();
                    } else {
                        alert(result.message || 'Error reading PDF file.');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred while reading the PDF file.');
                } finally {
                    loadingOverlay.classList.add('d-none');
                }
            }
            
            // Initialize page selection UI
            function initPageSelection() {
                const pageList = document.getElementById('pageList');
                pageList.innerHTML = '';
                
                for (let i = 1; i <= totalPages; i++) {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'btn btn-outline-secondary page-item page-number';
                    btn.textContent = i;
                    btn.dataset.page = i;
                    btn.onclick = () => togglePage(i);
                    pageList.appendChild(btn);
                }
            }
            
            // Toggle page selection
            function togglePage(pageNum) {
                if (selectedPages.has(pageNum)) {
                    selectedPages.delete(pageNum);
                } else {
                    selectedPages.add(pageNum);
                }
                updatePageSelectionUI();
                updateSplitButton();
            }
            
            // Update page selection UI
            function updatePageSelectionUI() {
                document.querySelectorAll('.page-item').forEach(btn => {
                    const page = parseInt(btn.dataset.page);
                    btn.classList.toggle('selected', selectedPages.has(page));
                });
                
                if (selectedPages.size > 0) {
                    const pages = Array.from(selectedPages).sort((a, b) => a - b);
                    previewContainer.classList.remove('d-none');
                    
                    if (currentSplitMode === 'remove') {
                        selectedSummary.textContent = `${selectedPages.size} page(s) will be REMOVED`;
                    } else {
                        selectedSummary.textContent = `${selectedPages.size} page(s) selected: ${pages.join(', ')}`;
                    }
                } else {
                    previewContainer.classList.add('d-none');
                }
            }
            
            // Split mode selection
            window.selectSplitMode = function(mode) {
                currentSplitMode = mode;
                
                document.getElementById('modeRange').checked = (mode === 'range');
                document.getElementById('modeEvery').checked = (mode === 'every');
                document.getElementById('modeRemove').checked = (mode === 'remove');
                
                document.getElementById('rangeOptions').classList.toggle('d-none', mode !== 'range');
                document.getElementById('pageSelection').classList.toggle('d-none', mode !== 'every' && mode !== 'remove');
                
                if (mode === 'every') {
                    // Select all pages for splitting
                    selectedPages = new Set();
                    for (let i = 1; i <= totalPages; i++) {
                        selectedPages.add(i);
                    }
                    updatePageSelectionUI();
                } else if (mode === 'remove') {
                    // Clear selection for remove mode
                    selectedPages.clear();
                    updatePageSelectionUI();
                } else {
                    selectedPages.clear();
                    previewContainer.classList.add('d-none');
                }
                
                updateSplitButton();
            };
            
            // Update split button state
            function updateSplitButton() {
                let canSplit = false;
                
                if (currentSplitMode === 'range') {
                    const start = parseInt(document.getElementById('startPage').value);
                    const end = parseInt(document.getElementById('endPage').value);
                    canSplit = start >= 1 && end >= start && end <= totalPages;
                } else if (currentSplitMode === 'every') {
                    canSplit = selectedPages.size > 0;
                } else if (currentSplitMode === 'remove') {
                    canSplit = selectedPages.size > 0 && selectedPages.size < totalPages;
                }
                
                splitBtn.disabled = !canSplit;
            }
            
            // Page range inputs
            document.getElementById('startPage').addEventListener('change', updateSplitButton);
            document.getElementById('endPage').addEventListener('change', updateSplitButton);
            
            // Select/Deselect/Invert buttons
            document.getElementById('selectAllBtn').addEventListener('click', function() {
                for (let i = 1; i <= totalPages; i++) {
                    selectedPages.add(i);
                }
                updatePageSelectionUI();
                updateSplitButton();
            });
            
            document.getElementById('deselectAllBtn').addEventListener('click', function() {
                selectedPages.clear();
                updatePageSelectionUI();
                updateSplitButton();
            });
            
            document.getElementById('invertSelectionBtn').addEventListener('click', function() {
                const newSet = new Set();
                for (let i = 1; i <= totalPages; i++) {
                    if (!selectedPages.has(i)) {
                        newSet.add(i);
                    }
                }
                selectedPages = newSet;
                updatePageSelectionUI();
                updateSplitButton();
            });
            
            // Split button
            splitBtn.addEventListener('click', async function() {
                if (!selectedFile) return;
                
                let startPage = 1, endPage = totalPages;
                
                if (currentSplitMode === 'range') {
                    startPage = parseInt(document.getElementById('startPage').value);
                    endPage = parseInt(document.getElementById('endPage').value);
                }
                
                const formData = new FormData();
                formData.append('file', selectedFile);
                formData.append('startPage', startPage);
                formData.append('endPage', endPage);
                
                loadingOverlay.classList.remove('d-none');
                
                try {
                    const response = await fetch('@Url.Action("Split")', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.text();
                    document.body.innerHTML = result;
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred while processing your file.');
                } finally {
                    loadingOverlay.classList.add('d-none');
                }
            });
        });
    </script>
}
