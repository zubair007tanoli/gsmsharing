@{
    ViewData["Title"] = "Unlock PDF - Remove Password Protection";
}
<div class="tool-page" style="padding: 2rem 0;">
    <div class="container">
        <div class="tool-header" style="text-align: center; margin-bottom: 2rem;">
            <h1 class="tool-title" style="font-size: 2rem; font-weight: 700; color: var(--text-dark);">Unlock PDF</h1>
            <p class="tool-description" style="color: var(--text-light);">Remove password protection from your PDF</p>
        </div>
        <div class="upload-zone" style="border: 3px dashed #d0d0d0; border-radius: 20px; padding: 3rem; text-align: center; background: #fff;">
            <i class="fas fa-cloud-upload-alt" style="font-size: 4rem; color: var(--primary-color); margin-bottom: 1rem;"></i>
            <p>Drag & drop your password-protected PDF here</p>
        </div>
    </div>
</div>
