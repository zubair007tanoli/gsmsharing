@{
    ViewData["Title"] = "Excel to PDF - Convert XLS/XLSX to PDF";
}

@Html.AntiForgeryToken()

<div class="tool-wrap py-5">
    <div class="container">
        <div class="text-center mb-4">
            <h1 class="fw-bold mb-2">Excel to PDF</h1>
            <p class="text-muted mb-0">Create print-ready PDFs while preserving workbook layout and text searchability</p>
        </div>

        <input type="file" id="fileInput" accept=".xls,.xlsx,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" style="display:none;" />

        <div class="row g-4 justify-content-center">
            <div class="col-lg-8">
                <div id="uploadZone" class="upload-zone card shadow-sm border-0">
                    <div class="card-body p-5 text-center">
                        <div class="upload-icon mb-3">
                            <i class="fas fa-file-excel"></i>
                        </div>
                        <h5 class="mb-2">Drop Excel file here</h5>
                        <p class="text-muted mb-3">or select a workbook from your device</p>
                        <button type="button" class="btn btn-success px-4" id="selectFileBtn">
                            <i class="fas fa-folder-open me-2"></i>Select Excel
                        </button>
                        <p class="small text-muted mt-3 mb-0">Supported: .xls, .xlsx</p>
                    </div>
                </div>

                <div id="fileCard" class="card shadow-sm border-0 mt-3 d-none">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <div class="fw-semibold" id="fileName">-</div>
                                <div class="small text-muted" id="fileMeta">-</div>
                                <div class="small text-muted">Output is generated with worksheet print settings and page-fit analysis.</div>
                            </div>
                            <button type="button" class="btn-close" id="clearFile" aria-label="Clear"></button>
                        </div>
                        <div class="d-grid mt-4">
                            <button type="button" class="btn btn-success btn-lg" id="convertBtn">
                                <i class="fas fa-file-pdf me-2"></i>Convert to PDF
                            </button>
                        </div>
                    </div>
                </div>

                <div id="loading" class="text-center mt-3 d-none">
                    <div class="spinner-border text-success" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <div class="mt-2 text-muted">Converting Excel to PDF...</div>
                </div>

                <div id="errorAlert" class="alert alert-danger mt-3 d-none" role="alert"></div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 info-card">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3"><i class="fas fa-circle-info me-2"></i>Conversion Notes</h6>
                        <div class="small text-muted">
                            <div class="mb-2">Page orientation and margins are auto-evaluated per worksheet.</div>
                            <div class="mb-2">Large sheets are fitted to avoid clipped content.</div>
                            <div class="mb-2">Searchable text is preserved where source cells contain text.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .tool-wrap {
            background:
                radial-gradient(circle at 10% 20%, rgba(25, 135, 84, 0.12), transparent 40%),
                radial-gradient(circle at 88% 18%, rgba(13, 110, 253, 0.08), transparent 36%),
                #f8f9fb;
        }

        .upload-zone {
            border: 2px dashed #e2e6ea;
            transition: all 0.2s ease;
            cursor: pointer;
            background: #fff;
        }

        .upload-zone:hover,
        .upload-zone.dragover {
            border-color: #198754;
            transform: translateY(-1px);
        }

        .upload-icon {
            font-size: 3rem;
            color: #198754;
        }

        .info-card {
            position: sticky;
            top: 88px;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const fileInput = document.getElementById('fileInput');
            const uploadZone = document.getElementById('uploadZone');
            const selectFileBtn = document.getElementById('selectFileBtn');
            const fileCard = document.getElementById('fileCard');
            const fileName = document.getElementById('fileName');
            const fileMeta = document.getElementById('fileMeta');
            const clearFile = document.getElementById('clearFile');
            const convertBtn = document.getElementById('convertBtn');
            const loading = document.getElementById('loading');
            const errorAlert = document.getElementById('errorAlert');

            let currentFile = null;

            function isExcel(name) {
                const lower = (name || '').toLowerCase();
                return lower.endsWith('.xls') || lower.endsWith('.xlsx');
            }

            function parseJsonSafe(text) {
                if (!text || !text.trim()) return {};
                try { return JSON.parse(text); } catch { return {}; }
            }

            function formatBytes(bytes) {
                if (!bytes) return '0 B';
                const units = ['B', 'KB', 'MB', 'GB'];
                let value = bytes;
                let i = 0;
                while (value >= 1024 && i < units.length - 1) {
                    value /= 1024;
                    i++;
                }
                return `${value.toFixed(value >= 100 ? 0 : 2)} ${units[i]}`;
            }

            function showError(message) {
                errorAlert.textContent = message;
                errorAlert.classList.remove('d-none');
            }

            function hideError() {
                errorAlert.classList.add('d-none');
                errorAlert.textContent = '';
            }

            function reset() {
                currentFile = null;
                fileInput.value = '';
                fileCard.classList.add('d-none');
                uploadZone.classList.remove('d-none');
                loading.classList.add('d-none');
                convertBtn.disabled = false;
                convertBtn.innerHTML = '<i class="fas fa-file-pdf me-2"></i>Convert to PDF';
                hideError();
            }

            function setFile(file) {
                hideError();
                if (!file || !isExcel(file.name)) {
                    showError('Please select an Excel file (.xls or .xlsx).');
                    return;
                }
                currentFile = file;
                fileName.textContent = file.name;
                fileMeta.textContent = `Size: ${formatBytes(file.size)}`;
                uploadZone.classList.add('d-none');
                fileCard.classList.remove('d-none');
            }

            function postWithXhr(url, formData) {
                return new Promise((resolve, reject) => {
                    const xhr = new XMLHttpRequest();
                    xhr.open('POST', url, true);
                    xhr.withCredentials = true;
                    xhr.onreadystatechange = function () {
                        if (xhr.readyState !== 4) return;
                        resolve({
                            ok: xhr.status >= 200 && xhr.status < 300,
                            status: xhr.status,
                            text: xhr.responseText || ''
                        });
                    };
                    xhr.onerror = function () {
                        reject(new Error('Network transport failed (XHR).'));
                    };
                    xhr.send(formData);
                });
            }

            selectFileBtn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                fileInput.click();
            });

            uploadZone.addEventListener('click', function () {
                fileInput.click();
            });

            fileInput.addEventListener('change', function (e) {
                if (e.target.files && e.target.files.length > 0) {
                    setFile(e.target.files[0]);
                }
            });

            uploadZone.addEventListener('dragover', function (e) {
                e.preventDefault();
                uploadZone.classList.add('dragover');
            });

            uploadZone.addEventListener('dragleave', function () {
                uploadZone.classList.remove('dragover');
            });

            uploadZone.addEventListener('drop', function (e) {
                e.preventDefault();
                uploadZone.classList.remove('dragover');
                const file = e.dataTransfer?.files?.[0];
                if (file) setFile(file);
            });

            clearFile.addEventListener('click', reset);

            convertBtn.addEventListener('click', async function () {
                if (!currentFile) return;

                hideError();
                convertBtn.disabled = true;
                convertBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Converting...';
                loading.classList.remove('d-none');

                try {
                    const fd = new FormData();
                    fd.append('file', currentFile);

                    let res;
                    try {
                        const fetchRes = await fetch('/Pdf/ConvertFromExcel', { method: 'POST', body: fd });
                        res = { ok: fetchRes.ok, status: fetchRes.status, text: await fetchRes.text() };
                    } catch {
                        res = await postWithXhr('/Pdf/ConvertFromExcel', fd);
                    }

                    const result = parseJsonSafe(res.text);
                    if (result.success && result.downloadUrl) {
                        window.location.href = result.downloadUrl;
                    } else {
                        const statusText = !res.ok ? ` (HTTP ${res.status})` : '';
                        showError(result.message || `Conversion failed${statusText}.`);
                    }
                } catch (err) {
                    showError('Error while converting Excel to PDF: ' + (err.message || 'Unknown error'));
                } finally {
                    loading.classList.add('d-none');
                    convertBtn.disabled = false;
                    convertBtn.innerHTML = '<i class="fas fa-file-pdf me-2"></i>Convert to PDF';
                }
            });
        });
    </script>
}
