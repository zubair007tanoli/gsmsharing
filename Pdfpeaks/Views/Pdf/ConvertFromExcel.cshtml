@{
    ViewData["Title"] = "Excel to PDF - Convert XLSX to PDF";
}
<div class="tool-page" style="padding: 2rem 0;">
    <div class="container">
        <div class="tool-header" style="text-align: center; margin-bottom: 2rem;">
            <h1 class="tool-title" style="font-size: 2rem; font-weight: 700; color: var(--text-dark); margin-bottom: 0.5rem;">Excel to PDF</h1>
            <p class="tool-description" style="color: var(--text-light); font-size: 1.1rem;">Convert your Excel spreadsheets to PDF</p>
        </div>
        <div class="upload-zone" style="border: 3px dashed #d0d0d0; border-radius: 20px; padding: 3rem; text-align: center; background: #fff;">
            <i class="fas fa-cloud-upload-alt" style="font-size: 4rem; color: #217346; margin-bottom: 1rem;"></i>
            <p style="font-size: 1.2rem; color: var(--text-dark); margin-bottom: 0.5rem;">Drag & drop your Excel file here</p>
            <p style="color: var(--text-light); font-size: 0.9rem;">.xls, .xlsx</p>
        </div>
    </div>
</div>
