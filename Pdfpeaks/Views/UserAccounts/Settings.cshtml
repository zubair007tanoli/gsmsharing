@{
    ViewData["Title"] = "Settings - PdfPeaks";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <h4 class="fw-bold mb-4"><i class="fas fa-cog me-2" style="color: var(--primary-color);"></i> Account Settings</h4>
            
            <div class="row">
                <!-- Settings Navigation -->
                <div class="col-lg-3 mb-4">
                    <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                        <div class="card-body p-3">
                            <nav class="nav flex-column">
                                <a class="nav-link active py-3 px-3 rounded mb-2" href="#security" data-bs-toggle="tab" style="background: rgba(233, 64, 87, 0.1); color: var(--primary-color);">
                                    <i class="fas fa-shield-alt me-2"></i> Security
                                </a>
                                <a class="nav-link py-3 px-3 rounded mb-2" href="#notifications" data-bs-toggle="tab" style="color: var(--text-dark);">
                                    <i class="fas fa-bell me-2"></i> Notifications
                                </a>
                                <a class="nav-link py-3 px-3 rounded mb-2" href="#privacy" data-bs-toggle="tab" style="color: var(--text-dark);">
                                    <i class="fas fa-user-secret me-2"></i> Privacy
                                </a>
                                <a class="nav-link py-3 px-3 rounded mb-2" href="#storage" data-bs-toggle="tab" style="color: var(--text-dark);">
                                    <i class="fas fa-cloud me-2"></i> Storage
                                </a>
                                <a class="nav-link py-3 px-3 rounded" href="#integrations" data-bs-toggle="tab" style="color: var(--text-dark);">
                                    <i class="fas fa-plug me-2"></i> Integrations
                                </a>
                            </nav>
                        </div>
                    </div>
                </div>
                
                <!-- Settings Content -->
                <div class="col-lg-9">
                    <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                        <div class="card-body p-5">
                            <div class="tab-content">
                                <!-- Security Tab -->
                                <div class="tab-pane fade show active" id="security">
                                    <h5 class="fw-bold mb-4">Security Settings</h5>
                                    
                                    <div class="mb-5">
                                        <h6 class="fw-bold mb-3">Change Password</h6>
                                        <form>
                                            <div class="mb-3">
                                                <label class="form-label">Current Password</label>
                                                <input type="password" class="form-control" style="border-radius: 10px;">
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">New Password</label>
                                                <input type="password" class="form-control" style="border-radius: 10px;">
                                            </div>
                                            <div class="mb-4">
                                                <label class="form-label">Confirm New Password</label>
                                                <input type="password" class="form-control" style="border-radius: 10px;">
                                            </div>
                                            <button type="submit" class="btn text-white px-4" style="background: var(--gradient-1); border-radius: 10px;">Update Password</button>
                                        </form>
                                    </div>
                                    
                                    <hr class="my-4">
                                    
                                    <div class="mb-4">
                                        <h6 class="fw-bold mb-3">Two-Factor Authentication</h6>
                                        <div class="d-flex justify-content-between align-items-center p-3 rounded" style="background: rgba(255,255,255,0.5); border: 1px solid #e0e0e0;">
                                            <div>
                                                <p class="mb-0 fw-bold">2FA Status</p>
                                                <p class="text-muted small mb-0">Add an extra layer of security to your account</p>
                                            </div>
                                            <button class="btn btn-outline-success" style="border-radius: 10px;"><i class="fas fa-check-circle me-1"></i> Enabled</button>
                                        </div>
                                    </div>
                                    
                                    <div>
                                        <h6 class="fw-bold mb-3">Active Sessions</h6>
                                        <div class="d-flex justify-content-between align-items-center p-3 rounded mb-2" style="background: rgba(233, 64, 87, 0.1);">
                                            <div class="d-flex align-items-center">
                                                <i class="fas fa-desktop me-3 fs-4" style="color: var(--primary-color);"></i>
                                                <div>
                                                    <p class="mb-0 fw-bold">Windows - Chrome</p>
                                                    <p class="text-muted small mb-0">Current session • Karachi, PK</p>
                                                </div>
                                            </div>
                                            <span class="badge bg-success">Active</span>
                                        </div>
                                        <button class="btn btn-outline-danger btn-sm" style="border-radius: 8px;"><i class="fas fa-sign-out-alt me-1"></i> Sign out all other sessions</button>
                                    </div>
                                </div>
                                
                                <!-- Notifications Tab -->
                                <div class="tab-pane fade" id="notifications">
                                    <h5 class="fw-bold mb-4">Notification Preferences</h5>
                                    
                                    <div class="mb-4">
                                        <h6 class="fw-bold mb-3">Email Notifications</h6>
                                        <div class="form-check form-switch mb-3">
                                            <input class="form-check-input" type="checkbox" id="emailConversion" checked>
                                            <label class="form-check-label" for="emailConversion">Conversion completed</label>
                                        </div>
                                        <div class="form-check form-switch mb-3">
                                            <input class="form-check-input" type="checkbox" id="emailStorage" checked>
                                            <label class="form-check-label" for="emailStorage">Storage limit warnings</label>
                                        </div>
                                        <div class="form-check form-switch mb-3">
                                            <input class="form-check-input" type="checkbox" id="emailPromo">
                                            <label class="form-check-label" for="emailPromo">Promotional emails</label>
                                        </div>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="emailNewsletter" checked>
                                            <label class="form-check-label" for="emailNewsletter">Weekly newsletter</label>
                                        </div>
                                    </div>
                                    
                                    <hr class="my-4">
                                    
                                    <div class="mb-4">
                                        <h6 class="fw-bold mb-3">Push Notifications</h6>
                                        <div class="form-check form-switch mb-3">
                                            <input class="form-check-input" type="checkbox" id="pushBrowser" checked>
                                            <label class="form-check-label" for="pushBrowser">Browser notifications</label>
                                        </div>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="pushMobile">
                                            <label class="form-check-label" for="pushMobile">Mobile app notifications</label>
                                        </div>
                                    </div>
                                    
                                    <button class="btn text-white px-4" style="background: var(--gradient-1); border-radius: 10px;"><i class="fas fa-save me-2"></i> Save Preferences</button>
                                </div>
                                
                                <!-- Privacy Tab -->
                                <div class="tab-pane fade" id="privacy">
                                    <h5 class="fw-bold mb-4">Privacy Settings</h5>
                                    
                                    <div class="mb-4">
                                        <h6 class="fw-bold mb-3">Profile Visibility</h6>
                                        <select class="form-select" style="border-radius: 10px;">
                                            <option selected>Public - Anyone can see your profile</option>
                                            <option>Private - Only you can see your profile</option>
                                            <option>Friends - Only connected users can see</option>
                                        </select>
                                    </div>
                                    
                                    <div class="mb-4">
                                        <h6 class="fw-bold mb-3">Activity Status</h6>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="activityStatus" checked>
                                            <label class="form-check-label" for="activityStatus">Show when I'm active</label>
                                        </div>
                                    </div>
                                    
                                    <hr class="my-4">
                                    
                                    <div class="mb-4">
                                        <h6 class="fw-bold mb-3 text-danger">Danger Zone</h6>
                                        <div class="p-4 rounded" style="background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.3);">
                                            <p class="mb-3">Once you delete your account, there is no going back. Please be certain.</p>
                                            <button class="btn btn-outline-danger" style="border-radius: 10px;"><i class="fas fa-trash me-1"></i> Delete Account</button>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Storage Tab -->
                                <div class="tab-pane fade" id="storage">
                                    <h5 class="fw-bold mb-4">Storage Management</h5>
                                    
                                    <div class="mb-4">
                                        <div class="d-flex justify-content-between mb-2">
                                            <span class="fw-bold">Storage Used</span>
                                            <span class="fw-bold">2.4 GB / 5 GB</span>
                                        </div>
                                        <div class="progress" style="height: 20px; border-radius: 10px;">
                                            <div class="progress-bar" role="progressbar" style="width: 48%; background: var(--gradient-1); border-radius: 10px;"></div>
                                        </div>
                                    </div>
                                    
                                    <div class="mb-4">
                                        <h6 class="fw-bold mb-3">Files by Type</h6>
                                        <div class="row text-center">
                                            <div class="col-3">
                                                <div class="p-3 rounded" style="background: rgba(233, 64, 87, 0.1);">
                                                    <i class="fas fa-file-pdf fa-2x mb-2" style="color: var(--primary-color);"></i>
                                                    <p class="mb-0 fw-bold">1.2 GB</p>
                                                    <p class="text-muted small">PDFs</p>
                                                </div>
                                            </div>
                                            <div class="col-3">
                                                <div class="p-3 rounded" style="background: rgba(102, 126, 234, 0.1);">
                                                    <i class="fas fa-file-word fa-2x mb-2" style="color: #2b579a;"></i>
                                                    <p class="mb-0 fw-bold">0.8 GB</p>
                                                    <p class="text-muted small">Word</p>
                                                </div>
                                            </div>
                                            <div class="col-3">
                                                <div class="p-3 rounded" style="background: rgba(242, 113, 33, 0.1);">
                                                    <i class="fas fa-file-excel fa-2x mb-2" style="color: #217346;"></i>
                                                    <p class="mb-0 fw-bold">0.3 GB</p>
                                                    <p class="text-muted small">Excel</p>
                                                </div>
                                            </div>
                                            <div class="col-3">
                                                <div class="p-3 rounded" style="background: rgba(138, 86, 172, 0.1);">
                                                    <i class="fas fa-file-image fa-2x mb-2" style="color: var(--accent-color);"></i>
                                                    <p class="mb-0 fw-bold">0.1 GB</p>
                                                    <p class="text-muted small">Images</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <button class="btn btn-outline-danger" style="border-radius: 10px;"><i class="fas fa-trash me-1"></i> Clear All Files</button>
                                </div>
                                
                                <!-- Integrations Tab -->
                                <div class="tab-pane fade" id="integrations">
                                    <h5 class="fw-bold mb-4">Connected Apps & Services</h5>
                                    
                                    <div class="mb-4">
                                        <div class="d-flex justify-content-between align-items-center p-4 rounded mb-3" style="background: rgba(255,255,255,0.5); border: 1px solid #e0e0e0;">
                                            <div class="d-flex align-items-center">
                                                <i class="fab fa-dropbox fa-2x me-3" style="color: #0061ff;"></i>
                                                <div>
                                                    <p class="mb-0 fw-bold">Dropbox</p>
                                                    <p class="text-muted small mb-0">Sync files with Dropbox</p>
                                                </div>
                                            </div>
                                            <button class="btn btn-outline-danger btn-sm" style="border-radius: 8px;">Disconnect</button>
                                        </div>
                                        
                                        <div class="d-flex justify-content-between align-items-center p-4 rounded mb-3" style="background: rgba(255,255,255,0.5); border: 1px solid #e0e0e0;">
                                            <div class="d-flex align-items-center">
                                                <i class="fab fa-google-drive fa-2x me-3" style="color: #4285f4;"></i>
                                                <div>
                                                    <p class="mb-0 fw-bold">Google Drive</p>
                                                    <p class="text-muted small mb-0">Sync files with Google Drive</p>
                                                </div>
                                            </div>
                                            <button class="btn btn-outline-success btn-sm" style="border-radius: 8px;"><i class="fas fa-check me-1"></i> Connected</button>
                                        </div>
                                        
                                        <div class="d-flex justify-content-between align-items-center p-4 rounded" style="background: rgba(255,255,255,0.5); border: 1px solid #e0e0e0;">
                                            <div class="d-flex align-items-center">
                                                <i class="fab fa-slack fa-2x me-3" style="color: #4a154b;"></i>
                                                <div>
                                                    <p class="mb-0 fw-bold">Slack</p>
                                                    <p class="text-muted small mb-0">Get notifications in Slack</p>
                                                </div>
                                            </div>
                                            <button class="btn btn-outline-primary btn-sm" style="border-radius: 8px;">Connect</button>
                                        </div>
                                    </div>
                                    
                                    <h6 class="fw-bold mb-3">API Access</h6>
                                    <div class="p-4 rounded" style="background: rgba(255,255,255,0.5); border: 1px solid #e0e0e0;">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <span class="fw-bold">API Key</span>
                                            <button class="btn btn-outline-primary btn-sm" style="border-radius: 8px;"><i class="fas fa-key me-1"></i> Generate New Key</button>
                                        </div>
                                        <input type="password" class="form-control" value="pk_live_xxxxxxxxxxxxxxxxxxxxxxxx" readonly style="border-radius: 10px;">
                                        <p class="text-muted small mt-2 mb-0">Use this key to access the PdfPeaks API</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: all 0.3s ease;
    }
    
    .nav-link:hover {
        background: rgba(233, 64, 87, 0.1) !important;
    }
    
    .form-control:focus, .form-select:focus {
        box-shadow: none;
        border-color: var(--primary-color);
    }
    
    .form-switch .form-check-input:checked {
        background-color: var(--primary-color);
        border-color: var(--primary-color);
    }
    
    .progress {
        background: rgba(233, 64, 87, 0.2);
    }
</style>
