@{
    ViewData["Title"] = "User Accounts - PdfPeaks";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <i class="fas fa-user-circle fa-4x mb-4" style="color: var(--primary-color);"></i>
        <h2 class="fw-bold mb-3">Welcome to PdfPeaks</h2>
        <p class="text-muted mb-4">Manage your account and preferences</p>
        
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="d-grid gap-3">
                    <a href="/UserAccounts/Login" class="btn py-3 fw-bold text-white" style="background: var(--gradient-1); border-radius: 10px;">
                        <i class="fas fa-sign-in-alt me-2"></i> Sign In
                    </a>
                    <a href="/UserAccounts/Register" class="btn py-3 fw-bold text-white" style="background: var(--gradient-2); border-radius: 10px;">
                        <i class="fas fa-user-plus me-2"></i> Create Account
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row justify-content-center mt-5">
        <div class="col-lg-8">
            <div class="row text-center">
                <div class="col-md-4 mb-4">
                    <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
                        <div class="card-body py-4">
                            <i class="fas fa-tachometer-alt fa-2x mb-3" style="color: var(--primary-color);"></i>
                            <h5 class="fw-bold">Dashboard</h5>
                            <p class="text-muted small">View your conversion history and stats</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
                        <div class="card-body py-4">
                            <i class="fas fa-user fa-2x mb-3" style="color: var(--accent-color);"></i>
                            <h5 class="fw-bold">Profile</h5>
                            <p class="text-muted small">Manage your personal information</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
                        <div class="card-body py-4">
                            <i class="fas fa-cog fa-2x mb-3" style="color: var(--secondary-color);"></i>
                            <h5 class="fw-bold">Settings</h5>
                            <p class="text-muted small">Configure your account preferences</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: all 0.3s ease;
    }
    
    .card:hover {
        transform: translateY(-5px);
    }
    
    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(233, 64, 87, 0.3);
    }
</style>
