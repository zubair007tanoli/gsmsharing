@{
    ViewData["Title"] = "My Profile - PdfPeaks";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Profile Header -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 20px; overflow: hidden;">
                <div class="card-header py-5" style="background: var(--gradient-1);"></div>
                <div class="card-body px-5">
                    <div class="row align-items-end">
                        <div class="col-md-3">
                            <img src="https://via.placeholder.com/150" alt="Profile" class="rounded-circle mb-n4 ms-3" style="width: 150px; height: 150px; object-fit: cover; border: 5px solid white; box-shadow: 0 5px 20px rgba(0,0,0,0.1);">
                        </div>
                        <div class="col-md-6 mb-3">
                            <h4 class="fw-bold mb-1">John Doe</h4>
                            <p class="text-muted mb-0">Premium Member</p>
                            <span class="badge mt-2" style="background: var(--gradient-1);">Pro Plan</span>
                        </div>
                        <div class="col-md-3 mb-3 text-md-end">
                            <button class="btn btn-outline-primary me-2"><i class="fas fa-edit me-1"></i> Edit Profile</button>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <!-- Profile Info -->
                <div class="col-lg-8 mb-4">
                    <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                        <div class="card-header bg-white py-4 border-0">
                            <h5 class="fw-bold mb-0"><i class="fas fa-user me-2" style="color: var(--primary-color);"></i> Personal Information</h5>
                        </div>
                        <div class="card-body p-4">
                            <form>
                                <div class="row">
                                    <div class="col-md-6 mb-4">
                                        <label class="form-label fw-bold">First Name</label>
                                        <input type="text" class="form-control" value="John" style="border-radius: 10px;">
                                    </div>
                                    <div class="col-md-6 mb-4">
                                        <label class="form-label fw-bold">Last Name</label>
                                        <input type="text" class="form-control" value="Doe" style="border-radius: 10px;">
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold">Email Address</label>
                                    <input type="email" class="form-control" value="john.doe@example.com" style="border-radius: 10px;">
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold">Username</label>
                                    <div class="input-group">
                                        <span class="input-group-text" style="border-radius: 10px 0 0 10px;">@@</span>
                                        <input type="text" class="form-control" value="johndoe" style="border-radius: 0 10px 10px 0;">
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold">Phone Number</label>
                                    <input type="tel" class="form-control" value="+1 234 567 8900" style="border-radius: 10px;">
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold">Bio</label>
                                    <textarea class="form-control" rows="4" style="border-radius: 10px;">Passionate about document management and productivity tools. Love using PdfPeaks for all my PDF needs.</textarea>
                                </div>
                                <button type="submit" class="btn text-white px-4 py-2" style="background: var(--gradient-1); border-radius: 10px;">
                                    <i class="fas fa-save me-2"></i> Save Changes
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                
                <!-- Sidebar -->
                <div class="col-lg-4">
                    <!-- Account Stats -->
                    <div class="card border-0 shadow-sm mb-4" style="border-radius: 20px;">
                        <div class="card-header bg-white py-4 border-0">
                            <h5 class="fw-bold mb-0"><i class="fas fa-chart-bar me-2" style="color: var(--primary-color);"></i> Statistics</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted">Conversions</span>
                                <span class="fw-bold">1,284</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted">Files Processed</span>
                                <span class="fw-bold">3,567</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted">Member Since</span>
                                <span class="fw-bold">Jan 2025</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted">Storage Used</span>
                                <span class="fw-bold">2.4 GB</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Subscription -->
                    <div class="card border-0 shadow-sm mb-4" style="border-radius: 20px;">
                        <div class="card-header bg-white py-4 border-0">
                            <h5 class="fw-bold mb-0"><i class="fas fa-credit-card me-2" style="color: var(--primary-color);"></i> Subscription</h5>
                        </div>
                        <div class="card-body">
                            <div class="text-center mb-3">
                                <span class="badge px-3 py-2 fs-6" style="background: var(--gradient-1);">Pro Plan</span>
                            </div>
                            <p class="text-center text-muted mb-3">$9.99/month</p>
                            <div class="d-grid gap-2">
                                <button class="btn btn-outline-primary" style="border-radius: 10px;"><i class="fas fa-sync me-1"></i> Manage Subscription</button>
                                <button class="btn btn-outline-secondary" style="border-radius: 10px;"><i class="fas fa-history me-1"></i> Billing History</button>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Connected Accounts -->
                    <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                        <div class="card-header bg-white py-4 border-0">
                            <h5 class="fw-bold mb-0"><i class="fas fa-link me-2" style="color: var(--primary-color);"></i> Connected Accounts</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between mb-3 p-2 rounded" style="background: rgba(255,255,255,0.5);">
                                <div class="d-flex align-items-center">
                                    <i class="fab fa-google me-3 fs-5" style="color: #db4437;"></i>
                                    <span>Google</span>
                                </div>
                                <span class="badge bg-success">Connected</span>
                            </div>
                            <div class="d-flex align-items-center justify-content-between p-2 rounded" style="background: rgba(255,255,255,0.5);">
                                <div class="d-flex align-items-center">
                                    <i class="fab fa-github me-3 fs-5" style="color: #333;"></i>
                                    <span>GitHub</span>
                                </div>
                                <button class="btn btn-sm btn-outline-primary" style="border-radius: 8px;">Connect</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: all 0.3s ease;
    }
    
    .form-control:focus, .form-control:focus {
        box-shadow: none;
        border-color: var(--primary-color);
    }
    
    .btn:hover {
        transform: translateY(-2px);
    }
</style>
