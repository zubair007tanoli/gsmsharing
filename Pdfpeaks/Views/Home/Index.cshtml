@{
    ViewData["Title"] = "Home";
}

<style>
    /* Hero Section */
    .hero-section {
        padding: 4rem 0 3rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        background: var(--gradient-1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 1.5rem;
        animation: fadeInUp 0.8s ease;
    }

    .hero-subtitle {
        font-size: 1.3rem;
        color: var(--text-light);
        margin-bottom: 2rem;
        animation: fadeInUp 0.8s ease 0.2s backwards;
    }

    .hero-features {
        display: flex;
        justify-content: center;
        gap: 2rem;
        flex-wrap: wrap;
        margin-top: 2rem;
        animation: fadeInUp 0.8s ease 0.4s backwards;
    }

    .hero-feature {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-light);
        font-weight: 500;
    }

        .hero-feature i {
            color: var(--primary-color);
            font-size: 1.2rem;
        }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Tools Section */
    .tools-section {
        padding: 2rem 0 3rem;
    }

    .section-title {
        font-size: 2.5rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 1rem;
        color: var(--text-dark);
    }

    .section-subtitle {
        text-align: center;
        color: var(--text-light);
        font-size: 1.1rem;
        margin-bottom: 3rem;
    }

    /* Tool Cards */
    .tool-card {
        background: #fff;
        border-radius: 20px;
        padding: 2rem 1.5rem;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        box-shadow: var(--card-shadow);
        border: 2px solid transparent;
        height: 100%;
        position: relative;
        overflow: hidden;
        animation: fadeInScale 0.6s ease backwards;
        text-decoration: none;
        display: block;
    }

        .tool-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--gradient-1);
            opacity: 0;
            transition: opacity 0.4s ease;
            z-index: 0;
        }

        .tool-card:hover::before {
            opacity: 0.03;
        }

        .tool-card:hover {
            transform: translateY(-10px);
            box-shadow: var(--hover-shadow);
            border-color: var(--primary-color);
        }

        .tool-card > * {
            position: relative;
            z-index: 1;
        }

    .tool-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        border-radius: 20px;
        transition: all 0.4s ease;
        position: relative;
    }

    .tool-card:hover .tool-icon {
        transform: scale(1.1) rotate(5deg);
    }

    /* Different gradient backgrounds for tool icons */
    .tool-icon.gradient-1 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .tool-icon.gradient-2 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
    .tool-icon.gradient-3 { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
    .tool-icon.gradient-4 { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
    .tool-icon.gradient-5 { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
    .tool-icon.gradient-6 { background: linear-gradient(135deg, #30cfd0 0%, #330867 100%); }
    .tool-icon.gradient-7 { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }
    .tool-icon.gradient-8 { background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%); }
    .tool-icon.gradient-9 { background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%); }
    .tool-icon.gradient-10 { background: linear-gradient(135deg, #ff6e7f 0%, #bfe9ff 100%); }
    .tool-icon.gradient-11 { background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%); }
    .tool-icon.gradient-12 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }

    .tool-icon i { color: #fff; }

    .tool-title {
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 0.8rem;
        color: var(--text-dark);
    }

    .tool-description {
        font-size: 0.9rem;
        color: var(--text-light);
        line-height: 1.6;
    }

    @@keyframes fadeInScale {
        from { opacity: 0; transform: scale(0.9); }
        to { opacity: 1; transform: scale(1); }
    }

    /* Staggered animation delay for cards */
    .tool-card:nth-child(1) { animation-delay: 0.1s; }
    .tool-card:nth-child(2) { animation-delay: 0.15s; }
    .tool-card:nth-child(3) { animation-delay: 0.2s; }
    .tool-card:nth-child(4) { animation-delay: 0.25s; }
    .tool-card:nth-child(5) { animation-delay: 0.3s; }
    .tool-card:nth-child(6) { animation-delay: 0.35s; }
    .tool-card:nth-child(7) { animation-delay: 0.4s; }
    .tool-card:nth-child(8) { animation-delay: 0.45s; }
    .tool-card:nth-child(9) { animation-delay: 0.5s; }
    .tool-card:nth-child(10) { animation-delay: 0.55s; }
    .tool-card:nth-child(11) { animation-delay: 0.6s; }
    .tool-card:nth-child(12) { animation-delay: 0.65s; }

    /* Scanning Tools Section Styling */
    .tools-section:nth-of-type(2) {
        background: linear-gradient(135deg, rgba(233, 64, 87, 0.03) 0%, rgba(138, 86, 172, 0.03) 100%);
        padding: 3rem 0;
        margin-top: 2rem;
        border-radius: 30px;
    }

    .tools-section:nth-of-type(2) .section-title {
        background: var(--gradient-1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Features Section */
    .features-section {
        padding: 4rem 0;
        background: #fff;
        border-radius: 30px;
        margin: 3rem 0;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
    }

    .feature-box {
        text-align: center;
        padding: 2rem;
        transition: all 0.3s ease;
    }

        .feature-box:hover {
            transform: translateY(-5px);
        }

    .feature-icon {
        width: 70px;
        height: 70px;
        margin: 0 auto 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--gradient-1);
        border-radius: 50%;
        font-size: 2rem;
        color: #fff;
    }

    .feature-title {
        font-size: 1.3rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--text-dark);
    }

    .feature-text {
        color: var(--text-light);
        line-height: 1.6;
    }

    /* AdSense Placeholder */
    .ad-container {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border-radius: 15px;
        padding: 2rem;
        text-align: center;
        margin: 3rem 0;
        min-height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .hero-title { font-size: 2.5rem; }
        .hero-subtitle { font-size: 1.1rem; }
        .section-title { font-size: 2rem; }
        .tool-icon { width: 70px; height: 70px; font-size: 2rem; }
    }
</style>

