@{
    ViewData["Title"] = "Error";
    var statusCode = Context.Response.StatusCode;
    var errorMessage = statusCode switch
    {
        400 => "Bad Request",
        401 => "Unauthorized - Please sign in to access this page",
        403 => "Forbidden - You don't have permission to access this resource",
        404 => "Page Not Found",
        405 => "Method Not Allowed",
        408 => "Request Timeout",
        429 => "Too Many Requests - Please try again later",
        500 => "Internal Server Error",
        502 => "Bad Gateway",
        503 => "Service Unavailable",
        504 => "Gateway Timeout",
        _ => "An error occurred"
    };
}

<style>
    .error-section {
        padding: 6rem 0;
        text-align: center;
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .error-code {
        font-size: 8rem;
        font-weight: 900;
        background: var(--gradient-1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1;
        margin-bottom: 1rem;
    }

    .error-message {
        font-size: 2rem;
        color: var(--text-dark);
        margin-bottom: 1rem;
    }

    .error-description {
        font-size: 1.1rem;
        color: var(--text-light);
        max-width: 600px;
        margin: 0 auto 2rem;
        line-height: 1.6;
    }

    .error-actions {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .error-icon {
        width: 120px;
        height: 120px;
        margin: 0 auto 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--gradient-1);
        border-radius: 50%;
        font-size: 4rem;
        color: #fff;
    }

    @@media (max-width: 768px) {
        .error-code { font-size: 5rem; }
        .error-message { font-size: 1.5rem; }
    }
</style>

<section class="error-section">
    <div class="container">
        <div class="error-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <h1 class="error-code">@statusCode</h1>
        <h2 class="error-message">@errorMessage</h2>
        
        @if (statusCode == 404)
        {
            <p class="error-description">
                The page you're looking for doesn't exist or has been moved. 
                Check the URL for errors or use the navigation below.
            </p>
        }
        else if (statusCode == 500)
        {
            <p class="error-description">
                Something went wrong on our end. We're working to fix this issue.
                Please try again later or contact support if the problem persists.
            </p>
        }
        else
        {
            <p class="error-description">
                @Context.Items["ErrorMessage"]
            </p>
        }

        <div class="error-actions">
            <a href="/" class="btn btn-lg px-5 py-3 fw-bold text-white" style="background: var(--gradient-1); border-radius: 10px;">
                <i class="fas fa-home me-2"></i> Home
            </a>
            <a href="/Home/Contact" class="btn btn-lg btn-outline-secondary px-5 py-3" style="border-radius: 10px;">
                <i class="fas fa-envelope me-2"></i> Contact Support
            </a>
        </div>
    </div>
</section>
