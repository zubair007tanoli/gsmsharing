@{
    ViewData["Title"] = "Flip Image - PdfPeaks";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <!-- Header -->
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold text-primary">
                    <i class="bi bi-arrow-left-right"></i> Flip Image
                </h1>
                <p class="lead text-muted">Flip your images horizontally or vertically with instant preview</p>
            </div>

            <div class="row">
                <!-- Upload + Options -->
                <div class="col-lg-4">
                    <div class="card shadow-sm mb-4">
                        <div class="card-body">
                            <div id="flipDropZone" class="drop-zone border-2 border-dashed rounded-4 p-4 text-center bg-light">
                                <div class="mb-3">
                                    <i class="bi bi-cloud-upload display-4 text-primary"></i>
                                </div>
                                <h5 class="mb-2">Drop your image here</h5>
                                <p class="text-muted mb-3">or</p>
                                <button type="button" class="btn btn-primary" id="flipSelectImageBtn">
                                    <i class="bi bi-folder-plus"></i> Select Image
                                </button>
                                <input type="file" id="flipFileInput" accept="image/*" style="display:none" />
                            </div>
                        </div>
                    </div>

                    <div id="flipOptions" class="card shadow-sm mb-4 d-none">
                        <div class="card-header bg-white">
                            <h5 class="mb-0"><i class="bi bi-sliders"></i> Flip Options</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Choose direction:</label>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-outline-primary flex-fill" id="flipHorizontalBtn">
                                        <i class="bi bi-arrow-left-right"></i> Horizontal
                                    </button>
                                    <button type="button" class="btn btn-outline-primary flex-fill" id="flipVerticalBtn">
                                        <i class="bi bi-arrow-up-down"></i> Vertical
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white">
                            <button id="flipApplyBtn" class="btn btn-success w-100" disabled>
                                <i class="bi bi-check-circle"></i> Apply Flip
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Preview -->
                <div class="col-lg-8">
                    <div id="flipPreviewContainer" class="card shadow-sm d-none">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="bi bi-eye"></i> Preview</h5>
                        </div>
                        <div class="card-body bg-dark">
                            <div id="flipImagePreview" class="position-relative d-flex justify-content-center align-items-center" style="min-height: 400px;">
                                <div id="flipLoadingSpinner" class="text-white">
                                    <div class="spinner-border" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white">
                            <div class="row text-center">
                                <div class="col-6">
                                    <small class="text-muted d-block">Original</small>
                                    <strong id="flipOriginalInfo">-</strong>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">Flip</small>
                                    <strong id="flipActionInfo">-</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="flipEmptyPreview" class="card shadow-sm">
                        <div class="card-body text-center py-5">
                            <i class="bi bi-image display-1 text-muted"></i>
                            <h4 class="mt-3 text-muted">No image selected</h4>
                            <p class="text-muted">Upload an image to see the preview and flip options</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="flipLoadingOverlay" class="loading-overlay d-none">
    <div class="spinner-container">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h4 class="mt-3 text-white">Processing image...</h4>
    </div>
</div>

@section Styles {
    <style>
        .drop-zone {
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .drop-zone:hover {
            background-color: #e3f2fd !important;
            border-color: #0d6efd !important;
        }

        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .loading-overlay .spinner-container {
            text-align: center;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const dropZone = document.getElementById('flipDropZone');
            const fileInput = document.getElementById('flipFileInput');
            const selectImageBtn = document.getElementById('flipSelectImageBtn');
            const flipOptions = document.getElementById('flipOptions');
            const previewContainer = document.getElementById('flipPreviewContainer');
            const emptyPreview = document.getElementById('flipEmptyPreview');
            const imagePreview = document.getElementById('flipImagePreview');
            const flipApplyBtn = document.getElementById('flipApplyBtn');
            const flipHorizontalBtn = document.getElementById('flipHorizontalBtn');
            const flipVerticalBtn = document.getElementById('flipVerticalBtn');
            const loadingOverlay = document.getElementById('flipLoadingOverlay');

            let currentFile = null;
            let flipDirection = null; // 'horizontal' or 'vertical'

            if (selectImageBtn) {
                selectImageBtn.addEventListener('click', () => fileInput.click());
            }

            fileInput.addEventListener('change', (e) => {
                if (e.target.files.length > 0) {
                    handleFile(e.target.files[0]);
                }
            });

            dropZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                dropZone.classList.add('bg-primary', 'text-white');
            });

            dropZone.addEventListener('dragleave', (e) => {
                e.preventDefault();
                dropZone.classList.remove('bg-primary', 'text-white');
            });

            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropZone.classList.remove('bg-primary', 'text-white');
                if (e.dataTransfer.files.length > 0) {
                    handleFile(e.dataTransfer.files[0]);
                }
            });

            function handleFile(file) {
                if (!file.type.startsWith('image/')) {
                    alert('Please select an image file.');
                    return;
                }

                currentFile = file;
                flipDirection = null;
                flipApplyBtn.disabled = true;
                flipHorizontalBtn.classList.remove('active');
                flipVerticalBtn.classList.remove('active');

                flipOptions.classList.remove('d-none');
                previewContainer.classList.remove('d-none');
                emptyPreview.classList.add('d-none');

                const reader = new FileReader();
                reader.onload = (e) => {
                    imagePreview.innerHTML = `
                        <img src="${e.target.result}" alt="Preview" class="img-fluid preview-image" style="max-height: 400px; object-fit: contain;">
                    `;
                    document.getElementById('flipOriginalInfo').textContent = formatFileSize(file.size);
                    document.getElementById('flipActionInfo').textContent = '-';
                };
                reader.readAsDataURL(file);
            }

            function formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }

            flipHorizontalBtn.addEventListener('click', () => {
                flipDirection = 'horizontal';
                flipApplyBtn.disabled = !currentFile;
                flipHorizontalBtn.classList.add('active');
                flipVerticalBtn.classList.remove('active');
                document.getElementById('flipActionInfo').textContent = 'Horizontal';
            });

            flipVerticalBtn.addEventListener('click', () => {
                flipDirection = 'vertical';
                flipApplyBtn.disabled = !currentFile;
                flipVerticalBtn.classList.add('active');
                flipHorizontalBtn.classList.remove('active');
                document.getElementById('flipActionInfo').textContent = 'Vertical';
            });

            flipApplyBtn.addEventListener('click', async () => {
                if (!currentFile || !flipDirection) return;

                loadingOverlay.classList.remove('d-none');

                try {
                    const formData = new FormData();
                    formData.append('file', currentFile);
                    formData.append('horizontal', flipDirection === 'horizontal');

                    const response = await fetch('/Image/Flip', {
                        method: 'POST',
                        body: formData
                    });

                    const result = await response.json();

                    loadingOverlay.classList.add('d-none');

                    if (result.success && result.downloadUrl) {
                        window.location.href = result.downloadUrl;
                    } else {
                        alert(result.message || 'Flip failed.');
                    }
                } catch (error) {
                    loadingOverlay.classList.add('d-none');
                    console.error(error);
                    alert('An error occurred while flipping the image.');
                }
            });
        });
    </script>
}
