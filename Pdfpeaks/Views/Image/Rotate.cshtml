@{
    ViewData["Title"] = "Rotate Image - PdfPeaks";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <!-- Header -->
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold text-primary">
                    <i class="bi bi-arrow-clockwise"></i> Rotate Image
                </h1>
                <p class="lead text-muted">Rotate your images by any angle with high-quality rotation</p>
            </div>

            <div class="row">
                <!-- Upload Section -->
                <div class="col-lg-4">
                    <div class="card shadow-sm mb-4">
                        <div class="card-body">
                            <div id="dropZone" class="drop-zone border-2 border-dashed rounded-4 p-4 text-center bg-light" style="position: relative;">
                                <div class="mb-3">
                                    <i class="bi bi-cloud-upload display-4 text-primary"></i>
                                </div>
                                <h5 class="mb-2">Drop your image here</h5>
                                <p class="text-muted mb-3">or</p>
                                <label class="btn btn-primary" style="position: relative; z-index: 1; cursor: pointer;">
                                    <i class="bi bi-folder-plus"></i> Select Image
                                    <input type="file" id="fileInput" accept="image/*" style="position: absolute; opacity: 0; width: 100%; height: 100%; top: 0; left: 0; cursor: pointer; z-index: 2;">
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Rotation Options -->
                    <div id="rotateOptions" class="card shadow-sm mb-4 d-none">
                        <div class="card-header bg-white">
                            <h5 class="mb-0"><i class="bi bi-sliders"></i> Rotation Options</h5>
                        </div>
                        <div class="card-body">
                            <!-- Quick Rotation Buttons -->
                            <div class="mb-4">
                                <label class="form-label fw-bold">Quick Rotate:</label>
                                <div class="d-flex gap-2 mb-3">
                                    <button type="button" class="btn btn-outline-primary flex-fill rotate-quick" data-degrees="-90">
                                        <i class="bi bi-arrow-counterclockwise"></i> 90° CCW
                                    </button>
                                    <button type="button" class="btn btn-outline-primary flex-fill rotate-quick" data-degrees="90">
                                        <i class="bi bi-arrow-clockwise"></i> 90° CW
                                    </button>
                                </div>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-outline-primary flex-fill rotate-quick" data-degrees="180">
                                        <i class="bi bi-arrow-repeat"></i> 180°
                                    </button>
                                    <button type="button" class="btn btn-outline-primary flex-fill rotate-quick" data-degrees="-180">
                                        <i class="bi bi-arrow-repeat"></i> -180°
                                    </button>
                                </div>
                            </div>

                            <!-- Custom Angle -->
                            <div class="mb-4">
                                <label class="form-label fw-bold">Custom Angle:</label>
                                <div class="input-group">
                                    <input type="number" id="customDegrees" class="form-control" min="-360" max="360" value="0">
                                    <span class="input-group-text">degrees</span>
                                </div>
                                <small class="text-muted">Enter any angle between -360 and 360</small>
                            </div>

                            <!-- Flip Options -->
                            <div class="mb-4">
                                <label class="form-label fw-bold">Flip:</label>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-outline-secondary flex-fill flip-image" data-flip="horizontal">
                                        <i class="bi bi-arrow-left-right"></i> Horizontal
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary flex-fill flip-image" data-flip="vertical">
                                        <i class="bi bi-arrow-up-down"></i> Vertical
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white">
                            <button id="rotateBtn" class="btn btn-success w-100" disabled>
                                <i class="bi bi-check-circle"></i> Apply Rotation
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Preview Section -->
                <div class="col-lg-8">
                    <div id="previewContainer" class="card shadow-sm d-none">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="bi bi-eye"></i> Preview</h5>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-outline-secondary active" data-scale="fit">
                                    <i class="bi bi-fullscreen"></i> Fit
                                </button>
                                <button type="button" class="btn btn-outline-secondary" data-scale="100">
                                    <i class="bi bi-zoom-in"></i> 100%
                                </button>
                            </div>
                        </div>
                        <div class="card-body bg-dark">
                            <div id="imagePreview" class="position-relative d-flex justify-content-center align-items-center" style="min-height: 400px;">
                                <div id="loadingSpinner" class="text-white">
                                    <div class="spinner-border" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white">
                            <div class="row text-center">
                                <div class="col-4">
                                    <small class="text-muted d-block">Original</small>
                                    <strong id="originalInfo">-</strong>
                                </div>
                                <div class="col-4">
                                    <i class="bi bi-arrow-right text-primary"></i>
                                </div>
                                <div class="col-4">
                                    <small class="text-muted d-block">Rotation</small>
                                    <strong id="rotationInfo">0°</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Empty State -->
                    <div id="emptyPreview" class="card shadow-sm">
                        <div class="card-body text-center py-5">
                            <i class="bi bi-image display-1 text-muted"></i>
                            <h4 class="mt-3 text-muted">No image selected</h4>
                            <p class="text-muted">Upload an image to see the preview and rotation options</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Success Result -->
            @if (TempData["Success"] != null)
            {
                <div class="card shadow-sm mt-4">
                    <div class="card-body text-center">
                        <div class="mb-4">
                            <i class="bi bi-check-circle-fill text-success display-1"></i>
                        </div>
                        <h3 class="card-title">@TempData["Success"]</h3>
                        <p class="text-muted">@TempData["Info"]</p>
                        
                        <!-- Interactive Image Preview -->
                        @if (TempData["DownloadUrl"] != null)
                        {
                            <div class="my-4 interactive-image-container" style="max-width: 500px; margin: 0 auto;">
                                <img src="@TempData["DownloadUrl"]" alt="Rotated Image Preview" 
                                     class="img-fluid preview-image" style="cursor: grab;"/>
                            </div>
                        }
                        
                        <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
                            <a href="@TempData["DownloadUrl"]" class="btn btn-primary btn-lg" data-download="@TempData["DownloadUrl"]" data-filename="@TempData["FileName"]">
                                <i class="bi bi-download"></i> Download Rotated Image
                            </a>
                            <button type="button" class="btn btn-outline-primary btn-lg" onclick="showShareModal('Rotated Image', '@TempData["DownloadUrl"]', 'Check out my rotated image from PdfPeaks!')">
                                <i class="bi bi-share"></i> Share
                            </button>
                            <a asp-action="Rotate" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-repeat"></i> Rotate Another
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- Error Alert -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="loading-overlay d-none">
    <div class="spinner-container">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h4 class="mt-3 text-white">Processing your image...</h4>
        <p class="text-white-50">This may take a few moments</p>
    </div>
</div>

@section Styles {
    <style>
        .drop-zone {
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .drop-zone:hover {
            background-color: #e3f2fd !important;
            border-color: #0d6efd !important;
        }
        
        .preview-image {
            max-width: 100%;
            max-height: 400px;
            object-fit: contain;
            border: 2px solid #dee2e6;
            border-radius: 4px;
        }
        
        .interactive-image-container img {
            cursor: grab;
        }
        
        .interactive-image-container img:active {
            cursor: grabbing;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const dropZone = document.getElementById('dropZone');
            const fileInput = document.getElementById('fileInput');
            const rotateOptions = document.getElementById('rotateOptions');
            const previewContainer = document.getElementById('previewContainer');
            const emptyPreview = document.getElementById('emptyPreview');
            const rotateBtn = document.getElementById('rotateBtn');
            const customDegrees = document.getElementById('customDegrees');
            const loadingOverlay = document.getElementById('loadingOverlay');
            
            let currentFile = null;
            let currentRotation = 0;
            let currentFlipHorizontal = false;
            let currentFlipVertical = false;

            // Drop zone events - only trigger file input from the select button
            const selectImageBtn = document.getElementById('selectImageBtn');
            if (selectImageBtn) {
                selectImageBtn.addEventListener('click', () => fileInput.click());
            }
            
            fileInput.addEventListener('change', (e) => {
                if (e.target.files.length > 0) {
                    handleFile(e.target.files[0]);
                }
            });
            
            dropZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                dropZone.classList.add('drag-over');
            });
            
            dropZone.addEventListener('dragleave', () => {
                dropZone.classList.remove('drag-over');
            });
            
            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropZone.classList.remove('drag-over');
                if (e.dataTransfer.files.length > 0) {
                    handleFile(e.dataTransfer.files[0]);
                }
            });

            function handleFile(file) {
                if (!file.type.startsWith('image/')) {
                    alert('Please select an image file.');
                    return;
                }
                
                currentFile = file;
                
                // Show options and preview
                rotateOptions.classList.remove('d-none');
                previewContainer.classList.remove('d-none');
                emptyPreview.classList.add('d-none');
                rotateBtn.disabled = false;
                
                // Show image preview
                const reader = new FileReader();
                reader.onload = (e) => {
                    const preview = document.getElementById('imagePreview');
                    preview.innerHTML = `
                        <div class="interactive-image-container position-relative" style="cursor: grab; overflow: hidden;">
                            <img src="${e.target.result}" alt="Preview" class="img-fluid preview-image" style="max-height: 400px; object-fit: contain;">
                        </div>
                    `;
                    document.getElementById('originalInfo').textContent = formatFileSize(file.size);
                    document.getElementById('rotationInfo').textContent = '0°';
                    
                    // Initialize interactive image
                    setTimeout(() => {
                        if (typeof initializeInteractiveImages === 'function') {
                            initializeInteractiveImages();
                        }
                    }, 100);
                };
                reader.readAsDataURL(file);
            }

            function formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }

            // Quick rotation buttons
            document.querySelectorAll('.rotate-quick').forEach(btn => {
                btn.addEventListener('click', () => {
                    const degrees = parseInt(btn.dataset.degrees);
                    currentRotation = (currentRotation + degrees) % 360;
                    customDegrees.value = currentRotation;
                    updateRotationInfo();
                });
            });

            // Custom degrees input
            customDegrees.addEventListener('input', () => {
                currentRotation = parseInt(customDegrees.value) || 0;
                updateRotationInfo();
            });

            // Flip buttons
            document.querySelectorAll('.flip-image').forEach(btn => {
                btn.addEventListener('click', () => {
                    if (btn.dataset.flip === 'horizontal') {
                        currentFlipHorizontal = !currentFlipHorizontal;
                        btn.classList.toggle('active', currentFlipHorizontal);
                    } else {
                        currentFlipVertical = !currentFlipVertical;
                        btn.classList.toggle('active', currentFlipVertical);
                    }
                });
            });

            function updateRotationInfo() {
                let info = currentRotation + '°';
                if (currentFlipHorizontal) info += ' + H-Flip';
                if (currentFlipVertical) info += ' + V-Flip';
                document.getElementById('rotationInfo').textContent = info;
            }

            // Rotate button
            rotateBtn.addEventListener('click', async () => {
                if (!currentFile) return;
                
                loadingOverlay.classList.remove('d-none');
                
                try {
                    const formData = new FormData();
                    formData.append('file', currentFile);
                    formData.append('degrees', currentRotation);
                    
                    const response = await fetch('/Image/Rotate', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    
                    loadingOverlay.classList.add('d-none');
                    
                    if (result.success) {
                        // Update the download URL
                        window.location.href = result.downloadUrl;
                    } else {
                        alert('Rotation failed: ' + result.message);
                    }
                } catch (error) {
                    loadingOverlay.classList.add('d-none');
                    alert('An error occurred during rotation.');
                    console.error(error);
                }
            });
        });
    </script>
}
