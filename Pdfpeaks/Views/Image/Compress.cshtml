@{
    ViewData["Title"] = "Compress Image - PdfPeaks";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold text-primary">
                    <i class="bi bi-file-earmark-zip"></i> Compress Image
                </h1>
                <p class="lead text-muted">Reduce image file size while keeping great visual quality</p>
            </div>

            <div class="row">
                <!-- Upload + Options -->
                <div class="col-lg-4">
                    <div class="card shadow-sm mb-4">
                        <div class="card-body">
                            <div id="compressDropZone" class="drop-zone border-2 border-dashed rounded-4 p-4 text-center bg-light">
                                <div class="mb-3">
                                    <i class="bi bi-cloud-upload display-4 text-primary"></i>
                                </div>
                                <h5 class="mb-2">Drop your image here</h5>
                                <p class="text-muted mb-3">or</p>
                                <button type="button" class="btn btn-primary" id="compressSelectImageBtn">
                                    <i class="bi bi-folder-plus"></i> Select Image
                                </button>
                                <input type="file" id="compressFileInput" accept="image/*" style="display:none" />
                            </div>
                        </div>
                    </div>

                    <div id="compressOptions" class="card shadow-sm mb-4 d-none">
                        <div class="card-header bg-white">
                            <h5 class="mb-0"><i class="bi bi-sliders"></i> Compression Quality</h5>
                        </div>
                        <div class="card-body">
                            <label class="form-label fw-bold">Quality: <span id="qualityLabel">75%</span></label>
                            <input type="range" id="qualitySlider" class="form-range" min="30" max="100" value="75" />
                            <small class="text-muted d-block mt-1">
                                Higher quality = larger file. 70–85% is usually a good balance.
                            </small>
                        </div>
                        <div class="card-footer bg-white">
                            <button id="compressApplyBtn" class="btn btn-success w-100" disabled>
                                <i class="bi bi-check-circle"></i> Compress Image
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Preview + Stats -->
                <div class="col-lg-8">
                    <div id="compressPreviewContainer" class="card shadow-sm d-none">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="bi bi-graph-down"></i> Compression Summary</h5>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-md-4 mb-3">
                                    <small class="text-muted d-block">Original Size</small>
                                    <strong id="compressOriginalSize">-</strong>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <small class="text-muted d-block">Compressed Size</small>
                                    <strong id="compressNewSize">-</strong>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <small class="text-muted d-block">Saved</small>
                                    <strong id="compressSaved">-</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="compressEmptyPreview" class="card shadow-sm">
                        <div class="card-body text-center py-5">
                            <i class="bi bi-image display-1 text-muted"></i>
                            <h4 class="mt-3 text-muted">No image selected</h4>
                            <p class="text-muted">Upload an image to adjust compression and preview savings</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="compressLoadingOverlay" class="loading-overlay d-none">
    <div class="spinner-container">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h4 class="mt-3 text-white">Compressing image...</h4>
    </div>
</div>

@section Styles {
    <style>
        .drop-zone {
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .drop-zone:hover {
            background-color: #e3f2fd !important;
            border-color: #0d6efd !important;
        }

        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .loading-overlay .spinner-container {
            text-align: center;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const dropZone = document.getElementById('compressDropZone');
            const fileInput = document.getElementById('compressFileInput');
            const selectImageBtn = document.getElementById('compressSelectImageBtn');
            const optionsCard = document.getElementById('compressOptions');
            const previewCard = document.getElementById('compressPreviewContainer');
            const emptyPreview = document.getElementById('compressEmptyPreview');
            const qualitySlider = document.getElementById('qualitySlider');
            const qualityLabel = document.getElementById('qualityLabel');
            const applyBtn = document.getElementById('compressApplyBtn');
            const loadingOverlay = document.getElementById('compressLoadingOverlay');

            let currentFile = null;

            if (selectImageBtn) {
                selectImageBtn.addEventListener('click', () => fileInput.click());
            }

            fileInput.addEventListener('change', (e) => {
                if (e.target.files.length > 0) {
                    handleFile(e.target.files[0]);
                }
            });

            dropZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                dropZone.classList.add('bg-primary', 'text-white');
            });

            dropZone.addEventListener('dragleave', (e) => {
                e.preventDefault();
                dropZone.classList.remove('bg-primary', 'text-white');
            });

            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropZone.classList.remove('bg-primary', 'text-white');
                if (e.dataTransfer.files.length > 0) {
                    handleFile(e.dataTransfer.files[0]);
                }
            });

            function handleFile(file) {
                if (!file.type.startsWith('image/')) {
                    alert('Please select an image file.');
                    return;
                }

                currentFile = file;
                optionsCard.classList.remove('d-none');
                previewCard.classList.add('d-none');
                emptyPreview.classList.remove('d-none');
                applyBtn.disabled = false;
            }

            qualitySlider.addEventListener('input', () => {
                qualityLabel.textContent = qualitySlider.value + '%';
            });

            function formatSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }

            applyBtn.addEventListener('click', async () => {
                if (!currentFile) return;

                loadingOverlay.classList.remove('d-none');

                try {
                    const formData = new FormData();
                    formData.append('file', currentFile);
                    formData.append('quality', qualitySlider.value);

                    const response = await fetch('/Image/Compress', {
                        method: 'POST',
                        body: formData
                    });

                    const result = await response.json();

                    loadingOverlay.classList.add('d-none');

                    if (result.success && result.downloadUrl) {
                        const originalSize = result.originalSize || 0;
                        const compressedSize = result.compressedSize || 0;
                        document.getElementById('compressOriginalSize').textContent = formatSize(originalSize);
                        document.getElementById('compressNewSize').textContent = formatSize(compressedSize);
                        if (originalSize > 0 && compressedSize > 0) {
                            const savedPercent = Math.round((1 - compressedSize / originalSize) * 100);
                            document.getElementById('compressSaved').textContent = savedPercent + '%';
                        } else {
                            document.getElementById('compressSaved').textContent = '-';
                        }

                        previewCard.classList.remove('d-none');
                        emptyPreview.classList.add('d-none');

                        // Trigger download
                        window.location.href = result.downloadUrl;
                    } else {
                        alert(result.message || 'Compression failed.');
                    }
                } catch (err) {
                    loadingOverlay.classList.add('d-none');
                    console.error(err);
                    alert('An error occurred while compressing the image.');
                }
            });
        });
    </script>
}
