    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource Gray300}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource TextMuted}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource Card}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextMuted}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource Card}" />
        <Setter Property="BarTextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="IconColor" Value="{StaticResource Primary}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource Card}" />
        <Setter Property="BarTextColor" Value="{StaticResource Primary}" />
        <Setter Property="UnselectedTabColor" Value="{StaticResource TextMuted}" />
        <Setter Property="SelectedTabColor" Value="{StaticResource Primary}" />
    </Style>

    <!-- Custom surface styles for CamScanner-inspired UI -->
    <Style x:Key="CardFrameStyle" TargetType="Frame">
        <Setter Property="Padding" Value="16"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="HasShadow" Value="True"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource Gray200Brush}" Offset="0,6" Opacity="0.45" Radius="14" />
            </Setter.Value>
        </Setter>
        <Setter Property="BackgroundColor" Value="{StaticResource Card}"/>
        <Setter Property="BorderColor" Value="{StaticResource CardBorder}"/>
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
    </Style>

    <Style x:Key="MutedLabelStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
    </Style>

    <Style x:Key="ChipBorderStyle" TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource CardBorder}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="12"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BadgeLabelStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Primary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
    </Style>

    <Style x:Key="IconCircleStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="18"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
