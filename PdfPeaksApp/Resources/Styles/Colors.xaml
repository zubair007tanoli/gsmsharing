<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- CamScanner-inspired teal palette -->
    <Color x:Key="Primary">#00B483</Color>
    <Color x:Key="PrimaryDark">#008B64</Color>
    <Color x:Key="PrimaryLight">#7BEBC9</Color>
    <Color x:Key="Accent">#12D5B5</Color>
    <Color x:Key="Secondary">#0F2E3D</Color>
    <Color x:Key="SecondaryMuted">#163B4D</Color>

    <Color x:Key="Surface">#F6F9FB</Color>
    <Color x:Key="Card">#FFFFFF</Color>
    <Color x:Key="CardBorder">#E2EDF3</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <Color x:Key="TextPrimary">#0E1D27</Color>
    <Color x:Key="TextSecondary">#3C5566</Color>
    <Color x:Key="TextMuted">#6B7A88</Color>

    <Color x:Key="Success">#29D07C</Color>
    <Color x:Key="Warning">#FFC940</Color>
    <Color x:Key="Danger">#FF6B6B</Color>

    <Color x:Key="Gray100">#EEF4F7</Color>
    <Color x:Key="Gray200">#DFE8EE</Color>
    <Color x:Key="Gray300">#C6D4DD</Color>
    <Color x:Key="Gray400">#A7B5C0</Color>
    <Color x:Key="Gray500">#8898A7</Color>
    <Color x:Key="Gray600">#647583</Color>
    <Color x:Key="Gray900">#0D1C27</Color>
    <Color x:Key="Gray950">#0A141B</Color>

    <!-- Gradient stops for hero/header surfaces -->
    <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0B2C3A" Offset="0" />
        <GradientStop Color="#0F445A" Offset="0.6" />
        <GradientStop Color="#00B483" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardAccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#12D5B5" Offset="0" />
        <GradientStop Color="#0DAA81" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLight}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="SecondaryMutedBrush" Color="{StaticResource SecondaryMuted}"/>

    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource Card}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorder}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
