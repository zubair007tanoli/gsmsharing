<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PdfPeaksApp.MainPage"
             Title="PDFPeaksApp">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="PDFPeaks App Logo" />

            <Label
                Text="PDFPeaksApp"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Document Scanner &amp; PDF Manager"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Professional document scanning and management" />

            <Button
                x:Name="ScanButton"
                Text="Start Scanning"
                SemanticProperties.Hint="Tap to start scanning documents"
                Clicked="OnScanClicked"
                HorizontalOptions="Fill"
                HeightRequest="50"
                FontSize="16" />

            <Button
                x:Name="DocumentsButton"
                Text="My Documents"
                SemanticProperties.Hint="View your documents"
                Clicked="OnDocumentsClicked"
                HorizontalOptions="Fill"
                HeightRequest="50"
                FontSize="16" />

            <Button
                x:Name="SettingsButton"
                Text="Settings"
                SemanticProperties.Hint="Open settings"
                Clicked="OnSettingsClicked"
                HorizontalOptions="Fill"
                HeightRequest="50"
                FontSize="16" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
