<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PdfPeaksApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PdfPeaksApp"
    Title="PDFPeaksApp">

    <TabBar>
        <Tab Title="Home">
            <ShellContent
                Title="Home"
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>
        <Tab Title="Scan">
            <ShellContent
                Title="Scan"
                ContentTemplate="{DataTemplate local:ScanPage}"
                Route="ScanPage" />
        </Tab>
        <Tab Title="Documents">
            <ShellContent
                Title="Documents"
                ContentTemplate="{DataTemplate local:DocumentsPage}"
                Route="DocumentsPage" />
        </Tab>
        <Tab Title="AI Desk">
            <ShellContent
                Title="AI Desk"
                ContentTemplate="{DataTemplate local:AIDeskPage}"
                Route="AIDeskPage" />
        </Tab>
        <Tab Title="Profile">
            <ShellContent
                Title="Profile"
                ContentTemplate="{DataTemplate local:ProfilePage}"
                Route="ProfilePage" />
        </Tab>
    </TabBar>

</Shell>
