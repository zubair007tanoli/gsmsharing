            "content": {
              "size": 745,
              "mimeType": "text/css",
              "text": ".search-suggestions {\r\n    position: absolute;\r\n    top: 100%;\r\n    left: 0;\r\n    right: 40px;\r\n    background: white;\r\n    border: 1px solid #ddd;\r\n    border-radius: 4px;\r\n    box-shadow: 0 4px 6px rgba(0,0,0,0.1);\r\n    max-height: 400px;\r\n    overflow-y: auto;\r\n    z-index: 1000;\r\n    margin-top: 4px;\r\n}\r\n\r\n.suggestion-item {\r\n    padding: 12px 16px;\r\n    cursor: pointer;\r\n    border-bottom: 1px solid #f0f0f0;\r\n    transition: background 0.2s;\r\n}\r\n\r\n.suggestion-item:last-child {\r\n    border-bottom: none;\r\n}\r\n\r\n.suggestion-item:hover,\r\n.suggestion-item.active {\r\n    background: #f8f9fa;\r\n}\r\n\r\n.suggestion-title {\r\n    font-weight: 500;\r\n    color: #333;\r\n    margin-bottom: 2px;\r\n}\r\n\r\n.search-container {\r\n    position: relative;\r\n}\r\n\r\n"
