@using discussionspot9.Models.ViewModels
@model AuthViewModel
@{
    ViewData["Title"] = "Sign In to DiscussionSpot";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Auth-specific CSS - completely isolated to prevent navbar conflicts */
    .auth-content-wrapper {
        --auth-primary-color: #6366f1;
        --auth-primary-dark: #4f46e5;
        --auth-secondary-color: #64748b;
        --auth-success-color: #10b981;
        --auth-danger-color: #ef4444;
        --auth-warning-color: #f59e0b;
        --auth-info-color: #3b82f6;
        --auth-light-color: #f8fafc;
        --auth-dark-color: #1e293b;
        --auth-border-color: #e2e8f0;
        --auth-text-color: #334155;
        --auth-text-light: #64748b;
        --auth-bg-light: #ffffff;
        --auth-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        --auth-shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }

    .auth-content-wrapper .auth-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .auth-content-wrapper .auth-card {
        background: var(--auth-bg-light);
        border-radius: 20px;
        box-shadow: var(--auth-shadow-lg);
        overflow: hidden;
        width: 100%;
        max-width: 1000px;
        display: flex;
        min-height: 600px;
    }

    .auth-content-wrapper .auth-image {
        flex: 1;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem;
    }

    .auth-content-wrapper .auth-image::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="white" opacity="0.1"/><circle cx="75" cy="75" r="1" fill="white" opacity="0.1"/><circle cx="50" cy="10" r="0.5" fill="white" opacity="0.1"/><circle cx="10" cy="60" r="0.5" fill="white" opacity="0.1"/><circle cx="90" cy="40" r="0.5" fill="white" opacity="0.1"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
        opacity: 0.3;
    }

    .auth-content-wrapper .auth-image-content {
        position: relative;
        z-index: 1;
        text-align: center;
        color: white;
    }

    .auth-content-wrapper .auth-image-content h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .auth-content-wrapper .auth-image-content p {
        font-size: 1.1rem;
        opacity: 0.9;
        max-width: 400px;
        line-height: 1.6;
    }

    .auth-content-wrapper .auth-form-section {
        flex: 1;
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .auth-content-wrapper .auth-logo {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-content-wrapper .auth-logo h2 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--auth-primary-color);
        margin: 0;
    }

    .auth-content-wrapper .auth-tabs {
        display: flex;
        margin-bottom: 2rem;
        border-bottom: 2px solid var(--auth-border-color);
    }

    .auth-content-wrapper .auth-tab {
        flex: 1;
        padding: 1rem 1.5rem;
        font-weight: 600;
        cursor: pointer;
        position: relative;
        color: var(--auth-text-light);
        text-align: center;
        transition: all 0.3s ease;
        border: none;
        background: none;
    }

    .auth-content-wrapper .auth-tab.active {
        color: var(--auth-primary-color);
    }

    .auth-content-wrapper .auth-tab.active::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--auth-primary-color);
        border-radius: 2px 2px 0 0;
    }

    .auth-content-wrapper .auth-form {
        display: none;
    }

    .auth-content-wrapper .auth-form.active {
        display: block;
    }

    .auth-content-wrapper .form-floating {
        margin-bottom: 1.5rem;
    }

    .auth-content-wrapper .form-floating > label {
        color: var(--auth-text-light);
        font-weight: 500;
    }

    .auth-content-wrapper .form-control {
        background-color: var(--auth-bg-light);
        border: 2px solid var(--auth-border-color);
        color: var(--auth-text-color);
        border-radius: 12px;
        padding: 1rem 0.75rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-shadow: none;
    }

    .auth-content-wrapper .form-control:focus {
        background-color: var(--auth-bg-light);
        color: var(--auth-text-color);
        border-color: var(--auth-primary-color);
        box-shadow: 0 0 0 0.2rem rgba(99, 102, 241, 0.15);
        transform: translateY(-1px);
    }

    .auth-content-wrapper .form-control:focus + label {
        color: var(--auth-primary-color);
    }

    .auth-content-wrapper .btn-primary {
        background: linear-gradient(135deg, var(--auth-primary-color) 0%, var(--auth-primary-dark) 100%);
        border: none;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-shadow: var(--auth-shadow);
    }

    .auth-content-wrapper .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(99, 102, 241, 0.3);
    }

    .auth-content-wrapper .btn-primary:active {
        transform: translateY(0);
    }

    .auth-content-wrapper .social-login {
        margin-top: 2rem;
        text-align: center;
    }

    .auth-content-wrapper .social-login-title {
        position: relative;
        margin-bottom: 1.5rem;
        color: var(--auth-text-light);
        font-size: 0.9rem;
        font-weight: 500;
    }

    .auth-content-wrapper .social-login-title::before,
    .auth-content-wrapper .social-login-title::after {
        content: '';
        position: absolute;
        top: 50%;
        width: 30%;
        height: 1px;
        background-color: var(--auth-border-color);
    }

    .auth-content-wrapper .social-login-title::before {
        left: 0;
    }

    .auth-content-wrapper .social-login-title::after {
        right: 0;
    }

    .auth-content-wrapper .social-login-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .auth-content-wrapper .btn-social {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 50px;
        height: 50px;
        border-radius: 12px;
        color: white;
        transition: all 0.3s ease;
        text-decoration: none;
        box-shadow: var(--auth-shadow);
    }

    .auth-content-wrapper .btn-social:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        color: white;
    }

    .auth-content-wrapper .btn-google {
        background: linear-gradient(135deg, #db4437 0%, #c23321 100%);
    }

    .auth-content-wrapper .btn-facebook {
        background: linear-gradient(135deg, #4267b2 0%, #365899 100%);
    }

    .auth-content-wrapper .btn-twitter {
        background: linear-gradient(135deg, #1da1f2 0%, #0d8bd9 100%);
    }

    .auth-content-wrapper .btn-github {
        background: linear-gradient(135deg, #333 0%, #24292e 100%);
    }

    .auth-content-wrapper .btn-microsoft {
        background: linear-gradient(135deg, #00a4ef 0%, #0078d4 100%);
    }

    .auth-content-wrapper .auth-footer {
        margin-top: 2rem;
        text-align: center;
        color: var(--auth-text-light);
        font-size: 0.9rem;
    }

    .auth-content-wrapper .auth-footer a {
        color: var(--auth-primary-color);
        text-decoration: none;
        margin: 0 0.5rem;
    }

    .auth-content-wrapper .auth-footer a:hover {
        text-decoration: underline;
    }

    .auth-content-wrapper .alert {
        border-radius: 12px;
        border: none;
        padding: 1rem 1.5rem;
        margin-bottom: 1.5rem;
        font-weight: 500;
    }

    .auth-content-wrapper .alert-success {
        background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
        color: #065f46;
    }

    .auth-content-wrapper .alert-danger {
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        color: #991b1b;
    }

    .auth-content-wrapper .alert-info {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        color: #1e40af;
    }

    .auth-content-wrapper .form-check {
        margin-bottom: 1rem;
    }

    .auth-content-wrapper .form-check-input {
        background-color: var(--auth-bg-light);
        border: 2px solid var(--auth-border-color);
        border-radius: 6px;
        width: 1.2em;
        height: 1.2em;
    }

    .auth-content-wrapper .form-check-input:checked {
        background-color: var(--auth-primary-color);
        border-color: var(--auth-primary-color);
    }

    .auth-content-wrapper .form-check-label {
        color: var(--auth-text-color);
        font-weight: 500;
    }

    .auth-content-wrapper .text-decoration-none {
        color: var(--auth-primary-color);
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .auth-content-wrapper .text-decoration-none:hover {
        color: var(--auth-primary-dark);
        text-decoration: underline !important;
    }

    .auth-content-wrapper .validation-summary-errors {
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        color: #991b1b;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        margin-bottom: 1.5rem;
        border: none;
    }

    .auth-content-wrapper .validation-summary-errors ul {
        list-style: none;
        padding-left: 0;
        margin-bottom: 0;
    }

    .auth-content-wrapper .field-validation-error {
        color: var(--auth-danger-color);
        font-size: 0.875em;
        margin-top: 0.5rem;
        display: block;
    }

    .auth-content-wrapper .input-validation-error {
        border-color: var(--auth-danger-color) !important;
    }

    .auth-content-wrapper .input-validation-error:focus {
        border-color: var(--auth-danger-color) !important;
        box-shadow: 0 0 0 0.2rem rgba(239, 68, 68, 0.15) !important;
    }

    /* Responsive Design */
    @@media (max-width: 991.98px) {
        .auth-content-wrapper .auth-card {
            flex-direction: column;
            max-width: 500px;
        }

        .auth-content-wrapper .auth-image {
            min-height: 200px;
            padding: 2rem;
        }

        .auth-content-wrapper .auth-image-content h1 {
            font-size: 2rem;
        }

        .auth-content-wrapper .auth-form-section {
            padding: 2rem;
        }
    }

    @@media (max-width: 575.98px) {
        .auth-content-wrapper .auth-container {
            padding: 1rem;
        }

        .auth-content-wrapper .auth-form-section {
            padding: 1.5rem;
        }

        .auth-content-wrapper .social-login-buttons {
            gap: 0.5rem;
        }

        .auth-content-wrapper .btn-social {
            width: 45px;
            height: 45px;
        }
    }

    /* Loading States */
    .auth-content-wrapper .btn-loading {
        position: relative;
        color: transparent !important;
    }

    .auth-content-wrapper .btn-loading::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 20px;
        height: 20px;
        margin: -10px 0 0 -10px;
        border: 2px solid transparent;
        border-top: 2px solid currentColor;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    /* Dark Mode Support */
    @@media (prefers-color-scheme: dark) {
        .auth-content-wrapper {
            --auth-bg-light: #1e293b;
            --auth-text-color: #f1f5f9;
            --auth-text-light: #94a3b8;
            --auth-border-color: #334155;
        }
    }
</style>

<!-- Auth page content only - navbar remains outside -->
<div class="auth-content-wrapper">
    <div class="auth-container">
        <div class="auth-card">
            <!-- Left Side - Image/Content -->
            <div class="auth-image">
                <div class="auth-image-content">
                    <h1>Welcome to DiscussionSpot</h1>
                    <p>Join our vibrant community where knowledge meets conversation. Connect with like-minded individuals, share insights, and discover new perspectives.</p>
                </div>
            </div>

            <!-- Right Side - Auth Forms -->
            <div class="auth-form-section">
                <div class="auth-logo">
                    <h2>Discussion<b style="color: var(--auth-primary-dark);">Spot</b></h2>
                </div>

                <!-- Success/Error Messages -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success" role="alert">
                        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    </div>
                }

                @if (TempData["ErrorMessageUserName"] != null)
                {
                    <div class="alert alert-danger" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessageUserName"]
                    </div>
                }

                @if (TempData["InfoMessage"] != null)
                {
                    <div class="alert alert-info" role="alert">
                        <i class="fas fa-info-circle me-2"></i>@TempData["InfoMessage"]
                    </div>
                }

                <!-- Auth Tabs -->
                <div class="auth-tabs">
                    <button class="auth-tab active" id="loginTab" type="button">
                        <i class="fas fa-sign-in-alt me-2"></i>Sign In
                    </button>
                    <button class="auth-tab" id="registerTab" type="button">
                        <i class="fas fa-user-plus me-2"></i>Register
                    </button>
                </div>

                <!-- Login Form -->
                <form id="loginForm" class="auth-form active" asp-controller="Account" asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />
                    
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                    <div class="form-floating">
                        <input type="email" class="form-control" id="loginEmail" asp-for="LoginModel.Email" placeholder="Email" required>
                        <label for="loginEmail"><i class="fas fa-envelope me-2"></i>Email Address</label>
                        <span asp-validation-for="LoginModel.Email" class="field-validation-error"></span>
                    </div>

                    <div class="form-floating">
                        <input type="password" class="form-control" id="loginPassword" asp-for="LoginModel.Password" placeholder="Password" required>
                        <label for="loginPassword"><i class="fas fa-lock me-2"></i>Password</label>
                        <span asp-validation-for="LoginModel.Password" class="field-validation-error"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe" asp-for="LoginModel.RememberMe">
                            <label class="form-check-label" for="rememberMe">
                                Remember me
                            </label>
                        </div>
                        <a asp-action="ForgotPassword" class="text-decoration-none">
                            <i class="fas fa-key me-1"></i>Forgot password?
                        </a>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3">
                        <i class="fas fa-sign-in-alt me-2"></i>Sign In
                    </button>

                    <div class="social-login">
                        <div class="social-login-title">
                            <span>Or continue with</span>
                        </div>

                        <div class="social-login-buttons">
                            <a href="/Account/ExternalLogin?provider=Google&returnUrl=@Model.ReturnUrl" class="btn-social btn-google" title="Sign in with Google">
                                <i class="fab fa-google"></i>
                            </a>
                            <a href="/Account/ExternalLogin?provider=Facebook&returnUrl=@Model.ReturnUrl" class="btn-social btn-facebook" title="Sign in with Facebook">
                                <i class="fab fa-facebook-f"></i>
                            </a>
                            <a href="/Account/ExternalLogin?provider=Twitter&returnUrl=@Model.ReturnUrl" class="btn-social btn-twitter" title="Sign in with Twitter">
                                <i class="fab fa-twitter"></i>
                            </a>
                            <a href="/Account/ExternalLogin?provider=GitHub&returnUrl=@Model.ReturnUrl" class="btn-social btn-github" title="Sign in with GitHub">
                                <i class="fab fa-github"></i>
                            </a>
                            <a href="/Account/ExternalLogin?provider=Microsoft&returnUrl=@Model.ReturnUrl" class="btn-social btn-microsoft" title="Sign in with Microsoft">
                                <i class="fab fa-microsoft"></i>
                            </a>
                        </div>
                    </div>
                </form>

                <!-- Register Form -->
                <form id="registerForm" class="auth-form" asp-controller="Account" asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                    <div class="form-floating">
                        <input type="text" class="form-control" id="registerDisplayName" asp-for="RegisterModel.DisplayName" placeholder="Display Name" required>
                        <label for="registerDisplayName"><i class="fas fa-user me-2"></i>Display Name</label>
                        <span asp-validation-for="RegisterModel.DisplayName" class="field-validation-error"></span>
                    </div>

                    <div class="form-floating">
                        <input type="email" class="form-control" id="registerEmail" asp-for="RegisterModel.Email" placeholder="Email" required>
                        <label for="registerEmail"><i class="fas fa-envelope me-2"></i>Email Address</label>
                        <span asp-validation-for="RegisterModel.Email" class="field-validation-error"></span>
                    </div>

                    <div class="form-floating">
                        <input type="password" class="form-control" id="registerPassword" asp-for="RegisterModel.Password" placeholder="Password" required>
                        <label for="registerPassword"><i class="fas fa-lock me-2"></i>Password</label>
                        <span asp-validation-for="RegisterModel.Password" class="field-validation-error"></span>
                    </div>

                    <div class="form-floating">
                        <input type="password" class="form-control" id="registerConfirmPassword" asp-for="RegisterModel.ConfirmPassword" placeholder="Confirm Password" required>
                        <label for="registerConfirmPassword"><i class="fas fa-lock me-2"></i>Confirm Password</label>
                        <span asp-validation-for="RegisterModel.ConfirmPassword" class="field-validation-error"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" asp-for="RegisterModel.AgreeToTerms" type="checkbox" id="agreeTerms" required>
                        <label class="form-check-label" for="agreeTerms">
                            I agree to the <a href="/terms" class="text-decoration-none">Terms of Service</a> and <a href="/privacy" class="text-decoration-none">Privacy Policy</a>
                        </label>
                        <span asp-validation-for="RegisterModel.AgreeToTerms" class="field-validation-error"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3">
                        <i class="fas fa-user-plus me-2"></i>Create Account
                    </button>

                    <div class="social-login">
                        <div class="social-login-title">
                            <span>Or register with</span>
                        </div>

                        <div class="social-login-buttons">
                            <a href="/Account/ExternalLogin?provider=Google&returnUrl=@Model.ReturnUrl" class="btn-social btn-google" title="Register with Google">
                                <i class="fab fa-google"></i>
                            </a>
                            <a href="/Account/ExternalLogin?provider=Facebook&returnUrl=@Model.ReturnUrl" class="btn-social btn-facebook" title="Register with Facebook">
                                <i class="fab fa-facebook-f"></i>
                            </a>
                            <a href="/Account/ExternalLogin?provider=Twitter&returnUrl=@Model.ReturnUrl" class="btn-social btn-twitter" title="Register with Twitter">
                                <i class="fab fa-twitter"></i>
                            </a>
                            <a href="/Account/ExternalLogin?provider=GitHub&returnUrl=@Model.ReturnUrl" class="btn-social btn-github" title="Register with GitHub">
                                <i class="fab fa-github"></i>
                            </a>
                            <a href="/Account/ExternalLogin?provider=Microsoft&returnUrl=@Model.ReturnUrl" class="btn-social btn-microsoft" title="Register with Microsoft">
                                <i class="fab fa-microsoft"></i>
                            </a>
                        </div>
                    </div>
                </form>

                <div class="auth-footer">
                    <p>&copy; @DateTime.Now.Year DiscussionSpot. All rights reserved.</p>
                    <div>
                        <a href="/terms">Terms</a>
                        <a href="/privacy">Privacy</a>
                        <a href="/help">Help</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Enhanced JavaScript -->
<script>
    // Auth Tabs Functionality
    const loginTab = document.getElementById('loginTab');
    const registerTab = document.getElementById('registerTab');
    const loginForm = document.getElementById('loginForm');
    const registerForm = document.getElementById('registerForm');

    function switchToLogin() {
        loginTab.classList.add('active');
        registerTab.classList.remove('active');
        loginForm.classList.add('active');
        registerForm.classList.remove('active');
    }

    function switchToRegister() {
        registerTab.classList.add('active');
        loginTab.classList.remove('active');
        registerForm.classList.add('active');
        loginForm.classList.remove('active');
    }

    loginTab.addEventListener('click', switchToLogin);
    registerTab.addEventListener('click', switchToRegister);

    // Form Loading States
    function addLoadingState(form) {
        const submitBtn = form.querySelector('button[type="submit"]');
        submitBtn.classList.add('btn-loading');
        submitBtn.disabled = true;
    }

    function removeLoadingState(form) {
        const submitBtn = form.querySelector('button[type="submit"]');
        submitBtn.classList.remove('btn-loading');
        submitBtn.disabled = false;
    }

    // Add loading states to forms
    document.getElementById('loginForm').addEventListener('submit', function() {
        addLoadingState(this);
    });

    document.getElementById('registerForm').addEventListener('submit', function() {
        addLoadingState(this);
    });

    // Enhanced Form Validation
    function validateForm(form) {
        const inputs = form.querySelectorAll('input[required]');
        let isValid = true;

        inputs.forEach(input => {
            if (!input.value.trim()) {
                input.classList.add('input-validation-error');
                isValid = false;
            } else {
                input.classList.remove('input-validation-error');
            }
        });

        return isValid;
    }

    // Real-time validation
    document.querySelectorAll('input[required]').forEach(input => {
        input.addEventListener('blur', function() {
            if (!this.value.trim()) {
                this.classList.add('input-validation-error');
            } else {
                this.classList.remove('input-validation-error');
            }
        });

        input.addEventListener('input', function() {
            if (this.value.trim()) {
                this.classList.remove('input-validation-error');
            }
        });
    });

    // Password strength indicator
    const passwordInput = document.getElementById('registerPassword');
    if (passwordInput) {
        passwordInput.addEventListener('input', function() {
            const password = this.value;
            const strength = getPasswordStrength(password);
            updatePasswordStrengthIndicator(strength);
        });
    }

    function getPasswordStrength(password) {
        let strength = 0;
        if (password.length >= 8) strength++;
        if (/[a-z]/.test(password)) strength++;
        if (/[A-Z]/.test(password)) strength++;
        if (/[0-9]/.test(password)) strength++;
        if (/[^A-Za-z0-9]/.test(password)) strength++;
        return strength;
    }

    function updatePasswordStrengthIndicator(strength) {
        // This could be enhanced with a visual strength indicator
        console.log('Password strength:', strength);
    }

    // Auto-focus first input
    document.addEventListener('DOMContentLoaded', function() {
        const firstInput = document.querySelector('.auth-form.active input');
        if (firstInput) {
            firstInput.focus();
        }
    });

    // Handle form errors and show appropriate tab
    @if (Model.ShowRegister) {
        <text>
        switchToRegister();
        </text>
    }
</script>