@model discussionspot9.Models.ViewModels.UserStatsViewModel
@{
    ViewData["Title"] = $"{Model.DisplayName} - User Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/user-profile.css" />
}

<div class="container-fluid py-4">
    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- User Profile Header -->
            <div class="user-profile-header">
                <div class="profile-banner">
                    <div class="banner-overlay"></div>
                </div>
                
                <div class="profile-content">
                    <div class="profile-avatar-section">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" alt="@Model.DisplayName" class="profile-avatar" />
                        }
                        else
                        {
                            <div class="profile-avatar profile-avatar-default">
                                @Model.DisplayName.Substring(0, Math.Min(2, Model.DisplayName.Length)).ToUpper()
                            </div>
                        }
                        
                        @if (Model.IsVerified)
                        {
                            <div class="verification-badge">
                                <i class="fas fa-check-circle"></i>
                            </div>
                        }
                    </div>
                    
                    <div class="profile-info">
                        <h1 class="profile-name">@Model.DisplayName</h1>
                        <div class="profile-stats">
                            <div class="stat-item">
                                <span class="stat-number">@Model.KarmaPoints</span>
                                <span class="stat-label">Karma</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">@Model.PostCount</span>
                                <span class="stat-label">Posts</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">@Model.CommentCount</span>
                                <span class="stat-label">Comments</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">@Model.JoinDate.ToString("MMM yyyy")</span>
                                <span class="stat-label">Joined</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Profile Tabs -->
            <div class="profile-tabs">
                <nav class="nav nav-tabs" id="profileTabs" role="tablist">
                    <button class="nav-link active" id="posts-tab" data-bs-toggle="tab" data-bs-target="#posts" type="button" role="tab">
                        <i class="fas fa-comment-dots me-2"></i>Posts (@Model.PostCount)
                    </button>
                    <button class="nav-link" id="comments-tab" data-bs-toggle="tab" data-bs-target="#comments" type="button" role="tab">
                        <i class="fas fa-comments me-2"></i>Comments (@Model.CommentCount)
                    </button>
                    <button class="nav-link" id="activity-tab" data-bs-toggle="tab" data-bs-target="#activity" type="button" role="tab">
                        <i class="fas fa-chart-line me-2"></i>Activity
                    </button>
                </nav>
                
                <div class="tab-content" id="profileTabsContent">
                    <!-- Posts Tab -->
                    <div class="tab-pane fade show active" id="posts" role="tabpanel">
                        <div class="profile-content-section">
                            <div class="text-center py-5">
                                <i class="fas fa-comment-dots fa-3x text-muted mb-3"></i>
                                <h4>Posts by @Model.DisplayName</h4>
                                <p class="text-muted">This user has made @Model.PostCount post@(Model.PostCount != 1 ? "s" : "").</p>
                                <a href="/u/@Model.DisplayName/posts" class="btn btn-primary">
                                    <i class="fas fa-external-link-alt me-2"></i>View All Posts
                                </a>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Comments Tab -->
                    <div class="tab-pane fade" id="comments" role="tabpanel">
                        <div class="profile-content-section">
                            <div class="text-center py-5">
                                <i class="fas fa-comments fa-3x text-muted mb-3"></i>
                                <h4>Comments by @Model.DisplayName</h4>
                                <p class="text-muted">This user has made @Model.CommentCount comment@(Model.CommentCount != 1 ? "s" : "").</p>
                                <a href="/u/@Model.DisplayName/comments" class="btn btn-primary">
                                    <i class="fas fa-external-link-alt me-2"></i>View All Comments
                                </a>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Activity Tab -->
                    <div class="tab-pane fade" id="activity" role="tabpanel">
                        <div class="profile-content-section">
                            <div class="text-center py-5">
                                <i class="fas fa-chart-line fa-3x text-muted mb-3"></i>
                                <h4>Activity Overview</h4>
                                <p class="text-muted">Activity tracking coming soon!</p>
                                <div class="row mt-4">
                                    <div class="col-md-4">
                                        <div class="activity-card">
                                            <div class="activity-icon">
                                                <i class="fas fa-star text-warning"></i>
                                            </div>
                                            <div class="activity-info">
                                                <h5>@Model.KarmaPoints</h5>
                                                <p>Karma Points</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="activity-card">
                                            <div class="activity-icon">
                                                <i class="fas fa-calendar text-primary"></i>
                                            </div>
                                            <div class="activity-info">
                                                <h5>@Model.JoinDate.ToString("MMM yyyy")</h5>
                                                <p>Member Since</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="activity-card">
                                            <div class="activity-icon">
                                                <i class="fas fa-trophy text-success"></i>
                                            </div>
                                            <div class="activity-info">
                                                <h5>@(Model.PostCount + Model.CommentCount)</h5>
                                                <p>Total Contributions</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- User Info Card -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-user me-2"></i>About @Model.DisplayName
                    </h5>
                </div>
                <div class="card-body">
                    <div class="user-info-item">
                        <i class="fas fa-calendar-alt text-muted me-2"></i>
                        <span>Joined @Model.JoinDate.ToString("MMMM dd, yyyy")</span>
                    </div>
                    
                    @if (Model.IsVerified)
                    {
                        <div class="user-info-item">
                            <i class="fas fa-check-circle text-primary me-2"></i>
                            <span>Verified User</span>
                        </div>
                    }
                    
                    <div class="user-info-item">
                        <i class="fas fa-star text-warning me-2"></i>
                        <span>@Model.KarmaPoints karma points</span>
                    </div>
                </div>
            </div>

            <!-- Quick Stats -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-chart-bar me-2"></i>Quick Stats
                    </h5>
                </div>
                <div class="card-body">
                    <div class="quick-stats">
                        <div class="stat-row">
                            <span class="stat-label">Posts</span>
                            <span class="stat-value">@Model.PostCount</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Comments</span>
                            <span class="stat-value">@Model.CommentCount</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Karma</span>
                            <span class="stat-value">@Model.KarmaPoints</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Member Since</span>
                            <span class="stat-value">@Model.JoinDate.ToString("MMM yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-cog me-2"></i>Actions
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="/u/@Model.DisplayName/posts" class="btn btn-outline-primary">
                            <i class="fas fa-comment-dots me-2"></i>View Posts
                        </a>
                        <a href="/u/@Model.DisplayName/comments" class="btn btn-outline-secondary">
                            <i class="fas fa-comments me-2"></i>View Comments
                        </a>
                        <button class="btn btn-outline-success" onclick="followUser('@Model.DisplayName')">
                            <i class="fas fa-user-plus me-2"></i>Follow User
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function followUser(displayName) {
        // Placeholder for follow functionality
        alert('Follow functionality coming soon for ' + displayName + '!');
    }
</script>

<style>
/* User Profile Styles */
.user-profile-header {
    position: relative;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 2rem;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
}

.profile-banner {
    height: 200px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    position: relative;
}

.banner-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.1);
}

.profile-content {
    position: relative;
    padding: 2rem;
    color: white;
}

.profile-avatar-section {
    position: relative;
    display: inline-block;
    margin-bottom: 1rem;
}

.profile-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 4px solid white;
    object-fit: cover;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
}

.profile-avatar-default {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 4px solid white;
    background: linear-gradient(135deg, #ff6b6b, #feca57);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: bold;
    color: white;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
}

.verification-badge {
    position: absolute;
    bottom: 10px;
    right: 10px;
    background: #4caf50;
    color: white;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

.profile-name {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1rem;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
}

.profile-stats {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
}

.stat-item {
    text-align: center;
}

.stat-number {
    display: block;
    font-size: 1.5rem;
    font-weight: bold;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
}

.stat-label {
    font-size: 0.9rem;
    opacity: 0.9;
}

.profile-tabs {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    overflow: hidden;
}

.profile-tabs .nav-tabs {
    border-bottom: 1px solid #e1e8ed;
    margin: 0;
}

.profile-tabs .nav-link {
    border: none;
    border-radius: 0;
    padding: 1rem 1.5rem;
    font-weight: 500;
    color: #657786;
    transition: all 0.3s ease;
}

.profile-tabs .nav-link:hover {
    background: #f8f9fa;
    color: #667eea;
}

.profile-tabs .nav-link.active {
    background: #667eea;
    color: white;
    border: none;
}

.profile-content-section {
    padding: 2rem;
    min-height: 300px;
}

.activity-card {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
    transition: transform 0.3s ease;
}

.activity-card:hover {
    transform: translateY(-2px);
}

.activity-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
}

.activity-info h5 {
    margin-bottom: 0.5rem;
    font-weight: bold;
}

.activity-info p {
    margin: 0;
    color: #657786;
    font-size: 0.9rem;
}

.user-info-item {
    display: flex;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid #f0f2f5;
}

.user-info-item:last-child {
    border-bottom: none;
}

.quick-stats {
    space-y: 0.5rem;
}

.stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f0f2f5;
}

.stat-row:last-child {
    border-bottom: none;
}

.stat-label {
    color: #657786;
    font-weight: 500;
}

.stat-value {
    font-weight: bold;
    color: #1a1a1a;
}

/* Responsive Design */
@@media (max-width: 768px) {
    .profile-content {
        padding: 1rem;
    }
    
    .profile-name {
        font-size: 2rem;
    }
    
    .profile-avatar,
    .profile-avatar-default {
        width: 80px;
        height: 80px;
        font-size: 1.8rem;
    }
    
    .profile-stats {
        gap: 1rem;
    }
    
    .stat-number {
        font-size: 1.2rem;
    }
    
    .profile-tabs .nav-link {
        padding: 0.75rem 1rem;
        font-size: 0.9rem;
    }
    
    .profile-content-section {
        padding: 1rem;
    }
}
</style>
