@model discussionspot9.Models.ViewModels.UserStatsViewModel
@{
    ViewData["Title"] = $"{Model.DisplayName} - User Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/user-profile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile-enhanced.css" asp-append-version="true" />
}

<div class="container-fluid py-4 user-profile-page">
<div class="profile-enhanced-layout">
    
    @* Left Sidebar *@
    @{
        var sidebarViewData = new ViewDataDictionary(ViewData);
        // Don't re-add existing ViewData keys
    }
    @await Html.PartialAsync("_ProfileSidebarLeft", Model, sidebarViewData)
    
    @* Main Content *@
    <div class="profile-main-content">
    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- User Profile Header -->
            <div class="user-profile-header">
                <div class="profile-banner">
                    <div class="banner-overlay"></div>
                </div>
                
                <div class="profile-content">
                    <div class="profile-avatar-section">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" alt="@Model.DisplayName" class="profile-avatar" />
                        }
                        else
                        {
                            <div class="profile-avatar profile-avatar-default">
                                @Model.DisplayName.Substring(0, Math.Min(2, Model.DisplayName.Length)).ToUpper()
                            </div>
                        }
                        
                        @if (Model.IsVerified)
                        {
                            <div class="verification-badge">
                                <i class="fas fa-check-circle"></i>
                            </div>
                        }
                    </div>
                    
                    <div class="profile-info">
                        <h1 class="profile-name">@Model.DisplayName</h1>
                        <div class="profile-stats">
                            <div class="stat-item">
                                <span class="stat-number">@Model.KarmaPoints</span>
                                <span class="stat-label">Karma</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">@Model.PostCount</span>
                                <span class="stat-label">Posts</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">@Model.CommentCount</span>
                                <span class="stat-label">Comments</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">@Model.JoinDate.ToString("MMM yyyy")</span>
                                <span class="stat-label">Joined</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Profile Tabs -->
            <div class="profile-tabs">
                <nav class="nav nav-tabs" id="profileTabs" role="tablist">
                    <button class="nav-link active" id="posts-tab" data-bs-toggle="tab" data-bs-target="#posts" type="button" role="tab">
                        <i class="fas fa-comment-dots me-2"></i>Posts (@Model.PostCount)
                    </button>
                    <button class="nav-link" id="comments-tab" data-bs-toggle="tab" data-bs-target="#comments" type="button" role="tab">
                        <i class="fas fa-comments me-2"></i>Comments (@Model.CommentCount)
                    </button>
                    <button class="nav-link" id="activity-tab" data-bs-toggle="tab" data-bs-target="#activity" type="button" role="tab">
                        <i class="fas fa-chart-line me-2"></i>Activity
                    </button>
                </nav>
                
                <div class="tab-content" id="profileTabsContent">
                    <!-- Posts Tab -->
                    <div class="tab-pane fade show active" id="posts" role="tabpanel">
                        <div class="profile-content-section">
                            <div class="text-center py-5">
                                <i class="fas fa-comment-dots fa-3x text-muted mb-3"></i>
                                <h4>Posts by @Model.DisplayName</h4>
                                <p class="text-muted">This user has made @Model.PostCount post@(Model.PostCount != 1 ? "s" : "").</p>
                                <a href="/u/@Model.DisplayName/posts" class="btn btn-primary">
                                    <i class="fas fa-external-link-alt me-2"></i>View All Posts
                                </a>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Comments Tab -->
                    <div class="tab-pane fade" id="comments" role="tabpanel">
                        <div class="profile-content-section">
                            <div class="text-center py-5">
                                <i class="fas fa-comments fa-3x text-muted mb-3"></i>
                                <h4>Comments by @Model.DisplayName</h4>
                                <p class="text-muted">This user has made @Model.CommentCount comment@(Model.CommentCount != 1 ? "s" : "").</p>
                                <a href="/u/@Model.DisplayName/comments" class="btn btn-primary">
                                    <i class="fas fa-external-link-alt me-2"></i>View All Comments
                                </a>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Activity Tab -->
                    <div class="tab-pane fade" id="activity" role="tabpanel">
                        <div class="profile-content-section">
                            <div class="text-center py-5">
                                <i class="fas fa-chart-line fa-3x text-muted mb-3"></i>
                                <h4>Activity Overview</h4>
                                <p class="text-muted">Activity tracking coming soon!</p>
                                <div class="row mt-4">
                                    <div class="col-md-4">
                                        <div class="activity-card">
                                            <div class="activity-icon">
                                                <i class="fas fa-star text-warning"></i>
                                            </div>
                                            <div class="activity-info">
                                                <h5>@Model.KarmaPoints</h5>
                                                <p>Karma Points</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="activity-card">
                                            <div class="activity-icon">
                                                <i class="fas fa-calendar text-primary"></i>
                                            </div>
                                            <div class="activity-info">
                                                <h5>@Model.JoinDate.ToString("MMM yyyy")</h5>
                                                <p>Member Since</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="activity-card">
                                            <div class="activity-icon">
                                                <i class="fas fa-trophy text-success"></i>
                                            </div>
                                            <div class="activity-info">
                                                <h5>@(Model.PostCount + Model.CommentCount)</h5>
                                                <p>Total Contributions</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- User Info Card -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-user me-2"></i>About @Model.DisplayName
                    </h5>
                </div>
                <div class="card-body">
                    <div class="user-info-item">
                        <i class="fas fa-calendar-alt text-muted me-2"></i>
                        <span>Joined @Model.JoinDate.ToString("MMMM dd, yyyy")</span>
                    </div>
                    
                    @if (Model.IsVerified)
                    {
                        <div class="user-info-item">
                            <i class="fas fa-check-circle text-primary me-2"></i>
                            <span>Verified User</span>
                        </div>
                    }
                    
                    <div class="user-info-item">
                        <i class="fas fa-star text-warning me-2"></i>
                        <span>@Model.KarmaPoints karma points</span>
                    </div>
                </div>
            </div>

            <!-- Quick Stats -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-chart-bar me-2"></i>Quick Stats
                    </h5>
                </div>
                <div class="card-body">
                    <div class="quick-stats">
                        <div class="stat-row">
                            <span class="stat-label">Posts</span>
                            <span class="stat-value">@Model.PostCount</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Comments</span>
                            <span class="stat-value">@Model.CommentCount</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Karma</span>
                            <span class="stat-value">@Model.KarmaPoints</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Member Since</span>
                            <span class="stat-value">@Model.JoinDate.ToString("MMM yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-cog me-2"></i>Actions
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="/u/@Model.DisplayName/posts" class="btn btn-outline-primary">
                            <i class="fas fa-comment-dots me-2"></i>View Posts
                        </a>
                        <a href="/u/@Model.DisplayName/comments" class="btn btn-outline-secondary">
                            <i class="fas fa-comments me-2"></i>View Comments
                        </a>
                        <button class="btn btn-outline-success" onclick="followUser('@Model.DisplayName')">
                            <i class="fas fa-user-plus me-2"></i>Follow User
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
    @* End Main Content *@
    
    @* Right Sidebar *@
    @await Html.PartialAsync("_ProfileSidebarRight")
    
</div>
@* End profile-enhanced-layout *@
</div>
@* End container *@

<!-- Followers Modal -->
<div class="modal fade" id="followersModal" tabindex="-1" aria-labelledby="followersModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="followersModalLabel">
                    <i class="fas fa-users me-2"></i>Followers
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="followersContent"></div>
            </div>
            <div class="modal-footer">
                <div id="followersPagination"></div>
            </div>
        </div>
    </div>
</div>

<!-- Following Modal -->
<div class="modal fade" id="followingModal" tabindex="-1" aria-labelledby="followingModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="followingModalLabel">
                    <i class="fas fa-user-friends me-2"></i>Following
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="followingContent"></div>
            </div>
            <div class="modal-footer">
                <div id="followingPagination"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/follow-system.js" asp-append-version="true"></script>
}
