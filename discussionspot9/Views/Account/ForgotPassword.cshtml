@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Forgot Password specific styles - scoped to avoid conflicts */
    .forgot-password-page {
        --auth-primary-color: #6366f1;
        --auth-primary-dark: #4f46e5;
        --auth-secondary-color: #64748b;
        --auth-success-color: #10b981;
        --auth-danger-color: #ef4444;
        --auth-warning-color: #f59e0b;
        --auth-info-color: #3b82f6;
        --auth-light-color: #f8fafc;
        --auth-dark-color: #1e293b;
        --auth-border-color: #e2e8f0;
        --auth-text-color: #334155;
        --auth-text-light: #64748b;
        --auth-bg-light: #ffffff;
        --auth-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        --auth-shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }

    .forgot-password-page .auth-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .forgot-password-page .auth-card {
        background: var(--auth-bg-light);
        border-radius: 20px;
        box-shadow: var(--auth-shadow-lg);
        overflow: hidden;
        width: 100%;
        max-width: 500px;
        display: flex;
        flex-direction: column;
    }

    .forgot-password-page .auth-image {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        min-height: 200px;
    }

    .forgot-password-page .auth-image::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="white" opacity="0.1"/><circle cx="75" cy="75" r="1" fill="white" opacity="0.1"/><circle cx="50" cy="10" r="0.5" fill="white" opacity="0.1"/><circle cx="10" cy="60" r="0.5" fill="white" opacity="0.1"/><circle cx="90" cy="40" r="0.5" fill="white" opacity="0.1"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
        opacity: 0.3;
    }

    .forgot-password-page .auth-image-content {
        position: relative;
        z-index: 1;
        text-align: center;
        color: white;
    }

    .forgot-password-page .auth-image-content h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 1rem;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .forgot-password-page .auth-image-content p {
        font-size: 1rem;
        opacity: 0.9;
        line-height: 1.6;
    }

    .forgot-password-page .auth-form-section {
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .forgot-password-page .auth-logo {
        text-align: center;
        margin-bottom: 2rem;
    }

    .forgot-password-page .auth-logo h2 {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--auth-primary-color);
        margin: 0;
    }

    .forgot-password-page .form-floating {
        margin-bottom: 1.5rem;
    }

    .forgot-password-page .form-floating > label {
        color: var(--auth-text-light);
        font-weight: 500;
    }

    .forgot-password-page .form-control {
        background-color: var(--auth-bg-light);
        border: 2px solid var(--auth-border-color);
        color: var(--auth-text-color);
        border-radius: 12px;
        padding: 1rem 0.75rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-shadow: none;
    }

    .forgot-password-page .form-control:focus {
        background-color: var(--auth-bg-light);
        color: var(--auth-text-color);
        border-color: var(--auth-primary-color);
        box-shadow: 0 0 0 0.2rem rgba(99, 102, 241, 0.15);
        transform: translateY(-1px);
    }

    .forgot-password-page .form-control:focus + label {
        color: var(--auth-primary-color);
    }

    .forgot-password-page .btn-primary {
        background: linear-gradient(135deg, var(--auth-primary-color) 0%, var(--auth-primary-dark) 100%);
        border: none;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-shadow: var(--auth-shadow);
        width: 100%;
    }

    .forgot-password-page .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(99, 102, 241, 0.3);
    }

    .forgot-password-page .btn-primary:active {
        transform: translateY(0);
    }

    .forgot-password-page .btn-secondary {
        background: transparent;
        border: 2px solid var(--auth-border-color);
        color: var(--auth-text-color);
        border-radius: 12px;
        padding: 0.75rem 1.5rem;
        font-weight: 500;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        margin-top: 1rem;
    }

    .forgot-password-page .btn-secondary:hover {
        background: var(--auth-light-color);
        border-color: var(--auth-primary-color);
        color: var(--auth-primary-color);
        transform: translateY(-1px);
    }

    .forgot-password-page .alert {
        border-radius: 12px;
        border: none;
        padding: 1rem 1.5rem;
        margin-bottom: 1.5rem;
        font-weight: 500;
    }

    .forgot-password-page .alert-success {
        background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
        color: #065f46;
    }

    .forgot-password-page .alert-danger {
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        color: #991b1b;
    }

    .forgot-password-page .alert-info {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        color: #1e40af;
    }

    .forgot-password-page .text-decoration-none {
        color: var(--auth-primary-color);
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .forgot-password-page .text-decoration-none:hover {
        color: var(--auth-primary-dark);
        text-decoration: underline !important;
    }

    .forgot-password-page .validation-summary-errors {
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        color: #991b1b;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        margin-bottom: 1.5rem;
        border: none;
    }

    .forgot-password-page .validation-summary-errors ul {
        list-style: none;
        padding-left: 0;
        margin-bottom: 0;
    }

    .forgot-password-page .field-validation-error {
        color: var(--auth-danger-color);
        font-size: 0.875em;
        margin-top: 0.5rem;
        display: block;
    }

    .forgot-password-page .input-validation-error {
        border-color: var(--auth-danger-color) !important;
    }

    .forgot-password-page .input-validation-error:focus {
        border-color: var(--auth-danger-color) !important;
        box-shadow: 0 0 0 0.2rem rgba(239, 68, 68, 0.15) !important;
    }

    /* Responsive Design */
    @@media (max-width: 575.98px) {
        .forgot-password-page .auth-container {
            padding: 1rem;
        }

        .forgot-password-page .auth-form-section {
            padding: 2rem;
        }

        .forgot-password-page .auth-image {
            padding: 2rem 1rem;
        }

        .forgot-password-page .auth-image-content h1 {
            font-size: 1.5rem;
        }
    }

    /* Loading States */
    .forgot-password-page .btn-loading {
        position: relative;
        color: transparent !important;
    }

    .forgot-password-page .btn-loading::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 20px;
        height: 20px;
        margin: -10px 0 0 -10px;
        border: 2px solid transparent;
        border-top: 2px solid currentColor;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>

<div class="forgot-password-page">
    <div class="auth-container">
        <div class="auth-card">
            <!-- Header Section -->
            <div class="auth-image">
                <div class="auth-image-content">
                    <h1><i class="fas fa-key me-3"></i>Forgot Password?</h1>
                    <p>Don't worry, it happens to the best of us. Enter your email and we'll send you a reset link.</p>
                </div>
            </div>

            <!-- Form Section -->
            <div class="auth-form-section">
                <div class="auth-logo">
                    <h2>Discussion<b style="color: var(--auth-primary-dark);">Spot</b></h2>
                </div>

                <!-- Success/Error Messages -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success" role="alert">
                        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    </div>
                }

                @if (TempData["InfoMessage"] != null)
                {
                    <div class="alert alert-info" role="alert">
                        <i class="fas fa-info-circle me-2"></i>@TempData["InfoMessage"]
                    </div>
                }

                <form asp-action="ForgotPassword" method="post" id="forgotPasswordForm">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                    <div class="form-floating">
                        <input type="email" class="form-control" id="email" name="email" placeholder="Email" required>
                        <label for="email"><i class="fas fa-envelope me-2"></i>Email Address</label>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane me-2"></i>Send Reset Link
                    </button>

                    <a asp-action="Auth" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Back to Sign In
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Enhanced JavaScript -->
<script>
    // Form Loading State
    function addLoadingState(form) {
        const submitBtn = form.querySelector('button[type="submit"]');
        submitBtn.classList.add('btn-loading');
        submitBtn.disabled = true;
    }

    function removeLoadingState(form) {
        const submitBtn = form.querySelector('button[type="submit"]');
        submitBtn.classList.remove('btn-loading');
        submitBtn.disabled = false;
    }

    // Add loading state to form
    document.getElementById('forgotPasswordForm').addEventListener('submit', function() {
        addLoadingState(this);
    });

    // Enhanced Form Validation
    function validateForm(form) {
        const inputs = form.querySelectorAll('input[required]');
        let isValid = true;

        inputs.forEach(input => {
            if (!input.value.trim()) {
                input.classList.add('input-validation-error');
                isValid = false;
            } else {
                input.classList.remove('input-validation-error');
            }
        });

        return isValid;
    }

    // Real-time validation
    document.querySelectorAll('input[required]').forEach(input => {
        input.addEventListener('blur', function() {
            if (!this.value.trim()) {
                this.classList.add('input-validation-error');
            } else {
                this.classList.remove('input-validation-error');
            }
        });

        input.addEventListener('input', function() {
            if (this.value.trim()) {
                this.classList.remove('input-validation-error');
            }
        });
    });

    // Auto-focus first input
    document.addEventListener('DOMContentLoaded', function() {
        const firstInput = document.querySelector('input[type="email"]');
        if (firstInput) {
            firstInput.focus();
        }
    });
</script>