@model List<discussionspot9.Models.Domain.Category>
@{
    ViewData["Title"] = "Community Categories - DiscussionSpot";
    ViewData["Description"] = "Explore all community categories and discover engaging discussions across various topics.";
}

<!-- Main Content -->
<main class="main-content" id="mainContent">
    <div class="container-fluid">
        <!-- Hero Header Section -->
        <section class="hero-section mb-5">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h1 class="section-title">
                        <i class="fas fa-layer-group me-3"></i>
                        Categories & Communities
                    </h1>
                    <p class="section-subtitle">Discover communities organized by topics and interests</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <div class="stats-inline-group">
                        <div class="stat-inline-item">
                            <span class="stat-number">@(Model?.Count ?? 0)</span>
                            <span class="stat-label">Categories</span>
                        </div>
                        <div class="stat-inline-item">
                            <span class="stat-number">@(Model?.SelectMany(c => c.Communities).Count() ?? 0)</span>
                            <span class="stat-label">Communities</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        @if (Model != null && Model.Any())
        {
            <!-- Categories Grid -->
            <section class="mb-5">
                @foreach (var category in Model.Where(c => c.IsActive).OrderBy(c => c.DisplayOrder))
                {
                    <!-- Category Section -->
                    <div class="category-section mb-5">
                        <!-- Category Header -->
                        <div class="category-header-modern" onclick="toggleCategory(@category.CategoryId)" data-category-id="@category.CategoryId">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="category-icon-modern">
                                        <i class="@GetCategoryIcon(category.Name)"></i>
                                    </div>
                                    <div>
                                        <h2 class="category-title-modern">@category.Name</h2>
                                        @if (!string.IsNullOrEmpty(category.Description))
                                        {
                                            <p class="category-description-modern">@category.Description</p>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-4">
                                    <div class="category-stats-modern">
                                        <div class="stat-item-modern">
                                            <i class="fas fa-users"></i>
                                            <span>@(category.Communities?.Count ?? 0) Communities</span>
                                        </div>
                                        <div class="stat-item-modern">
                                            <i class="fas fa-comments"></i>
                                            <span>@(category.Communities?.Sum(c => c.PostCount) ?? 0) Posts</span>
                                        </div>
                                    </div>
                                    <i class="fas fa-chevron-down expand-toggle-modern"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Communities Grid -->
                        @if (category.Communities != null && category.Communities.Any())
                        {
                            <div class="communities-grid-modern" id="communities-@category.CategoryId" style="display: none;">
                                <div class="row g-4 mt-1">
                                    @foreach (var community in category.Communities.Where(c => !c.IsDeleted).OrderByDescending(c => c.MemberCount))
                                    {
                                        var bgImages = new[] {
                                            "https://images.unsplash.com/photo-1552664730-d307ca884978?w=500&h=500&fit=crop",
                                            "https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=500&h=500&fit=crop",
                                            "https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=500&h=500&fit=crop",
                                            "https://images.unsplash.com/photo-1516321318423-f06f70d504504?w=500&h=500&fit=crop",
                                            "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=500&h=500&fit=crop",
                                            "https://images.unsplash.com/photo-1514525253161-7a46d19cd819?w=500&h=500&fit=crop"
                                        };
                                        var bgImage = bgImages[category.Communities.ToList().IndexOf(community) % bgImages.Length];
                                        
                                        <div class="col-lg-4 col-md-6">
                                            <div class="social-card" style="background-image: url('@bgImage');">
                                                <div class="social-card-content">
                                                    <span class="social-card-category">@category.Name</span>
                                                    <h3 class="social-card-title">@community.Name</h3>
                                                    <p class="social-card-description">
                                                        @(string.IsNullOrEmpty(community.ShortDescription) 
                                                            ? (community.Description?.Length > 100 ? community.Description.Substring(0, 100) + "..." : community.Description ?? "Join this community and start discussions") 
                                                            : (community.ShortDescription.Length > 100 ? community.ShortDescription.Substring(0, 100) + "..." : community.ShortDescription))
                                                    </p>
                                                    <div class="social-card-stats">
                                                        <div class="stat-item"><i class="fas fa-users"></i> @community.MemberCount.ToString("N0") Members</div>
                                                        <div class="stat-item"><i class="fas fa-comments"></i> @community.PostCount.ToString("N0") Posts</div>
                                                    </div>
                                                </div>
                                                <a asp-controller="Community" asp-action="Details" asp-route-communitySlug="@community.Slug" class="stretched-link"></a>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="communities-grid-modern" id="communities-@category.CategoryId" style="display: none;">
                                <div class="empty-state-modern">
                                    <i class="fas fa-inbox fa-3x"></i>
                                    <h4>No Communities Yet</h4>
                                    <p>This category is waiting for its first community.</p>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>
        }
        else
        {
            <!-- Empty State -->
            <section class="empty-state-modern text-center py-5">
                <i class="fas fa-exclamation-triangle fa-4x text-muted mb-4"></i>
                <h3>No Categories Available</h3>
                <p class="text-muted">Categories will appear here once they're created by administrators.</p>
            </section>
        }

        <!-- Call to Action Section -->
        <section class="cta-section mb-5">
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="social-card" style="background-image: url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&h=400&fit=crop');">
                        <div class="social-card-content">
                            <span class="social-card-category">Explore</span>
                            <h3 class="social-card-title">Browse All Posts</h3>
                            <p class="social-card-description">Discover trending conversations and join discussions across all communities</p>
                            <div class="social-card-stats">
                                <div class="stat-item"><i class="fas fa-compass"></i> Explore Now</div>
                            </div>
                        </div>
                        <a href="/post/all" class="stretched-link"></a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="social-card" style="background-image: url('https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=600&h=400&fit=crop');">
                        <div class="social-card-content">
                            <span class="social-card-category">Communities</span>
                            <h3 class="social-card-title">View All Communities</h3>
                            <p class="social-card-description">Find your tribe and connect with people who share your passions</p>
                            <div class="social-card-stats">
                                <div class="stat-item"><i class="fas fa-users"></i> View Communities</div>
                            </div>
                        </div>
                        <a href="/communities" class="stretched-link"></a>
                    </div>
                </div>
            </div>
        </section>
    </div>
</main>

<style>
    /* Category Header Modern */
    .category-header-modern {
        background: white;
        border-radius: 1rem;
        padding: 1.5rem 2rem;
        margin-bottom: 1rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        cursor: pointer;
        transition: all 0.3s ease;
        border-left: 4px solid transparent;
    }

    .category-header-modern:hover {
        box-shadow: 0 8px 25px rgba(0,0,0,0.12);
        border-left-color: #FF4500;
        transform: translateX(4px);
    }

    .category-icon-modern {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #FF4500 0%, #FF8C00 100%);
        color: white;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        flex-shrink: 0;
        box-shadow: 0 4px 15px rgba(255, 69, 0, 0.3);
    }

    .category-title-modern {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0;
        color: #1a1a1b;
    }

    .category-description-modern {
        font-size: 1rem;
        color: #7c7c7c;
        margin: 0.25rem 0 0 0;
    }

    .category-stats-modern {
        display: flex;
        gap: 2rem;
        align-items: center;
    }

    .stat-item-modern {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.95rem;
        color: #7c7c7c;
        font-weight: 500;
    }

    .stat-item-modern i {
        color: #FF4500;
        font-size: 1rem;
    }

    .expand-toggle-modern {
        font-size: 1.5rem;
        color: #7c7c7c;
        transition: transform 0.3s ease, color 0.3s ease;
    }

    .category-header-modern.expanded .expand-toggle-modern {
        transform: rotate(180deg);
        color: #FF4500;
    }

    .communities-grid-modern {
        padding: 0 2rem 1rem 2rem;
        animation: slideDown 0.4s ease;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .empty-state-modern {
        text-align: center;
        padding: 3rem;
        background: white;
        border-radius: 1rem;
        color: #7c7c7c;
    }

    .empty-state-modern i {
        color: #d7dadc;
        margin-bottom: 1rem;
    }

    .empty-state-modern h4 {
        color: #1a1a1b;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .stats-inline-group {
        display: flex;
        gap: 2rem;
        justify-content: flex-end;
    }

    .stat-inline-item {
        text-align: center;
    }

    .stat-inline-item .stat-number {
        display: block;
        font-size: 2rem;
        font-weight: 800;
        color: #FF4500;
        line-height: 1;
        margin-bottom: 0.25rem;
    }

    .stat-inline-item .stat-label {
        font-size: 0.875rem;
        color: #7c7c7c;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
    }

    .category-section {
        margin-bottom: 2.5rem;
    }

    /* Responsive Design */
    @@media (max-width: 992px) {
        .category-stats-modern {
            display: none;
        }

        .category-header-modern {
            padding: 1.25rem 1.5rem;
        }

        .category-icon-modern {
            width: 50px;
            height: 50px;
            font-size: 1.5rem;
        }

        .category-title-modern {
            font-size: 1.5rem;
        }

        .stats-inline-group {
            flex-direction: column;
            gap: 1rem;
        }
    }

    @@media (max-width: 768px) {
        .communities-grid-modern {
            padding: 0 1rem 1rem 1rem;
        }

        .category-title-modern {
            font-size: 1.25rem;
        }

        .category-description-modern {
            font-size: 0.9rem;
        }

        .stat-inline-item .stat-number {
            font-size: 1.5rem;
        }
    }
</style>

@section Scripts {
    <script>
        function toggleCategory(categoryId) {
            const header = document.querySelector(`[data-category-id="${categoryId}"]`);
            const communitiesDiv = document.getElementById(`communities-${categoryId}`);
            
            if (header && communitiesDiv) {
                const isExpanded = header.classList.contains('expanded');
                
                if (isExpanded) {
                    header.classList.remove('expanded');
                    communitiesDiv.style.display = 'none';
                } else {
                    header.classList.add('expanded');
                    communitiesDiv.style.display = 'block';
                }

                // Store state in localStorage
                const expandedCategories = JSON.parse(localStorage.getItem('expandedCategories') || '[]');
                if (header.classList.contains('expanded')) {
                    if (!expandedCategories.includes(categoryId)) {
                        expandedCategories.push(categoryId);
                    }
                } else {
                    const index = expandedCategories.indexOf(categoryId);
                    if (index > -1) {
                        expandedCategories.splice(index, 1);
                    }
                }
                localStorage.setItem('expandedCategories', JSON.stringify(expandedCategories));
            }
        }

        // Restore expanded state on page load
        document.addEventListener('DOMContentLoaded', function() {
            const expandedCategories = JSON.parse(localStorage.getItem('expandedCategories') || '[]');
            expandedCategories.forEach(categoryId => {
                const header = document.querySelector(`[data-category-id="${categoryId}"]`);
                const communitiesDiv = document.getElementById(`communities-${categoryId}`);
                if (header && communitiesDiv) {
                    header.classList.add('expanded');
                    communitiesDiv.style.display = 'block';
                }
            });
        });
    </script>
}

@functions {
    private string GetCategoryIcon(string categoryName)
    {
        return categoryName?.ToLower() switch
        {
            var name when name.Contains("technology") || name.Contains("tech") => "fas fa-microchip",
            var name when name.Contains("gaming") || name.Contains("game") => "fas fa-gamepad",
            var name when name.Contains("art") || name.Contains("creative") => "fas fa-palette",
            var name when name.Contains("music") => "fas fa-music",
            var name when name.Contains("sports") => "fas fa-futbol",
            var name when name.Contains("science") => "fas fa-flask",
            var name when name.Contains("education") || name.Contains("learning") => "fas fa-graduation-cap",
            var name when name.Contains("business") => "fas fa-briefcase",
            var name when name.Contains("health") => "fas fa-heartbeat",
            var name when name.Contains("food") => "fas fa-utensils",
            var name when name.Contains("travel") => "fas fa-plane",
            var name when name.Contains("movie") || name.Contains("film") => "fas fa-film",
            var name when name.Contains("book") => "fas fa-book",
            var name when name.Contains("news") => "fas fa-newspaper",
            _ => "fas fa-layer-group"
        };
    }
}
