@* Login/Register Prompt Modal *@
<div class="modal fade" id="loginPromptModal" tabindex="-1" aria-labelledby="loginPromptModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center px-4 pt-0 pb-4">
                <div class="mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded-circle" style="width: 80px; height: 80px;">
                        <i class="fas fa-comment-dots fa-3x text-primary"></i>
                    </div>
                </div>
                <h4 class="mb-3 fw-bold">Join the Conversation</h4>
                <p class="text-muted mb-4">
                    You need to be logged in to post comments and engage with the community. 
                    Sign in to your account or create a new one to get started!
                </p>
                <div class="d-grid gap-3">
                    <a href="#" id="loginPromptLoginBtn" class="btn btn-primary btn-lg">
                        <i class="fas fa-sign-in-alt me-2"></i>Login
                    </a>
                    <a href="#" id="loginPromptRegisterBtn" class="btn btn-outline-primary btn-lg">
                        <i class="fas fa-user-plus me-2"></i>Create Account
                    </a>
                </div>
                <div class="mt-3">
                    <small class="text-muted">You'll be redirected back here after signing in</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    #loginPromptModal .modal-content {
        border-radius: 1rem;
    }
    
    #loginPromptModal .btn-lg {
        padding: 0.875rem 1.5rem;
        font-weight: 500;
        border-radius: 0.5rem;
        transition: all 0.3s ease;
    }
    
    #loginPromptModal .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.3);
    }
    
    #loginPromptModal .btn-outline-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
    }
</style>

