@model discussionspot9.Models.ViewModels.CreativeViewModels.PostCardViewModel

<div class="post-actions d-flex align-items-center">
    <a href="@Model.PostUrl" class="post-action me-2">
        <i class="far fa-comment"></i>
        <span>@Model.FormattedCommentCount Comments</span>
    </a>
    <button class="post-action me-2 share-btn" 
            data-post-id="@Model.PostId"
            data-post-url="@($"{Context.Request.Scheme}://{Context.Request.Host}{Model.PostUrl}")"
            data-post-title="@Model.Title">
        <i class="fas fa-share"></i>
        <span>Share</span>
    </button>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <button class="post-action me-2 save-btn" data-post-id="@Model.PostId">
            <i class="far fa-bookmark"></i>
            <span>Save</span>
        </button>
    }
    <div class="dropdown">
        <button class="post-action dropdown-toggle" data-bs-toggle="dropdown">
            <i class="fas fa-ellipsis-h"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="#"><i class="fas fa-flag me-2"></i>Report</a></li>
            <li><a class="dropdown-item" href="#"><i class="fas fa-eye-slash me-2"></i>Hide</a></li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <a class="dropdown-item copy-link" href="#" data-url="@Model.PostUrl">
                    <i class="fas fa-link me-2"></i>Copy Link
                </a>
            </li>
        </ul>
    </div>
</div>