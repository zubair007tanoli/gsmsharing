@model List<discussionspot9.Models.ViewModels.HomePage.TrendingTopicViewModel>

<div class="card sidebar-card mb-4">
    <div class="card-header">
        <h6 class="mb-0">Trending Today</h6>
    </div>
    <div class="card-body">
        <ul class="list-unstyled mb-0 trending-topics">
            @{
                int index = 1;
            }
            @foreach (var topic in Model.Take(5))
            {
                <li>
                    <a href="@topic.PostUrl" class="text-decoration-none">
                        <span class="trending-number">@index</span>
                        @topic.ShortTitle
                    </a>
                    <div class="small text-muted mt-1">
                        @topic.CategoryName • @topic.FormattedReplyCount discussing
                    </div>
                </li>
                index++;
            }
        </ul>
    </div>
</div>