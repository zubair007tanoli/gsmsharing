@model discussionspot9.Models.ViewModels.CreativeViewModels.CommentTreeViewModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<div class="comment-item @(Model.Depth > 0 ? "nested-comment" : "")" 
     data-comment-id="@Model.Comment.CommentId" 
     style="margin-left: @(Model.Depth * 20)px">
    
    <div class="d-flex">
        <!-- Vote buttons -->
        <div class="comment-voting me-3">
            <button class="vote-btn comment-upvote @(Model.Comment.CurrentUserVote == 1 ? "active" : "")"
                    data-comment-id="@Model.Comment.CommentId" data-vote-type="1">
                <i class="fas fa-arrow-up"></i>
            </button>
            <span class="vote-count">@Model.Comment.Score</span>
            <button class="vote-btn comment-downvote @(Model.Comment.CurrentUserVote == -1 ? "active" : "")"
                    data-comment-id="@Model.Comment.CommentId" data-vote-type="-1">
                <i class="fas fa-arrow-down"></i>
            </button>
        </div>
        
        <!-- Comment content -->
        <div class="flex-grow-1">
            <div class="comment-header mb-2">
                <strong class="me-2">@Model.Comment.AuthorDisplayName</strong>
                <span class="text-muted small">@Model.Comment.TimeAgo</span>
                @if (Model.Comment.IsEdited)
                {
                    <span class="text-muted small">(edited)</span>
                }
            </div>
            
            <div class="comment-body mb-2">
                @if (Model.Comment.IsDeleted)
                {
                    <em class="text-muted">[deleted]</em>
                }
                else
                {
                    @Html.Raw(Model.Comment.Content)
                }
            </div>
            
            @if (!Model.Comment.IsDeleted)
            {
                <div class="comment-actions">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <button class="btn btn-sm btn-link text-muted reply-btn" 
                                data-comment-id="@Model.Comment.CommentId">
                            <i class="fas fa-reply me-1"></i>Reply
                        </button>
                    }
                    
                    @if (Model.Comment.IsCurrentUserAuthor)
                    {
                        <button class="btn btn-sm btn-link text-muted edit-btn"
                                data-comment-id="@Model.Comment.CommentId">
                            <i class="fas fa-edit me-1"></i>Edit
                        </button>
                        <button class="btn btn-sm btn-link text-danger delete-btn"
                                data-comment-id="@Model.Comment.CommentId">
                            <i class="fas fa-trash me-1"></i>Delete
                        </button>
                    }
                </div>
                
                <!-- Reply form (hidden by default) -->
                <div id="reply-form-@Model.Comment.CommentId" class="reply-form mt-3 d-none">
                    <form class="reply-comment-form">
                        <input type="hidden" name="PostId" value="@ViewBag.PostId" />
                        <input type="hidden" name="ParentCommentId" value="@Model.Comment.CommentId" />
                        <textarea name="Content" class="form-control mb-2" rows="3" required></textarea>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-sm btn-primary">Reply</button>
                            <button type="button" class="btn btn-sm btn-secondary cancel-reply">Cancel</button>
                        </div>
                    </form>
                </div>
            }
        </div>
    </div>
    
    <!-- Nested comments -->
    @if (Model.Children.Any())
    {
        <div class="comment-children mt-3">
            @foreach (var child in Model.Children)
            {
                <partial name="_CommentItem" model="child" />
            }
        </div>
    }
</div>