@model discussionspot9.Models.ViewModels.CreativeViewModels.CommentTreeViewModel
@using discussionspot9.Helpers;

<div class="comment-item" id="commentsContainer@(Model.Comment.CommentId)" data-comment-id="@Model.Comment.CommentId">
    <div class="comment-content" style="margin-left: @(Model.Depth > 0 ? "2.5" : "0")rem;">
        @* Indent comments based on depth *@
        <div class="comment-meta">
            <div class="user-avatar @(Model.Depth > 0 ? "small" : "")" style="background-color: @(Model.Comment.AuthorDisplayName.ToAvatarColor())">
                @Model.Comment.AuthorInitials
            </div>
            <span class="comment-author">@Model.Comment.AuthorDisplayName</span>
            <span class="comment-time">@Model.Comment.TimeAgo @(Model.Comment.IsEdited ? "(edited)" : "")</span>
        </div>
        <div class="comment-text">
            @Html.Raw(Model.Comment.Content)
        </div>
        <div class="comment-actions">
            <div class="comment-vote">
                <button class="comment-vote-btn upvote @(Model.Comment.CurrentUserVote == 1 ? "active" : "")" data-comment-id="@Model.Comment.CommentId" data-vote-type="1">
                    <i class="fas fa-arrow-up"></i>
                </button>
                <span class="comment-vote-count" id="commentVote@(Model.Comment.CommentId)">@(Model.Comment.UpvoteCount - Model.Comment.DownvoteCount)</span>
                <button class="comment-vote-btn downvote @(Model.Comment.CurrentUserVote == -1 ? "active" : "")" data-comment-id="@Model.Comment.CommentId" data-vote-type="-1">
                    <i class="fas fa-arrow-down"></i>
                </button>
            </div>
            <button class="comment-reply-btn" data-comment-id="@Model.Comment.CommentId">
                <i class="fas fa-reply"></i>
                <span>Reply</span>
            </button>
        </div>
        <!-- Reply Form -->
        <!-- FIX: Added 'd-flex' class to ensure the form displays correctly as a flex container when 'd-none' is removed. -->
        <div class="reply-form d-none d-flex flex-column" id="replyForm@(Model.Comment.CommentId)" data-comment-id="@Model.Comment.CommentId">
            <div class="d-flex gap-2">
                <div class="user-avatar small" style="background-color: @(User.Identity?.IsAuthenticated == true ? User.Identity.Name.ToAvatarColor() : "gray")">
                    @(User.Identity?.IsAuthenticated == true ? User.Identity.Name.ToInitials() : "U")
                </div>
                <textarea class="form-control" placeholder="Write a reply..." data-comment-id="@Model.Comment.CommentId"></textarea>
            </div>
            <div class="reply-form-actions d-flex justify-content-end mt-2">
                <button class="reply-cancel-btn" data-comment-id="@Model.Comment.CommentId">Cancel</button>
                <button class="reply-submit-btn" data-comment-id="@Model.Comment.CommentId">Reply</button>
            </div>
        </div>
    </div>

    @* Always render the comment-replies div, even if empty, so it can be targeted by JavaScript. *@
    @* Add a unique ID to the comment-replies div using the parent comment's ID. *@
    <div class="comment-replies" id="commentReplies-@(Model.Comment.CommentId)">
        @if (Model.Children != null && Model.Children.Any())
        {
            @foreach (var childCommentTree in Model.Children)
            {
                @await Html.PartialAsync("Partials/V1/_CommentItem", childCommentTree)
            }
        }
    </div>
</div>
