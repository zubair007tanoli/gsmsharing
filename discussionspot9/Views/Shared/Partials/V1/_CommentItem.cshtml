@model discussionspot9.Models.ViewModels.CreativeViewModels.CommentTreeViewModel
@using discussionspot9.Helpers;

<div class="comment-item" id="commentsContainer@(Model.Comment.CommentId)" data-comment-id="@Model.Comment.CommentId">
    <div class="comment-content" style="margin-left: @(Model.Depth > 0 ? "2.5" : "0")rem;">
        @* Indent comments based on depth *@
        <div class="comment-meta">
            <div class="user-avatar @(Model.Depth > 0 ? "small" : "")" style="background-color: @(Model.Comment.AuthorDisplayName.ToAvatarColor())">
                @Model.Comment.AuthorInitials
            </div>
            <span class="comment-author">@Model.Comment.AuthorDisplayName</span>
            <span class="comment-time">@Model.Comment.TimeAgo @(Model.Comment.IsEdited ? "(edited)" : "")</span>
        </div>
        <div class="comment-text">
            @Html.Raw(Model.Comment.Content)
        </div>
        
        @* Display link previews if any exist *@
        @if (Model.Comment.LinkPreviews != null && Model.Comment.LinkPreviews.Any())
        {
            <div class="comment-link-previews">
                @foreach (var linkPreview in Model.Comment.LinkPreviews)
                {
                    @await Html.PartialAsync("Partials/_LinkPreview", linkPreview)
                }
            </div>
        }
        
        <div class="comment-actions">
            <div class="comment-vote">
                <button class="comment-vote-btn upvote @(Model.Comment.CurrentUserVote == 1 ? "active" : "")" 
                        data-comment-id="@Model.Comment.CommentId" 
                        data-vote-type="1"
                        title="Upvote">
                    <i class="fas fa-arrow-up"></i>
                </button>
                <div class="comment-vote-counts">
                    <span class="comment-upvote-number" id="commentUpvote@(Model.Comment.CommentId)">@Model.Comment.UpvoteCount</span>
                    <span class="comment-vote-separator">•</span>
                    <span class="comment-downvote-number" id="commentDownvote@(Model.Comment.CommentId)">@Model.Comment.DownvoteCount</span>
                </div>
                <button class="comment-vote-btn downvote @(Model.Comment.CurrentUserVote == -1 ? "active" : "")" 
                        data-comment-id="@Model.Comment.CommentId" 
                        data-vote-type="-1"
                        title="Downvote">
                    <i class="fas fa-arrow-down"></i>
                </button>
            </div>
            <button class="comment-reply-btn" data-comment-id="@Model.Comment.CommentId">
                <i class="fas fa-reply"></i>
                <span>Reply</span>
            </button>
            
            @* Comment Actions Dropdown *@
            <div class="dropdown d-inline-block ms-2">
                <button class="btn btn-sm btn-link text-muted p-0 dropdown-toggle comment-actions-toggle" 
                        type="button" 
                        data-bs-toggle="dropdown" 
                        aria-expanded="false"
                        style="font-size: 0.875rem;">
                    <i class="fas fa-ellipsis-h"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="min-width: 180px;">
                    @if (Model.Comment.IsPinned)
                    {
                        <li>
                            <span class="dropdown-item-text text-success">
                                <i class="fas fa-thumbtack me-2"></i> Pinned Comment
                            </span>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                    }
                    
                    @* Show Edit/Delete to comment author *@
                    @if (User.Identity?.IsAuthenticated == true && User.Identity.Name == Model.Comment.AuthorDisplayName)
                    {
                        <li>
                            <a class="dropdown-item edit-comment-btn" 
                               href="#" 
                               data-comment-id="@Model.Comment.CommentId"
                               onclick="editComment(@Model.Comment.CommentId); return false;">
                                <i class="fas fa-edit me-2"></i> Edit
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item text-danger delete-comment-btn" 
                               href="#" 
                               data-comment-id="@Model.Comment.CommentId"
                               onclick="deleteComment(@Model.Comment.CommentId); return false;">
                                <i class="fas fa-trash me-2"></i> Delete
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                    }
                    
                    @* Show Pin/Unpin to post author (passed via ViewData) *@
                    @if (ViewData["IsPostAuthor"] != null && (bool)ViewData["IsPostAuthor"])
                    {
                        <li>
                            <a class="dropdown-item pin-comment-btn" 
                               href="#" 
                               data-comment-id="@Model.Comment.CommentId"
                               data-is-pinned="@Model.Comment.IsPinned.ToString().ToLower()"
                               onclick="togglePinComment(@Model.Comment.CommentId, @Model.Comment.IsPinned.ToString().ToLower()); return false;">
                                <i class="fas fa-thumbtack me-2"></i> @(Model.Comment.IsPinned ? "Unpin" : "Pin") Comment
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                    }
                    
                    @* Report option for all authenticated users *@
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li>
                            <a class="dropdown-item" href="#" onclick="return false;">
                                <i class="fas fa-flag me-2"></i> Report
                            </a>
                        </li>
                    }
                    
                    <li>
                        <a class="dropdown-item" 
                           href="#" 
                           onclick="copyCommentLink(@Model.Comment.CommentId); return false;">
                            <i class="fas fa-link me-2"></i> Copy Link
                        </a>
                    </li>
                </ul>
            </div>
        </div>
        <!-- Reply Form -->
        <div class="reply-form d-none" id="replyForm@(Model.Comment.CommentId)" data-comment-id="@Model.Comment.CommentId">
            <div class="d-flex gap-2 align-items-start">
                <div class="user-avatar small" style="background-color: @(User.Identity?.IsAuthenticated == true ? User.Identity.Name.ToAvatarColor() : "gray")">
                    @(User.Identity?.IsAuthenticated == true ? User.Identity.Name.ToInitials() : "U")
                </div>
                <div class="flex-grow-1">
                    <!-- Reply Editor Container -->
                    <div class="reply-editor-container">
                        <div id="replyEditor@(Model.Comment.CommentId)"></div>
                    </div>
                    <!-- Hidden textarea for content storage -->
                    <textarea class="reply-content-storage" id="replyContent@(Model.Comment.CommentId)" style="display: none;" data-comment-id="@Model.Comment.CommentId"></textarea>
                </div>
            </div>
            <div class="reply-form-actions d-flex justify-content-end gap-2 mt-2">
                <button class="btn btn-sm btn-secondary reply-cancel-btn" data-comment-id="@Model.Comment.CommentId">
                    <i class="fas fa-times me-1"></i>Cancel
                </button>
                <button class="btn btn-sm btn-primary reply-submit-btn" data-comment-id="@Model.Comment.CommentId">
                    <i class="fas fa-paper-plane me-1"></i>Reply
                </button>
            </div>
        </div>
        
        <!-- Edit Form -->
        <div class="edit-form d-none" id="editForm@(Model.Comment.CommentId)" data-comment-id="@Model.Comment.CommentId">
            <div class="d-flex gap-2 align-items-start">
                <div class="user-avatar small" style="background-color: @(User.Identity?.IsAuthenticated == true ? User.Identity.Name.ToAvatarColor() : "gray")">
                    @(User.Identity?.IsAuthenticated == true ? User.Identity.Name.ToInitials() : "U")
                </div>
                <div class="flex-grow-1">
                    <!-- Edit Editor Container -->
                    <div class="edit-editor-container">
                        <div id="editEditor@(Model.Comment.CommentId)"></div>
                    </div>
                    <!-- Hidden textarea for content storage -->
                    <textarea class="edit-content-storage" id="editContent@(Model.Comment.CommentId)" style="display: none;" data-comment-id="@Model.Comment.CommentId"></textarea>
                </div>
            </div>
            <div class="edit-form-actions d-flex justify-content-end gap-2 mt-2">
                <button class="btn btn-sm btn-secondary edit-cancel-btn" data-comment-id="@Model.Comment.CommentId">
                    <i class="fas fa-times me-1"></i>Cancel
                </button>
                <button class="btn btn-sm btn-primary edit-submit-btn" data-comment-id="@Model.Comment.CommentId">
                    <i class="fas fa-save me-1"></i>Save
                </button>
            </div>
        </div>
    </div>

    @* Always render the comment-replies div, even if empty, so it can be targeted by JavaScript. *@
    @* Add a unique ID to the comment-replies div using the parent comment's ID. *@
    <div class="comment-replies" id="commentReplies-@(Model.Comment.CommentId)">
        @if (Model.Children != null && Model.Children.Any())
        {
            @foreach (var childCommentTree in Model.Children)
            {
                @await Html.PartialAsync("Partials/V1/_CommentItem", childCommentTree)
            }
        }
    </div>
</div>
