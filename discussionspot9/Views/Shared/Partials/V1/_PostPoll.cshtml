@model discussionspot9.Models.ViewModels.PollViewModels.PollViewModel
@if (Model != null)
{
    <div class="poll-container">
        <div class="poll-badge">
            <i class="fas fa-poll"></i>
            <span>POLL</span>
        </div>
        <h5 class="poll-question">@Model.Question</h5>
        <div class="poll-options" id="pollOptions">
            @* This ID should ideally be unique if multiple polls on page. For single post, it's fine. *@
            @foreach (var option in Model.Options)
            {
                <div class="poll-option @(option.HasUserVoted.HasValue && option.HasUserVoted.Value ? "selected voted" : "")" data-option="@option.PollOptionId">
                    <div class="poll-radio"></div>
                    <div class="poll-option-content">
                        <span class="poll-option-text">@option.OptionText</span>
                        <span class="poll-percentage">@option.VotePercentage.ToString("F0")%</span> @* Format to 0 decimal places *@
                    </div>
                    <div class="poll-progress" style="width: @(option.VotePercentage.ToString("F0"))%"></div>
                </div>
            }
        </div>
        <div class="d-flex justify-content-center mb-3">
            <button class="vote-button" id="submitVote" @(Model.HasUserVoted ? "disabled" : "")>
                @(Model.HasUserVoted ? "Vote Submitted" : "Cast Your Vote")
            </button>
        </div>
        <div class="poll-stats">
            <div class="poll-votes">
                <i class="fas fa-chart-bar"></i>
                <span id="totalVotes">@Model.TotalVotes.ToString("N0") votes</span>
            </div>
            <div class="poll-time">
                <i class="fas fa-clock"></i>
                <span>Poll closes in @(Model.EndDate.HasValue ? (Model.EndDate.Value - DateTime.UtcNow).TotalDays.ToString("F0") + " days" : "N/A")</span>
            </div>
        </div>
    </div>
}
