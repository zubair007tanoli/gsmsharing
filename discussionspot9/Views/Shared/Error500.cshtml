@{
    ViewData["Title"] = "Server Error - 500";
    ViewData["Description"] = "We're experiencing technical difficulties. Our team has been notified.";
    ViewData["Robots"] = "noindex, nofollow"; // Prevent indexing of error pages
    ViewData["CanonicalUrl"] = $"{Context.Request.Scheme}://{Context.Request.Host}/Error/500";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="error-page-container" style="min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 2rem;">
    <div class="error-content text-center" style="max-width: 600px;">
        <div class="error-icon mb-4">
            <i class="fas fa-exclamation-triangle" style="font-size: 5rem; color: #dc3545; opacity: 0.3;"></i>
        </div>
        
        <h1 class="display-4 mb-3" style="font-weight: 700;">Something Went Wrong</h1>
        <p class="lead text-muted mb-4">
            We're experiencing technical difficulties. Our team has been notified and is working on it.
        </p>
        
        <div class="error-suggestions mb-4">
            <div class="d-grid gap-2 col-md-8 mx-auto mt-3">
                <button onclick="window.location.reload()" class="btn btn-primary btn-lg">
                    <i class="fas fa-redo me-2"></i>Try Again
                </button>
                <a href="/" class="btn btn-outline-primary">
                    <i class="fas fa-home me-2"></i>Go to Homepage
                </a>
            </div>
        </div>
        
        <div class="error-help mt-4">
            <p class="small text-muted">
                <i class="fas fa-info-circle me-1"></i>
                Error ID: @ViewData["ErrorId"] | Time: @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss UTC")
            </p>
        </div>
    </div>
</div>

<style>
    .error-page-container {
        background: linear-gradient(135deg, #fff5f5 0%, #fee2e2 100%);
    }
    
    .error-icon i {
        animation: pulse 2s ease-in-out infinite;
    }
    
    @@keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 0.3; }
        50% { transform: scale(1.1); opacity: 0.5; }
    }
</style>

