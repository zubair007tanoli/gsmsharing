@{
    var activities = ViewBag.Activities as List<object> ?? new List<object>();
}

@if (activities.Any())
{
    <div class="activity-feed">
        @foreach (var activity in activities)
        {
            var activityType = activity.GetType().GetProperty("Type")?.GetValue(activity)?.ToString();
            var createdAt = (DateTime)(activity.GetType().GetProperty("CreatedAt")?.GetValue(activity) ?? DateTime.Now);
            var timeAgo = GetTimeAgo(createdAt);

            @if (activityType == "post")
            {
                var title = activity.GetType().GetProperty("Title")?.GetValue(activity)?.ToString();
                var content = activity.GetType().GetProperty("Content")?.GetValue(activity)?.ToString();
                var communityName = activity.GetType().GetProperty("CommunityName")?.GetValue(activity)?.ToString();
                var upvoteCount = (int)(activity.GetType().GetProperty("UpvoteCount")?.GetValue(activity) ?? 0);
                var downvoteCount = (int)(activity.GetType().GetProperty("DownvoteCount")?.GetValue(activity) ?? 0);
                var commentCount = (int)(activity.GetType().GetProperty("CommentCount")?.GetValue(activity) ?? 0);
                var viewCount = (int)(activity.GetType().GetProperty("ViewCount")?.GetValue(activity) ?? 0);
                var url = activity.GetType().GetProperty("Url")?.GetValue(activity)?.ToString();

                <div class="activity-item">
                    <div class="d-flex align-items-center gap-3">
                        <div class="activity-info flex-grow-1">
                            <div class="activity-title">
                                <a href="@url" class="text-decoration-none">@title</a>
                            </div>
                            <div class="activity-meta">
                                Posted in r/@communityName • @timeAgo
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="activity-action">
                                <i class="fas fa-arrow-up text-primary"></i>
                                <span>@upvoteCount</span>
                            </div>
                            <div class="activity-action">
                                <i class="fas fa-arrow-down text-danger"></i>
                                <span>@downvoteCount</span>
                            </div>
                            <div class="activity-action">
                                <i class="far fa-comment-alt"></i>
                                <span>@commentCount</span>
                            </div>
                            <div class="activity-action">
                                <i class="fas fa-eye"></i>
                                <span>@viewCount</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (activityType == "comment")
            {
                var content = activity.GetType().GetProperty("Content")?.GetValue(activity)?.ToString();
                var postTitle = activity.GetType().GetProperty("PostTitle")?.GetValue(activity)?.ToString();
                var communityName = activity.GetType().GetProperty("CommunityName")?.GetValue(activity)?.ToString();
                var upvoteCount = (int)(activity.GetType().GetProperty("UpvoteCount")?.GetValue(activity) ?? 0);
                var downvoteCount = (int)(activity.GetType().GetProperty("DownvoteCount")?.GetValue(activity) ?? 0);
                var url = activity.GetType().GetProperty("Url")?.GetValue(activity)?.ToString();

                <div class="activity-item">
                    <div class="d-flex align-items-center gap-3">
                        <div class="activity-info flex-grow-1">
                            <div class="activity-title">
                                Comment on: <a href="@url" class="text-decoration-none">@postTitle</a>
                            </div>
                            <div class="activity-meta">
                                In r/@communityName • @timeAgo
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="activity-action">
                                <i class="fas fa-arrow-up text-primary"></i>
                                <span>@upvoteCount</span>
                            </div>
                            <div class="activity-action">
                                <i class="fas fa-arrow-down text-danger"></i>
                                <span>@downvoteCount</span>
                            </div>
                            <div class="activity-action">
                                <a href="@url" class="text-decoration-none text-muted">
                                    <i class="fas fa-external-link-alt"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>
        No recent activity to display.
    </div>
}

@functions {
    private string GetTimeAgo(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime.ToUniversalTime();

        if (timeSpan.TotalSeconds < 60)
            return "just now";
        else if (timeSpan.TotalSeconds < 3600)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        else if (timeSpan.TotalSeconds < 86400)
            return $"{(int)timeSpan.TotalHours}h ago";
        else
            return dateTime.ToString("MMM dd, yyyy");
    }
}


