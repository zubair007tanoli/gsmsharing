@model discussionspot9.Models.ViewModels.CreativeViewModels.HeaderViewModel
<header class="main-header sticky-top">
    <div class="container">
        <nav class="navbar navbar-expand-lg">
            <a href="index.html" class="logo me-3">
                <div class="logo-icon">D</div>
                <span class="logo-text d-none d-sm-inline">iscussion<b>Spot</b></span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <i class="fas fa-bars"></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="categories.html">
                            <i class="fas fa-th-large"></i> <span>Categories</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="forums.html">
                            <i class="fas fa-comments"></i> <span>Forums</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="popular.html">
                            <i class="fas fa-fire"></i> <span>Popular</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="recent.html">
                            <i class="fas fa-clock"></i> <span>Recent</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="members.html">
                            <i class="fas fa-users"></i> <span>Members</span>
                        </a>
                    </li>
                </ul>

                <!-- Combined right-side elements into one container -->
                <div class="navbar-right">
                    <div class="search-container">
                        <input type="text" class="form-control form-control-sm" placeholder="Search forums...">
                        <button class="search-btn"><i class="fas fa-search"></i></button>
                    </div>

                    <div class="nav-actions">
                        <div class="action-icon dark-mode-toggle" title="Toggle Dark Mode">
                            <i class="fas fa-moon"></i>
                            <i class="fas fa-sun"></i>
                        </div>
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <!-- Notification Dropdown -->
                            <div class="dropdown">
                                <a href="#" class="action-icon notification-btn" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                                    <i class="fas fa-bell"></i>
                                    @if (Model.UnreadNotifications > 0)
                                    {
                                        <span class="notification-badge">@Model.UnreadNotifications</span>
                                    }
                                </a>
                                <div class="dropdown-menu dropdown-menu-end notification-dropdown">
                                    <div class="notification-header">
                                        <span><i class="fas fa-bell me-1"></i> Notifications</span>
                                        @if (Model.UnreadNotifications > 0)
                                        {
                                            <span class="badge bg-danger rounded-pill">@Model.UnreadNotifications</span>
                                        }
                                    </div>
                                    <div class="notification-list">
                                        @if (Model.RecentNotifications != null && Model.RecentNotifications.Any())
                                        {
                                            @foreach (var notification in Model.RecentNotifications)
                                            {
                                                <div class="notification-item @(notification.IsRead ? "" : "unread")">
                                                    <div class="notification-title">@notification.Title</div>
                                                    @if (!string.IsNullOrEmpty(notification.Message))
                                                    {
                                                        <div class="notification-text">@notification.Message</div>
                                                    }
                                                    <div class="notification-info">
                                                        <span><i class="far fa-clock me-1"></i>@notification.CreatedAt.ToString("MMM dd, HH:mm")</span>
                                                        <a href="@notification.Url" class="text-primary">View</a>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="notification-item">
                                                <div class="notification-title">No new notifications</div>
                                                <div class="notification-text">You're all caught up!</div>
                                            </div>
                                        }
                                    </div>
                                    <div class="notification-footer">
                                        <a href="/notifications" class="text-primary">View all notifications</a>
                                    </div>
                                </div>
                            </div>

                            <!-- User Dropdown - Show when logged in -->
                            <div class="dropdown user-dropdown">
                                <button class="user-btn" type="button" data-bs-toggle="dropdown">
                                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                                    {
                                        <img src="@Model.AvatarUrl" alt="Profile" class="avatar-img" width="32" height="32">
                                    }
                                    else
                                    {
                                        <div class="avatar">
                                            @if (!string.IsNullOrEmpty(Model.DisplayName))
                                            {
                                                @Model.DisplayName.Substring(0, Math.Min(2, Model.DisplayName.Length)).ToUpper()
                                            }
                                            else
                                            {
                                                <span>U</span>
                                            }
                                        </div>
                                    }
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li class="dropdown-header">
                                        <strong>@Model.DisplayName</strong>
                                        @if (Model.IsVerified)
                                        {
                                            <i class="fas fa-check-circle text-primary ms-1" title="Verified Account"></i>
                                        }
                                        <br>
                                        <small class="text-muted">@Model.Email</small>
                                        <br>
                                        <small class="text-muted">@Model.KarmaPoints karma points</small>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/profile"><i class="fas fa-user me-2"></i>Profile</a></li>
                                    <li><a class="dropdown-item" href="/profile/edit"><i class="fas fa-cog me-2"></i>Settings</a></li>
                                    <li><a class="dropdown-item" href="/notifications"><i class="fas fa-bookmark me-2"></i>Bookmarks</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item">
                                                <i class="fas fa-sign-out-alt me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <!-- Authentication buttons - show when logged out -->
                            <div class="auth-btns">
                                <a asp-action="Auth" asp-controller="Account" class="btn btn-primary btn-sm">
                                    <i class="fas fa-sign-in-alt"></i> <span>Login</span> / <i class="fas fa-user-plus"></i> <span>Register</span>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </div>
</header>