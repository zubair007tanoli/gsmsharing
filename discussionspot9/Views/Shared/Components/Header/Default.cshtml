 @model discussionspot9.Models.ViewModels.CreativeViewModels.HeaderViewModel
<header class="main-header sticky-top">
        <div class="container">
            <nav class="navbar navbar-expand-lg">
                <a href="index.html" class="logo me-3">
                    <div class="logo-icon">D</div>
                    <span class="logo-text d-none d-sm-inline">iscussion<b>Spot</b></span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <i class="fas fa-bars"></i>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link active" href="categories.html">
                                <i class="fas fa-th-large"></i> <span>Categories</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="forums.html">
                                <i class="fas fa-comments"></i> <span>Forums</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="popular.html">
                                <i class="fas fa-fire"></i> <span>Popular</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="recent.html">
                                <i class="fas fa-clock"></i> <span>Recent</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="members.html">
                                <i class="fas fa-users"></i> <span>Members</span>
                            </a>
                        </li>
                    </ul>

                    <!-- Combined right-side elements into one container -->
                    <div class="navbar-right">
                        <div class="search-container">
                            <input type="text" class="form-control form-control-sm" placeholder="Search forums...">
                            <button class="search-btn"><i class="fas fa-search"></i></button>
                        </div>

                        <div class="nav-actions">
                            <div class="action-icon dark-mode-toggle" title="Toggle Dark Mode">
                                <i class="fas fa-moon"></i>
                                <i class="fas fa-sun"></i>
                            </div>
                            @if (User?.Identity?.IsAuthenticated == true)
                            {
                            <!-- Notification Dropdown -->
                           <!-- Notifications Dropdown -->
                <div class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle position-relative" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-bell"></i>
                        @if (Model.UnreadNotifications > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                @Model.UnreadNotifications
                            </span>
                        }
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end" style="width: 350px;">
                        <li><h6 class="dropdown-header">Notifications</h6></li>
                        @if (Model.RecentNotifications.Any())
                        {
                            @foreach (var notification in Model.RecentNotifications)
                            {
                                <li>
                                    <a class="dropdown-item @(notification.IsRead ? "" : "fw-bold")" 
                                       href="@GetNotificationUrl(notification)">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="flex-grow-1">
                                                <div class="fw-semibold">@notification.Title</div>
                                                @if (!string.IsNullOrEmpty(notification.Message))
                                                {
                                                    <small class="text-muted d-block">@notification.Message</small>
                                                }
                                                <small class="text-muted">@notification.CreatedAt.ToString("MMM dd, HH:mm")</small>
                                            </div>
                                            @if (!notification.IsRead)
                                            {
                                                <span class="badge bg-primary rounded-pill ms-2">New</span>
                                            }
                                        </div>
                                    </a>
                                </li>
                            }
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-center" href="/notifications">View All Notifications</a></li>
                        }
                        else
                        {
                            <li><span class="dropdown-item text-muted">No notifications</span></li>
                        }
                    </ul>
                </div>

                <!-- User Profile Dropdown -->
                <div class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" alt="Profile" class="rounded-circle me-2" width="32" height="32">
                        }
                        else
                        {
                            <div class="bg-secondary rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                <i class="bi bi-person text-white"></i>
                            </div>
                        }
                        <div class="d-flex flex-column align-items-start">
                            <span class="fw-semibold">
                                @Model.DisplayName
                                @if (Model.IsVerified)
                                {
                                    <i class="bi bi-patch-check-fill text-primary ms-1" title="Verified Account"></i>
                                }
                            </span>
                            <small class="text-muted">@Model.KarmaPoints karma</small>
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <div class="dropdown-item-text">
                                <strong>@Model.DisplayName</strong>
                                @if (Model.IsVerified)
                                {
                                    <i class="bi bi-patch-check-fill text-primary ms-1"></i>
                                }
                                <br>
                                <small class="text-muted">@Model.Email</small>
                                <br>
                                <small class="text-muted">@Model.KarmaPoints karma points</small>
                            </div>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                        <li><a class="dropdown-item" href="/profile/edit"><i class="bi bi-gear me-2"></i>Settings</a></li>
                        <li><a class="dropdown-item" href="/notifications"><i class="bi bi-bell me-2"></i>Notifications</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                                <button type="submit" class="dropdown-item">
                                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <a class="nav-link" href="/login">Login</a>
                <a class="nav-link" href="/register">Register</a>
            }
        </div>                       

                          
                        </div>
                    </div>
                </div>
            </nav>
        </div>
    </header>
