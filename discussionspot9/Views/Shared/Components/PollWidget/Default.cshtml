<!-- Views/Shared/Components/PollWidget/Default.cshtml -->
@model discussionspot9.Models.ViewModels.PollViewModels.PollViewModel

<div class="pd-poll-container" data-poll-id="@Model.PostId">
    <div class="pd-poll-badge mb-3">
        <i class="fas fa-poll me-2"></i>
        <span class="text-uppercase fw-semibold small">POLL</span>
        @if (!Model.HasUserVoted && !Model.IsExpired)
        {
            <span class="pd-status-indicator active ms-2"></span>
        }
    </div>

    <h5 class="pd-poll-question mb-4">@Model.Question</h5>

    <div class="pd-poll-options"
         data-poll-voted="@Model.HasUserVoted.ToString().ToLower()"
         data-poll-expired="@Model.IsExpired.ToString().ToLower()"
         data-allow-multiple="@Model.AllowMultipleChoices.ToString().ToLower()">

        @foreach (var option in Model.Options)
        {
            <div class="pd-poll-option @(Model.UserVotedOptionIds.Contains(option.PollOptionId) ? "selected" : "")"
                 data-option-id="@option.PollOptionId">
                <div class="pd-poll-checkbox @(Model.AllowMultipleChoices ? "checkbox" : "radio")">
                    @if (Model.UserVotedOptionIds.Contains(option.PollOptionId))
                    {
                        <i class="fas fa-check"></i>
                    }
                </div>
                <div class="pd-poll-option-content">
                    <span class="pd-poll-option-text">@option.OptionText</span>
                    @if (Model.HasUserVoted || Model.ShowResultsBeforeVoting)
                    {
                        <span class="pd-poll-percentage fw-semibold">@option.VotePercentage.ToString("0.0")%</span>
                    }
                </div>
                @if (Model.HasUserVoted || Model.ShowResultsBeforeVoting)
                {
                    <div class="pd-poll-progress" style="width: @option.VotePercentage%"></div>
                }
            </div>
        }
    </div>

    @if (!Model.HasUserVoted && !Model.IsExpired && User.Identity.IsAuthenticated)
    {
        <div class="text-center mt-4">
            <button class="btn btn-primary pd-vote-button pd-interactive"
                    data-poll-id="@Model.PostId"
                    disabled>
                Cast Your Vote
            </button>
        </div>
    }

    <div class="pd-poll-stats mt-4 pt-3 border-top">
        <div class="d-flex justify-content-between align-items-center">
            <div class="pd-poll-votes">
                <i class="fas fa-chart-bar me-2"></i>
                <span class="fw-semibold">@Model.TotalVotes votes</span>
            </div>
            @if (Model.EndDate.HasValue)
            {
                <div class="pd-poll-time text-muted">
                    <i class="fas fa-clock me-2"></i>
                    @if (Model.IsExpired)
                    {
                        <span>Poll ended</span>
                    }
                    else
                    {
                        <span>Ends @Model.EndDate.Value.ToString("MMM d, yyyy")</span>
                    }
                </div>
            }
        </div>
    </div>
</div>