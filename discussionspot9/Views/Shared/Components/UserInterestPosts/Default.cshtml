@model List<discussionspot9.Models.ViewModels.CreativeViewModels.UserInterestPostViewModel>

<div class="sidebar-card modern-interest-posts">
    <div class="sidebar-header">
        <i class="fas fa-star me-2"></i> 
        @if (User.Identity?.IsAuthenticated == true)
        {
            <span>Updates from Your Communities</span>
        }
        else
        {
            <span>Trending Posts</span>
        }
    </div>
    <div class="sidebar-content">
        @if (Model != null && Model.Any())
        {
            @foreach (var post in Model)
            {
                <div class="interest-post-item">
                    <div class="interest-post-header">
                        <a href="/r/@post.CommunitySlug/posts/@post.Slug" class="interest-post-title">
                            @post.Title
                        </a>
                    </div>
                    <div class="interest-post-meta">
                        <span class="community-badge">
                            <i class="fas fa-users"></i> r/@post.CommunityName
                        </span>
                        <div class="post-stats-mini">
                            <span class="upvotes">
                                <i class="fas fa-arrow-up"></i> @post.UpvoteCount
                            </span>
                            <span class="comments">
                                <i class="fas fa-comment"></i> @post.CommentCount
                            </span>
                        </div>
                        <span class="time-ago">
                            <i class="fas fa-clock"></i> @post.TimeAgo
                        </span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="no-posts-message">
                <i class="fas fa-inbox"></i>
                <p>No posts available. Join communities to see updates!</p>
            </div>
        }
    </div>
</div>

<style>
.modern-interest-posts {
    margin-bottom: 1.5rem;
}

.interest-post-item {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-color, #e0e0e0);
}

.interest-post-item:last-child {
    border-bottom: none;
}

.interest-post-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-color, #333);
    text-decoration: none;
    display: block;
    margin-bottom: 0.5rem;
    line-height: 1.3;
}

.interest-post-title:hover {
    color: var(--primary-color, #007bff);
}

.interest-post-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: var(--text-light, #666);
}

.community-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.125rem 0.375rem;
    background: var(--bg-light, #f8f9fa);
    border-radius: 3px;
    font-weight: 500;
    width: fit-content;
}

.post-stats-mini {
    display: flex;
    gap: 0.75rem;
}

.post-stats-mini span {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
}

.time-ago {
    color: var(--text-lighter, #999);
}

.no-posts-message {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--text-light, #666);
}

.no-posts-message i {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    opacity: 0.5;
}

.no-posts-message p {
    margin: 0;
    font-size: 0.875rem;
}
</style>

