        }
        else
        {
            <p class="text-success text-center small mb-3">
                <i class="fas fa-check-circle"></i> You have voted in this poll
            </p>
        }

        <div class="poll-options" id="pollOptions">
            @foreach (var option in Model.Options)
            {
                <div class="poll-option @(option.HasUserVoted.HasValue && option.HasUserVoted.Value ? "selected voted" : "")"
                     data-option-id="@option.PollOptionId">

                    @if (!Model.HasUserVoted)
