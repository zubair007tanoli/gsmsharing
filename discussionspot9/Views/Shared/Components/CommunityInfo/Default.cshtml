@using discussionspot9.Models.ViewModels.CreativeViewModels
@model CommunityViewModel

<div class="sidebar-card enhanced-about-panel">
    <div class="sidebar-header">
        <i class="fas fa-info-circle me-2"></i> About r/@Model.Name
    </div>
    <div class="sidebar-content">
        <p class="community-description">@Model.Description</p>

        <!-- Enhanced Stats Grid -->
        <div class="community-stats-enhanced">
            <div class="stat-card">
                <div class="stat-icon members">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-details">
                    <div class="stat-value">@Model.MemberCount.ToString("N0")</div>
                    <div class="stat-label">Members</div>
                    <div class="stat-trend">
                        <i class="fas fa-arrow-up text-success"></i>
                        <span class="small text-muted">+12.5% this month</span>
                    </div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon online">
                    <i class="fas fa-circle"></i>
                </div>
                <div class="stat-details">
                    <div class="stat-value">@Model.OnlineCount.ToString("N0")</div>
                    <div class="stat-label">Online Now</div>
                    <div class="stat-trend">
                        <span class="small text-muted">Peak: @(Model.OnlineCount * 2) today</span>
                    </div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon posts">
                    <i class="fas fa-comments"></i>
                </div>
                <div class="stat-details">
                    <div class="stat-value">@((Model.MemberCount / 10).ToString("N0"))</div>
                    <div class="stat-label">Total Posts</div>
                    <div class="stat-trend">
                        <span class="small text-muted">@((Model.MemberCount / 100).ToString("N0")) this week</span>
                    </div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon activity">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div class="stat-details">
                    <div class="stat-value">@((Model.MemberCount / 5).ToString("N0"))</div>
                    <div class="stat-label">Comments</div>
                    <div class="stat-trend">
                        <span class="small text-muted">Very active</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Info -->
        <div class="community-quick-info mt-3">
            <div class="info-item">
                <i class="fas fa-cake-candles text-primary"></i>
                <span>Created @Model.CreatedAt.ToString("MMMM yyyy")</span>
            </div>
            <div class="info-item">
                <i class="fas fa-shield-alt text-success"></i>
                <span>Moderated 24/7</span>
            </div>
            <div class="info-item">
                <i class="fas fa-star text-warning"></i>
                <span>Top 10% Community</span>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="community-buttons mt-3">
            <a href="/r/@Model.Slug" class="community-btn join-btn primary text-decoration-none">
                <i class="fas fa-users me-2"></i> View Community
            </a>
            <a href="/r/@Model.Slug/submit" class="community-btn create-post-btn secondary text-decoration-none">
                <i class="fas fa-pen me-2"></i> Create Post
            </a>
        </div>

        <!-- Top Contributors (New) -->
        <div class="top-contributors mt-4">
            <h6 class="section-title">
                <i class="fas fa-trophy me-2"></i>Top Contributors
            </h6>
            <div class="contributors-list">
                <div class="contributor-item">
                    <div class="contributor-avatar">JD</div>
                    <div class="contributor-info">
                        <div class="contributor-name">JohnDoe</div>
                        <div class="contributor-stats">
                            <i class="fas fa-fire text-danger"></i> 450 posts
                        </div>
                    </div>
                </div>
                <div class="contributor-item">
                    <div class="contributor-avatar">AS</div>
                    <div class="contributor-info">
                        <div class="contributor-name">AliceSmith</div>
                        <div class="contributor-stats">
                            <i class="fas fa-fire text-danger"></i> 380 posts
                        </div>
                    </div>
                </div>
                <div class="contributor-item">
                    <div class="contributor-avatar">BJ</div>
                    <div class="contributor-info">
                        <div class="contributor-name">BobJones</div>
                        <div class="contributor-stats">
                            <i class="fas fa-fire text-danger"></i> 325 posts
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>