<style>
    .user-stats-sidebar {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        padding: 1.5rem;
        color: white;
        margin-bottom: 1.5rem;
    }

    .user-stats-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .user-stats-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 700;
        border: 3px solid rgba(255, 255, 255, 0.3);
    }

    .user-stats-info h5 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 700;
    }

    .user-stats-level {
        background: rgba(255, 255, 255, 0.2);
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        margin-top: 0.25rem;
    }

    .karma-stats {
        background: rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .karma-current {
        font-size: 2rem;
        font-weight: 700;
        margin: 0.5rem 0;
    }

    .karma-progress {
        margin-top: 0.75rem;
    }

    .progress {
        height: 8px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 10px;
        overflow: hidden;
    }

    .progress-bar {
        background: rgba(255, 255, 255, 0.9);
        transition: width 0.6s ease;
    }

    .karma-next {
        font-size: 0.85rem;
        margin-top: 0.5rem;
        opacity: 0.9;
    }

    .activity-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .activity-stat {
        background: rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        padding: 0.75rem;
        text-align: center;
    }

    .activity-stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0.25rem 0;
    }

    .activity-stat-label {
        font-size: 0.85rem;
        opacity: 0.9;
    }

    .verified-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        background: rgba(255, 255, 255, 0.2);
        padding: 0.15rem 0.5rem;
        border-radius: 12px;
        font-size: 0.75rem;
        margin-left: 0.5rem;
    }
</style>

<div class="user-stats-sidebar">
    <div class="user-stats-header">
        <div class="user-stats-avatar">
            @Model.Initials
        </div>
        <div class="user-stats-info">
            <h5>
                @Model.DisplayName
                @if (Model.IsVerified)
                {
                    <span class="verified-badge">
                        <i class="fas fa-check-circle"></i>
                    </span>
                }
            </h5>
            <span class="user-stats-level">@Model.KarmaLevel</span>
        </div>
    </div>

    <div class="karma-stats">
        <div class="text-center">
            <div style="font-size: 0.9rem; opacity: 0.9;">Karma Points</div>
            <div class="karma-current">@Model.KarmaPoints.ToString("N0")</div>
        </div>

        <div class="karma-progress">
            <div class="progress">
                <div class="progress-bar" style="width: @Model.KarmaProgress%"></div>
            </div>
            <div class="karma-next">
                @Model.KarmaNeeded.ToString("N0") karma to @Model.KarmaLevelName
            </div>
        </div>
    </div>

    <div class="activity-stats">
        <div class="activity-stat">
            <div class="activity-stat-label">Posts</div>
            <div class="activity-stat-value">@Model.PostCount</div>
        </div>
        <div class="activity-stat">
            <div class="activity-stat-label">Comments</div>
            <div class="activity-stat-value">@Model.CommentCount</div>
        </div>
    </div>

    <div style="margin-top: 1rem; text-align: center;">
        <a href="/profile" class="btn btn-light btn-sm" style="width: 100%;">
            <i class="fas fa-user me-1"></i>View Profile
        </a>
    </div>
</div>

