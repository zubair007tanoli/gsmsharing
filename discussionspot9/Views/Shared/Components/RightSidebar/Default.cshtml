@using discussionspot9.Models.ViewModels.CreativeViewModels
<!-- Views/Shared/Components/RightSidebar/Default.cshtml -->
@model (CommunityDetailViewModel community, List<PostCardViewModel> relatedPosts)

<!-- Community Info -->
@if (Model.community != null)
{
    <div class="pd-sidebar-card mb-3">
        <div class="pd-sidebar-header">
            <i class="fas fa-info-circle me-2"></i> About @Model.community.Name
        </div>
        <div class="pd-sidebar-content">
            @if (!string.IsNullOrEmpty(Model.community.Description))
            {
                <p class="mb-3">@Model.community.Description</p>
            }

            <div class="pd-community-stats mb-3">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="text-center">
                            <div class="h5 mb-0">@Model.community.FormattedMemberCount</div>
                            <div class="text-muted small">Members</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-center">
                            <div class="h5 mb-0">@Model.community.FormattedPostCount</div>
                            <div class="text-muted small">Posts</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pd-community-buttons">
                @if (User.Identity.IsAuthenticated)
                {
                    <button class="btn btn-primary w-100 mb-2 pd-join-btn"
                            data-community-id="@Model.community.CommunityId"
                            data-is-member="@Model.community.IsCurrentUserMember.ToString().ToLower()">
                        @if (Model.community.IsCurrentUserMember)
                        {
                            <i class="fas fa-check me-2"></i>
                            <span>Joined</span>
                        }
                        else
                        {
                            <i class="fas fa-plus me-2"></i>
                            <span>Join</span>
                        }
                    </button>
                }
                <a href="/c/@Model.community.Slug/submit"
                   class="btn btn-outline-secondary w-100 text-decoration-none">
                    <i class="fas fa-pen me-2"></i>
                    Create Post
                </a>
            </div>

            <div class="text-muted small mt-3">
                Created @Model.community.CreatedTimeAgo
            </div>
        </div>
    </div>

    <!-- Community Rules -->
    @if (!string.IsNullOrEmpty(Model.community.Rules))
    {
        <div class="pd-sidebar-card mb-3">
            <div class="pd-sidebar-header">
                <i class="fas fa-gavel me-2"></i> Community Rules
            </div>
            <div class="pd-sidebar-content">
                <div class="pd-rules-content">
                    @Html.Raw(Model.community.Rules)
                </div>
            </div>
        </div>
    }

    <!-- Moderators -->
    @if (Model.community.Moderators?.Any() == true)
    {
        <div class="pd-sidebar-card mb-3">
            <div class="pd-sidebar-header">
                <i class="fas fa-shield-alt me-2"></i> Moderators
            </div>
            <div class="pd-sidebar-content">
                <div class="pd-moderator-list">
                    @foreach (var mod in Model.community.Moderators.Take(5))
                    {
                        <div class="d-flex align-items-center mb-2">
                            <div class="pd-user-avatar small me-2">
                                @if (!string.IsNullOrEmpty(mod.ProfilePictureUrl))
                                {
                                    <img src="@mod.ProfilePictureUrl" alt="@mod.DisplayName" />
                                }
                                else
                                {
                                    <span>@mod.DisplayName.Substring(0, 1).ToUpper()</span>
                                }
                            </div>
                            <a href="/u/@mod.Username" class="text-decoration-none">
                                u/@mod.Username
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

<!-- Related Posts -->
@if (Model.relatedPosts?.Any() == true)
{
    <div class="pd-sidebar-card">
        <div class="pd-sidebar-header">
            <i class="fas fa-link me-2"></i> Related Posts
        </div>
        <div class="pd-sidebar-content">
            <div class="pd-related-posts">
                @foreach (var post in Model.relatedPosts.Take(5))
                {
                    <div class="pd-related-post mb-3">
                        <a href="/c/@post.CommunitySlug/post/@post.Slug"
                           class="text-decoration-none">
                            <h6 class="mb-1">@post.Title</h6>
                        </a>
                        <div class="d-flex align-items-center gap-2 text-muted small">
                            <span><i class="fas fa-arrow-up"></i> @post.UpvoteCount</span>
                            <span><i class="fas fa-comment"></i> @post.CommentCount</span>
                            <span>@post.TimeAgo</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}