</style>

@inject discussionspot9.Services.LiveStatsService LiveStatsService
@{
    var liveStats = await LiveStatsService.GetLiveStatsAsync();
}

<!-- Live Bar -->
<div class="live-bar">
    <div class="container">
        <div class="live-bar-content">
            <div class="live-item">
                <span class="live-icon"><i class="fas fa-circle" style="font-size: 0.5rem;"></i></span>
                <span class="live-badge hot">LIVE</span>
                <span>🔥 <span id="online-count-dynamic">@liveStats.OnlineUsersCount</span> users online right now</span>
            </div>
            <div class="live-item">
                <i class="fas fa-fire"></i>
                <span>Trending: @liveStats.TrendingPost</span>
            </div>
            <div class="live-item">
                <i class="fas fa-bolt"></i>
                <span>New: @liveStats.PostsLastHour posts in the last hour</span>
            </div>
            <div class="live-item">
                <i class="fas fa-star"></i>
                <span>Hot Topic: @liveStats.HotTopic.Title - @liveStats.HotTopic.FormattedViewCount views</span>
            </div>
            <div class="live-item">
                <i class="fas fa-trophy"></i>
                <span>Top Contributor: @liveStats.TopContributor</span>
            </div>
            <!-- Duplicate items for seamless loop -->
            <div class="live-item">
                <span class="live-icon"><i class="fas fa-circle" style="font-size: 0.5rem;"></i></span>
                <span class="live-badge hot">LIVE</span>
                <span>🔥 <span id="online-count-dynamic-2">@liveStats.OnlineUsersCount</span> users online right now</span>
            </div>
            <div class="live-item">
                <i class="fas fa-fire"></i>
                <span>Trending: @liveStats.TrendingPost</span>
            </div>
            <div class="live-item">
                <i class="fas fa-bolt"></i>
                <span>New: @liveStats.PostsLastHour posts in the last hour</span>
            </div>
            <div class="live-item">
                <i class="fas fa-star"></i>
                <span>Hot Topic: @liveStats.HotTopic.Title - @liveStats.HotTopic.FormattedViewCount views</span>
            </div>
            <div class="live-item">
                <i class="fas fa-trophy"></i>
                <span>Top Contributor: @liveStats.TopContributor</span>
            </div>
        </div>
    </div>
</div>

<script>
// Auto-refresh online count every minute
(function() {
    function updateOnlineCount() {
        fetch('/api/stats/online-count')
            .then(response => response.json())
            .then(data => {
                if (data.count !== undefined) {
                    const count1 = document.getElementById('online-count-dynamic');
                    const count2 = document.getElementById('online-count-dynamic-2');
                    const count3 = document.getElementById('online-count');
                    
                    if (count1) count1.textContent = data.count;
                    if (count2) count2.textContent = data.count;
                    if (count3) count3.textContent = data.count.toLocaleString();
                }
            })
            .catch(err => console.log('Failed to fetch online count:', err));
    }
    
    // Update every minute
    setInterval(updateOnlineCount, 60000);
})();
</script>

