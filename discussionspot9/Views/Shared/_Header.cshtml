<style>
    /* Prevent horizontal scroll globally */
    html, body {
        overflow-x: hidden !important;
        max-width: 100vw !important;
        width: 100% !important;
        position: relative;
    }

    /* Prevent animations from affecting ad spaces */
    .ad-space, .ad-space *, 
    .sticky-ad-enhanced, .sticky-ad-enhanced *,
    .ad-content, .ad-content *,
    .adsbygoogle, .adsbygoogle * {
        animation: none !important;
        transform: none !important;
    }

    .ad-space::before, .ad-space::after,
    .sticky-ad-enhanced::before, .sticky-ad-enhanced::after {
        display: none !important;
    }

    /* Ensure announcement bar doesn't cause overflow */
    .announcement-bar-container,
    .announcement-bar,
    .announcement-content,
    .announcement-item {
        box-sizing: border-box !important;
    }

    .announcement-item::before,
    .announcement-item::after {
        content: none !important;
        display: none !important;
    }

    /* Live Bar Styles */
    .live-bar {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 0.6rem 0;
        overflow: hidden;
        position: relative;
        box-shadow: 0 2px 8px rgba(102, 126, 234, 0.2);
    }

    .live-bar-content {
        display: flex;
        align-items: center;
        gap: 2rem;
        animation: scroll-left 30s linear infinite;
    }

    .live-bar:hover .live-bar-content {
        animation-play-state: paused;
    }

    .live-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        white-space: nowrap;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .live-badge {
        background: rgba(255, 255, 255, 0.25);
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .live-badge.hot {
        background: #ff4500;
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes scroll-left {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
    }

    /* Modern Glassmorphism Navbar Design */
    .main-header {
        padding: 0.75rem 0 !important;
        background: rgba(255, 255, 255, 0.85) !important;
        backdrop-filter: blur(20px) !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2) !important;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1) !important;
        position: relative !important;
    }

    .main-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%) !important;
        border-radius: 0 0 20px 20px !important;
        pointer-events: none !important;
    }

    .main-header .navbar {
        padding: 0 !important;
        position: relative !important;
        z-index: 1 !important;
    }

    .main-header .navbar-nav .nav-link {
