@using discussionspot9.Models.Domain
@{
    var comments = ViewBag.Comments as List<Comment> ?? new List<Comment>();
}

@if (comments.Any())
{
    <div class="activity-feed">
        @foreach (var comment in comments)
        {
            <div class="activity-item">
                <div class="d-flex align-items-center gap-3">
                    <div class="activity-info flex-grow-1">
                        <div class="activity-title">
                            Comment on: <a href="/r/@comment.Post?.Community?.Slug/posts/@comment.Post?.Slug#comment-@comment.CommentId" class="text-decoration-none">
                                @comment.Post?.Title
                            </a>
                        </div>
                        <div class="activity-meta">
                            In r/@comment.Post?.Community?.Name • @GetTimeAgo(comment.CreatedAt)
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="activity-action">
                            <i class="fas fa-arrow-up text-primary"></i>
                            <span>@comment.UpvoteCount</span>
                        </div>
                        <div class="activity-action">
                            <i class="fas fa-arrow-down text-danger"></i>
                            <span>@comment.DownvoteCount</span>
                        </div>
                        <div class="activity-action">
                            <a href="/r/@comment.Post?.Community?.Slug/posts/@comment.Post?.Slug#comment-@comment.CommentId" class="text-decoration-none text-muted">
                                <i class="fas fa-external-link-alt"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>
        No comments to display.
    </div>
}
@functions {
    private string GetTimeAgo(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime.ToUniversalTime();

        if (timeSpan.TotalSeconds < 60)
            return "just now";
        else if (timeSpan.TotalSeconds < 3600)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        else if (timeSpan.TotalSeconds < 86400)
            return $"{(int)timeSpan.TotalHours}h ago";
        else
            return dateTime.ToString("MMM dd, yyyy");
    }
}
