@* Chat Widget - Bottom Left Collapsible *@
<link href="~/css/chat.css" rel="stylesheet" />

<!-- SignalR Library (required for chat) -->
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>

<!-- Google AdSense (for chat ads) -->
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-YOUR_PUBLISHER_ID"
     crossorigin="anonymous"></script>

<div id="chatWidget" class="chat-widget minimized">
    <!-- Chat Header -->
    <div class="chat-header" onclick="toggleChatWidget()">
        <div class="chat-header-left">
            <div class="chat-icon">
                <i class="fas fa-comments"></i>
            </div>
            <div class="chat-title-section">
                <h3 class="chat-title">Messages</h3>
                <span class="chat-subtitle" id="chatSubtitle">Click to open</span>
            </div>
        </div>
        <div class="chat-header-actions">
            <span class="chat-unread-badge" id="chatUnreadBadge" style="display: none;">0</span>
            <button class="chat-toggle-btn" onclick="event.stopPropagation(); toggleChatWidget()">
                <i class="fas fa-chevron-down" id="chatToggleIcon"></i>
            </button>
        </div>
    </div>

    <!-- Chat Content (Hidden when minimized) -->
    <div id="chatContent" class="chat-content" style="display: none;">
        <!-- Chat Tabs -->
        <div class="chat-tabs">
            <button class="chat-tab active" data-tab="direct" onclick="switchChatTab('direct')">
                <i class="fas fa-user me-1"></i> Direct
            </button>
            <button class="chat-tab" data-tab="users" onclick="switchChatTab('users')">
                <i class="fas fa-circle me-1" style="color: #46d160; font-size: 0.7rem;"></i> Online
            </button>
            <button class="chat-tab" data-tab="rooms" onclick="switchChatTab('rooms')">
                <i class="fas fa-users me-1"></i> Rooms
            </button>
        </div>

        <!-- Direct Messages List -->
        <div id="directChatList" class="chat-list">
            <div class="chat-empty-state">
                <div class="chat-empty-icon">
                    <i class="far fa-comment-dots"></i>
                </div>
                <div class="chat-empty-text">No messages yet.<br>Click on online members to start chatting!</div>
            </div>
        </div>

        <!-- Online Users List -->
        <div id="onlineUsersList" class="chat-list" style="display: none;">
            <div class="chat-empty-state" id="onlineUsersEmpty" style="display: none;">
                <div class="chat-empty-icon">
                    <i class="fas fa-user-slash"></i>
                </div>
                <div class="chat-empty-text">No users online right now.</div>
            </div>
            <div id="onlineUsersContent">
                <!-- Online users will be loaded here -->
            </div>
        </div>

        <!-- Rooms List -->
        <div id="roomsChatList" class="chat-list" style="display: none;">
            <div class="chat-list-header">
                <button class="chat-create-room-btn" onclick="openCreateRoomModal()" title="Create New Room">
                    <i class="fas fa-plus"></i> Create Room
                </button>
            </div>
            <div id="roomsListContent">
                <div class="chat-empty-state">
                    <div class="chat-empty-icon">
                        <i class="far fa-comments"></i>
                    </div>
                    <div class="chat-empty-text">No chat rooms yet.<br>Create one to start group conversations!</div>
                </div>
            </div>
        </div>

        <!-- Chat Window (When chatting with someone) -->
        <div id="chatWindow" class="chat-window">
            <div class="chat-window-header">
                <div class="chat-window-user">
                    <button class="chat-back-btn" onclick="closeChatWindow()">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <div class="chat-user-avatar" id="chatWindowAvatar">JD</div>
                    <div class="chat-window-user-info">
                        <div class="chat-window-user-name" id="chatWindowUserName">User Name</div>
                        <div class="chat-window-user-status online" id="chatWindowStatus">
                            <i class="fas fa-circle" style="font-size: 0.5rem;"></i> Online
                        </div>
                    </div>
                </div>
            </div>

            <div class="chat-messages" id="chatMessages">
                <!-- Messages will be dynamically loaded here -->
                <div class="chat-empty-messages" id="chatEmptyMessages" style="display: none; text-align: center; padding: 2rem; color: #7c7c7c;">
                    <i class="far fa-comment-dots" style="font-size: 2rem; opacity: 0.3; margin-bottom: 0.5rem;"></i>
                    <p style="margin: 0; font-size: 0.9rem;">No messages yet. Start the conversation!</p>
                </div>
            </div>

            <div class="chat-typing-indicator" id="chatTypingIndicator">
                <div class="typing-dots">
                    <span class="typing-dot"></span>
                    <span class="typing-dot"></span>
                    <span class="typing-dot"></span>
                </div>
                <span>typing...</span>
            </div>

            <div class="chat-input-area">
                <div class="chat-input-wrapper">
                    <button class="chat-emoji-btn" id="chatEmojiBtn" onclick="toggleEmojiPicker()" title="Add emoji">
                        <i class="far fa-smile"></i>
                    </button>
                    <input type="text" class="chat-input" id="chatInput" placeholder="Type a message..." autocomplete="off" />
                    <button class="chat-send-btn" id="chatSendBtn" onclick="sendChatMessage()">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
                <!-- Emoji Picker -->
                <div id="emojiPicker" class="emoji-picker" style="display: none;">
                    <div class="emoji-picker-header">
                        <span>Emojis</span>
                        <button class="emoji-picker-close" onclick="toggleEmojiPicker()">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="emoji-picker-content" id="emojiPickerContent">
                        <!-- Emojis will be populated here -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/chat/chat-service.js"></script>
<script src="~/js/chat/chat-controller.js"></script>
<script src="~/js/chat/chat-ui.js"></script>

<script>
    // Global chat variables
    let chatWidget = null;
    let chatController = null;
    let isMinimized = true;

    // Initialize chat when DOM is ready
    document.addEventListener('DOMContentLoaded', async function() {
        chatWidget = document.getElementById('chatWidget');
        
        // Initialize chat controller
        if (typeof ChatController !== 'undefined') {
            chatController = new ChatController();
            window.chatController = chatController; // Expose globally
            
            // Initialize the chat system
            await chatController.initialize();
            
            // Set current user ID if available
            @if (User.Identity.IsAuthenticated)
            {
                <text>
                window.currentUserId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';
                </text>
            }
            
            console.log('✅ Chat widget initialized');
        } else {
            console.error('❌ ChatController not found');
        }
    });

    // Toggle chat widget
    function toggleChatWidget() {
        isMinimized = !isMinimized;
        const widget = document.getElementById('chatWidget');
        const content = document.getElementById('chatContent');
        const icon = document.getElementById('chatToggleIcon');
        const subtitle = document.getElementById('chatSubtitle');

        if (isMinimized) {
            widget.classList.add('minimized');
            content.style.display = 'none';
            icon.className = 'fas fa-chevron-down';
            subtitle.textContent = 'Click to open';
        } else {
            widget.classList.remove('minimized');
            content.style.display = 'flex';
            icon.className = 'fas fa-chevron-up';
            subtitle.textContent = 'Online now';
            
            // Re-initialize ChatUI to find container after widget is expanded
            if (chatController && chatController.chatUI) {
                chatController.chatUI.initialize();
            }
        }
    }

    // Switch between tabs
    function switchChatTab(tabName) {
        // Update active tab
        document.querySelectorAll('.chat-tab').forEach(tab => {
            tab.classList.remove('active');
        });
        document.querySelector(`.chat-tab[data-tab="${tabName}"]`).classList.add('active');

        // Show appropriate content
        document.getElementById('directChatList').style.display = tabName === 'direct' ? 'block' : 'none';
        document.getElementById('onlineUsersList').style.display = tabName === 'users' ? 'block' : 'none';
        document.getElementById('roomsChatList').style.display = tabName === 'rooms' ? 'block' : 'none';
        
        // Load online users when tab is switched to 'users'
        if (tabName === 'users' && chatController) {
            chatController.loadOnlineUsers();
        }
    }

    // Open chat window with specific user
    async function openChatWindow(userId, userName, avatar) {
        console.log('🔵 openChatWindow called:', { userId, userName, avatar });
        
        // Hide lists and show chat window
        document.getElementById('directChatList').style.display = 'none';
        document.getElementById('onlineUsersList').style.display = 'none';
        document.getElementById('roomsChatList').style.display = 'none';
        
        const chatWindow = document.getElementById('chatWindow');
        chatWindow.classList.add('active');
        console.log('✅ Chat window activated:', chatWindow.classList.contains('active'));
        
        // Update window header
        document.getElementById('chatWindowUserName').textContent = userName;
        const avatarEl = document.getElementById('chatWindowAvatar');
        avatarEl.textContent = avatar || userName.substring(0, 2).toUpperCase();
        avatarEl.style.background = getColorFromName(userName);
        document.getElementById('chatWindowStatus').innerHTML = '<i class="fas fa-circle" style="font-size: 0.5rem;"></i> Online';
        
        // Store current user ID (clear room ID)
        window.currentChatUserId = userId;
        window.currentChatRoomId = null;
        
        console.log('📝 Set currentChatUserId:', window.currentChatUserId);
        console.log('📝 Current user ID (self):', window.currentUserId);
        
        // Ensure ChatUI is initialized with widget container
        if (chatController && chatController.chatUI) {
            // Force re-initialize to find widget container
            chatController.chatUI.messagesContainer = document.getElementById('chatMessages');
            
            if (!chatController.chatUI.messagesContainer) {
                console.error('❌ ChatUI: Cannot find chatMessages container');
            } else {
                console.log('✅ ChatUI: Found chatMessages container:', chatController.chatUI.messagesContainer);
            }
        }
        
        // Load chat history
        if (chatController) {
            console.log('📜 Loading chat history for user:', userId);
            console.log('📜 SignalR connected:', chatController.chatService?.isConnected);
            
            try {
                await chatController.loadChatHistory(userId);
                console.log('✅ Chat history loaded');
            } catch (error) {
                console.error('❌ Error loading chat history:', error);
            }
            
            // Scroll to bottom after loading
            setTimeout(() => {
                const messagesContainer = document.getElementById('chatMessages');
                if (messagesContainer) {
                    messagesContainer.scrollTop = messagesContainer.scrollHeight;
                    console.log('✅ Scrolled to bottom, messages count:', messagesContainer.children.length);
                    console.log('📝 Messages container innerHTML length:', messagesContainer.innerHTML.length);
                } else {
                    console.error('❌ Cannot scroll - messages container not found');
                }
            }, 300);
        } else {
            console.error('❌ ChatController not initialized');
        }
    }

    // Open room chat window (unified with direct messages)
    async function openRoomChatWindow(roomId, roomName, roomIcon) {
        // Hide lists and show chat window
        document.getElementById('directChatList').style.display = 'none';
        document.getElementById('onlineUsersList').style.display = 'none';
        document.getElementById('roomsChatList').style.display = 'none';
        document.getElementById('chatWindow').classList.add('active');
        
        // Update window header
        document.getElementById('chatWindowUserName').textContent = roomName || 'Room';
        const avatarEl = document.getElementById('chatWindowAvatar');
        avatarEl.textContent = roomIcon || roomName?.substring(0, 2).toUpperCase() || 'R';
        avatarEl.style.background = getColorFromName(roomName || 'Room');
        document.getElementById('chatWindowStatus').innerHTML = '<i class="fas fa-users" style="font-size: 0.7rem;"></i> Room';
        
        // Store current room ID (clear user ID)
        window.currentChatRoomId = roomId;
        window.currentChatUserId = null;
        
        // Ensure ChatUI is initialized with widget container
        if (chatController && chatController.chatUI) {
            chatController.chatUI.messagesContainer = null;
            chatController.chatUI.initialize();
            
            if (!chatController.chatUI.messagesContainer) {
                console.error('❌ ChatUI: Still cannot find chatMessages container');
            } else {
                console.log('✅ ChatUI: Found chatMessages container in widget');
            }
        }
        
        // Load room chat history
        if (chatController) {
            console.log('📜 Loading room chat history for room:', roomId);
            await chatController.loadRoomHistory(roomId);
            
            // Scroll to bottom after loading
            setTimeout(() => {
                const messagesContainer = document.getElementById('chatMessages');
                if (messagesContainer) {
                    messagesContainer.scrollTop = messagesContainer.scrollHeight;
                    console.log('✅ Scrolled to bottom, messages count:', messagesContainer.children.length);
                } else {
                    console.error('❌ Cannot scroll - messages container not found');
                }
            }, 200);
        } else {
            console.error('❌ ChatController not initialized');
        }
    }

    // Close chat window
    function closeChatWindow() {
        document.getElementById('chatWindow').classList.remove('active');
        
        // Clear current chat
        window.currentChatUserId = null;
        window.currentChatRoomId = null;
        
        // Show the active tab list
        const activeTab = document.querySelector('.chat-tab.active')?.getAttribute('data-tab') || 'direct';
        switchChatTab(activeTab);
    }

    // Send message
    async function sendChatMessage() {
        const input = document.getElementById('chatInput');
        if (!input) {
            console.warn('⚠️ Chat input not found');
            return;
        }
        
        const message = input.value.trim();
        
        if (!message) {
            // Silently return - no need to log empty messages
            return;
        }
        
        console.log('📤 sendChatMessage called:', {
            messageLength: message.length,
            currentChatUserId: window.currentChatUserId,
            currentChatRoomId: window.currentChatRoomId,
            currentUserId: window.currentUserId,
            chatControllerExists: !!chatController,
            isConnected: chatController?.chatService?.isConnected
        });
        
        if (!chatController) {
            console.error('❌ ChatController not initialized');
            alert('Chat system not ready. Please wait a moment and try again.');
            return;
        }
        
        if (!chatController.chatService?.isConnected) {
            console.error('❌ SignalR not connected');
            alert('Not connected to chat server. Please refresh the page.');
            return;
        }
        
        if (!window.currentChatUserId && !window.currentChatRoomId) {
            console.error('❌ No chat recipient selected');
            alert('Please select a user or room to chat with.');
            return;
        }
        
        try {
            console.log('📤 Calling chatController.sendMessage...');
            await chatController.sendMessage(message);
            input.value = '';
            console.log('✅ Message sent successfully');
            
            // Scroll to bottom after sending
            setTimeout(() => {
                const messagesContainer = document.getElementById('chatMessages');
                if (messagesContainer) {
                    messagesContainer.scrollTop = messagesContainer.scrollHeight;
                    console.log('✅ Scrolled to bottom after sending');
                }
            }, 100);
        } catch (error) {
            console.error('❌ Error sending message:', error);
            alert('Failed to send message: ' + (error.message || 'Unknown error'));
        }
    }

    // Handle input typing for typing indicator
    document.addEventListener('DOMContentLoaded', function() {
        const input = document.getElementById('chatInput');
        if (input) {
            input.addEventListener('input', function() {
                if (chatController && window.currentChatUserId) {
                    chatController.handleTyping();
                }
            });
        }
    });

    // Enter key to send
    document.addEventListener('DOMContentLoaded', function() {
        const input = document.getElementById('chatInput');
        if (input) {
            input.addEventListener('keypress', function(e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendChatMessage();
                }
            });
        }
    });

    // Helper function - Get color from name (deterministic)
    function getColorFromName(name) {
        const colors = ['#0079d3', '#ff4500', '#46d160', '#ffa500', '#7c7c7c', '#0056b3', '#8b5cf6', '#ec4899'];
        let hash = 0;
        for (let i = 0; i < name.length; i++) {
            hash = name.charCodeAt(i) + ((hash << 5) - hash);
        }
        return colors[Math.abs(hash) % colors.length];
    }
    
    // Alias for backwards compatibility
    function getRandomColor() {
        return getColorFromName(Math.random().toString());
    }
    
    // Helper function - Get initials from name
    function getInitials(name) {
        if (!name) return 'U';
        const parts = name.split(' ').filter(p => p.length > 0);
        if (parts.length >= 2) {
            return (parts[0][0] + parts[1][0]).toUpperCase();
        }
        return name.substring(0, Math.min(2, name.length)).toUpperCase();
    }

    // Emoji picker functionality
    const commonEmojis = ['😀', '😃', '😄', '😁', '😆', '😅', '😂', '🤣', '😊', '😇', 
                          '🙂', '🙃', '😉', '😌', '😍', '🥰', '😘', '😗', '😙', '😚',
                          '😋', '😛', '😝', '😜', '🤪', '🤨', '🧐', '🤓', '😎', '🤩',
                          '🥳', '😏', '😒', '😞', '😔', '😟', '😕', '🙁', '☹️', '😣',
                          '😖', '😫', '😩', '🥺', '😢', '😭', '😤', '😠', '😡', '🤬',
                          '❤️', '🧡', '💛', '💚', '💙', '💜', '🖤', '🤍', '🤎', '💔',
                          '👍', '👎', '👌', '✌️', '🤞', '🤟', '🤘', '👏', '🙌', '👐',
                          '🔥', '💯', '⭐', '🌟', '✨', '💫', '🎉', '🎊', '🎈', '🎁'];

    function toggleEmojiPicker() {
        const picker = document.getElementById('emojiPicker');
        const content = document.getElementById('emojiPickerContent');
        
        if (picker.style.display === 'none') {
            picker.style.display = 'block';
            
            // Populate emojis if not already done
            if (content.children.length === 0) {
                commonEmojis.forEach(emoji => {
                    const emojiBtn = document.createElement('button');
                    emojiBtn.className = 'emoji-item';
                    emojiBtn.textContent = emoji;
                    emojiBtn.onclick = () => insertEmoji(emoji);
                    content.appendChild(emojiBtn);
                });
            }
        } else {
            picker.style.display = 'none';
        }
    }

    function insertEmoji(emoji) {
        const input = document.getElementById('chatInput');
        if (input) {
            const cursorPos = input.selectionStart || input.value.length;
            const textBefore = input.value.substring(0, cursorPos);
            const textAfter = input.value.substring(cursorPos);
            input.value = textBefore + emoji + textAfter;
            input.focus();
            input.setSelectionRange(cursorPos + emoji.length, cursorPos + emoji.length);
        }
    }

    // Close emoji picker when clicking outside
    document.addEventListener('click', function(event) {
        const picker = document.getElementById('emojiPicker');
        const emojiBtn = document.getElementById('chatEmojiBtn');
        if (picker && picker.style.display === 'block' && 
            !picker.contains(event.target) && 
            event.target !== emojiBtn && 
            !emojiBtn.contains(event.target)) {
            picker.style.display = 'none';
        }
    });

    // Global function to open chat from anywhere (e.g., online members)
    window.openChat = function(userId, displayName) {
        // Expand widget if minimized
        if (isMinimized) {
            toggleChatWidget();
        }
        
        // Switch to direct messages tab
        switchChatTab('direct');
        
        // Get initials
        const initials = displayName.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
        
        // Open chat window
        openChatWindow(userId, displayName, initials);
    };

    // Note: openChatRoomWindow is defined above as openRoomChatWindow - use that instead
    // This is an alias for backwards compatibility
    window.openChatRoomWindow = openRoomChatWindow;

    // Open create room modal
    function openCreateRoomModal() {
        const modal = document.getElementById('createRoomModal');
        if (modal) {
            modal.style.display = 'flex';
        }
    }

    // Close create room modal
    function closeCreateRoomModal() {
        const modal = document.getElementById('createRoomModal');
        if (modal) {
            modal.style.display = 'none';
            document.getElementById('createRoomForm').reset();
        }
    }

    // Create chat room form handler
    async function createChatRoom(event) {
        event.preventDefault();
        
        const form = event.target;
        const name = form.name.value.trim();
        const description = form.description.value.trim();
        const isPublic = form.isPublic.checked;
        
        if (!name) {
            alert('Please enter a room name');
            return;
        }
        
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalText = submitBtn.textContent;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Creating...';
        
        try {
            if (chatController) {
                const result = await chatController.createChatRoom(name, description || null, isPublic);
                
                if (result.success) {
                    closeCreateRoomModal();
                } else {
                    alert(result.message || 'Failed to create room');
                }
            } else {
                alert('Chat system not initialized');
            }
        } catch (error) {
            console.error('Error creating room:', error);
            alert('An error occurred while creating the room');
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
        }
    }
</script>

<!-- Create Room Modal -->
<div id="createRoomModal" class="chat-modal" style="display: none;">
    <div class="chat-modal-content">
        <div class="chat-modal-header">
            <h3>Create New Chat Room</h3>
            <button class="chat-modal-close" onclick="closeCreateRoomModal()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <form id="createRoomForm" onsubmit="createChatRoom(event)">
            <div class="chat-modal-body">
                <div class="chat-form-group">
                    <label for="roomName">Room Name *</label>
                    <input type="text" id="roomName" name="name" required maxlength="100" placeholder="Enter room name" />
                </div>
                <div class="chat-form-group">
                    <label for="roomDescription">Description (optional)</label>
                    <textarea id="roomDescription" name="description" rows="3" maxlength="500" placeholder="Describe what this room is about"></textarea>
                </div>
                <div class="chat-form-group">
                    <label class="chat-checkbox-label">
                        <input type="checkbox" id="roomIsPublic" name="isPublic" checked />
                        <span>Public Room (others can discover and join)</span>
                    </label>
                </div>
            </div>
            <div class="chat-modal-footer">
                <button type="button" class="chat-btn-secondary" onclick="closeCreateRoomModal()">Cancel</button>
                <button type="submit" class="chat-btn-primary">Create Room</button>
            </div>
        </form>
    </div>
</div>

