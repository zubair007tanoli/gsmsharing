@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Admin Dashboard</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
    <!-- Custom Styles -->
    <link href="~/css/admin-dashboard.css" rel="stylesheet" />
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body data-theme="light">
    
    <!-- Admin Navbar (Compact) -->
    <nav class="admin-navbar">
        <div class="container-fluid">
            <div class="admin-nav-content">
                <div class="admin-nav-left">
                    <button class="sidebar-toggle" id="sidebarToggle">
                        <i class="fas fa-bars"></i>
                    </button>
                    <a href="/admin/dashboard" class="admin-logo">
                        <i class="fas fa-shield-alt"></i>
                        <span>Admin Dashboard</span>
                    </a>
                </div>
                
                <div class="admin-nav-right">
                    <div class="admin-search">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Search admin..." id="adminSearch">
                    </div>
                    
                    <div class="dropdown">
                        <button class="admin-user-btn" data-bs-toggle="dropdown">
                            <i class="fas fa-user-shield"></i>
                            <span class="d-none d-md-inline">@User.Identity.Name</span>
                            <i class="fas fa-chevron-down ms-2"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/"><i class="fas fa-home me-2"></i>Back to Site</a></li>
                            <li><a class="dropdown-item" href="/profile"><i class="fas fa-user me-2"></i>My Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item">
                                        <i class="fas fa-sign-out-alt me-2"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>
    
    <div class="admin-container">
        <!-- Left Sidebar -->
        <aside class="admin-sidebar" id="adminSidebar">
            @await Component.InvokeAsync("AdminSidebar")
        </aside>
        
        <!-- Main Content -->
        <main class="admin-main">
            <!-- Breadcrumb -->
            @if (ViewData["Breadcrumb"] != null)
            {
                <nav aria-label="breadcrumb" class="admin-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/admin/dashboard"><i class="fas fa-home"></i> Dashboard</a></li>
                        @Html.Raw(ViewData["Breadcrumb"])
                    </ol>
                </nav>
            }
            
            <!-- Page Title -->
            @if (ViewData["PageTitle"] != null)
            {
                <div class="admin-page-header">
                    <h1>@ViewData["PageTitle"]</h1>
                    @if (ViewData["PageDescription"] != null)
                    {
                        <p class="text-muted">@ViewData["PageDescription"]</p>
                    }
                </div>
            }
            
            <!-- Main Content Area -->
            <div class="admin-content">
                @RenderBody()
            </div>
            
            <!-- Footer -->
            <footer class="admin-footer">
                <div class="container-fluid">
                    <p class="mb-0 text-muted">© @DateTime.Now.Year DiscussionSpot. Admin Dashboard v1.0</p>
                </div>
            </footer>
        </main>
    </div>
    
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin-dashboard.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

