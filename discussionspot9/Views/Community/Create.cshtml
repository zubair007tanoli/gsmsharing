
@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    /* Scoped styles for community creator to prevent conflicts */
    .community-creator-container * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .community-creator-container {
        font-family: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background-color: #DAE0E6;
        color: #1c1c1c;
        line-height: 1.4;
        font-size: 14px;
        min-height: 100vh;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* Dark mode compatibility */
    body.dark-mode .community-creator-container {
        background-color: #111827;
        color: #f9fafb;
    }

    /* Reddit-like Header */
    .community-creator-container .reddit-header {
        background: #fff;
        border-bottom: 1px solid #ccc;
        padding: 0;
        position: sticky;
        top: 0;
        z-index: 100;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode .community-creator-container .reddit-header {
        background: #111827;
        border-bottom-color: #374151;
    }

    .community-creator-container .header-content {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        padding: 0 20px;
        height: 48px;
    }

    .community-creator-container .reddit-logo {
        font-size: 20px;
        font-weight: bold;
        color: #FF4500;
        text-decoration: none;
        margin-right: 20px;
    }

    .community-creator-container .header-nav {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-left: auto;
    }

    .community-creator-container .header-btn {
        padding: 4px 16px;
        border: 1px solid #0079D3;
        background: transparent;
        color: #0079D3;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
    }

    body.dark-mode .community-creator-container .header-btn {
        border-color: #818cf8;
        color: #818cf8;
    }

    .community-creator-container .header-btn.primary {
        background: #0079D3;
        color: white;
    }

    body.dark-mode .community-creator-container .header-btn.primary {
        background: #818cf8;
        border-color: #818cf8;
    }

    /* Main Layout */
    .community-creator-container .container-fluid.main-container {
        max-width: none;
        padding: 0 15px;
        margin: 20px auto;
        display: grid;
        grid-template-columns: 312px 1fr 312px;
        gap: 20px;
        padding: 0 20px;
    }

    /* Left Sidebar */
    .community-creator-container .left-sidebar {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .community-creator-container .sidebar-card {
        background: #fff;
        border: 1px solid #ccc;
        border-radius: 4px;
        overflow: hidden;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode .community-creator-container .sidebar-card {
        background: #1f2937;
        border-color: #4b5563;
    }

    .community-creator-container .sidebar-header {
        background: #f6f7f8;
        padding: 12px 16px;
        border-bottom: 1px solid #edeff1;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: #7c7c7c;
        letter-spacing: 0.5px;
        transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
    }

    body.dark-mode .community-creator-container .sidebar-header {
        background: rgba(0, 0, 0, 0.2);
        border-bottom-color: #4b5563;
        color: #d1d5db;
    }

    .community-creator-container .sidebar-content {
        padding: 16px;
    }

    /* Main Content */
    .community-creator-container .main-content {
        background: white;
        border: 1px solid #ccc;
        border-radius: 4px;
        overflow: hidden;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode .community-creator-container .main-content {
        background: #1f2937;
        border-color: #4b5563;
    }

    .community-creator-container .community-header {
        background: #f6f7f8;
        padding: 16px 20px;
        border-bottom: 1px solid #edeff1;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode .community-creator-container .community-header {
        background: rgba(0, 0, 0, 0.2);
        border-bottom-color: #4b5563;
    }

    .community-creator-container .community-title {
        font-size: 18px;
        font-weight: 500;
        margin: 0;
        color: #1c1c1c;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .community-title {
        color: #f9fafb;
    }

    .community-creator-container .breadcrumb {
        font-size: 12px;
        color: #7c7c7c;
        margin-top: 4px;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .breadcrumb {
        color: #d1d5db;
    }

    .community-creator-container .breadcrumb a {
        color: #0079D3;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .breadcrumb a {
        color: #818cf8;
    }

    /* Form Content */
    .community-creator-container .form-container {
        padding: 20px;
    }

    .community-creator-container .form-group {
        margin-bottom: 16px;
    }

    .community-creator-container .form-label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: #1c1c1c;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .form-label {
        color: #f9fafb;
    }

    .community-creator-container .form-input,
    .community-creator-container .form-textarea,
    .community-creator-container .form-select {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #edeff1;
        border-radius: 4px;
        font-size: 14px;
        font-family: inherit;
        background: white;
        transition: all 0.3s ease;
    }

    body.dark-mode .community-creator-container .form-input,
    body.dark-mode .community-creator-container .form-textarea,
    body.dark-mode .community-creator-container .form-select {
        background: #374151;
        border-color: #4b5563;
        color: #f9fafb;
    }

    .community-creator-container .form-input:focus,
    .community-creator-container .form-textarea:focus,
    .community-creator-container .form-select:focus {
        outline: none;
        border-color: #0079D3;
    }

    body.dark-mode .community-creator-container .form-input:focus,
    body.dark-mode .community-creator-container .form-textarea:focus,
    body.dark-mode .community-creator-container .form-select:focus {
        border-color: #818cf8;
        box-shadow: 0 0 0 0.25rem rgba(129, 140, 248, 0.25);
    }

    .community-creator-container .form-textarea {
        min-height: 100px;
        resize: vertical;
    }

    .community-creator-container .char-count {
        font-size: 12px;
        color: #7c7c7c;
        text-align: right;
        margin-top: 4px;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .char-count {
        color: #d1d5db;
    }

    /* Form Row */
    .community-creator-container .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    /* File Upload */
    .community-creator-container .upload-area {
        border: 2px dashed #edeff1;
        border-radius: 4px;
        padding: 40px 20px;
        text-align: center;
        background: #f6f7f8;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    body.dark-mode .community-creator-container .upload-area {
        border-color: #4b5563;
        background: #374151;
    }

    .community-creator-container .upload-area:hover,
    .community-creator-container .upload-area.dragover {
        border-color: #0079D3;
        background: rgba(0, 121, 211, 0.05);
    }

    body.dark-mode .community-creator-container .upload-area:hover,
    body.dark-mode .community-creator-container .upload-area.dragover {
        border-color: #818cf8;
        background: rgba(129, 140, 248, 0.1);
    }

    .community-creator-container .upload-icon {
        font-size: 48px;
        color: #7c7c7c;
        margin-bottom: 12px;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .upload-icon {
        color: #d1d5db;
    }

    .community-creator-container .upload-text {
        font-size: 16px;
        color: #1c1c1c;
        margin-bottom: 4px;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .upload-text {
        color: #f9fafb;
    }

    .community-creator-container .upload-subtext {
        font-size: 12px;
        color: #7c7c7c;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .upload-subtext {
        color: #d1d5db;
    }

    /* Toggle Switch Styles */
    .community-creator-container .toggle-switch {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 24px;
    }

        .community-creator-container .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .community-creator-container .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: .4s;
        border-radius: 24px;
    }

    body.dark-mode .community-creator-container .toggle-slider {
        background-color: #4b5563;
    }

    .community-creator-container .toggle-slider:before {
        position: absolute;
        content: "";
        height: 18px;
        width: 18px;
        left: 3px;
        bottom: 3px;
        background-color: white;
        transition: .4s;
        border-radius: 50%;
    }

    .community-creator-container .toggle-switch input:checked + .toggle-slider {
        background-color: #0079D3;
    }

    body.dark-mode .community-creator-container .toggle-switch input:checked + .toggle-slider {
        background-color: #818cf8;
    }

    .community-creator-container .toggle-switch input:checked + .toggle-slider:before {
        transform: translateX(20px);
    }

    /* Community Options */
    .community-creator-container .community-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid #edeff1;
        transition: border-color 0.3s ease;
    }

    body.dark-mode .community-creator-container .community-options {
        border-top-color: #4b5563;
    }

    .community-creator-container .option-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        color: #1c1c1c;
        padding: 12px 16px;
        background: #f9f9f9;
        border: 1px solid #edeff1;
        border-radius: 6px;
        transition: all 0.2s ease;
    }

    body.dark-mode .community-creator-container .option-toggle {
        color: #f9fafb;
        background: #374151;
        border-color: #4b5563;
    }

    .community-creator-container .option-toggle:hover {
        background: #f0f0f0;
        border-color: #0079D3;
    }

    body.dark-mode .community-creator-container .option-toggle:hover {
        background: #4b5563;
        border-color: #818cf8;
    }

    .community-creator-container .option-toggle span {
        user-select: none;
        flex: 1;
    }

    /* Action Buttons */
    .community-creator-container .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        padding: 16px 20px;
        background: #f6f7f8;
        border-top: 1px solid #edeff1;
        transition: all 0.3s ease;
    }

    body.dark-mode .community-creator-container .form-actions {
        background: rgba(0, 0, 0, 0.2);
        border-top-color: #4b5563;
    }

    .community-creator-container .btn {
        padding: 8px 16px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s ease;
        border: none;
    }

    .community-creator-container .btn-primary {
        background: #0079D3;
        color: white;
    }

    body.dark-mode .community-creator-container .btn-primary {
        background: #818cf8;
    }

    .community-creator-container .btn-primary:hover {
        background: #0066b3;
    }

    body.dark-mode .community-creator-container .btn-primary:hover {
        background: #a5b4fc;
    }

    .community-creator-container .btn-secondary {
        background: transparent;
        color: #0079D3;
        border: 1px solid #0079D3;
    }

    body.dark-mode .community-creator-container .btn-secondary {
        color: #818cf8;
        border-color: #818cf8;
    }

    .community-creator-container .btn-secondary:hover {
        background: #0079D3;
        color: white;
    }

    body.dark-mode .community-creator-container .btn-secondary:hover {
        background: #818cf8;
        color: white;
    }

    .community-creator-container .btn-ghost {
        background: transparent;
        color: #7c7c7c;
        border: 1px solid #edeff1;
    }

    body.dark-mode .community-creator-container .btn-ghost {
        color: #d1d5db;
        border-color: #4b5563;
    }

    .community-creator-container .btn-ghost:hover {
        background: #f6f7f8;
        color: #1c1c1c;
    }

    body.dark-mode .community-creator-container .btn-ghost:hover {
        background: #374151;
        color: #f9fafb;
    }

    /* Right Sidebar */
    .community-creator-container .right-sidebar {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .community-creator-container .tips-list {
        list-style: none;
    }

        .community-creator-container .tips-list li {
            padding: 10px 0;
            font-size: 13px;
            color: #7c7c7c;
            display: flex;
            align-items: flex-start;
            gap: 8px;
            line-height: 1.4;
            transition: color 0.3s ease;
        }

    body.dark-mode .community-creator-container .tips-list li {
        color: #d1d5db;
    }

    .community-creator-container .tips-list i {
        color: #46D160;
        margin-top: 2px;
        font-size: 10px;
    }

    /* Community Preview */
    .community-creator-container .community-preview {
        background: #f9f9f9;
        border: 1px solid #edeff1;
        border-radius: 4px;
        padding: 16px;
        margin-top: 16px;
        transition: all 0.3s ease;
    }

    body.dark-mode .community-creator-container .community-preview {
        background: #374151;
        border-color: #4b5563;
    }

    .community-creator-container .community-preview h3 {
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 12px;
        color: #1c1c1c;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .community-preview h3 {
        color: #f9fafb;
    }

    .community-creator-container .preview-community {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        background: white;
        border: 1px solid #edeff1;
        border-radius: 4px;
        transition: all 0.3s ease;
    }

    body.dark-mode .community-creator-container .preview-community {
        background: #1f2937;
        border-color: #4b5563;
    }

    .community-creator-container .preview-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #0079D3;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: bold;
        flex-shrink: 0;
    }

    body.dark-mode .community-creator-container .preview-icon {
        background: #818cf8;
    }

    .community-creator-container .preview-info h4 {
        font-size: 16px;
        font-weight: 600;
        margin: 0 0 4px 0;
        color: #1c1c1c;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .preview-info h4 {
        color: #f9fafb;
    }

    .community-creator-container .preview-info p {
        font-size: 12px;
        color: #7c7c7c;
        margin: 0;
        line-height: 1.3;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .preview-info p {
        color: #d1d5db;
    }

    /* Rules Editor */
    .community-creator-container .rules-editor {
        border: 1px solid #edeff1;
        border-radius: 4px;
        background: white;
        transition: all 0.3s ease;
    }

    body.dark-mode .community-creator-container .rules-editor {
        border-color: #4b5563;
        background: #374151;
    }

    .community-creator-container .rules-toolbar {
        padding: 8px 12px;
        border-bottom: 1px solid #edeff1;
        background: #f6f7f8;
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
        transition: all 0.3s ease;
    }

    body.dark-mode .community-creator-container .rules-toolbar {
        border-bottom-color: #4b5563;
        background: rgba(0, 0, 0, 0.2);
    }

    .community-creator-container .rules-btn {
        padding: 6px 8px;
        border: none;
        background: transparent;
        color: #7c7c7c;
        cursor: pointer;
        border-radius: 2px;
        font-size: 14px;
        transition: all 0.2s ease;
    }

    body.dark-mode .community-creator-container .rules-btn {
        color: #d1d5db;
    }

    .community-creator-container .rules-btn:hover {
        background: #edeff1;
        color: #1c1c1c;
    }

    body.dark-mode .community-creator-container .rules-btn:hover {
        background: #4b5563;
        color: #f9fafb;
    }

    .community-creator-container .rules-content {
        padding: 12px;
        min-height: 120px;
        outline: none;
        font-size: 14px;
        line-height: 1.5;
        transition: color 0.3s ease;
    }

    body.dark-mode .community-creator-container .rules-content {
        color: #f9fafb;
    }

    .community-creator-container .rules-content:empty:before {
        content: "Enter community rules and guidelines...";
        color: #7c7c7c;
    }

    body.dark-mode .community-creator-container .rules-content:empty:before {
        color: #9ca3af;
    }

    /* Image Preview */
    .community-creator-container .image-preview {
        margin-top: 8px;
        display: none;
    }

    .community-creator-container .preview-image {
        max-width: 200px;
        max-height: 200px;
        border-radius: 4px;
        border: 1px solid #edeff1;
        transition: border-color 0.3s ease;
    }

    body.dark-mode .community-creator-container .preview-image {
        border-color: #4b5563;
    }

    /* Status Messages */
    .community-creator-container .status-message {
        position: fixed;
        top: 60px;
        right: 20px;
        padding: 12px 16px;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 500;
        z-index: 1000;
        display: none;
        animation: slideIn 0.3s ease;
        transition: all 0.3s ease;
    }

        .community-creator-container .status-message.success {
            background: #46D160;
            color: white;
        }

        .community-creator-container .status-message.error {
            background: #FF4500;
            color: white;
        }

        .community-creator-container .status-message.info {
            background: #0079D3;
            color: white;
        }

    body.dark-mode .community-creator-container .status-message.info {
        background: #818cf8;
    }

    @@keyframes slideIn {
        from

    {
        transform: translateX(100%);
        opacity: 0;
    }

    to {
        transform: translateX(0);
        opacity: 1;
    }

    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .community-creator-container .container-fluid.main-container

    {
        grid-template-columns: 1fr;
        max-width: 800px;
        margin: 0 auto;
    }

    .community-creator-container .left-sidebar,
    .community-creator-container .right-sidebar {
        display: none;
    }

    }

    @@media (max-width: 768px) {
        .community-creator-container .main-container

    {
        margin: 10px auto;
        padding: 0 10px;
    }

    .community-creator-container .form-container {
        padding: 16px;
    }

    .community-creator-container .form-row {
        grid-template-columns: 1fr;
    }

    .community-creator-container .community-options {
        grid-template-columns: 1fr;
    }

    }
</style>
<div class="community-creator-container">
    <!-- Main Container -->
    <div class="container-fluid main-container">
        <!-- Left Sidebar -->
        <aside class="left-sidebar">
            <!-- Community Guidelines -->
            <div class="sidebar-card">
                <div class="sidebar-header">
                    <i class="fas fa-info-circle"></i> Community Creation Guidelines
                </div>
                <div class="sidebar-content">
                    <ul class="tips-list">
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Choose a unique and descriptive name</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Write clear community rules and guidelines</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Select the appropriate category</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Add an engaging description</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Upload a community icon and banner</span>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Popular Categories -->
            <div class="sidebar-card">
                <div class="sidebar-header">
                    <i class="fas fa-tags"></i> Popular Categories
                </div>
                <div class="sidebar-content">
                    <div style="display: flex; flex-direction: column; gap: 8px;">
                        <div style="padding: 8px; background: #f9f9f9; border-radius: 4px; font-size: 12px;">
                            <strong>Technology</strong> - 1,234 communities
                        </div>
                        <div style="padding: 8px; background: #f9f9f9; border-radius: 4px; font-size: 12px;">
                            <strong>Gaming</strong> - 987 communities
                        </div>
                        <div style="padding: 8px; background: #f9f9f9; border-radius: 4px; font-size: 12px;">
