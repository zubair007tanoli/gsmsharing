        <!-- Main Content -->
        <main class="main-content">
            <div class="community-header">
                <h1 class="community-title">Create a new community</h1>
                <div class="breadcrumb">
                    <a href="/">Home</a> / <a href="/communities">Communities</a> / Create Community
