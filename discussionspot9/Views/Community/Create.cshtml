@model discussionspot9.Models.ViewModels.CreativeViewModels.CreateCommunityViewModel
@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="/css/CustomStyles/V1/CreateCommunityStyle.css" rel="stylesheet" />
<div class="community-creator-container">
    <!-- Main Container -->
    <div class="container-fluid main-container">
        <!-- Left Sidebar -->
        <aside class="left-sidebar">
            <!-- Community Guidelines -->
            <div class="sidebar-card">
                <div class="sidebar-header">
                    <i class="fas fa-info-circle"></i> Community Creation Guidelines
                </div>
                <div class="sidebar-content">
                    <ul class="tips-list">
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Choose a unique and descriptive name</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Write clear community rules and guidelines</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Select the appropriate category</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Add an engaging description</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Upload a community icon and banner</span>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Popular Categories -->
            <div class="sidebar-card">
                <div class="sidebar-header">
                    <i class="fas fa-tags"></i> Popular Categories
                </div>
                <div class="sidebar-content">
                    <div style="display: flex; flex-direction: column; gap: 8px;">
                        @{
                            var popularCategories = ViewData["PopularCategories"] as List<dynamic>;
                        }
                        @if (popularCategories != null && popularCategories.Any())
                        {
                            foreach (var cat in popularCategories)
                            {
                                <div style="padding: 8px; background: #f9f9f9; border-radius: 4px; font-size: 12px; cursor: pointer;" onclick="selectCategory('@cat.CategoryName')">
                                    <strong>@cat.CategoryName</strong> - @cat.CommunityCount.ToString("N0") @(cat.CommunityCount == 1 ? "community" : "communities")
                                </div>
                            }
                        }
                        else
                        {
                            <div style="padding: 8px; background: #f9f9f9; border-radius: 4px; font-size: 12px;">
                                <em>No categories yet</em>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="community-header">
                <h1 class="community-title">Create a new community</h1>
                <div class="breadcrumb">
                    <a href="/">Home</a> / <a href="/communities">Communities</a> / Create Community
                </div>
            </div>

            <!-- Form Container -->
            <div class="form-container">
                <form id="communityForm" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    
                    <!-- Hidden fields -->
                    <input type="hidden" asp-for="Slug" />
                    <input type="hidden" asp-for="CreatorId" />
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    <!-- Basic Information -->
                    <div class="form-group">
                        <label class="form-label" asp-for="Name">Community Name *</label>
                        <input type="text" class="form-input" asp-for="Name" placeholder="Enter community name" maxlength="100" required>
                        <div class="char-count">
                            <span id="nameCount">0</span>/100
                        </div>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Title">Display Title *</label>
                        <input type="text" class="form-input" asp-for="Title" placeholder="A descriptive title for your community" maxlength="200" required>
                        <div class="char-count">
                            <span id="titleCount">0</span>/200
                        </div>
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" asp-for="CategoryId">Category *</label>
                            <select class="form-select" asp-for="CategoryId" id="categorySelect" required>
                                <option value="">Select a category</option>
                                @foreach (var category in Model.AvailableCategories)
                                {
                                    <option value="@category.CategoryId" 
                                            data-icon="@category.Icon" 
                                            data-description="@category.Description">
                                        @category.Name
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label" asp-for="CommunityType">Community Type *</label>
                            <select class="form-select" asp-for="CommunityType" required>
                                <option value="public">Public - Anyone can view and join</option>
                                <option value="restricted">Restricted - Anyone can view, approval required to join</option>
                                <option value="private">Private - Invitation only</option>
                            </select>
                            <span asp-validation-for="CommunityType" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="ShortDescription">Short Description *</label>
                        <input type="text" class="form-input" asp-for="ShortDescription" placeholder="Brief description for community listings" maxlength="500" required>
                        <div class="char-count">
                            <span id="shortDescCount">0</span>/500
                        </div>
                        <span asp-validation-for="ShortDescription" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Description">Full Description</label>
                        <textarea class="form-textarea" asp-for="Description" rows="5" placeholder="Detailed description of your community, its purpose, and what members can expect..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <!-- Visual Elements -->
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" asp-for="IconFile">Community Icon</label>
                            <div class="upload-area" onclick="document.getElementById('iconUpload').click()">
                                <div class="upload-icon">
                                    <i class="fas fa-image"></i>
                                </div>
                                <div class="upload-text">Upload Icon</div>
                                <div class="upload-subtext">Recommended: 256x256px</div>
                            </div>
                            <input type="file" id="iconUpload" asp-for="IconFile" accept="image/*" style="display: none;">
                            <div class="image-preview" id="iconPreview">
                                <img class="preview-image" id="iconImage" alt="Community Icon Preview">
                            </div>
                            <span asp-validation-for="IconFile" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label" asp-for="BannerFile">Community Banner</label>
                            <div class="upload-area" onclick="document.getElementById('bannerUpload').click()">
                                <div class="upload-icon">
                                    <i class="fas fa-panorama"></i>
                                </div>
                                <div class="upload-text">Upload Banner</div>
                                <div class="upload-subtext">Recommended: 1920x384px</div>
                            </div>
                            <input type="file" id="bannerUpload" asp-for="BannerFile" accept="image/*" style="display: none;">
                            <div class="image-preview" id="bannerPreview">
                                <img class="preview-image" id="bannerImage" alt="Community Banner Preview">
                            </div>
                            <span asp-validation-for="BannerFile" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="ThemeColor">Theme Color</label>
                        <input type="color" class="form-input" asp-for="ThemeColor" style="height: 40px;">
                        <span asp-validation-for="ThemeColor" class="text-danger"></span>
                    </div>

                    <!-- Community Rules -->
                    <div class="form-group">
                        <label class="form-label" asp-for="Rules">Community Rules & Guidelines</label>
                        <div class="rules-editor">
                            <div class="rules-toolbar">
                                <button type="button" class="rules-btn" title="Bold">
                                    <i class="fas fa-bold"></i>
                                </button>
                                <button type="button" class="rules-btn" title="Italic">
                                    <i class="fas fa-italic"></i>
                                </button>
                                <button type="button" class="rules-btn" title="List">
                                    <i class="fas fa-list"></i>
                                </button>
                                <button type="button" class="rules-btn" title="Link">
                                    <i class="fas fa-link"></i>
                                </button>
                            </div>
                            <div class="rules-content" contenteditable="true" id="rulesEditor">@Html.Raw(Model.Rules)</div>
                        </div>
                        <textarea asp-for="Rules" id="rulesHidden" style="display: none;"></textarea>
                        <span asp-validation-for="Rules" class="text-danger"></span>
                    </div>

                    <!-- Community Options -->
                    <div class="community-options">
                        <label class="option-toggle">
                            <span>NSFW Community</span>
                            <div class="toggle-switch">
                                <input type="checkbox" asp-for="IsNSFW">
                                <span class="toggle-slider"></span>
                            </div>
                        </label>
                        <span asp-validation-for="IsNSFW" class="text-danger"></span>
                    </div>

                    <!-- Community Preview -->
                    <div class="community-preview">
                        <h3><i class="fas fa-eye"></i> Community Preview</h3>
                        <div class="preview-community">
                            <div class="preview-icon" id="previewIcon">C</div>
                            <div class="preview-info">
                                <h4 id="previewName">Community Name</h4>
                                <p id="previewDescription">Community description will appear here</p>
                                <div style="font-size: 11px; color: #46D160; margin-top: 4px;">
                                    <span id="previewType">Public</span> • <span id="previewCategory">Category</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <button type="button" class="btn btn-ghost" id="saveAsDraft">
                    <i class="fas fa-save"></i> Save Draft
                </button>
                <button type="button" class="btn btn-secondary" id="previewBtn">
                    <i class="fas fa-eye"></i> Preview
                </button>
                <button type="submit" class="btn btn-primary" id="createCommunity" form="communityForm">
                    <i class="fas fa-plus"></i> Create Community
                </button>
            </div>
        </main>


        <!-- Right Sidebar -->
        <aside class="right-sidebar">
            <!-- Community Tips -->
            <div class="sidebar-card">
                <div class="sidebar-header">
                    <i class="fas fa-lightbulb"></i> Community Success Tips
                </div>
                <div class="sidebar-content">
                    <ul class="tips-list">
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Start with clear, enforceable rules</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Be active and engage with your members</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Create quality content to attract users</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Moderate consistently and fairly</span>
                        </li>
                        <li>
                            <i class="fas fa-lightbulb"></i>
                            <span>Promote your community in relevant places</span>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Community Stats -->
            <div class="sidebar-card">
                <div class="sidebar-header">Platform Statistics</div>
                <div class="sidebar-content">
                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        <div style="text-align: center;">
                            <div style="font-size: 24px; font-weight: bold; color: #0079D3;">12,847</div>
                            <div style="font-size: 12px; color: #7c7c7c;">Total Communities</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 24px; font-weight: bold; color: #46D160;">2.3M</div>
                            <div style="font-size: 12px; color: #7c7c7c;">Active Members</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 24px; font-weight: bold; color: #FF4500;">156</div>
                            <div style="font-size: 12px; color: #7c7c7c;">New Communities This Week</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Communities -->
            <div class="sidebar-card">
                <div class="sidebar-header">Recently Created</div>
                <div class="sidebar-content">
                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <div style="width: 24px; height: 24px; background: #FF6B6B; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 10px; font-weight: bold;">AI</div>
                            <div>
                                <div style="font-size: 12px; font-weight: 600;">r/AIDiscussion</div>
                                <div style="font-size: 10px; color: #7c7c7c;">2 hours ago</div>
                            </div>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <div style="width: 24px; height: 24px; background: #4ECDC4; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 10px; font-weight: bold;">WD</div>
                            <div>
                                <div style="font-size: 12px; font-weight: 600;">r/WebDev</div>
                                <div style="font-size: 10px; color: #7c7c7c;">5 hours ago</div>
                            </div>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <div style="width: 24px; height: 24px; background: #A8E6CF; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 10px; font-weight: bold;">ST</div>
                            <div>
                                <div style="font-size: 12px; font-weight: 600;">r/StartupLife</div>
                                <div style="font-size: 10px; color: #7c7c7c;">1 day ago</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>

    <!-- Status Message -->
    <div class="status-message" id="statusMessage">
        <span id="statusText">Status message</span>
    </div>
</div>
@section Scripts {
    <!-- Choices.js for enhanced dropdowns -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
    
    <script src="/js/CustomScripts/V1/CreateCommunityScript.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize Choices.js on category dropdown
            const categorySelect = new Choices('#categorySelect', {
                searchEnabled: true,
                itemSelectText: '',
                shouldSort: false,
                placeholderValue: 'Select a category',
                noResultsText: 'No categories found',
                searchPlaceholderValue: 'Search categories...',
                callbackOnCreateTemplates: function(template) {
                    return {
                        // Custom template for options with icons
                        choice: (classNames, data) => {
                            const icon = data.customProperties?.icon || 'fa-folder';
                            const description = data.customProperties?.description || '';
                            return template(`
                                <div class="${classNames.item} ${classNames.itemChoice} ${
                                    data.disabled ? classNames.itemDisabled : classNames.itemSelectable
                                }" data-select-text="${this.config.itemSelectText}" data-choice ${
                                    data.disabled ? 'data-choice-disabled aria-disabled="true"' : 'data-choice-selectable'
                                } data-id="${data.id}" data-value="${data.value}" ${
                                    data.groupId > 0 ? 'role="treeitem"' : 'role="option"'
                                }>
                                    <i class="fas ${icon}" style="margin-right: 8px; color: #0079D3;"></i>
                                    <span>${data.label}</span>
                                    ${description ? `<br><small style="color: #6b7280; margin-left: 26px;">${description}</small>` : ''}
                                </div>
                            `);
                        },
                        // Template for selected item
                        item: (classNames, data) => {
                            const icon = data.customProperties?.icon || 'fa-folder';
                            return template(`
                                <div class="${classNames.item} ${
                                    data.highlighted ? classNames.highlightedState : classNames.itemSelectable
                                }" data-item data-id="${data.id}" data-value="${data.value}" ${
                                    data.active ? 'aria-selected="true"' : ''
                                } ${data.disabled ? 'aria-disabled="true"' : ''}>
                                    <i class="fas ${icon}" style="margin-right: 8px;"></i>
                                    ${data.label}
                                </div>
                            `);
                        }
                    };
                }
            });
            
            // Pass icon and description data to Choices
            const selectElement = document.querySelector('#categorySelect');
            const options = Array.from(selectElement.options).slice(1); // Skip first empty option
            const choicesData = options.map(option => ({
                value: option.value,
                label: option.text,
                customProperties: {
                    icon: option.dataset.icon,
                    description: option.dataset.description
                }
            }));
            
            // Update Choices with custom properties
            if (choicesData.length > 0) {
                categorySelect.setChoices(choicesData, 'value', 'label', true);
            }
        });
        
        // Helper function to select category from sidebar click
        function selectCategory(categoryName) {
            const categorySelect = document.querySelector('#categorySelect');
            const option = Array.from(categorySelect.options).find(opt => 
                opt.text.toLowerCase() === categoryName.toLowerCase()
            );
            if (option) {
                categorySelect.value = option.value;
                // Trigger change event for Choices.js
                categorySelect.dispatchEvent(new Event('change', { bubbles: true }));
            }
        }
    </script>
}


