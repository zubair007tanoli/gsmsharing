            <!-- Form Container -->
            <div class="form-container">
                <form id="communityForm" method="post" enctype="multipart/form-data">
                    <!-- Hidden fields -->
                    <input type="hidden" id="creatorId" name="CreatorId" value="">
                    <input type="hidden" id="slug" name="Slug" value="">

                    <!-- Basic Information -->
                    <div class="form-group">
                        <label class="form-label" for="communityName">Community Name *</label>
                        <input type="text" class="form-input" id="communityName" name="Name" placeholder="Enter community name" maxlength="100" required>
                        <div class="char-count">
                            <span id="nameCount">0</span>/100
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="communityTitle">Display Title *</label>
                        <input type="text" class="form-input" id="communityTitle" name="Title" placeholder="A descriptive title for your community" maxlength="200" required>
