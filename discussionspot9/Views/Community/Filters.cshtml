    <script>
        // Banned word functionality
        function addBannedWord() {
            const word = document.getElementById('newBannedWord').value.trim();
            if (!word) {
                alert('Please enter a word or phrase');
                return;
            }
            
            // TODO: Implement API call to add banned word
            alert(`Add banned word functionality will be implemented with API integration`);
