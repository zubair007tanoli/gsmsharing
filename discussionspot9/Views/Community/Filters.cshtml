        }

        function removeBannedWord(wordId) {
            if (confirm('Are you sure you want to remove this banned word?')) {
                // TODO: Implement API call to remove banned word
                alert(`Remove banned word functionality will be implemented with API integration`);
            }
        }

        function saveBannedWord() {
            const word = document.getElementById('bannedWordText').value.trim();
            const action = document.getElementById('bannedWordAction').value;
            const replacement = document.getElementById('bannedWordReplacement').value;
            const caseSensitive = document.getElementById('bannedWordCaseSensitive').checked;
            const wholeWord = document.getElementById('bannedWordWholeWord').checked;

            if (!word) {
                alert('Please enter a word or phrase');
                return;
            }

            // TODO: Implement API call to save banned word
            alert(`Save banned word functionality will be implemented with API integration`);
            bootstrap.Modal.getInstance(document.getElementById('bannedWordModal')).hide();
        }

        // Action change handler
        document.getElementById('bannedWordAction').addEventListener('change', function() {
            const replacementGroup = document.getElementById('replacementGroup');
            if (this.value === 'replace') {
                replacementGroup.style.display = 'block';
            } else {
                replacementGroup.style.display = 'none';
            }
        });

        // Spam threshold slider
        document.getElementById('spamThreshold').addEventListener('input', function() {
            document.querySelector('.range-value').textContent = this.value;
        });

        // Save settings
        function saveSettings() {
            // TODO: Implement API call to save all settings
            alert('Settings save functionality will be implemented with API integration');
        }

        // Auto-save on change
        document.addEventListener('change', function(e) {
            if (e.target.matches('input, select, textarea')) {
                // Debounce auto-save
                clearTimeout(window.autoSaveTimeout);
                window.autoSaveTimeout = setTimeout(saveSettings, 2000);
            }
        });
    </script>
}
