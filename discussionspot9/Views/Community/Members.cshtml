@model discussionspot9.Models.ViewModels.CommunityMembersViewModel
@{
    ViewData["Title"] = $"{Model.CommunityName} - Members";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/community-settings.css" />
    <link rel="stylesheet" href="~/css/community-pages.css" />
}

<div class="community-members-container">
    <!-- Header -->
    <div class="members-header">
        <div class="header-content">
            <h1>
                <i class="fas fa-users"></i> Community Members
            </h1>
            <p class="text-muted">Manage and moderate community members</p>
        </div>
        <div class="header-actions">
            <a href="/r/@Model.CommunitySlug" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back to Community
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
                <div class="stat-number">@Model.TotalMembers</div>
                <div class="stat-label">Total Members</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-crown"></i>
            </div>
            <div class="stat-content">
                <div class="stat-number">@Model.TotalAdmins</div>
                <div class="stat-label">Admins</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-shield-alt"></i>
            </div>
            <div class="stat-content">
                <div class="stat-number">@Model.TotalModerators</div>
                <div class="stat-label">Moderators</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-user-plus"></i>
            </div>
            <div class="stat-content">
                <div class="stat-number">@Model.NewMembersThisWeek</div>
                <div class="stat-label">New This Week</div>
            </div>
        </div>
    </div>

    <!-- Filters and Search -->
    <div class="filters-section">
        <div class="row">
            <div class="col-md-6">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" id="memberSearch" class="form-control" placeholder="Search members..." value="@Model.SearchTerm">
                </div>
            </div>
            <div class="col-md-3">
                <select id="roleFilter" class="form-select">
                    <option value="all" selected="@(Model.RoleFilter == "all")">All Roles</option>
                    <option value="admin" selected="@(Model.RoleFilter == "admin")">Admins</option>
                    <option value="moderator" selected="@(Model.RoleFilter == "moderator")">Moderators</option>
                    <option value="member" selected="@(Model.RoleFilter == "member")">Members</option>
                </select>
            </div>
            <div class="col-md-3">
                <select id="sortBy" class="form-select">
                    <option value="joined" selected="@(Model.SortBy == "joined")">Joined Date</option>
                    <option value="name" selected="@(Model.SortBy == "name")">Name</option>
                    <option value="activity" selected="@(Model.SortBy == "activity")">Activity</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Members List -->
    <div class="members-list">
        @if (Model.Members.Any())
        {
            @foreach (var member in Model.Members)
            {
                <div class="member-card" data-user-id="@member.UserId">
                    <div class="member-avatar">
                        @if (!string.IsNullOrEmpty(member.AvatarUrl))
                        {
                            <img src="@member.AvatarUrl" alt="@member.DisplayName">
                        }
                        else
                        {
                            <div class="avatar-initials">@member.Initials</div>
                        }
                        @if (member.IsOnline)
                        {
                            <div class="online-indicator"></div>
                        }
                    </div>
                    
                    <div class="member-info">
                        <div class="member-name">
                            <strong>@member.DisplayName</strong>
                            @if (member.IsBanned)
                            {
                                <span class="badge bg-danger">Banned</span>
                            }
                        </div>
                        <div class="member-details">
                            <span class="role-badge @member.Role.ToLower()">
                                <i class="fas @(member.Role == "admin" ? "fa-crown" : member.Role == "moderator" ? "fa-shield-alt" : "fa-user")"></i>
                                @member.Role.ToUpper()
                            </span>
                            <span class="join-date">Joined @member.FormattedJoinedAt</span>
                        </div>
                        <div class="member-stats">
                            <span><i class="fas fa-file-alt"></i> @member.PostCount posts</span>
                            <span><i class="fas fa-comments"></i> @member.CommentCount comments</span>
                            <span><i class="fas fa-heart"></i> @member.Karma karma</span>
                        </div>
                    </div>
                    
                    <div class="member-actions">
                        @if (Model.CanManageMembers)
                        {
                            <div class="action-buttons">
                                @if (Model.CanChangeRoles && member.Role != "admin")
                                {
                                    <button class="btn btn-sm btn-outline-primary" onclick="changeRole('@member.UserId', '@member.DisplayName')">
                                        <i class="fas fa-user-edit"></i> Change Role
                                    </button>
                                }
                                @if (Model.CanBanMembers && member.Role != "admin")
                                {
                                    <button class="btn btn-sm btn-outline-danger" onclick="banMember('@member.UserId', '@member.DisplayName')">
                                        <i class="fas fa-ban"></i> Ban
                                    </button>
                                }
                                <button class="btn btn-sm btn-outline-info" onclick="viewProfile('@member.UserId')">
                                    <i class="fas fa-eye"></i> View Profile
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-users"></i>
                <h3>No members found</h3>
                <p>Try adjusting your search or filter criteria.</p>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Members pagination">
            <ul class="pagination justify-content-center">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="?page=@(Model.CurrentPage - 1)&search=@Model.SearchTerm&role=@Model.RoleFilter&sort=@Model.SortBy&order=@Model.SortOrder">
                            <i class="fas fa-chevron-left"></i> Previous
                        </a>
                    </li>
                }
                
                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i&search=@Model.SearchTerm&role=@Model.RoleFilter&sort=@Model.SortBy&order=@Model.SortOrder">@i</a>
                    </li>
                }
                
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="?page=@(Model.CurrentPage + 1)&search=@Model.SearchTerm&role=@Model.RoleFilter&sort=@Model.SortBy&order=@Model.SortOrder">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<!-- Change Role Modal -->
<div class="modal fade" id="changeRoleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-user-edit"></i> Change Member Role
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Change role for: <strong id="changeRoleUserName"></strong></p>
                <input type="hidden" id="changeRoleUserId">
                
                <div class="mb-3">
                    <label for="newRole" class="form-label">New Role:</label>
                    <select id="newRole" class="form-select">
                        <option value="member">👤 Member - Regular member</option>
                        <option value="moderator">🛡️ Moderator - Can moderate content</option>
                        <option value="admin">👑 Admin - Full community control</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="confirmRoleChange()">
                    <i class="fas fa-check"></i> Change Role
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Ban Member Modal -->
<div class="modal fade" id="banMemberModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-ban"></i> Ban Member
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i> This will remove the user from the community and prevent them from rejoining.
                </div>
                
                <p>Banning user: <strong id="banMemberUserName"></strong></p>
                <input type="hidden" id="banMemberUserId">
                
                <div class="mb-3">
                    <label for="banReason" class="form-label">Reason (Required):</label>
                    <textarea id="banReason" class="form-control" rows="3" placeholder="Explain why..." required></textarea>
                </div>
                
                <div class="mb-3">
                    <label for="banDuration" class="form-label">Duration:</label>
                    <select id="banDuration" class="form-select">
                        <option value="1">1 Day</option>
                        <option value="7">7 Days</option>
                        <option value="30">30 Days</option>
                        <option value="90">90 Days</option>
                        <option value="0" selected>Permanent</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmBan()">
                    <i class="fas fa-ban"></i> Confirm Ban
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Search functionality
        document.getElementById('memberSearch').addEventListener('input', function() {
            const searchTerm = this.value;
            const currentUrl = new URL(window.location);
            currentUrl.searchParams.set('search', searchTerm);
            currentUrl.searchParams.set('page', '1');
            window.location.href = currentUrl.toString();
        });

        // Filter functionality
        document.getElementById('roleFilter').addEventListener('change', function() {
            const role = this.value;
            const currentUrl = new URL(window.location);
            currentUrl.searchParams.set('role', role);
            currentUrl.searchParams.set('page', '1');
            window.location.href = currentUrl.toString();
        });

        document.getElementById('sortBy').addEventListener('change', function() {
            const sort = this.value;
            const currentUrl = new URL(window.location);
            currentUrl.searchParams.set('sort', sort);
            currentUrl.searchParams.set('page', '1');
            window.location.href = currentUrl.toString();
        });

        // Change role functionality
        function changeRole(userId, userName) {
            document.getElementById('changeRoleUserId').value = userId;
            document.getElementById('changeRoleUserName').textContent = userName;
            new bootstrap.Modal(document.getElementById('changeRoleModal')).show();
        }

        function confirmRoleChange() {
            const userId = document.getElementById('changeRoleUserId').value;
            const newRole = document.getElementById('newRole').value;
            
            // TODO: Implement API call to change role
            alert(`Role change functionality will be implemented with API integration`);
            bootstrap.Modal.getInstance(document.getElementById('changeRoleModal')).hide();
        }

        // Ban member functionality
        function banMember(userId, userName) {
            document.getElementById('banMemberUserId').value = userId;
            document.getElementById('banMemberUserName').textContent = userName;
            document.getElementById('banReason').value = '';
            new bootstrap.Modal(document.getElementById('banMemberModal')).show();
        }

        function confirmBan() {
