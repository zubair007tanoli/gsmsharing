@model discussionspot9.Models.ViewModels.CreativeViewModels.CreateCommunityViewModel
@{
    ViewData["Title"] = Model.Title ?? "Community";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* @section Styles {
    <link rel="stylesheet" href="~/css/modern-style.css" />
    <link rel="stylesheet" href="~/css/dark-mode.css" />
    <link rel="stylesheet" href="~/css/DiscussionMain.css" />
    <link rel="stylesheet" href="~/css/Improve.css" />
} *@

<div class="main-container">
    <!-- Left Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h3><i class="fas fa-layer-group"></i> Categories</h3>
        </div>
        <ul class="category-list">
            <li><a href="/"><i class="fas fa-home"></i> Home</a></li>
            <li><a href="/communities" class="active"><i class="fas fa-users"></i> Communities</a></li>
            <li><a href="/categories/technology"><i class="fas fa-laptop-code"></i> Technology</a></li>
            <li><a href="/categories/gaming"><i class="fas fa-gamepad"></i> Gaming</a></li>
            <li><a href="/categories/creative-arts"><i class="fas fa-palette"></i> Creative Arts</a></li>
            <li><a href="/categories/science"><i class="fas fa-flask"></i> Science</a></li>
            <li><a href="/categories/sports"><i class="fas fa-football-ball"></i> Sports</a></li>
            <li><a href="/categories/music"><i class="fas fa-music"></i> Music</a></li>
            <li><a href="/categories/movies"><i class="fas fa-film"></i> Movies & TV</a></li>
            <li><a href="/categories/books"><i class="fas fa-book"></i> Books</a></li>
        </ul>

        <!-- Sidebar Ad -->
        <div class="sidebar-ad">
            <div class="ad-placeholder">
                <!-- Google AdSense -->
                <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-xxxxxxxxxxxxxxxx"
                     data-ad-slot="xxxxxxxxxx"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
                <script>
                    (adsbygoogle = window.adsbygoogle || []).push({});
                </script>
                <div class="ad-label">Advertisement</div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main>
        <!-- Community Header -->
        <div class="community-header" style="background: linear-gradient(135deg, @(Model.ThemeColor ?? "#0079D3"), @(Model.ThemeColor ?? "#0079D3")88);">
            @if (!string.IsNullOrEmpty(Model.BannerUrl))
            {
                <div class="community-banner" style="background-image: url('@Model.BannerUrl');"></div>
            }
            <div class="community-header-content">
                <div class="community-info">
                    <div class="community-avatar">
                        @if (!string.IsNullOrEmpty(Model.IconUrl))
                        {
                            <img src="@Model.IconUrl" alt="@Model.Name" class="community-icon-img" />
                        }
                        else
                        {
                            <div class="community-icon-placeholder">
                                <i class="fas fa-users"></i>
                            </div>
                        }
                    </div>
                    <div class="community-details">
                        <h1 class="community-title">@Model.Title</h1>
                        <p class="community-name">r/@Model.Name</p>
                        <p class="community-description">@Model.ShortDescription</p>
                        <div class="community-meta">
                            <span class="community-type">
                                <i class="fas fa-@(Model.CommunityType == "public" ? "globe" : Model.CommunityType == "private" ? "lock" : "shield-alt")"></i>
                                @Model.CommunityType.ToUpper()
                            </span>
                            @if (Model.IsNSFW)
                            {
                                <span class="nsfw-badge">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    NSFW
                                </span>
                            }
                        </div>
                    </div>
                </div>
                <div class="community-actions">
                    <button class="btn btn-primary join-btn" id="joinCommunityBtn">
                        <i class="fas fa-plus"></i> Join Community
                    </button>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <button class="btn btn-outline-light edit-btn" data-bs-toggle="modal" data-bs-target="#editCommunityModal">
                            <i class="fas fa-edit"></i> Edit Community
                        </button>
                    }
                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-ellipsis-h"></i>
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#"><i class="fas fa-share"></i> Share</a></li>
                            <li><a class="dropdown-item" href="#"><i class="fas fa-flag"></i> Report</a></li>
                            <li><a class="dropdown-item" href="#"><i class="fas fa-bookmark"></i> Save</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Community Navigation -->
        <div class="community-navigation">
            <nav class="nav nav-pills">
                <a class="nav-link active" href="#posts" data-tab="posts">
                    <i class="fas fa-newspaper"></i> Posts
                </a>
                <a class="nav-link" href="#about" data-tab="about">
                    <i class="fas fa-info-circle"></i> About
                </a>
                <a class="nav-link" href="#rules" data-tab="rules">
                    <i class="fas fa-gavel"></i> Rules
                </a>
                <a class="nav-link" href="#members" data-tab="members">
                    <i class="fas fa-users"></i> Members
                </a>
            </nav>
            <div class="sort-options">
                <select class="form-select form-select-sm">
                    <option value="hot">🔥 Hot</option>
                    <option value="new">🆕 New</option>
                    <option value="top">⭐ Top</option>
                    <option value="rising">📈 Rising</option>
                </select>
            </div>
        </div>

        <!-- Tab Content -->
        <div class="tab-content">
            <!-- Posts Tab -->
            <div class="tab-pane active" id="posts-content">
                <!-- Create Post Button -->
                <div class="create-post-section">
                    <a href="/posts/create?community=@Model.Slug" class="btn btn-primary create-post-btn">
                        <i class="fas fa-plus"></i> Create Post
                    </a>
                </div>

                <!-- Posts List -->
                <div class="posts-container">
                    <!-- Sample Post Items -->
                    <div class="post-item-detailed">
                        <div class="post-stats">
                            <div class="stat-box">
                                <div class="stat-number">42</div>
                                <div class="stat-label">votes</div>
                            </div>
                            <div class="stat-box">
                                <div class="stat-number">15</div>
                                <div class="stat-label">replies</div>
                            </div>
                        </div>
                        <div class="post-main-content">
                            <h3><a href="/posts/sample-post">Welcome to our amazing community!</a></h3>
                            <p class="post-excerpt">This is a sample post to show how posts appear in the community. Join our discussions and share your thoughts...</p>
                            <div class="post-meta">
                                <div class="post-info">
                                    <span><i class="fas fa-user"></i> by <strong>CommunityMod</strong></span>
                                    <span><i class="fas fa-clock"></i> 2 hours ago</span>
                                    <span><i class="fas fa-eye"></i> 156 views</span>
                                </div>
                                <div class="post-tags">
                                    <span class="tag">announcement</span>
                                    <span class="tag">welcome</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- More posts would be loaded here -->
                    <div class="load-more-section">
                        <button class="btn btn-outline-primary load-more-btn">
                            <i class="fas fa-chevron-down"></i> Load More Posts
                        </button>
                    </div>
                </div>
            </div>

            <!-- About Tab -->
            <div class="tab-pane" id="about-content">
                <div class="about-section">
                    <h3>About This Community</h3>
                    <div class="about-content">
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <p>@Html.Raw(Model.Description.Replace("\n", "<br>"))</p>
                        }
                        else
                        {
                            <p>@Model.ShortDescription</p>
                        }
                    </div>

                    <div class="community-stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-users"></i></div>
                            <div class="stat-info">
                                <div class="stat-number">1,234</div>
                                <div class="stat-label">Members</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-newspaper"></i></div>
                            <div class="stat-info">
                                <div class="stat-number">567</div>
                                <div class="stat-label">Posts</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-comments"></i></div>
                            <div class="stat-info">
                                <div class="stat-number">2,890</div>
                                <div class="stat-label">Comments</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-calendar"></i></div>
                            <div class="stat-info">
                                <div class="stat-number">Jan 2024</div>
                                <div class="stat-label">Created</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Rules Tab -->
            <div class="tab-pane" id="rules-content">
                <div class="rules-section">
                    <h3>Community Rules</h3>
                    @if (!string.IsNullOrEmpty(Model.Rules))
                    {
                        <div class="rules-content">
                            @Html.Raw(Model.Rules.Replace("\n", "<br>"))
                        </div>
                    }
                    else
                    {
                        <div class="no-rules">
                            <i class="fas fa-info-circle"></i>
                            <p>No specific rules have been set for this community yet. Please follow general community guidelines.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Members Tab -->
            <div class="tab-pane" id="members-content">
                <div class="members-section">
                    <h3>Community Members</h3>
                    <div class="members-grid">
                        <!-- Sample members -->
                        <div class="member-card">
                            <div class="member-avatar">JD</div>
                            <div class="member-info">
                                <div class="member-name">JohnDoe</div>
                                <div class="member-role">Moderator</div>
                                <div class="member-stats">
                                    <span>42 posts</span>
                                    <span>156 karma</span>
                                </div>
                            </div>
                        </div>
                        <!-- More members would be loaded here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Google AdSense Banner -->
        <div class="ad-banner-section">
            <div class="ad-label">Advertisement</div>
            <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-xxxxxxxxxxxxxxxx"
                 data-ad-slot="xxxxxxxxxx"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>
                (adsbygoogle = window.adsbygoogle || []).push({});
            </script>
        </div>
    </main>

    <!-- Right Sidebar -->
    <aside class="right-sidebar">
        <!-- Community Quick Stats -->
        <div class="sidebar-section">
            <h3><i class="fas fa-chart-line"></i> Quick Stats</h3>
            <div class="stats">
                <ul>
                    <li><i class="fas fa-users"></i> <span>1,234 Members</span></li>
                    <li><i class="fas fa-user-clock"></i> <span>89 Online</span></li>
                    <li><i class="fas fa-newspaper"></i> <span>567 Posts</span></li>
                    <li><i class="fas fa-comments"></i> <span>2,890 Comments</span></li>
                    <li><i class="fas fa-calendar"></i> <span>Created Jan 2024</span></li>
                </ul>
            </div>
        </div>

        <!-- Online Members -->
        <div class="sidebar-section">
            <h3><i class="fas fa-circle text-success"></i> Online Now</h3>
            <div class="user-avatars">
                <div class="user-avatar" title="User1">U1</div>
                <div class="user-avatar" title="User2">U2</div>
                <div class="user-avatar" title="User3">U3</div>
                <div class="user-avatar" title="User4">U4</div>
                <div class="user-avatar" title="User5">U5</div>
                <div class="more-users">+84</div>
