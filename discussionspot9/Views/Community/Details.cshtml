@model discussionspot9.Models.ViewModels.CreativeViewModels.CommunityDetailPageViewModel
@{
    ViewData["Title"] = Model.Community.Title ?? "Community";
    ViewData["Description"] = Model.Community.ShortDescription ?? Model.Community.Description ?? $"Join r/{Model.Community.Name} on DiscussionSpot.";
    ViewData["Keywords"] = $"{Model.Community.Title}, community, discussion, r/{Model.Community.Name}";
    var canonicalCommunitySlug = Model.Community.Slug ?? Model.Community.Name;
    ViewData["CanonicalUrl"] = $"{Context.Request.Scheme}://{Context.Request.Host}/r/{canonicalCommunitySlug}";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

@section Styles {
    <link rel="stylesheet" href="~/css/modern-style.css" />
    <link rel="stylesheet" href="~/css/dark-mode.css" />
    <link rel="stylesheet" href="~/css/DiscussionMain.css" />
    <link rel="stylesheet" href="~/css/Improve.css" />
    <link rel="stylesheet" href="~/css/community-pages.css" />
}

<div class="main-container community-detail-page">
    <!-- Left Sidebar -->
    <aside class="sidebar">
        <!-- Your Communities -->
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="sidebar-section">
                <div class="sidebar-header">
                    <h3><i class="fas fa-star"></i> Your Communities</h3>
                </div>
                <div class="community-list" id="yourCommunities">
                    <div class="text-muted small p-2">Loading...</div>
                </div>
            </div>
        }

        <!-- Suggested Communities -->
        <div class="sidebar-section">
            <div class="sidebar-header">
                <h3><i class="fas fa-compass"></i> Suggested Communities</h3>
            </div>
            <div class="community-list" id="suggestedCommunities">
                <div class="text-muted small p-2">Loading...</div>
            </div>
        </div>

        <!-- Categories -->
        <div class="sidebar-section">
            <div class="sidebar-header">
                <h3><i class="fas fa-layer-group"></i> Categories</h3>
            </div>
            <ul class="category-list">
                @await Component.InvokeAsync("CategoryDetail")
            </ul>
        </div>

        <!-- Sidebar Ad -->
        <div class="sidebar-section">
            <div class="ad-placeholder">
                <div class="ad-label">Advertisement</div>
                <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-xxxxxxxxxxxxxxxx"
                     data-ad-slot="xxxxxxxxxx"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
                <script>
                    (adsbygoogle = window.adsbygoogle || []).push({});
                </script>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main>
        <!-- Community Header -->
        <div class="community-header" style="background: linear-gradient(135deg, @(Model.Community.ThemeColor ?? "#1a73e8"), @(Model.Community.ThemeColor ?? "#4285f4"));">
            @if (!string.IsNullOrEmpty(Model.Community.BannerUrl))
            {
                <div class="community-banner" style="background-image: url('@Model.Community.BannerUrl');"></div>
            }
            <div class="community-header-content">
                <div class="community-info">
                    <div class="community-avatar">
                        @if (!string.IsNullOrEmpty(Model.Community.IconUrl))
                        {
                            <img src="@Model.Community.IconUrl" alt="@Model.Community.Name" class="community-icon-img" />
                        }
                        else
                        {
                            <div class="community-icon-placeholder">
                                @Model.Community.Name.Substring(0, Math.Min(2, Model.Community.Name.Length)).ToUpper()
                            </div>
                        }
                    </div>
                    <div class="community-details">
                        <h1>@Model.Community.Title</h1>
                        <p class="community-name">r/@Model.Community.Name</p>
                        <p class="community-description">@Model.Community.ShortDescription</p>
                        <div class="community-meta">
                            <span class="community-type">
                                <i class="fas fa-@(Model.Community.CommunityType == "public" ? "globe" : Model.Community.CommunityType == "private" ? "lock" : "shield-alt")"></i>
                                @Model.Community.CommunityType.ToUpper()
                            </span>
                            @if (Model.Community.IsNSFW)
                            {
                                <span class="nsfw-badge">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    NSFW
                                </span>
                            }
                        </div>
                    </div>
                </div>
                <div class="community-actions">
                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (Model.Community.IsCurrentUserModerator)
                        {
                            <!-- Admin/Moderator Controls -->
                            <span class="badge bg-warning text-dark me-2" style="padding: 0.5rem 1rem; font-size: 0.9rem;">
                                <i class="fas fa-shield-alt"></i> @(Model.Community.CurrentUserRole?.ToUpper() ?? "MODERATOR")
                            </span>
                            <a href="@Url.Action("Settings", "Community", new { slug = Model.Community.Slug })" class="btn btn-light">
                                <i class="fas fa-cog"></i> Mod Tools
                            </a>
                            <button class="btn btn-outline-light" data-bs-toggle="modal" data-bs-target="#editCommunityModal">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                        }
                        else
                        {
                            <button class="btn @(Model.Community.IsCurrentUserMember ? "btn-outline-light" : "btn-primary") join-btn" 
                                    id="joinCommunityBtn" 
                                    data-community-id="@Model.Community.CommunityId"
                                    data-is-member="@Model.Community.IsCurrentUserMember.ToString().ToLower()">
                                <i class="fas fa-@(Model.Community.IsCurrentUserMember ? "check" : "plus")"></i> 
                                @(Model.Community.IsCurrentUserMember ? "Joined" : "Join Community")
                            </button>
                        }
                    }
                    else
                    {
                        <a href="/Account/Auth?returnUrl=@Uri.EscapeDataString(Context.Request.Path)" class="btn btn-primary join-btn">
                            <i class="fas fa-plus"></i> Join Community
                        </a>
                    }
                    
                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-ellipsis-h"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#" onclick="shareCommunity(); return false;"><i class="fas fa-share"></i> Share</a></li>
                            @if (Model.Community.IsCurrentUserModerator)
                            {
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/r/@Model.Community.Slug/members"><i class="fas fa-users-cog"></i> Members & Moderators</a></li>
                                <li><a class="dropdown-item" href="/r/@Model.Community.Slug/analytics"><i class="fas fa-chart-bar"></i> Statistics</a></li>
                                <li><a class="dropdown-item" href="/r/@Model.Community.Slug/filters"><i class="fas fa-filter"></i> Content Filters</a></li>
                            }
                            else
                            {
                                <li><a class="dropdown-item" href="#"><i class="fas fa-flag"></i> Report</a></li>
                            }
                            <li><a class="dropdown-item" href="#"><i class="fas fa-bookmark"></i> Save</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Community Navigation -->
        <div class="community-navigation">
            <nav class="nav nav-pills">
                <a class="nav-link active" href="#posts" data-tab="posts">
                    <i class="fas fa-newspaper"></i> Posts
                </a>
                <a class="nav-link" href="#about" data-tab="about">
                    <i class="fas fa-info-circle"></i> About
                </a>
                <a class="nav-link" href="#rules" data-tab="rules">
                    <i class="fas fa-gavel"></i> Rules
                </a>
                <a class="nav-link" href="#members" data-tab="members">
                    <i class="fas fa-users"></i> Members
                </a>
            </nav>
            <div class="sort-options">
                <select class="form-select form-select-sm">
                    <option value="hot">🔥 Hot</option>
                    <option value="new">🆕 New</option>
                    <option value="top">⭐ Top</option>
                    <option value="rising">📈 Rising</option>
                </select>
            </div>
        </div>

        <!-- Tab Content -->
        <div class="tab-content">
            <!-- Posts Tab -->
            <div class="tab-pane active" id="posts-content">
                <!-- Create Post Section -->
                <div class="create-post-section">
                    <a asp-controller="Post"
                       asp-action="CreateTest"
                       asp-route-communitySlug="@Model.Community.Slug"
                       asp-route-returnUrl="@Context.Request.Path"
                       class="btn create-post-btn">
                        <i class="fas fa-plus"></i> Create Post
                    </a>
                </div>


                <!-- Posts List -->
                <div class="posts-container">
                    @if (Model.Posts?.Posts != null && Model.Posts.Posts.Any())
                    {
                        var postIndex = 0;
                        @foreach (var post in Model.Posts.Posts)
                        {
                            postIndex++;
                            <div class="post-item-detailed">
                                <div class="post-stats">
                                    <button class="vote-button" data-vote="up">
                                        <i class="fas fa-chevron-up"></i>
                                    </button>
                                    <div class="vote-count">@post.Score</div>
                                    <button class="vote-button" data-vote="down">
                                        <i class="fas fa-chevron-down"></i>
                                    </button>
                                </div>
                                <div class="post-main-content">
                                    <h3><a href="@post.PostUrl">@post.Title</a></h3>
                                    @if (!string.IsNullOrEmpty(post.Content))
                                    {
                                        <p class="post-excerpt">@post.Excerpt</p>
                                    }
                                    <div class="post-meta">
                                        <div class="post-info">
                                            <span><i class="fas fa-user"></i> u/@post.AuthorDisplayName</span>
                                            <span><i class="fas fa-clock"></i> @post.TimeAgo</span>
                                            <span><i class="fas fa-comment"></i> @post.FormattedCommentCount comments</span>
                                            <span><i class="fas fa-eye"></i> @post.FormattedViewCount views</span>
                                        </div>
                                        @if (post.Tags.Any())
                                        {
                                            <div class="post-tags">
                                                @foreach (var tag in post.Tags.Take(3))
                                                {
                                                    <span class="tag">@tag</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <div class="post-actions mt-2">
                                        <div class="dropdown d-inline-block">
                                            <button class="btn btn-sm btn-link text-muted p-0 dropdown-toggle" 
                                                    type="button" 
                                                    data-bs-toggle="dropdown" 
                                                    aria-expanded="false"
                                                    style="font-size: 0.875rem;">
                                                <i class="fas fa-ellipsis-h"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-start shadow-sm" style="min-width: 200px;">
                                                <li>
                                                    <a class="dropdown-item share-post-item" 
                                                       href="#" 
                                                       data-share-url="@($"{Context.Request.Scheme}://{Context.Request.Host}{post.PostUrl}")"
                                                       data-share-title="@post.Title"
                                                       data-content-type="post"
                                                       data-content-id="@post.PostId"
                                                       onclick="sharePostFromDropdown(this); return false;">
                                                        <i class="fas fa-share me-2"></i> Share
                                                    </a>
                                                </li>
                                                @if (User.Identity?.IsAuthenticated == true)
                                                {
                                                    <li>
                                                        <a class="dropdown-item save-post-item" 
                                                           href="#" 
                                                           data-post-id="@post.PostId"
                                                           onclick="savePostFromDropdown(this); return false;">
                                                            <i class="far fa-bookmark me-2"></i> Save
                                                        </a>
                                                    </li>
                                                }
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <a class="dropdown-item" href="#" onclick="return false;">
                                                        <i class="fas fa-flag me-2"></i> Report
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" href="#" onclick="return false;">
                                                        <i class="fas fa-eye-slash me-2"></i> Hide
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <a class="dropdown-item" 
                                                       href="#" 
                                                       onclick="copyPostLink('@($"{Context.Request.Scheme}://{Context.Request.Host}{post.PostUrl}")'); return false;">
                                                        <i class="fas fa-link me-2"></i> Copy Link
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            @* In-Feed Ad after every 4th post *@
                            @if (postIndex % 4 == 0)
                            {
                                <div class="ad-in-feed my-3">
                                    <partial name="_AdUnit_InArticle" />
                                </div>
                            }
                        }
                    }
                    else
                    {
                        <div class="no-posts-message">
                            <div class="icon">
                                <i class="fas fa-newspaper"></i>
                            </div>
                            <h3>No posts yet</h3>
                            <p>Be the first to share something with this community!</p>
                            <a href="/posts/create?community=@Model.Community.Slug" class="btn">
                                <i class="fas fa-plus"></i> Create the first post
                            </a>
                        </div>
                    }

                    @if (Model.Posts?.Posts != null && Model.Posts.Posts.Any())
                    {
                        <div class="load-more-section">
                            <button class="btn load-more-btn">
                                <i class="fas fa-chevron-down"></i> Load More Posts
                            </button>
                        </div>
                    }
                </div>
            </div>

            <!-- About Tab -->
            <div class="tab-pane" id="about-content">
                <div class="about-section">
                    <h3>About This Community</h3>
                    <div class="about-content">
                        @if (!string.IsNullOrEmpty(Model.Community.Description))
                        {
                            <p>@Html.Raw(Model.Community.Description.Replace("\n", "<br>"))</p>
                        }
                        else
                        {
                            <p>@Model.Community.ShortDescription</p>
                        }
                    </div>

                    <div class="community-stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-users"></i></div>
                            <div class="stat-info">
                                <div class="stat-number">@Model.Community.FormattedMemberCount</div>
                                <div class="stat-label">Members</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-newspaper"></i></div>
                            <div class="stat-info">
                                <div class="stat-number">@Model.Community.FormattedPostCount</div>
                                <div class="stat-label">Posts</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-calendar"></i></div>
                            <div class="stat-info">
                                <div class="stat-number">@Model.Community.CreatedAt.ToString("MMM yyyy")</div>
                                <div class="stat-label">Created</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Rules Tab -->
            <div class="tab-pane" id="rules-content">
                <div class="rules-section">
                    <div class="rules-header">
                        <h3>Community Rules</h3>
                        <div class="rules-actions">
                            @if (Model.Community.IsCurrentUserModerator)
                            {
                                <a href="/r/@Model.Community.Slug/rules" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-edit"></i> Edit Rules
                                </a>
                            }
                            <button class="btn btn-outline-secondary btn-sm" onclick="reportRuleViolation()">
                                <i class="fas fa-flag"></i> Report Violation
                            </button>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Community.Rules))
                    {
                        <div class="rules-content">
                            @{
                                var rules = Model.Community.Rules.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                                var ruleNumber = 1;
                            }
                            @foreach (var rule in rules)
                            {
                                if (!string.IsNullOrWhiteSpace(rule))
                                {
                                    <div class="rule-item">
                                        <div class="rule-number">@ruleNumber</div>
                                        <div class="rule-text">@rule.Trim()</div>
                                        <div class="rule-actions">
                                            <button class="btn btn-sm btn-outline-primary" onclick="copyRuleLink(@ruleNumber)">
                                                <i class="fas fa-link"></i>
                                            </button>
                                        </div>
                                    </div>
                                    ruleNumber++;
                                }
                            }
                        </div>
                        
                        <div class="rules-footer">
                            <div class="rules-note">
                                <i class="fas fa-info-circle"></i>
                                <span>These rules help maintain a positive community environment. Please follow them to ensure everyone has a great experience.</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="no-rules">
                            <div class="no-rules-icon">
                                <i class="fas fa-gavel"></i>
                            </div>
                            <h4>No Rules Yet</h4>
                            <p>This community hasn't established specific rules yet. Please follow general community guidelines and be respectful to other members.</p>
                            @if (Model.Community.IsCurrentUserModerator)
                            {
                                <a href="/r/@Model.Community.Slug/rules" class="btn btn-primary">
                                    <i class="fas fa-plus"></i> Create First Rule
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Members Tab -->
            <div class="tab-pane" id="members-content">
                <div class="members-section">
                    <h3>Community Members</h3>
                    <div class="members-grid">
                        @if (Model.Community.Moderators != null && Model.Community.Moderators.Any())
                        {
                            @foreach (var moderator in Model.Community.Moderators)
                            {
                                <div class="member-card">
                                    <div class="member-avatar">@moderator.DisplayName?.Substring(0, 2).ToUpper()</div>
                                    <div class="member-info">
                                        <div class="member-name">@moderator.DisplayName</div>
                                        <div class="member-role">@moderator.Role</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="no-members">
                                <i class="fas fa-users"></i>
                                <p>No moderators to display.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Google AdSense Banner -->
        <div class="ad-banner-section">
            <div class="ad-label">Advertisement</div>
            <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-xxxxxxxxxxxxxxxx"
                 data-ad-slot="xxxxxxxxxx"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>
                (adsbygoogle = window.adsbygoogle || []).push({});
            </script>
        </div>
    </main>

    <!-- Right Sidebar -->
    <aside class="right-sidebar">
        @if (Model.Community.IsCurrentUserModerator)
        {
            <!-- Moderator Control Panel -->
            <div class="sidebar-section moderator-panel">
                <div class="moderator-panel-header">
                    <h3><i class="fas fa-shield-alt"></i> Moderator Tools</h3>
                    <span class="badge bg-warning text-dark">@(Model.Community.CurrentUserRole?.ToUpper() ?? "MOD")</span>
                </div>
                <div class="moderator-actions">
                    <a href="/r/@Model.Community.Slug/settings" class="mod-action-btn">
                        <i class="fas fa-cog"></i>
                        <span>Community Settings</span>
                    </a>
                    <a href="/r/@Model.Community.Slug/members" class="mod-action-btn">
                        <i class="fas fa-users-cog"></i>
                        <span>Manage Members</span>
                    </a>
                    <a href="/r/@Model.Community.Slug/rules" class="mod-action-btn">
                        <i class="fas fa-gavel"></i>
                        <span>Edit Rules</span>
                    </a>
                    <button class="mod-action-btn" data-bs-toggle="modal" data-bs-target="#editCommunityModal">
                        <i class="fas fa-edit"></i>
                        <span>Edit Details</span>
                    </button>
                    <a href="/r/@Model.Community.Slug/analytics" class="mod-action-btn">
                        <i class="fas fa-chart-bar"></i>
                        <span>View Analytics</span>
                    </a>
                    <a href="/r/@Model.Community.Slug/filters" class="mod-action-btn">
                        <i class="fas fa-filter"></i>
                        <span>Content Filters</span>
                    </a>
                </div>
                <div class="mod-quick-stats mt-3">
                    <div class="mod-stat-item">
                        <i class="fas fa-flag text-danger"></i>
                        <span>0 Reports</span>
                    </div>
                    <div class="mod-stat-item">
                        <i class="fas fa-clock text-warning"></i>
                        <span>0 Pending</span>
                    </div>
                </div>
            </div>
        }
        
        <!-- Community Quick Stats -->
        <div class="sidebar-section">
            <h3><i class="fas fa-chart-line"></i> Quick Stats</h3>
            <div class="stats">
                <ul>
                    <li><i class="fas fa-users"></i> <span>@Model.Community.FormattedMemberCount Members</span></li>
                    <li><i class="fas fa-newspaper"></i> <span>@Model.Community.FormattedPostCount Posts</span></li>
                    <li><i class="fas fa-calendar"></i> <span>Created @Model.Community.CreatedAt.ToString("MMM yyyy")</span></li>
                </ul>
            </div>
        </div>

        <!-- Sidebar Ad: discussionSide -->
        <div class="sidebar-section">
            <partial name="_AdUnit_Side" />
        </div>
        
        <!-- Second Sidebar Ad: Display -->
        <div class="sidebar-section mt-3">
            <partial name="_AdUnit_Display" />
        </div>

        <!-- Community Guidelines -->
        <div class="sidebar-section">
            <h3><i class="fas fa-shield-alt"></i> Guidelines</h3>
            <div class="guidelines-list">
                <div class="guideline-item">
                    <i class="fas fa-check-circle text-success"></i>
                    <span>Be respectful to all members</span>
                </div>
                <div class="guideline-item">
                    <i class="fas fa-check-circle text-success"></i>
                    <span>Stay on topic</span>
                </div>
                <div class="guideline-item">
                    <i class="fas fa-check-circle text-success"></i>
                    <span>No spam or self-promotion</span>
                </div>
                <div class="guideline-item">
                    <i class="fas fa-check-circle text-success"></i>
                    <span>Use appropriate language</span>
                </div>
            </div>
        </div>
    </aside>
</div>

<!-- Edit Community Modal -->
<div class="modal fade" id="editCommunityModal" tabindex="-1" aria-labelledby="editCommunityModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editCommunityModalLabel">
                    <i class="fas fa-edit"></i> Edit Community
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Update" asp-controller="Community" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Community.CommunityId" />
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Community.Name" class="form-label">Community Name</label>
                                <input asp-for="Community.Name" class="form-control" readonly />
                                <div class="form-text">Community name cannot be changed</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Community.Title" class="form-label">Title</label>
                                <input asp-for="Community.Title" class="form-control" />
                                <span asp-validation-for="Community.Title" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Community.ShortDescription" class="form-label">Short Description</label>
                        <textarea asp-for="Community.ShortDescription" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Community.ShortDescription" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Community.Description" class="form-label">Full Description</label>
                        <textarea asp-for="Community.Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Community.Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Community.CommunityType" class="form-label">Community Type</label>
                                <select asp-for="Community.CommunityType" class="form-select">
                                    <option value="public">Public</option>
                                    <option value="private">Private</option>
                                    <option value="restricted">Restricted</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Community.ThemeColor" class="form-label">Theme Color</label>
                                <input asp-for="Community.ThemeColor" type="color" class="form-control form-control-color" />
                            </div>
                        </div>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="Community.IsNSFW" class="form-check-input" type="checkbox" />
                        <label asp-for="Community.IsNSFW" class="form-check-label">
                            NSFW Content
                        </label>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Community.Rules" class="form-label">Community Rules</label>
                        <textarea asp-for="Community.Rules" class="form-control" rows="6" placeholder="Enter community rules, one per line..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tab switching functionality
        document.querySelectorAll('[data-tab]').forEach(tab => {
            tab.addEventListener('click', function(e) {
                e.preventDefault();

                // Remove active class from all tabs and content
                document.querySelectorAll('.nav-link').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.tab-pane').forEach(c => c.classList.remove('active'));

                // Add active class to clicked tab
                this.classList.add('active');

                // Show corresponding content
                const tabId = this.getAttribute('data-tab') + '-content';
                document.getElementById(tabId).classList.add('active');
            });
        });

        // Join community functionality
        const joinBtn = document.getElementById('joinCommunityBtn');
        if (joinBtn) {
            joinBtn.addEventListener('click', async function() {
                const btn = this;
                const communityId = parseInt(btn.getAttribute('data-community-id'));
                const isMember = btn.getAttribute('data-is-member') === 'true';
                
                // Disable button during request
                btn.disabled = true;
                const originalHtml = btn.innerHTML;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';

                try {
                    const response = await fetch('/api/community/togglemembership', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ communityId: communityId })
                    });

                    const result = await response.json();
                    console.log('Toggle membership result:', result);

                    if (result.success) {
                        // Toggle UI state
                        if (isMember) {
                            // Was member, now left
                            btn.innerHTML = '<i class="fas fa-plus"></i> Join Community';
                            btn.classList.remove('btn-outline-light');
                            btn.classList.add('btn-primary');
                            btn.setAttribute('data-is-member', 'false');
                            
                            // Update member count
                            const memberCountElement = document.querySelector('.stats li span');
                            if (memberCountElement) {
                                const currentCount = parseInt(memberCountElement.textContent.replace(/,/g, '').split(' ')[0]);
                                memberCountElement.textContent = (currentCount - 1).toLocaleString() + ' Members';
                            }
                        } else {
                            // Was not member, now joined
                            btn.innerHTML = '<i class="fas fa-check"></i> Joined';
                            btn.classList.remove('btn-primary');
                            btn.classList.add('btn-outline-light');
                            btn.setAttribute('data-is-member', 'true');
                            
                            // Update member count
                            const memberCountElement = document.querySelector('.stats li span');
                            if (memberCountElement) {
                                const currentCount = parseInt(memberCountElement.textContent.replace(/,/g, '').split(' ')[0]);
                                memberCountElement.textContent = (currentCount + 1).toLocaleString() + ' Members';
                            }
                        }
                    } else {
                        alert(result.message || 'Failed to update membership');
                        btn.innerHTML = originalHtml;
                    }
                } catch (error) {
                    console.error('Error toggling membership:', error);
                    alert('An error occurred. Please try again.');
                    btn.innerHTML = originalHtml;
                } finally {
                    btn.disabled = false;
                }
            });
        }

        // Vote functionality
        document.querySelectorAll('.vote-button').forEach(button => {
            button.addEventListener('click', function() {
                const voteType = this.getAttribute('data-vote');
                const postStats = this.closest('.post-stats');
                const upButton = postStats.querySelector('[data-vote="up"]');
                const downButton = postStats.querySelector('[data-vote="down"]');

                // Toggle vote state
                if (voteType === 'up') {
                    upButton.classList.toggle('upvoted');
                    downButton.classList.remove('downvoted');
                } else {
                    downButton.classList.toggle('downvoted');
                    upButton.classList.remove('upvoted');
                }
            });
        });

        // Dark mode toggle
        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('darkMode', document.body.classList.contains('dark-mode'));
        }

        // Load dark mode preference
        if (localStorage.getItem('darkMode') === 'true') {
            document.body.classList.add('dark-mode');
        }

        // Load more posts functionality
        document.querySelector('.load-more-btn')?.addEventListener('click', function() {
            // Simulate loading more posts
            this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading...';
            setTimeout(() => {
                this.innerHTML = '<i class="fas fa-chevron-down"></i> Load More Posts';
            }, 1000);
        });
        
        // Load user's communities and suggestions
        document.addEventListener('DOMContentLoaded', async function() {
            await loadYourCommunities();
            await loadSuggestedCommunities();
        });
        
        async function loadYourCommunities() {
            const container = document.getElementById('yourCommunities');
            if (!container) return;
            
            try {
                const response = await fetch('/api/community/user-communities');
                const data = await response.json();
                
                if (data.success && data.communities && data.communities.length > 0) {
                    container.innerHTML = data.communities.map(c => `
                        <a href="/r/${c.slug}" class="community-item ${c.slug === '@Model.Community.Slug' ? 'active' : ''}">
                            <div class="community-icon">
                                ${c.iconUrl ? `<img src="${c.iconUrl}" alt="${c.name}">` : `<div class="icon-placeholder">${c.name.substring(0, 2).toUpperCase()}</div>`}
                            </div>
                            <div class="community-info">
                                <div class="community-name">r/${c.name}</div>
                                <div class="community-meta">
                                    <span>${formatNumber(c.memberCount)} members</span>
                                    ${c.isAdmin ? '<span class="badge badge-sm bg-danger ms-1">👑 Admin</span>' : ''}
                                    ${c.isModerator ? '<span class="badge badge-sm bg-warning ms-1">🛡️ Mod</span>' : ''}
                                </div>
                            </div>
                        </a>
                    `).join('');
                } else {
                    container.innerHTML = '<div class="text-muted small p-2">Join communities to see them here!</div>';
                }
            } catch (error) {
                console.error('Error loading your communities:', error);
                container.innerHTML = '<div class="text-muted small p-2">Failed to load</div>';
            }
        }
        
        async function loadSuggestedCommunities() {
            const container = document.getElementById('suggestedCommunities');
            if (!container) return;
            
            try {
                const response = await fetch('/api/community/suggested?limit=5&exclude=@Model.Community.CommunityId');
                const data = await response.json();
                
                if (data.success && data.communities && data.communities.length > 0) {
                    container.innerHTML = data.communities.map(c => `
                        <a href="/r/${c.slug}" class="community-item">
                            <div class="community-icon">
                                ${c.iconUrl ? `<img src="${c.iconUrl}" alt="${c.name}">` : `<div class="icon-placeholder">${c.name.substring(0, 2).toUpperCase()}</div>`}
                            </div>
                            <div class="community-info">
                                <div class="community-name">r/${c.name}</div>
                                <div class="community-meta">
                                    <span>${formatNumber(c.memberCount)} members</span>
                                    <span>•</span>
                                    <span>${formatNumber(c.postCount)} posts</span>
                                </div>
                            </div>
                        </a>
                    `).join('');
                } else {
                    container.innerHTML = '<div class="text-muted small p-2">No suggestions available</div>';
                }
            } catch (error) {
                console.error('Error loading suggested communities:', error);
                // Fallback to popular communities
                loadPopularCommunities();
            }
        }
        
        async function loadPopularCommunities() {
            const container = document.getElementById('suggestedCommunities');
            try {
                const response = await fetch('/api/community/popular?limit=5');
                const data = await response.json();
                
                if (data.communities) {
                    container.innerHTML = data.communities.map(c => `
                        <a href="/r/${c.slug}" class="community-item">
                            <div class="community-icon">
                                ${c.iconUrl ? `<img src="${c.iconUrl}" alt="${c.name}">` : `<div class="icon-placeholder">${c.name.substring(0, 2).toUpperCase()}</div>`}
                            </div>
                            <div class="community-info">
                                <div class="community-name">r/${c.name}</div>
                                <div class="community-meta">${formatNumber(c.memberCount)} members</div>
                            </div>
                        </a>
                    `).join('');
                }
            } catch (error) {
                container.innerHTML = '<div class="text-muted small p-2">Failed to load</div>';
            }
        }
        
        function formatNumber(num) {
            if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
            if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
            return num.toString();
        }

        // Rules functionality
        function reportRuleViolation() {
            // TODO: Implement rule violation reporting
            alert('Rule violation reporting will be implemented');
        }

        function copyRuleLink(ruleNumber) {
            const url = window.location.href + '#rule-' + ruleNumber;
            navigator.clipboard.writeText(url).then(() => {
                // Show success message
                const button = event.target.closest('button');
                const originalHTML = button.innerHTML;
                button.innerHTML = '<i class="fas fa-check"></i>';
                button.classList.add('btn-success');
                button.classList.remove('btn-outline-primary');
                
                setTimeout(() => {
                    button.innerHTML = originalHTML;
                    button.classList.remove('btn-success');
                    button.classList.add('btn-outline-primary');
                }, 2000);
            }).catch(() => {
                alert('Failed to copy link to clipboard');
            });
        }

        // Share community functionality
        function shareCommunity() {
            const shareUrl = '@($"{Context.Request.Scheme}://{Context.Request.Host}/r/{Model.Community.Slug}")';
            const shareTitle = '@Html.Raw(Model.Community.Title)';
            const shareDescription = '@Html.Raw(Model.Community.ShortDescription ?? Model.Community.Title)';
            
            // Try native share API first (mobile devices)
            if (navigator.share) {
                navigator.share({
                    title: shareTitle,
                    text: shareDescription,
                    url: shareUrl
                }).catch(err => {
                    if (err.name !== 'AbortError') {
                        console.log('Error sharing:', err);
                        showShareModal(shareUrl, shareTitle);
                    }
                });
            } else {
                // Fallback: Show share modal
                showShareModal(shareUrl, shareTitle);
            }
        }
        
        function showShareModal(url, title) {
            const encodedUrl = encodeURIComponent(url);
            const encodedTitle = encodeURIComponent(title);
            
            const modalHTML = `
                <div class="modal fade" id="communityShareModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="fas fa-share"></i> Share Community</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="share-options-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px;">
                                    <a href="https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}" target="_blank" rel="noopener" class="share-option text-center text-decoration-none" style="padding: 15px; border: 1px solid #ddd; border-radius: 8px; transition: all 0.2s;">
                                        <i class="fab fa-facebook-f fa-2x mb-2" style="color: #1877f2;"></i>
                                        <div class="small">Facebook</div>
                                    </a>
                                    <a href="https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}" target="_blank" rel="noopener" class="share-option text-center text-decoration-none" style="padding: 15px; border: 1px solid #ddd; border-radius: 8px; transition: all 0.2s;">
                                        <i class="fab fa-twitter fa-2x mb-2" style="color: #1da1f2;"></i>
                                        <div class="small">Twitter</div>
                                    </a>
                                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}" target="_blank" rel="noopener" class="share-option text-center text-decoration-none" style="padding: 15px; border: 1px solid #ddd; border-radius: 8px; transition: all 0.2s;">
                                        <i class="fab fa-linkedin-in fa-2x mb-2" style="color: #0077b5;"></i>
                                        <div class="small">LinkedIn</div>
                                    </a>
                                    <a href="https://reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}" target="_blank" rel="noopener" class="share-option text-center text-decoration-none" style="padding: 15px; border: 1px solid #ddd; border-radius: 8px; transition: all 0.2s;">
                                        <i class="fab fa-reddit-alien fa-2x mb-2" style="color: #ff4500;"></i>
                                        <div class="small">Reddit</div>
                                    </a>
                                    <a href="https://wa.me/?text=${encodedTitle}%20${encodedUrl}" target="_blank" rel="noopener" class="share-option text-center text-decoration-none" style="padding: 15px; border: 1px solid #ddd; border-radius: 8px; transition: all 0.2s;">
                                        <i class="fab fa-whatsapp fa-2x mb-2" style="color: #25d366;"></i>
                                        <div class="small">WhatsApp</div>
                                    </a>
                                    <a href="mailto:?subject=${encodedTitle}&body=${encodedUrl}" class="share-option text-center text-decoration-none" style="padding: 15px; border: 1px solid #ddd; border-radius: 8px; transition: all 0.2s;">
                                        <i class="fas fa-envelope fa-2x mb-2" style="color: #6c757d;"></i>
                                        <div class="small">Email</div>
                                    </a>
                                </div>
                                <hr class="my-3">
                                <div class="input-group">
                                    <input type="text" class="form-control" id="shareLinkInput" value="${url}" readonly>
                                    <button class="btn btn-outline-secondary" type="button" onclick="copyCommunityLink()">
                                        <i class="fas fa-copy"></i> Copy
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            // Remove existing modal if any
            const existingModal = document.getElementById('communityShareModal');
            if (existingModal) {
                existingModal.remove();
            }
            
            // Add modal to body
            document.body.insertAdjacentHTML('beforeend', modalHTML);
            
            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('communityShareModal'));
            modal.show();
            
            // Clean up modal after hiding
            document.getElementById('communityShareModal').addEventListener('hidden.bs.modal', function() {
                this.remove();
            });
            
            // Add hover effects
            document.querySelectorAll('.share-option').forEach(option => {
                option.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-3px)';
                    this.style.boxShadow = '0 4px 12px rgba(0,0,0,0.15)';
                });
                option.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(0)';
                    this.style.boxShadow = 'none';
                });
            });
        }
        
        function copyCommunityLink() {
            const input = document.getElementById('shareLinkInput');
            input.select();
            navigator.clipboard.writeText(input.value).then(() => {
                const button = event.target.closest('button');
                const originalHTML = button.innerHTML;
                button.innerHTML = '<i class="fas fa-check"></i> Copied!';
                button.classList.add('btn-success');
                button.classList.remove('btn-outline-secondary');
                
                setTimeout(() => {
                    button.innerHTML = originalHTML;
                    button.classList.remove('btn-success');
                    button.classList.add('btn-outline-secondary');
                }, 2000);
            }).catch(err => {
                console.error('Failed to copy:', err);
                alert('Failed to copy link to clipboard');
            });
        }
        
        // Post share from dropdown
        function sharePostFromDropdown(element) {
            const shareUrl = element.getAttribute('data-share-url');
            const shareTitle = element.getAttribute('data-share-title');
            const contentType = element.getAttribute('data-content-type');
            const contentId = element.getAttribute('data-content-id');
            
            console.log('Sharing post from dropdown:', { shareUrl, shareTitle, contentType, contentId });
            
            // Validate URL
            if (!shareUrl) {
                console.error('Share URL is missing');
                alert('Unable to share: URL not found');
                return;
            }
            
            // Use the global showShareModal function
            if (typeof showShareModal === 'function') {
                showShareModal(shareUrl, shareTitle, contentType, contentId);
            } else {
                console.error('showShareModal function not found');
                alert('Share functionality not available');
            }
        }
        
        // Save post from dropdown
        async function savePostFromDropdown(element) {
            const postId = element.getAttribute('data-post-id');
            
            if (!postId) {
                console.error('Post ID is missing');
                return;
            }
            
            try {
                const response = await fetch('/Post/ToggleSave', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ postId: parseInt(postId) })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    // Update the icon
                    const icon = element.querySelector('i');
                    if (result.isSaved) {
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        element.querySelector('i').nextSibling.textContent = ' Saved';
                        showToast('success', 'Post saved!');
                    } else {
                        icon.classList.remove('fas');
                        icon.classList.add('far');
                        element.querySelector('i').nextSibling.textContent = ' Save';
                        showToast('success', 'Post unsaved!');
                    }
                } else {
                    showToast('error', result.message || 'Failed to save post');
                }
            } catch (error) {
                console.error('Error saving post:', error);
                showToast('error', 'An error occurred while saving the post');
            }
        }
        
        // Copy post link
        function copyPostLink(url) {
            if (!url) {
                console.error('URL is missing');
                return;
            }
            
            navigator.clipboard.writeText(url).then(() => {
                showToast('success', 'Link copied to clipboard!');
            }).catch(err => {
                console.error('Failed to copy:', err);
                alert('Failed to copy link to clipboard');
            });
        }
        
        // Toast notification function
        function showToast(type, message) {
            const toastContainer = document.createElement('div');
            toastContainer.className = 'position-fixed top-0 end-0 p-3';
            toastContainer.style.zIndex = '9999';
            
            const toast = document.createElement('div');
            toast.className = `toast align-items-center text-white bg-${type === 'success' ? 'success' : 'danger'} border-0`;
            toast.setAttribute('role', 'alert');
            toast.setAttribute('aria-live', 'assertive');
            toast.setAttribute('aria-atomic', 'true');
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>
                        ${message}
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            `;
            
            toastContainer.appendChild(toast);
            document.body.appendChild(toastContainer);
            
            const bsToast = new bootstrap.Toast(toast, { delay: 3000 });
            bsToast.show();
            
            // Remove toast container after it's hidden
            toast.addEventListener('hidden.bs.toast', () => {
                toastContainer.remove();
            });
        }
    </script>
}
