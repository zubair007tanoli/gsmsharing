<!-- Edit Community Modal -->
<div class="modal fade" id="editCommunityModal" tabindex="-1" aria-labelledby="editCommunityModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editCommunityModalLabel">
                    <i class="fas fa-edit"></i> Edit Community
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Update" asp-controller="Community" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Name" class="form-label">Community Name</label>
                                <input asp-for="Name" class="form-control" readonly />
                                <div class="form-text">Community name cannot be changed</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Title" class="form-label">Title</label>
                                <input asp-for="Title" class="form-control" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ShortDescription" class="form-label">Short Description</label>
                        <textarea asp-for="ShortDescription" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="ShortDescription" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="form-label">Full Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="CategoryId" class="form-label">Category</label>
                                <select asp-for="CategoryId" class="form-select">
                                    <option value="">Select Category</option>
                                    @foreach (var category in Model.AvailableCategories)
                                    {
                                        <option value="@category.CategoryId">@category.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="CommunityType" class="form-label">Community Type</label>
                                <select asp-for="CommunityType" class="form-select">
                                    <option value="public">Public</option>
                                    <option value="private">Private</option>
                                    <option value="restricted">Restricted</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="ThemeColor" class="form-label">Theme Color</label>
                                <input asp-for="ThemeColor" type="color" class="form-control form-control-color" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mt-4">
                                <input asp-for="IsNSFW" class="form-check-input" type="checkbox" />
                                <label asp-for="IsNSFW" class="form-check-label">
                                    NSFW Content
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="IconFile" class="form-label">Community Icon</label>
                                <input asp-for="IconFile" type="file" class="form-control" accept="image/*" />
                                <div class="form-text">Recommended: 256x256px, PNG or JPG</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="BannerFile" class="form-label">Community Banner</label>
                                <input asp-for="BannerFile" type="file" class="form-control" accept="image/*" />
                                <div class="form-text">Recommended: 1920x384px, PNG or JPG</div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Rules" class="form-label">Community Rules</label>
                        <textarea asp-for="Rules" class="form-control" rows="6" placeholder="Enter community rules, one per line..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tab switching functionality
        document.querySelectorAll('[data-tab]').forEach(tab => {
            tab.addEventListener('click', function(e) {
                e.preventDefault();

                // Remove active class from all tabs and content
                document.querySelectorAll('.nav-link').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.tab-pane').forEach(c => c.classList.remove('active'));

                // Add active class to clicked tab
                this.classList.add('active');

                // Show corresponding content
                const tabId = this.getAttribute('data-tab') + '-content';
                document.getElementById(tabId).classList.add('active');
            });
        });

        // Join community functionality
        document.getElementById('joinCommunityBtn').addEventListener('click', function() {
            const btn = this;
            const isJoined = btn.textContent.includes('Leave');

            if (isJoined) {
                btn.innerHTML = '<i class="fas fa-plus"></i> Join Community';
                btn.classList.remove('btn-danger');
                btn.classList.add('btn-primary');
            } else {
                btn.innerHTML = '<i class="fas fa-check"></i> Leave Community';
                btn.classList.remove('btn-primary');
                btn.classList.add('btn-danger');
            }
        });

        // Dark mode toggle
        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('darkMode', document.body.classList.contains('dark-mode'));
        }

        // Load dark mode preference
        if (localStorage.getItem('darkMode') === 'true') {
            document.body.classList.add('dark-mode');
        }

        // Image preview for file uploads
        function previewImage(input, previewId) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById(previewId).src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Load more posts functionality
        document.querySelector('.load-more-btn')?.addEventListener('click', function() {
            // Simulate loading more posts
            this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading...';
            setTimeout(() => {
                this.innerHTML = '<i class="fas fa-chevron-down"></i> Load More Posts';
            }, 1000);
        });

        // Form validation
        document.querySelector('form')?.addEventListener('submit', function(e) {
            const requiredFields = this.querySelectorAll('[required]');
            let isValid = true;

            requiredFields.forEach(field => {
                if (!field.value.trim()) {
                    field.classList.add('is-invalid');
                    isValid = false;
                } else {
                    field.classList.remove('is-invalid');
                }
            });

            if (!isValid) {
                e.preventDefault();
                alert('Please fill in all required fields.');
            }
        });
    </script>
}

<style>
    /* Additional styles for community page */
    .community-header {
        position: relative;
        color: white;
        padding: 2rem 0;
        margin-bottom: 0;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }

    .community-banner {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-size: cover;
        background-position: center;
        opacity: 0.3;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }

    .community-header-content {
        position: relative;
        z-index: 2;
        padding: 0 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 2rem;
    }

    .community-info {
        display: flex;
        gap: 1.5rem;
        align-items: flex-end;
    }

    .community-avatar {
        width: 5rem;
        height: 5rem;
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 3px solid white;
        background-color: white;
    }

    .community-icon-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .community-icon-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--primary-color);
        color: white;
        font-size: 1.5rem;
    }

    .community-title {
