@model discussionspot9.Models.ViewModels.CreativeViewModels.CommunityListViewModel
@using discussionspot9.Helpers
@{
    ViewData["Title"] = "Communities - DiscussionSpot";
}

@section Styles {
    <link rel="stylesheet" href="~/css/community-pages.css" />
}
<main class="page-wrap">
    <div class="container">
        <!-- Toolbar -->
        <section class="d-flex flex-wrap toolbar align-items-center justify-content-between mb-4" aria-label="Search and actions">
            <div class="d-flex flex-grow-1 me-2 search-wrap">
                <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M21 21l-4.3-4.3M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
                </svg>
                <input class="form-control ui-ctl" type="search" placeholder="Search communities by name or topic..." aria-label="Search communities" />
            </div>
            <div class="d-flex align-items-center gap-2 sort-wrap">
                <label for="sort" class="small text-secondary d-none d-md-inline">Sort</label>
                <select id="sort" class="form-select ui-ctl ui-btn-minw" aria-label="Sort communities">
                    <option value="trending">Sort: Trending</option>
                    <option value="newest">Newest</option>
                    <option value="active">Most Active</option>
                    <option value="members">Most Members</option>
                </select>
            </div>
        </section>

        <!-- 3-column layout -->
        <div class="row g-4">
            <!-- Left Sidebar -->
            <aside class="col-12 col-lg-3" aria-label="Filters">
                <div class="side-block p-3 mb-3">
                    <h2 class="h6 mb-3">Filters</h2>
                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <select class="form-select" onchange="filterByCategory(this.value)">
                            <option value="">All</option>
                            @foreach (var category in Model.CategoryCounts)
                            {
                                <option value="@category.Key">@category.Key (@category.Value)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Minimum Members</label>
                        <input type="number" class="form-control" placeholder="e.g. 1000" />
                    </div>
                    <div>
                        <label class="form-label">Active Posts</label>
                        <div class="d-flex flex-wrap gap-2">
                            <span class="tag">Daily</span>
                            <span class="tag">Weekly</span>
                            <span class="tag">Monthly</span>
                        </div>
                    </div>
                </div>

                <div class="side-block p-3 mb-3">
                    <h2 class="h6 mb-3">Trending Tags</h2>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="#" class="tag text-decoration-none">AI</a>
                        <a href="#" class="tag text-decoration-none">React</a>
                        <a href="#" class="tag text-decoration-none">Crypto</a>
                        <a href="#" class="tag text-decoration-none">Startups</a>
                        <a href="#" class="tag text-decoration-none">Photography</a>
                        <a href="#" class="tag text-decoration-none">Books</a>
                    </div>
                </div>

                <!-- Ad slot (sidebar) -->
                <div class="ad-slot mb-3" role="complementary" aria-label="Advertisement">
                    <!-- Replace with real AdSense snippet -->
                    <span>Ad — 300 × 250</span>
                </div>
            </aside>

            <!-- Main Content -->
            <section class="col-12 col-lg-6" aria-label="Community directory">
                <h1 class="h4 mb-3 text-balance">Discover Communities</h1>
                <p class="text-secondary mb-4">Browse popular groups by topic. See member counts and post volume at a glance.</p>

                <!-- Ad slot (in-feed) -->
                <div class="ad-slot mb-3" role="complementary" aria-label="Advertisement">
                    <span>In-Feed Ad — Responsive</span>
                </div>
@if (Model.Communities != null && Model.Communities.Any())
{
    <div class="vstack gap-3">
        @foreach (var community in Model.Communities)
        {
            <article class="card community-card">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div class="d-flex align-items-start gap-3">
                            <img class="avatar" src="@(string.IsNullOrEmpty(community.IconUrl) ? "/placeholder.svg?height=48&width=48" : community.IconUrl)" 
                                 alt="@community.Name community icon" />
                            <div>
                                <h2 class="h6 mb-1">
                                    <a href="/r/@community.Slug" class="text-decoration-none">@community.Name</a>
                                </h2>
                                <p class="mb-2 text-secondary">@community.Description</p>
                                <div class="d-flex flex-wrap gap-2">
                                    <span class="metric" aria-label="Members">
                                        <span class="visually-hidden">Members:</span>
                                        <strong>@community.MemberCount.ToString("N0")</strong> members
                                    </span>
                                    <span class="metric" aria-label="Posts">
                                        <span class="visually-hidden">Posts:</span>
                                        <strong>@community.PostCount.ToString("N0")</strong> posts
                                    </span>
                                    @if (community.OnlineMembers > 0)
                                    {
                                        <span class="metric" aria-label="Active now">
                                            <span class="visually-hidden">Active users now:</span>
                                            <strong>@community.OnlineMembers.ToString("N0")</strong> online
                                        </span>
                                    }
                                </div>
                                @if (community.Categories != null && community.Categories.Any())
                                {
                                    <div class="d-flex flex-wrap gap-2 mt-2">
                                        @foreach (var cat in community.Categories.Take(3))
                                        {
                                            <span class="tag">@cat</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="ms-3">
                            @if (User.Identity.IsAuthenticated)
                            {
                                @if (community.IsCurrentUserMember)
                                {
                                    <button class="btn btn-outline-secondary btn-sm" onclick="toggleMembership(@community.CommunityId)">Leave</button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-primary btn-sm" onclick="toggleMembership(@community.CommunityId)">Join</button>
                                }
                            }
                            else
                            {
                                <a href="/Identity/Account/Login" class="btn btn-outline-primary btn-sm">Join</a>
                            }
                        </div>
                    </div>
                </div>
            </article>
        }

        @if (Model.TotalPages > 1)
        {
            <div class="text-center">
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <button class="btn btn-secondary" onclick="loadMoreCommunities(@(Model.CurrentPage + 1))">
                        Load more (@(Model.TotalCount - (Model.CurrentPage * 12)) remaining)
                    </button>
                }
            </div>
        }
    </div>
}         
            
            </section>

            <!-- Right Sidebar -->
            <aside class="col-12 col-lg-3" aria-label="Featured and ads">
                <!-- Ad slot -->
                <div class="ad-slot mb-3" role="complementary" aria-label="Advertisement">
                    <span>Ad — 300 × 600</span>
                </div>

                <!-- Featured communities -->
                <div class="side-block p-3 mb-3">
                    <h2 class="h6 mb-3">Featured Communities</h2>

                    <div class="featured-item">
                        <img src="/placeholder.svg?height=36&width=36" alt="" />
                        <div>
                            <a href="#" class="text-decoration-none d-block">DataLab</a>
                            <small class="text-secondary">54k members</small>
                        </div>
                    </div>

                    <div class="featured-item">
                        <img src="/placeholder.svg?height=36&width=36" alt="" />
                        <div>
                            <a href="#" class="text-decoration-none d-block">LightRoom</a>
                            <small class="text-secondary">31k members</small>
                        </div>
                    </div>

                    <div class="featured-item">
                        <img src="/placeholder.svg?height=36&width=36" alt="" />
                        <div>
                            <a href="#" class="text-decoration-none d-block">FintechOps</a>
                            <small class="text-secondary">27k members</small>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions feature card -->
                <div class="side-block p-3 mb-3">
                    <h2 class="h6 mb-3">Quick Actions</h2>
                    <div class="vstack gap-2">
                        <button class="btn btn-outline-secondary ui-btn w-100" type="button" title="My Communities" aria-label="My Communities" onclick="window.location.href='/communities'">
                            <i class="fa-solid fa-users" aria-hidden="true"></i>
                            <span class="label">My Communities</span>
                        </button>
                        <a href="/create" class="btn btn-secondary ui-btn w-100" title="New Post" aria-label="New Post">
                            <i class="fa-regular fa-pen-to-square" aria-hidden="true"></i>
                            <span class="label">New Post</span>
                        </a>
                        <a href="/create-community" class="btn btn-primary ui-btn w-100" title="Create Community" aria-label="Create Community">
                            <i class="fa-solid fa-plus" aria-hidden="true"></i>
                            <span class="label">Create Community</span>
                        </a>

                        <hr class="my-2" />

                        <button class="btn btn-outline-primary ui-btn w-100" type="button">
                            <i class="fa-regular fa-comments" aria-hidden="true"></i>
                            <span class="label">Start a Discussion</span>
                        </button>
                        <button class="btn btn-outline-secondary ui-btn w-100" type="button">
                            <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
                            <span class="label">Invite Friends</span>
                        </button>
                        <button class="btn btn-outline-secondary ui-btn w-100" type="button">
                            <i class="fa-solid fa-bell" aria-hidden="true"></i>
                            <span class="label">Manage Subscriptions</span>
                        </button>
                    </div>
                </div>

                <!-- Top Contributors card for engagement -->
                <div class="side-block p-3 mb-3">
                    <h2 class="h6 mb-3">Top Contributors</h2>
                    <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                        <div class="d-flex align-items-center gap-2">
                            <img src="/placeholder-user.jpg" alt="" width="28" height="28" style="border-radius:50%;object-fit:cover" />
                            <span>Avi</span>
                        </div>
                        <small class="text-secondary">1.2k pts</small>
                    </div>
                    <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                        <div class="d-flex align-items-center gap-2">
                            <img src="/placeholder-user.jpg" alt="" width="28" height="28" style="border-radius:50%;object-fit:cover" />
                            <span>Nina</span>
                        </div>
                        <small class="text-secondary">980 pts</small>
                    </div>
                    <div class="d-flex align-items-center justify-content-between py-2">
                        <div class="d-flex align-items-center gap-2">
                            <img src="/placeholder-user.jpg" alt="" width="28" height="28" style="border-radius:50%;object-fit:cover" />
                            <span>Omar</span>
                        </div>
                        <small class="text-secondary">864 pts</small>
                    </div>
                </div>

                <!-- Newsletter / CTA -->
                <div class="side-block p-3">
                    <h2 class="h6 mb-2">Weekly Highlights</h2>
                    <p class="text-secondary">Top posts and communities, delivered every Friday.</p>
                    <form class="vstack gap-2" aria-label="Subscribe to highlights">
                        <label for="email" class="visually-hidden">Email address</label>
                        <input id="email" type="email" class="form-control" placeholder="you@example.com" />
                        <button class="btn btn-primary w-100" type="button">Subscribe</button>
                    </form>
                </div>
            </aside>
        </div>
    </div>
</main>
@section Scripts {
    <script>
        function toggleMembership(communityId) {
            @if (!User.Identity.IsAuthenticated)
            {
                    <text>
                    window.location.href = '/Identity/Account/Login';
                    return;
                    </text>
            }

            fetch('/api/community/togglemembership', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ communityId: communityId })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Failed to update membership');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('An error occurred while updating membership');
            });
        }

        function filterByCategory(category) {
            const url = new URL(window.location);
            if (category) {
                url.searchParams.set('category', category);
            } else {
                url.searchParams.delete('category');
            }
            url.searchParams.delete('page'); // Reset to page 1
            window.location.href = url.toString();
        }

        function updateSort(sortValue) {
            const url = new URL(window.location);
            url.searchParams.set('sort', sortValue);
            url.searchParams.delete('page'); // Reset to page 1
            window.location.href = url.toString();
        }

        function loadMoreCommunities(page) {
            const url = new URL(window.location);
            url.searchParams.set('page', page);
            window.location.href = url.toString();
        }

        // Update sort dropdown on page load
        document.addEventListener('DOMContentLoaded', function() {
            const sortSelect = document.getElementById('sort');
            if (sortSelect) {
                sortSelect.value = '@Model.CurrentSort';
                sortSelect.addEventListener('change', function() {
                    updateSort(this.value);
                });
            }
        });
    </script>
}
