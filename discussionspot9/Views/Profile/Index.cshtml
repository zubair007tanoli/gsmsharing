                            <input asp-for="AvatarUrl" class="form-control" type="url" />
                            <span asp-validation-for="AvatarUrl" class="text-danger"></span>
                            <div class="form-text">URL to your profile picture.</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="BannerUrl" class="form-label"></label>
                            <input asp-for="BannerUrl" class="form-control" type="url" />
                            <span asp-validation-for="BannerUrl" class="text-danger"></span>
                            <div class="form-text">URL to your profile banner image.</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Website" class="form-label"></label>
                            <input asp-for="Website" class="form-control" type="url" />
                            <span asp-validation-for="Website" class="text-danger"></span>
                            <div class="form-text">Your personal website or social media link.</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Location" class="form-label"></label>
                            <input asp-for="Location" class="form-control" />
