@model List<discussionspot9.Models.Domain.UserProfile>
@{
    ViewData["Title"] = "User Management";
    var activities = ViewBag.UserActivities as Dictionary<string, int>;
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h2">👥 User Management</h1>
            <p class="text-muted">Manage and monitor all users - Total: @ViewBag.TotalUsers</p>
        </div>
        <div class="col-auto">
            <a href="@Url.Action("Dashboard", "SeoAdmin")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Search Bar -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-10">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by username or bio..." />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Karma</th>
                            <th>Joined</th>
                            <th>Last Active</th>
                            <th>Activity (30d)</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            var activityCount = activities?.GetValueOrDefault(user.UserId, 0) ?? 0;
                            var isActive = user.LastActive >= DateTime.UtcNow.AddDays(-7);

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-2" style="width: 40px; height: 40px; background: #007bff; color: white; display: flex; align-items: center; justify-content: center; border-radius: 50%;">
                                            @(user.DisplayName?.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <strong>@user.DisplayName</strong><br/>
                                            @if (user.IsVerified)
                                            {
                                                <span class="badge bg-primary">✓ Verified</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-warning">@user.KarmaPoints pts</span>
                                </td>
                                <td>
                                    <small>@user.JoinDate.ToString("MMM dd, yyyy")</small>
                                </td>
                                <td>
                                    <small>@user.LastActive.ToString("MMM dd, yyyy")</small>
                                </td>
                                <td>
                                    <span class="badge bg-info">@activityCount actions</span>
                                </td>
                                <td>
                                    @if (isActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (ViewBag.TotalPages > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" href="?page=@i&search=@ViewBag.Search">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

