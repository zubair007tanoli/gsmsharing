@model List<discussionspot9.Models.Domain.UserActivity>
@{
    ViewData["Title"] = "User Activities";
    ViewData["PageTitle"] = "User Activities Dashboard";
    ViewData["PageDescription"] = "Track and analyze user behavior and engagement";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    
    var activityStats = ViewBag.ActivityStats as Dictionary<string, int> ?? new Dictionary<string, int>();
    var topActiveUsers = ViewBag.TopActiveUsers as List<discussionspot9.Services.UserActivitySummary> ?? new List<discussionspot9.Services.UserActivitySummary>();
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var days = ViewBag.Days as int? ?? 30;
    var userId = ViewBag.UserId as string;
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h2">📊 User Activities</h1>
            <p class="text-muted">Track user behavior and engagement metrics</p>
        </div>
        <div class="col-auto">
            <a href="@Url.Action("Dashboard", "SeoAdmin")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Days</label>
                    <select name="days" class="form-select">
                        <option value="7" selected="@(days == 7)">Last 7 days</option>
                        <option value="30" selected="@(days == 30)">Last 30 days</option>
                        <option value="90" selected="@(days == 90)">Last 90 days</option>
                        <option value="365" selected="@(days == 365)">Last year</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">User ID (optional)</label>
                    <input type="text" name="userId" class="form-control" value="@userId" placeholder="Filter by user ID">
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter"></i> Apply Filters
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        @foreach (var stat in activityStats)
        {
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">@stat.Key</h6>
                        <h3 class="mb-0">@stat.Value.ToString("N0")</h3>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row">
        <!-- Activities List -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Recent Activities</h5>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Activity</th>
                                        <th>Post/Community</th>
                                        <th>Time</th>
                                        <th>Details</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var activity in Model)
                                    {
                                        <tr>
                                            <td>
                                                <small class="text-muted">@(activity.UserId ?? "Anonymous")</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary">@activity.ActivityType</span>
                                            </td>
                                            <td>
                                                @if (activity.Post != null)
                                                {
                                                    <small>Post: @activity.Post.Title?.Substring(0, Math.Min(30, activity.Post.Title?.Length ?? 0))</small>
                                                }
                                                else if (activity.Community != null)
                                                {
                                                    <small>Community: @activity.Community.Name</small>
                                                }
                                                else
                                                {
                                                    <small class="text-muted">-</small>
                                                }
                                            </td>
                                            <td>
                                                <small>@activity.ActivityAt.ToString("MMM dd, HH:mm")</small>
                                            </td>
                                            <td>
                                                @if (activity.TimeSpentSeconds > 0)
                                                {
                                                    <small>@activity.TimeSpentSeconds s</small>
                                                }
                                                @if (activity.ScrollDepthPercent > 0)
                                                {
                                                    <small>@activity.ScrollDepthPercent% scroll</small>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        @if (totalPages > 1)
                        {
                            <nav>
                                <ul class="pagination justify-content-center">
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" href="?page=@(currentPage - 1)&days=@days&userId=@userId">Previous</a>
                                    </li>
                                    @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                                    {
                                        <li class="page-item @(i == currentPage ? "active" : "")">
                                            <a class="page-link" href="?page=@i&days=@days&userId=@userId">@i</a>
                                        </li>
                                    }
                                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                        <a class="page-link" href="?page=@(currentPage + 1)&days=@days&userId=@userId">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No activities found for the selected period.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Top Active Users -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Top Active Users</h5>
                </div>
                <div class="card-body">
                    @if (topActiveUsers.Any())
                    {
                        <div class="list-group">
                            @foreach (var user in topActiveUsers)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="mb-1">@user.UserId</h6>
                                            <small class="text-muted">@user.ActivityCount activities</small>
                                        </div>
                                        <small class="text-muted">@user.LastActivity.ToString("MMM dd")</small>
                                    </div>
                                    @if (user.ActivityTypes.Any())
                                    {
                                        <div class="mt-2">
                                            @foreach (var type in user.ActivityTypes.Take(3))
                                            {
                                                <span class="badge bg-secondary me-1">@type.Key: @type.Value</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center">No active users found.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

