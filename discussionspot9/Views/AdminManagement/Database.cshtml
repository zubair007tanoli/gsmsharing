@{
    ViewData["Title"] = "Database Management";
    ViewData["PageTitle"] = "Database Management";
    ViewData["PageDescription"] = "View database statistics and manage database operations";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    
    var stats = ViewBag.Stats as dynamic;
    var tableSizes = ViewBag.TableSizes as Dictionary<string, long> ?? new Dictionary<string, long>();
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h2">🗄️ Database Management</h1>
            <p class="text-muted">Monitor database statistics and connection status</p>
        </div>
        <div class="col-auto">
            <a href="/admin/manage/users" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back to Users
            </a>
        </div>
    </div>

    <!-- Connection Info -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-server text-primary"></i> Server Info
                    </h5>
                    <p class="mb-1"><strong>Server:</strong> @(stats?.ServerName ?? "Unknown")</p>
                    <p class="mb-1"><strong>Database:</strong> @(stats?.DatabaseName ?? "Unknown")</p>
                    <p class="mb-0">
                        <strong>Status:</strong> 
                        <span class="badge @(stats?.ConnectionState == "Open" ? "bg-success" : "bg-warning")">
                            @(stats?.ConnectionState ?? "Unknown")
                        </span>
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-info-circle text-info"></i> Quick Stats
                    </h5>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-primary">@(stats?.TotalUsers ?? 0)</h3>
                                <small class="text-muted">Users</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-success">@(stats?.TotalPosts ?? 0)</h3>
                                <small class="text-muted">Posts</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-info">@(stats?.TotalComments ?? 0)</h3>
                                <small class="text-muted">Comments</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-warning">@(stats?.TotalCommunities ?? 0)</h3>
                                <small class="text-muted">Communities</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Statistics -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="fas fa-table"></i> Table Statistics
            </h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Table Name</th>
                            <th>Record Count</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><i class="fas fa-users text-primary"></i> UserProfiles</td>
                            <td>@(stats?.TotalUsers ?? 0)</td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-newspaper text-success"></i> Posts</td>
                            <td>@(stats?.TotalPosts ?? 0)</td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-comments text-info"></i> Comments</td>
                            <td>@(stats?.TotalComments ?? 0)</td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-users-cog text-warning"></i> Communities</td>
                            <td>@(stats?.TotalCommunities ?? 0)</td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-flag text-danger"></i> PostReports</td>
                            <td>@(stats?.TotalReports ?? 0)</td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-chart-line text-primary"></i> UserActivities</td>
                            <td>@(stats?.TotalActivities ?? 0)</td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-bell text-warning"></i> Notifications</td>
                            <td>@(stats?.TotalNotifications ?? 0)</td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-image text-info"></i> Media</td>
                            <td>@(stats?.TotalMedia ?? 0)</td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Database Operations -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="fas fa-tools"></i> Database Operations
            </h5>
        </div>
        <div class="card-body">
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                <strong>Note:</strong> Database operations are read-only in this view. For advanced operations, use SQL Server Management Studio or command-line tools.
            </div>
            <div class="row">
                <div class="col-md-6">
                    <h6>Connection Details</h6>
                    <ul class="list-unstyled">
                        <li><strong>Server:</strong> @(stats?.ServerName ?? "Unknown")</li>
                        <li><strong>Database:</strong> @(stats?.DatabaseName ?? "Unknown")</li>
                        <li><strong>Connection State:</strong> 
                            <span class="badge @(stats?.ConnectionState == "Open" ? "bg-success" : "bg-warning")">
                                @(stats?.ConnectionState ?? "Unknown")
                            </span>
                        </li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <h6>Quick Actions</h6>
                    <div class="d-grid gap-2">
                        <a href="/admin/manage/users" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-users"></i> View Users
                        </a>
                        <a href="/admin/manage/posts" class="btn btn-outline-success btn-sm">
                            <i class="fas fa-newspaper"></i> View Posts
                        </a>
                        <a href="/admin/manage/analytics" class="btn btn-outline-info btn-sm">
                            <i class="fas fa-chart-bar"></i> View Analytics
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

