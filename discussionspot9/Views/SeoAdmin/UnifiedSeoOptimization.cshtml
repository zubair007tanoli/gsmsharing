        // Save optimizations
        async function saveOptimizations(postId) {
            try {
                // Try to get values from preview fields first, then fallback to results fields
                const title = document.getElementById('optTitle')?.value || 
                             (currentPreviewData?.optimizedTitle || '');
                const content = document.getElementById('optContent')?.value || 
                               (currentPreviewData?.optimizedContent || '');
                
                // Get meta description from preview field or stored data
                const metaField = document.getElementById('previewMetaDescription');
                const meta = metaField?.value || 
                           document.getElementById('optMeta')?.value || 
                           (currentPreviewData?.optimizedMetaDescription || 
                            currentPreviewData?.suggestedMetaDescription || 
                            currentPreviewData?.metaDescription || '');
                
                // Get keywords from preview field or stored data
                const keywordsField = document.getElementById('previewKeywords');
                let keywords = [];
                if (keywordsField && keywordsField.value.trim()) {
                    // Parse comma-separated keywords
                    keywords = keywordsField.value.split(',').map(k => k.trim()).filter(k => k.length > 0);
                } else if (currentPreviewData?.optimizedKeywords && currentPreviewData.optimizedKeywords.length > 0) {
                    keywords = currentPreviewData.optimizedKeywords;
                } else if (currentPreviewData?.suggestedKeywords && currentPreviewData.suggestedKeywords.length > 0) {
                    keywords = currentPreviewData.suggestedKeywords;
                } else if (currentPreviewData?.keywords && currentPreviewData.keywords.length > 0) {
                    keywords = currentPreviewData.keywords;
                } else if (currentPreviewData?.googleKeywords && currentPreviewData.googleKeywords.length > 0) {
                    // Fallback to Google keywords if optimized keywords not available
                    keywords = currentPreviewData.googleKeywords.slice(0, 10);
                }
                
                if (!title || !content) {
                    showToast('Missing optimization data', 'error');
                    return;
                }
                
                console.log('Saving optimizations:', {
                    postId,
                    title: title.substring(0, 50) + '...',
                    contentLength: content.length,
                    metaDescription: meta.substring(0, 50) + '...',
                    keywords: keywords
                });
                
                const response = await fetch('/admin/seo/api/save-optimizations', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        postId: postId,
                        optimizedTitle: title,
                        optimizedContent: content,
                        metaDescription: meta,
                        keywords: keywords
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    const message = result.newScore ? 
                        `✅ Optimizations saved! New SEO score: ${result.newScore.toFixed(1)} (${result.newTier})` :
                        '✅ Optimizations saved successfully!';
                    showToast(message, 'success', 6000);
                    
                    // Update queue if on queue tab
                    if (document.getElementById('queue-pane').classList.contains('active')) {
                        setTimeout(() => refreshQueue(), 1500);
                    }
                } else {
                    showToast('❌ Error: ' + result.error, 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error saving optimizations', 'error');
            }
        }
        async function autoGenerateProposals(limit = 5) {
            const btn = document.getElementById('autoGenerateBtn');
            let originalText = '';
            if (btn) {
                originalText = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Generating...';
            }
            try {
                const response = await fetch(`/admin/seo/api/auto-generate-proposals?limit=${limit}`, {
                    method: 'POST'
                });
                const result = await response.json();
                if (result.success) {
                    const failuresCount = result.failures ? result.failures.length : 0;
                    const message = `Generated ${result.createdCount || 0} proposal(s)` + (failuresCount > 0 ? `, ${failuresCount} failed.` : '.');
                    showToast('✅ ' + message, 'success', 6000);
                    scheduleApprovalsReload(true);
                    refreshQueue();
                } else {
                    showToast('❌ Error: ' + (result.error || 'Failed to auto-generate proposals'), 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error generating proposals automatically', 'error');
            } finally {
                if (btn) {
                    btn.disabled = false;
                    btn.innerHTML = originalText || '<i class="fas fa-robot"></i> Generate AI Proposals';
                }
            }
        }
        function changeApprovalsStatus(status) {
            approvalsStatus = status;
            approvalsSkip = 0;
            approvalsHasMore = true;
            loadPendingApprovals(true);
        }
        function prepareProposalAction(proposalId, postId) {
            currentProposalId = proposalId;
            currentPostId = postId;
        }
        async function loadPendingApprovals(reset = false) {
            const list = document.getElementById('approvalsList');
            const loadMoreContainer = document.getElementById('approvalsLoadMoreContainer');
            const loadMoreBtn = document.getElementById('approvalsLoadMoreBtn');
            const loadingIndicator = document.getElementById('approvalsLoadingIndicator');
            if (!list) {
                return;
            }
            if (reset) {
                approvalsSkip = 0;
                approvalsHasMore = true;
                list.innerHTML = '<div class="text-center py-4"><div class="spinner-border" role="status"></div></div>';
            }
            if (!approvalsHasMore && !reset) {
                return;
            }
            if (loadMoreBtn) loadMoreBtn.disabled = true;
            if (loadingIndicator) loadingIndicator.classList.remove('d-none');
            const params = new URLSearchParams({
                skip: approvalsSkip,
                take: 10
            });
            if (approvalsStatus && approvalsStatus !== 'All') {
                params.append('status', approvalsStatus);
            } else if (approvalsStatus === 'All') {
                params.append('status', 'All');
            }
            try {
                const response = await fetch(`/admin/seo/api/pending-proposals?${params.toString()}`);
                const result = await response.json();
                if (result.success) {
                    if (reset) {
                        list.innerHTML = '';
                    }
                    if (result.proposals && result.proposals.length > 0) {
                        renderApprovals(result.proposals);
                        approvalsSkip += result.proposals.length;
                        approvalsHasMore = result.hasMore;
                        if (loadMoreContainer) {
                            loadMoreContainer.style.display = result.hasMore ? 'block' : 'none';
                        }
                    } else if (reset) {
                        list.innerHTML = `<div class="text-center py-4 text-muted"><i class="fas fa-clipboard-check fa-2x mb-2"></i><p class="mb-0">No proposals found for ${approvalsStatus}.</p></div>`;
                        approvalsHasMore = false;
                        if (loadMoreContainer) loadMoreContainer.style.display = 'none';
                    }
                } else {
                    showToast('Error loading proposals: ' + (result.error || 'Unknown error'), 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error loading proposals', 'error');
            } finally {
                if (loadMoreBtn) loadMoreBtn.disabled = false;
                if (loadingIndicator) loadingIndicator.classList.add('d-none');
            }
            approvalsLoaded = true;
        }
        function renderApprovals(proposals) {
            const list = document.getElementById('approvalsList');
            if (!list) {
                return;
            }
            proposals.forEach(proposal => {
                const deltaValue = proposal.expectedScoreDelta !== null && proposal.expectedScoreDelta !== undefined
                    ? parseFloat(proposal.expectedScoreDelta)
                    : null;
                const deltaBadge = deltaValue !== null && !Number.isNaN(deltaValue)
                    ? `<span class="badge bg-${deltaValue >= 0 ? 'success' : 'danger'}">${deltaValue >= 0 ? '+' : ''}${deltaValue.toFixed(1)}</span>`
                    : '';
                const createdAt = proposal.createdAt ? new Date(proposal.createdAt).toLocaleString() : '';
                const statusBadgeClass = proposal.status === 'Approved'
                    ? 'success'
                    : proposal.status === 'Rejected'
                        ? 'danger'
                        : 'warning';
                const keywords = proposal.proposedKeywords
                    ? proposal.proposedKeywords.split(',').map(k => k.trim()).filter(Boolean)
                    : [];
                const card = document.createElement('div');
                card.className = 'card mb-3 shadow-sm';
                card.innerHTML = `
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                            <div>
                                <h5 class="mb-1">${escapeHtml(proposal.postTitle || 'Untitled Post')}</h5>
                                <div class="text-muted small">
                                    ${proposal.communityName ? `<span class="me-2"><i class="fas fa-users"></i> ${escapeHtml(proposal.communityName)}</span>` : ''}
                                    ${createdAt ? `<span><i class="fas fa-clock"></i> ${createdAt}</span>` : ''}
                                </div>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-${statusBadgeClass} me-2">${escapeHtml(proposal.status)}</span>
                                ${deltaBadge}
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <p class="text-muted small mb-1">Current Score</p>
                                <h4>${proposal.currentScore !== null && proposal.currentScore !== undefined ? Number(proposal.currentScore).toFixed(1) : 'N/A'}</h4>
                            </div>
                            <div class="col-md-6">
                                <p class="text-muted small mb-1">Expected Score</p>
                                <h4>${proposal.expectedScore !== null && proposal.expectedScore !== undefined ? Number(proposal.expectedScore).toFixed(1) : 'N/A'}</h4>
                            </div>
                        </div>
                        <div class="mt-3">
                            <p class="text-muted small mb-1">Proposed Title</p>
                            <p class="mb-2">${escapeHtml(proposal.proposedTitle || '')}</p>
                        </div>
                        <div class="mt-3">
                            <p class="text-muted small mb-1">Meta Description</p>
                            <p class="mb-2 small">${escapeHtml(proposal.proposedMetaDescription || '')}</p>
                        </div>
                        ${keywords.length > 0 ? `<div class="mt-3"><p class="text-muted small mb-1">Keywords</p><div class="d-flex flex-wrap gap-2">${keywords.map(kw => `<span class="badge bg-info">${escapeHtml(kw)}</span>`).join('')}</div></div>` : ''}
                        <div class="d-flex flex-wrap gap-2 mt-4">
                            <button class="btn btn-success btn-sm" onclick="showApprovalModal(${proposal.proposalId}, ${proposal.postId})">
                                <i class="fas fa-check me-1"></i>Review & Approve
                            </button>
                            <button class="btn btn-outline-danger btn-sm" onclick="prepareProposalAction(${proposal.proposalId}, ${proposal.postId}); rejectProposal();">
                                <i class="fas fa-times me-1"></i>Reject
                            </button>
                        </div>
                    </div>
                `;
                list.appendChild(card);
            });
        }
        // Toggle issues display (collapse/expand)
        function toggleIssues(postId) {
            const issuesElement = document.getElementById(`issues-${postId}`);
            if (!issuesElement) return;
            
            // Close all other open issues
            document.querySelectorAll('.issues-details.show').forEach(el => {
                if (el.id !== `issues-${postId}`) {
                    const bsCollapse = bootstrap.Collapse.getInstance(el);
                    if (bsCollapse) {
                        bsCollapse.hide();
                    }
                }
            });
            
            // Toggle current issues
            const bsCollapse = new bootstrap.Collapse(issuesElement, {
                toggle: true
            });
        }

        // Close issues when clicking outside
        document.addEventListener('click', function(event) {
            if (!event.target.closest('.issues-container')) {
                document.querySelectorAll('.issues-details.show').forEach(el => {
                    const bsCollapse = bootstrap.Collapse.getInstance(el);
                    if (bsCollapse) {
                        bsCollapse.hide();
                    }
                });
            }
        });

        // Load post in optimization tab (when clicking on row)
        async function loadPostInOptimizationTab(postId) {
            // Switch to optimization tab
            const optimizeTab = document.getElementById('optimize-tab');
            const optimizePane = document.getElementById('optimize-pane');
            
            // Check if tab is already active
            if (optimizeTab.classList.contains('active')) {
                // Tab is already active, just load the post
                await loadPostDetailsForOptimization(postId);
                return;
            }
            
            // Tab is not active, switch to it first
            // Use Bootstrap tab API to switch
            const tabTrigger = new bootstrap.Tab(optimizeTab);
            
            // Listen for tab shown event on the tab button itself
            optimizeTab.addEventListener('shown.bs.tab', function onShown() {
                optimizeTab.removeEventListener('shown.bs.tab', onShown);
                // Load post after tab is shown
                loadPostDetailsForOptimization(postId);
            }, { once: true });
            
            // Trigger tab switch
            tabTrigger.show();
        }

        // Optimize post from queue (from Optimize button)
        function optimizePostFromQueue(postId) {
            // Switch to optimization tab and load post
            loadPostInOptimizationTab(postId);
            
            // After post is loaded, automatically trigger optimization
            setTimeout(() => {
                const panel = document.getElementById('optimizationPanel');
                const optimizeBtn = panel.querySelector('button[onclick*="optimizePostWithAI"]');
                if (optimizeBtn) {
                    setTimeout(() => {
                        optimizePostWithAI(postId);
                    }, 1000);
                }
            }, 2000);
        }

        // Show approval modal
        async function showApprovalModal(proposalId, postId) {
            currentProposalId = proposalId;
            currentPostId = postId;
            
            try {
                const response = await fetch(`/admin/seo/api/get-proposal-details?proposalId=${proposalId}`);
                const result = await response.json();
                
                if (!result.success) {
                    showToast('Error loading proposal', 'error');
                    return;
                }
                
                const proposal = result.data;
                const modalBody = document.getElementById('approvalModalBody');
                
                modalBody.innerHTML = `
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6>Current Score</h6>
                                    <h3>${proposal.currentScore.toFixed(1)}</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-primary text-white">
                                <div class="card-body">
                                    <h6>Expected Score</h6>
                                    <h3>${proposal.expectedScore.toFixed(1)}</h3>
                                    <small>+${proposal.expectedScoreDelta.toFixed(1)} points</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Proposed Title</label>
                        <input type="text" class="form-control" value="${escapeHtml(proposal.proposedTitle)}" readonly>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Proposed Meta Description</label>
                        <textarea class="form-control" rows="3" readonly>${escapeHtml(proposal.proposedMetaDescription || '')}</textarea>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Changes Summary</label>
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>${escapeHtml(proposal.changesSummary || 'Content optimized for SEO')}
                        </div>
                    </div>
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Note:</strong> Approving this proposal will update the post title, content, and SEO metadata. The post will be automatically re-scored after approval.
                    </div>
                `;
                
                const modal = new bootstrap.Modal(document.getElementById('approvalModal'));
                modal.show();
            } catch (error) {
                console.error('Error:', error);
                showToast('Error loading proposal details', 'error');
            }
        }

        // Approve proposal
        async function approveProposal() {
            if (!currentProposalId) return;
            
            try {
                showToast('Approving proposal...', 'info', 2000);
                
                const response = await fetch(`/admin/seo/api/approve-proposal?proposalId=${currentProposalId}`, {
                    method: 'POST'
                });
                
                const result = await response.json();
                
                if (result.success) {
                    const message = result.newScore ? 
                        `✅ Proposal approved! New SEO score: ${result.newScore.toFixed(1)} (${result.newTier})` :
                        '✅ Proposal approved and applied!';
                    showToast(message, 'success', 6000);
                    bootstrap.Modal.getInstance(document.getElementById('approvalModal')).hide();
                    
                    // Refresh the queue and update the row
                    setTimeout(() => {
                        refreshQueue();
                        if (currentPostId && result.newScore) {
                            updatePostRow(currentPostId, { 
                                score: result.newScore, 
                                tier: result.newTier 
                            });
                        }
                        scheduleApprovalsReload(true);
                    }, 1000);
                } else {
                    showToast('❌ Error: ' + result.error, 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error approving proposal', 'error');
            }
        }

        // Reject proposal
        async function rejectProposal() {
            if (!currentProposalId) return;
            
            const reason = prompt('Reason for rejection (optional):');
            
            try {
                const response = await fetch(`/admin/seo/api/reject-proposal?proposalId=${currentProposalId}&reason=${encodeURIComponent(reason || '')}`, {
                    method: 'POST'
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showToast('Proposal rejected', 'info');
                    bootstrap.Modal.getInstance(document.getElementById('approvalModal')).hide();
                    refreshQueue();
                    scheduleApprovalsReload(true);
                } else {
                    showToast('Error: ' + result.error, 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error rejecting proposal', 'error');
            }
        }

        // Re-score post
        async function rescorePost(postId, silent = false) {
            if (!silent) {
                if (!confirm('Re-score this post? This may take a few seconds.')) return;
            }
            
            try {
                if (!silent) showToast('Re-scoring post...', 'info', 3000);
                
                const response = await fetch('/admin/seo/api/rescore-posts', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify([postId])
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showToast('✅ Post re-scored successfully!', 'success');
                    // Update the row with new score
                    if (result.results && result.results.length > 0) {
                        const scoreData = result.results.find(r => r.postId === postId) || result.results[0];
                        updatePostRow(postId, scoreData);
                    } else {
                        // Refresh queue to get updated scores
                        setTimeout(() => refreshQueue(), 500);
                    }
                } else {
                    showToast('❌ Error: ' + result.error, 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error re-scoring post', 'error');
            }
        }

        // Update post row with new score
        function updatePostRow(postId, scoreData) {
            const row = document.querySelector(`tr[data-post-id="${postId}"]`);
            if (!row) return;
            
            const scoreCell = row.cells[0];
            const scoreClass = scoreData.score >= 80 ? 'success' : scoreData.score >= 50 ? 'warning' : 'danger';
            const tierBadge = scoreData.tier === 'OK' ? 'success' : scoreData.tier === 'NeedsImprovement' ? 'warning' : 'danger';
            
            scoreCell.innerHTML = `
                <div class="d-flex flex-column align-items-center">
                    <span class="badge bg-${scoreClass} score-badge">${scoreData.score.toFixed(1)}</span>
                    <small class="text-muted mt-1">
                        <span class="badge bg-${tierBadge}">${scoreData.tier}</span>
                    </small>
                </div>
            `;
            
            // Add animation
            row.style.transition = 'background-color 0.5s';
            row.style.backgroundColor = '#d4edda';
            setTimeout(() => {
                row.style.backgroundColor = '';
            }, 2000);
        }

        // Refresh queue
        function refreshQueue() {
            currentSkip = 0;
            loadPosts(true);
        }

        // Apply filters
        function applyFilters() {
            currentFilters.tier = document.getElementById('tierFilter').value;
            currentFilters.communitySlug = document.getElementById('communityFilter').value;
            currentFilters.missingMeta = document.getElementById('missingMetaFilter').checked;
            currentSkip = 0;
            loadPosts(true);
        }

        // Load more posts
        function loadMorePosts() {
            loadPosts(false);
        }

        // Load posts
        function loadPosts(reset = false) {
            if (reset) {
                currentSkip = 0;
                const tbody = document.getElementById('postsTableBody');
                if (tbody) tbody.innerHTML = '<tr><td colspan="8" class="text-center py-4"><div class="spinner-border"></div></td></tr>';
            }

            const btn = document.getElementById('loadMoreBtn');
            const indicator = document.getElementById('loadingIndicator');
            if (btn) btn.disabled = true;
            if (indicator) indicator.classList.remove('d-none');

            const params = new URLSearchParams({
                skip: currentSkip,
                take: 10,
                ...(currentFilters.tier && { tier: currentFilters.tier }),
                ...(currentFilters.communitySlug && { communitySlug: currentFilters.communitySlug }),
                ...(currentFilters.missingMeta && { missingMeta: 'true' })
            });

            fetch(`/admin/seo/api/queue-posts?${params}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.posts) {
                        if (reset) {
                            document.getElementById('postsTableBody').innerHTML = '';
                        }
                        appendPosts(data.posts);
                        currentSkip += data.posts.length;
                        
                        if (!data.hasMore && document.getElementById('loadMoreContainer')) {
                            document.getElementById('loadMoreContainer').style.display = 'none';
                        }
                    } else {
                        showToast('Error loading posts: ' + (data.error || 'Unknown error'), 'error');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showToast('Error loading posts', 'error');
                })
                .finally(() => {
                    if (btn) btn.disabled = false;
                    if (indicator) indicator.classList.add('d-none');
                });
        }

        // Append posts to table
        function appendPosts(posts) {
            const tbody = document.getElementById('postsTableBody');
            if (!tbody) return;
            
            posts.forEach(post => {
                const scoreClass = post.score >= 80 ? 'success' : post.score >= 50 ? 'warning' : 'danger';
                const tierBadge = post.tier === 'OK' ? 'success' : post.tier === 'NeedsImprovement' ? 'warning' : 'danger';
                const pendingBadge = post.hasPendingProposal ? ' <span class="badge bg-warning text-dark ms-2">Pending proposal</span>' : '';
                
                const issuesHtml = post.issues && post.issues.length > 0
                    ? `<div class="issues-container">
                        <button class="btn btn-sm btn-outline-danger issues-btn" 
                                type="button" 
                                data-post-id="${post.postId}"
                                data-bs-toggle="tooltip"
                                data-bs-placement="left"
                                data-bs-html="true"
                                title="${post.issues.map(i => `• ${escapeHtml(i)}`).join('&#10;')}"
                                onclick="event.stopPropagation(); toggleIssues(${post.postId})">
                            <i class="fas fa-exclamation-triangle"></i> ${post.issues.length}
                        </button>
                        <div class="issues-details collapse" id="issues-${post.postId}" data-post-id="${post.postId}">
                            <div class="card card-body mt-2 p-2" style="min-width: 300px; max-width: 400px; font-size: 0.875rem;">
                                <strong class="text-danger mb-2"><i class="fas fa-exclamation-triangle"></i> SEO Issues:</strong>
                                <ul class="mb-0 ps-3">
                                    ${post.issues.map(issue => `<li class="mb-1">${escapeHtml(issue)}</li>`).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>`
                    : '<span class="text-success"><i class="fas fa-check"></i></span>';

                const row = `
                    <tr data-post-id="${post.postId}" class="post-row" style="cursor: pointer;" onclick="loadPostInOptimizationTab(${post.postId})">
                        <td>
                            <div class="d-flex flex-column align-items-center">
                                <span class="badge bg-${scoreClass} score-badge">${post.score.toFixed(1)}</span>
                                <small class="text-muted mt-1"><span class="badge bg-${tierBadge}">${post.tier}</span></small>
                            </div>
                        </td>
                        <td>
                            <strong>${escapeHtml(post.title)}${pendingBadge}</strong><br />
                            <small class="text-muted">${escapeHtml(post.communityName)} | 👁️ ${post.viewCount} | 💬 ${post.commentCount}</small>
                        </td>
                        <td>
                            <div class="progress progress-mini">
                                <div class="progress-bar ${post.googleCompetitivenessScore >= 50 ? 'bg-success' : 'bg-warning'}" 
                                     style="width: ${post.googleCompetitivenessScore}%">
                                    ${post.googleCompetitivenessScore.toFixed(0)}
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="progress progress-mini">
                                <div class="progress-bar ${post.contentQualityScore >= 50 ? 'bg-success' : 'bg-warning'}" 
                                     style="width: ${post.contentQualityScore}%">
                                    ${post.contentQualityScore.toFixed(0)}
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="progress progress-mini">
                                <div class="progress-bar ${post.metaCompletenessScore >= 50 ? 'bg-success' : 'bg-warning'}" 
                                     style="width: ${post.metaCompletenessScore}%">
                                    ${post.metaCompletenessScore.toFixed(0)}
                                </div>
                            </div>
                            ${!post.hasMeta ? '<small class="text-danger"><i class="fas fa-exclamation-triangle"></i></small>' : ''}
                        </td>
                        <td>
                            <div class="progress progress-mini">
                                <div class="progress-bar ${post.freshnessScore >= 50 ? 'bg-success' : 'bg-warning'}" 
                                     style="width: ${post.freshnessScore}%">
                                    ${post.freshnessScore.toFixed(0)}
                                </div>
                            </div>
                        </td>
                        <td class="text-center">${issuesHtml}</td>
                        <td>
                            <div class="action-buttons" onclick="event.stopPropagation();">
                                <button class="btn btn-sm btn-primary w-100" onclick="optimizePostFromQueue(${post.postId})">
                                    <i class="fas fa-magic"></i> Optimize
                                </button>
                                <button class="btn btn-sm btn-secondary w-100" onclick="rescorePost(${post.postId})">
                                    <i class="fas fa-sync"></i> Re-score
                                </button>
                                ${post.hasPendingProposal && post.proposalId ? 
                                    `<button class="btn btn-sm btn-success w-100" onclick="showApprovalModal(${post.proposalId}, ${post.postId})"><i class="fas fa-check"></i> Approve</button>` : 
                                    ''}
                            </div>
                        </td>
                    </tr>
                `;
                tbody.insertAdjacentHTML('beforeend', row);
            });

            // Re-initialize tooltips for issues
            setTimeout(() => {
                const tooltips = document.querySelectorAll('[data-bs-toggle="tooltip"]');
                tooltips.forEach(el => {
                    // Destroy existing tooltip if any
                    const existingTooltip = bootstrap.Tooltip.getInstance(el);
                    if (existingTooltip) {
                        existingTooltip.dispose();
                    }
                    // Create new tooltip
                    new bootstrap.Tooltip(el, {
                        trigger: 'hover',
                        placement: 'left',
                        html: true,
                        delay: { show: 300, hide: 100 }
                    });
                });
            }, 100);
        }

        // Helper functions
        function copyText(elementId) {
            const element = document.getElementById(elementId);
            element.select();
            document.execCommand('copy');
            showToast('Copied to clipboard!', 'success', 2000);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize popovers
            const popovers = document.querySelectorAll('[data-bs-toggle="popover"]');
            popovers.forEach(el => new bootstrap.Popover(el));
            
            // Load posts when optimization tab is clicked (only if not loading a specific post)
            document.getElementById('optimize-tab').addEventListener('shown.bs.tab', function() {
                // Only load posts list if we don't have a post already loaded
                const panel = document.getElementById('optimizationPanel');
                const isEmpty = panel.querySelector('.card-body.text-center.py-5');
                if (isEmpty) {
                    loadPostsForOptimization();
                }
            });
            
            // Post search
            const searchInput = document.getElementById('postSearch');
            if (searchInput) {
                searchInput.addEventListener('input', function(e) {
                    const term = e.target.value.toLowerCase();
                    document.querySelectorAll('.post-item').forEach(item => {
                        const title = item.textContent.toLowerCase();
                        item.style.display = title.includes(term) ? '' : 'none';
                    });
                });
            }
        });

        const approvalsTab = document.getElementById('approvals-tab');
        if (approvalsTab) {
            approvalsTab.addEventListener('shown.bs.tab', function() {
                if (!approvalsLoaded) {
                    loadPendingApprovals(true);
                }
            });
        }
    </script>
}


