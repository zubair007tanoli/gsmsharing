@model List<discussionspot9.Controllers.SeoAdminController.PostWithScoreViewModel>
@{
    ViewData["Title"] = "SEO Optimization Center";
    ViewData["PageTitle"] = "SEO Optimization";
    ViewData["PageDescription"] = "Comprehensive SEO optimization with scoring and AI-powered enhancements";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .score-badge {
        font-size: 1.1rem;
        padding: 0.5rem 1rem;
        font-weight: 600;
    }
    .progress-mini {
        height: 18px;
        font-size: 0.75rem;
    }
    .post-row {
        transition: background-color 0.2s;
    }
    .post-row:hover {
        background-color: #f8f9fa;
    }
    .post-row:active {
        background-color: #e9ecef;
    }
    .action-buttons {
        pointer-events: auto;
    }
    .toast-container {
        position: fixed;
        top: 80px;
        right: 20px;
        z-index: 9999;
    }
    .action-buttons .btn {
        margin: 0.25rem 0;
    }
    #optimizationPanel {
        max-height: calc(100vh - 200px);
        overflow-y: auto;
    }
    .issues-container {
        position: relative;
        display: inline-block;
    }
    .issues-details {
        position: absolute;
        z-index: 1000;
        left: 0;
        top: 100%;
        margin-top: 5px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        border-radius: 0.375rem;
    }
    .issues-details .card {
        border: 1px solid #dc3545;
        background-color: #fff;
    }
    .issues-details ul {
        list-style: none;
        padding-left: 0;
    }
    .issues-details li {
        color: #6c757d;
        line-height: 1.5;
    }
    .issues-details li:before {
        content: "• ";
        color: #dc3545;
        font-weight: bold;
        margin-right: 5px;
    }
    .issues-btn:hover {
        background-color: #dc3545;
        color: white;
    }
</style>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h1 class="h2">🚀 SEO Optimization Center</h1>
            <p class="text-muted">Score, optimize, and approve SEO improvements for your posts</p>
        </div>
        <div class="col-auto">
            <form asp-action="PopulateQueue" method="post" class="d-inline me-2" onsubmit="return confirm('Analyze posts and add eligible ones to the queue?');">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-magic"></i> Populate Queue
                </button>
            </form>
            <button type="button" class="btn btn-warning me-2" id="autoGenerateBtn" onclick="autoGenerateProposals()">
                <i class="fas fa-robot"></i> Generate AI Proposals
            </button>
            <a href="@Url.Action("Dashboard")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Dashboard
            </a>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Tabs: Queue View | AI Optimization -->
    <ul class="nav nav-tabs mb-4" id="mainTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="queue-tab" data-bs-toggle="tab" data-bs-target="#queue-pane" type="button" role="tab">
                <i class="fas fa-list me-2"></i>Queue View
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="optimize-tab" data-bs-toggle="tab" data-bs-target="#optimize-pane" type="button" role="tab">
                <i class="fas fa-robot me-2"></i>AI Optimization
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="approvals-tab" data-bs-toggle="tab" data-bs-target="#approvals-pane" type="button" role="tab">
                <i class="fas fa-clipboard-check me-2"></i>Approvals
            </button>
        </li>
    </ul>

    <div class="tab-content" id="mainTabContent">
        <!-- Queue View Tab -->
        <div class="tab-pane fade show active" id="queue-pane" role="tabpanel">
            <!-- Filters -->
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Score Tier</label>
                            <select id="tierFilter" class="form-select">
                                <option value="">All Tiers</option>
                                <option value="Critical">Critical (&lt;50)</option>
                                <option value="NeedsImprovement">Needs Improvement (50-79)</option>
                                <option value="OK">OK (≥80)</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Community</label>
                            <input type="text" id="communityFilter" class="form-control" placeholder="Community slug">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Options</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="missingMetaFilter">
                                <label class="form-check-label" for="missingMetaFilter">Missing Meta</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">&nbsp;</label>
                            <button type="button" class="btn btn-primary w-100" onclick="applyFilters()">
                                <i class="fas fa-filter"></i> Filter
                            </button>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">&nbsp;</label>
                            <button type="button" class="btn btn-secondary w-100" onclick="refreshQueue()">
                                <i class="fas fa-sync"></i> Refresh
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Posts Table -->
            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th style="width: 100px;">Score</th>
                                    <th>Post</th>
                                    <th style="width: 120px;">Google</th>
                                    <th style="width: 120px;">Content</th>
                                    <th style="width: 120px;">Meta</th>
                                    <th style="width: 120px;">Freshness</th>
                                    <th style="width: 80px;">Issues</th>
                                    <th style="width: 150px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="postsTableBody">
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var post in Model)
                                    {
                                    <tr data-post-id="@post.PostId" class="post-row" style="cursor: pointer;" onclick="loadPostInOptimizationTab(@post.PostId)">
                                        <td>
                                            @{
                                                var scoreClass = post.Score >= 80 ? "success" : post.Score >= 50 ? "warning" : "danger";
                                                var tierBadge = post.Tier == "OK" ? "success" : post.Tier == "NeedsImprovement" ? "warning" : "danger";
                                            }
                                            <div class="d-flex flex-column align-items-center">
                                                <span class="badge bg-@scoreClass score-badge">@post.Score.ToString("F1")</span>
                                                <small class="text-muted mt-1">
                                                    <span class="badge bg-@tierBadge">@post.Tier</span>
                                                </small>
                                            </div>
                                        </td>
                                        <td>
                                            <strong>@post.Title</strong><br />
                                            <small class="text-muted">
                                                @post.CommunityName | 👁️ @post.ViewCount | 💬 @post.CommentCount
                                            </small>
                                        </td>
                                            <td>
                                                <div class="progress progress-mini">
                                                    <div class="progress-bar @(post.GoogleCompetitivenessScore >= 50 ? "bg-success" : "bg-warning")" 
                                                         style="width: @post.GoogleCompetitivenessScore%">
                                                        @post.GoogleCompetitivenessScore.ToString("F0")
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="progress progress-mini">
                                                    <div class="progress-bar @(post.ContentQualityScore >= 50 ? "bg-success" : "bg-warning")" 
                                                         style="width: @post.ContentQualityScore%">
                                                        @post.ContentQualityScore.ToString("F0")
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="progress progress-mini">
                                                    <div class="progress-bar @(post.MetaCompletenessScore >= 50 ? "bg-success" : "bg-warning")" 
                                                         style="width: @post.MetaCompletenessScore%">
                                                        @post.MetaCompletenessScore.ToString("F0")
                                                    </div>
                                                </div>
                                                @if (!post.HasMeta)
                                                {
                                                    <small class="text-danger"><i class="fas fa-exclamation-triangle"></i></small>
                                                }
                                            </td>
                                            <td>
                                                <div class="progress progress-mini">
                                                    <div class="progress-bar @(post.FreshnessScore >= 50 ? "bg-success" : "bg-warning")" 
                                                         style="width: @post.FreshnessScore%">
                                                        @post.FreshnessScore.ToString("F0")
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                @if (post.Issues.Any())
                                                {
                                                    <div class="issues-container">
                                                        <button class="btn btn-sm btn-outline-danger issues-btn" 
                                                                type="button" 
                                                                data-post-id="@post.PostId"
                                                                data-bs-toggle="tooltip"
                                                                data-bs-placement="left"
                                                                data-bs-html="true"
                                                                title="@string.Join("&#10;", post.Issues.Select(i => $"• {i}"))"
                                                                onclick="event.stopPropagation(); toggleIssues(@post.PostId)">
                                                            <i class="fas fa-exclamation-triangle"></i> @post.Issues.Count
                                                        </button>
                                                        <div class="issues-details collapse" id="issues-@post.PostId" data-post-id="@post.PostId">
                                                            <div class="card card-body mt-2 p-2" style="min-width: 300px; max-width: 400px; font-size: 0.875rem;">
                                                                <strong class="text-danger mb-2"><i class="fas fa-exclamation-triangle"></i> SEO Issues:</strong>
                                                                <ul class="mb-0 ps-3">
                                                                    @foreach (var issue in post.Issues)
                                                                    {
                                                                        <li class="mb-1">@issue</li>
                                                                    }
                                                                </ul>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-success"><i class="fas fa-check"></i></span>
                                                }
                                            </td>
                        <td>
                            <div class="action-buttons" onclick="event.stopPropagation();">
                                <button class="btn btn-sm btn-primary w-100" onclick="optimizePostFromQueue(@post.PostId)" title="Optimize">
                                    <i class="fas fa-magic"></i> Optimize
                                </button>
                                <button class="btn btn-sm btn-secondary w-100" onclick="rescorePost(@post.PostId)" title="Re-score">
                                    <i class="fas fa-sync"></i> Re-score
                                </button>
                                @if (post.HasPendingProposal && post.ProposalId.HasValue)
                                {
                                    <button class="btn btn-sm btn-success w-100" onclick="showApprovalModal(@post.ProposalId.Value, @post.PostId)" title="Approve">
                                        <i class="fas fa-check"></i> Approve
                                    </button>
                                }
                            </div>
                        </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8" class="text-center py-4">
                                            <div class="alert alert-info mb-0">
                                                <i class="fas fa-info-circle"></i> No posts found. Click "Populate Queue" to analyze posts.
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Load More -->
            <div class="text-center mt-4" id="loadMoreContainer">
                <button class="btn btn-primary" id="loadMoreBtn" onclick="loadMorePosts()">
                    <i class="fas fa-arrow-down"></i> Load More Posts
                </button>
                <div id="loadingIndicator" class="d-none mt-2">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
            </div>
        </div>

        <!-- AI Optimization Tab -->
        <div class="tab-pane fade" id="optimize-pane" role="tabpanel">
            <div class="row">
                <!-- Left: Post Selection -->
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-list me-2"></i>Select Post</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <input type="text" class="form-control" id="postSearch" placeholder="Search posts...">
                            </div>
                            <div class="list-group" id="postsList" style="max-height: 600px; overflow-y: auto;">
                                <!-- Posts will be loaded here -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right: Optimization Panel -->
                <div class="col-lg-8">
                    <div id="optimizationPanel">
                        <div class="card">
                            <div class="card-body text-center py-5">
                                <i class="fas fa-robot fa-4x text-muted mb-3"></i>
                                <h4 class="text-muted">AI SEO Optimization</h4>
                                <p class="text-muted">Select a post to start optimizing with AI</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Approvals Tab -->
        <div class="tab-pane fade" id="approvals-pane" role="tabpanel">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-3">
                        <h5 class="mb-2 mb-md-0"><i class="fas fa-clipboard-list me-2"></i>Proposal Queue</h5>
                        <div class="d-flex gap-2 align-items-center">
                            <label class="text-muted small mb-0" for="approvalsStatusFilter">Status</label>
                            <select id="approvalsStatusFilter" class="form-select form-select-sm" style="max-width: 200px;" onchange="changeApprovalsStatus(this.value)">
                                <option value="Pending">Pending</option>
                                <option value="Approved">Approved</option>
                                <option value="Rejected">Rejected</option>
                                <option value="All">All</option>
                            </select>
                        </div>
                    </div>
                    <div id="approvalsList">
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-inbox fa-2x mb-2"></i>
                            <p class="mb-0">No proposals loaded yet. Switch to Pending to fetch data.</p>
                        </div>
                    </div>
                    <div class="text-center mt-3" id="approvalsLoadMoreContainer" style="display:none;">
                        <button class="btn btn-outline-primary" id="approvalsLoadMoreBtn" onclick="loadPendingApprovals(false)">
                            <i class="fas fa-arrow-down"></i> Load More
                        </button>
                        <div class="spinner-border spinner-border-sm d-none mt-2" id="approvalsLoadingIndicator" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Approval Modal -->
<div class="modal fade" id="approvalModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-check-circle me-2"></i>Approve Optimization Proposal</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="approvalModalBody">
                <!-- Content will be loaded here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="rejectProposal()">Reject</button>
                <button type="button" class="btn btn-success" onclick="approveProposal()">
                    <i class="fas fa-check me-2"></i>Approve & Apply
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Global state
        let currentSkip = @(Model?.Count ?? 10);
        let currentFilters = { tier: '', communitySlug: '', missingMeta: false };
        let selectedPostId = null;
        let currentProposalId = null;
        let currentPostId = null;
        // Store preview data globally so save function can access it
        let currentPreviewData = null;
        let approvalsSkip = 0;
        let approvalsStatus = 'Pending';
        let approvalsHasMore = true;
        let approvalsLoaded = false;

        // Toast notification system
        function showToast(message, type = 'success', duration = 5000) {
            const toast = document.createElement('div');
            toast.className = `toast align-items-center text-white bg-${type} border-0`;
            toast.setAttribute('role', 'alert');
            toast.setAttribute('aria-live', 'assertive');
            toast.setAttribute('aria-atomic', 'true');
            
            const icon = type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle';
            
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fas fa-${icon} me-2"></i>${message}
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            `;
            
            const container = document.getElementById('toastContainer');
            container.appendChild(toast);
            
            const bsToast = new bootstrap.Toast(toast, { delay: duration });
            bsToast.show();
            
            toast.addEventListener('hidden.bs.toast', () => toast.remove());
        }

        // Load posts for AI optimization tab (limited initial load)
        let optimizationPostsSkip = 0;
        const optimizationPostsTake = 10;
        let optimizationPostsHasMore = true;

        async function loadPostsForOptimization(reset = false) {
            try {
                if (reset) {
                    optimizationPostsSkip = 0;
                    optimizationPostsHasMore = true;
                }

                if (!optimizationPostsHasMore) return;

                const response = await fetch(`/admin/seo/api/optimization-posts?skip=${optimizationPostsSkip}&take=${optimizationPostsTake}`);
                const data = await response.json();
                
                if (data.success && data.posts) {
                    const list = document.getElementById('postsList');
                    
                    if (reset) {
                        list.innerHTML = '';
                    }

                    data.posts.forEach(post => {
                        const isActive = selectedPostId === post.postId ? 'active' : '';
                        const issuesCount = post.issues && post.issues.length > 0 ? post.issues.length : 0;
                        const issuesBadge = issuesCount > 0 
                            ? `<span class="badge bg-danger ms-1" title="${post.issues.join(', ')}">${issuesCount}</span>` 
                            : '';
                        
                        list.insertAdjacentHTML('beforeend', `
                        <a href="#" class="list-group-item list-group-item-action post-item ${isActive}" 
                           data-post-id="${post.postId}"
                           onclick="selectPostForOptimization(${post.postId}); return false;">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">${escapeHtml(post.title)}</h6>
                                <div>
                                    <small><span class="badge bg-${post.score >= 80 ? 'success' : post.score >= 50 ? 'warning' : 'danger'}">${post.score.toFixed(1)}</span></small>
                                    ${issuesBadge}
                                </div>
                            </div>
                            <p class="mb-1 text-muted small">
                                <i class="fas fa-users me-1"></i>${escapeHtml(post.communityName)}
                                <span class="ms-2"><i class="fas fa-eye me-1"></i>${post.viewCount}</span>
                            </p>
                        </a>
                    `);
                    });

                    optimizationPostsHasMore = data.hasMore;
                    optimizationPostsSkip += data.posts.length;

                    // Show/hide Load More button
                    const loadMoreBtn = document.getElementById('loadMoreOptimizationBtn');
                    if (loadMoreBtn) {
                        loadMoreBtn.style.display = optimizationPostsHasMore ? 'block' : 'none';
                    }
                }
            } catch (error) {
                console.error('Error loading posts:', error);
                showToast('Error loading posts', 'error');
            }
        }

        // Select post for optimization
        async function selectPostForOptimization(postId) {
            selectedPostId = postId;
            document.querySelectorAll('.post-item').forEach(item => item.classList.remove('active'));
            event.currentTarget.classList.add('active');
            
            await loadPostDetailsForOptimization(postId);
        }

        // Load post details for optimization
        async function loadPostDetailsForOptimization(postId) {
            try {
                selectedPostId = postId;
                const panel = document.getElementById('optimizationPanel');
                panel.innerHTML = '<div class="text-center py-4"><div class="spinner-border"></div><p class="mt-3">Loading post details...</p></div>';
                
                // Also load the posts list and highlight the selected one
                await loadPostsForOptimization();
                
                const response = await fetch(`/admin/seo/api/get-post-details?postId=${postId}`);
                const result = await response.json();
                
                if (!result.success) {
                    panel.innerHTML = `<div class="alert alert-danger">${result.error}</div>`;
                    return;
                }
                
                const post = result.data;
                panel.innerHTML = `
                    <div class="card">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0"><i class="fas fa-file-alt me-2"></i>${escapeHtml(post.title)}</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <strong>Community:</strong> r/${post.communitySlug} | 
                                <strong>Views:</strong> ${post.viewCount}
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Content Preview:</label>
                                <div class="border rounded p-3 bg-light" style="max-height: 200px; overflow-y: auto;">
                                    ${escapeHtml(post.content.substring(0, 500))}${post.content.length > 500 ? '...' : ''}
                                </div>
                            </div>
                            <button class="btn btn-primary w-100" onclick="previewOptimization(${postId})">
                                <i class="fas fa-eye me-2"></i>Preview Optimization
                            </button>
                        </div>
                    </div>
                `;
                
                // Highlight the selected post in the left panel
                document.querySelectorAll('.post-item').forEach(item => {
                    item.classList.remove('active');
                    if (parseInt(item.dataset.postId) === postId) {
                        item.classList.add('active');
                        item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    }
                });
                
            } catch (error) {
                console.error('Error:', error);
                showToast('Error loading post details', 'error');
            }
        }

        // Optimize post with AI
        // Preview optimization before applying
        async function previewOptimization(postId) {
            try {
                showToast('Generating optimization preview...', 'info', 3000);
                
                const panel = document.getElementById('optimizationPanel');
                panel.innerHTML = '<div class="text-center py-4"><div class="spinner-border"></div><p class="mt-3">Analyzing post and generating preview...</p></div>';
                
                const response = await fetch('/admin/seo/api/preview-optimization', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ postId: postId })
                });
                
                const result = await response.json();
                
                if (!result.success) {
                    panel.innerHTML = `<div class="alert alert-danger">${result.error}</div>`;
                    showToast('Preview failed: ' + result.error, 'error');
                    return;
                }
                
                // Debug: Log the response data
                console.log('Preview optimization response:', result.data);
                
                // Ensure meta description and keywords are populated
                if (!result.data.optimizedMetaDescription || result.data.optimizedMetaDescription.trim() === '') {
                    console.warn('Meta description is empty, attempting to generate fallback');
                    // Fallback: Use first 160 chars of optimized content or title
                    result.data.optimizedMetaDescription = result.data.optimizedContent 
                        ? result.data.optimizedContent.substring(0, 157) + '...'
                        : result.data.optimizedTitle;
                }
                
                if (!result.data.optimizedKeywords || result.data.optimizedKeywords.length === 0) {
                    console.warn('Keywords are empty, extracting from title');
                    // Fallback: Extract keywords from title
                    const titleWords = result.data.optimizedTitle.split(/\s+/).filter(w => w.length > 3);
                    result.data.optimizedKeywords = titleWords.slice(0, 5);
                }
                
                // Store preview data globally
                currentPreviewData = result.data;
                
                displayOptimizationPreview(result.data, postId);
                showToast('Preview generated successfully!', 'success');
            } catch (error) {
                console.error('Error:', error);
                showToast('Error generating preview', 'error');
            }
        }

        // Apply optimization after preview approval
        async function applyOptimization(postId) {
            try {
                showToast('Applying optimization...', 'info', 3000);
                
                const panel = document.getElementById('optimizationPanel');
                const loadingHtml = panel.innerHTML;
                panel.innerHTML = '<div class="text-center py-4"><div class="spinner-border"></div><p class="mt-3">Applying optimizations...</p></div>';
                
                const response = await fetch('/admin/seo/api/ai-optimize-post', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ postId: postId })
                });
                
                const result = await response.json();
                
                if (!result.success) {
                    panel.innerHTML = loadingHtml; // Restore preview
                    showToast('Optimization failed: ' + result.error, 'error');
                    return;
                }
                
                // Store preview data globally
                currentPreviewData = result.data;
                
                // Show success and create proposal for approval
                displayOptimizationResults(result.data, postId);
                showToast('Optimization completed! Review and approve to apply changes.', 'success', 5000);
            } catch (error) {
                console.error('Error:', error);
                showToast('Error applying optimization', 'error');
            }
        }

