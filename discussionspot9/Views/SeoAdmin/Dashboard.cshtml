@model discussionspot9.Models.ViewModels.AdminViewModels.DashboardViewModel
@{
    ViewData["Title"] = "SEO & Revenue Dashboard";
    ViewData["PageTitle"] = "SEO Dashboard";
    ViewData["PageDescription"] = "SEO optimization and revenue tracking";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .card { margin-bottom: 1.5rem; transition: transform 0.2s; }
    .card:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
    .metric-card { border-left: 4px solid; }
    .metric-card.revenue { border-left-color: #28a745; }
    .metric-card.today { border-left-color: #007bff; }
    .metric-card.pending { border-left-color: #ffc107; }
    .metric-card.completed { border-left-color: #17a2b8; }
    @@media (max-width: 768px) {
        .btn-group { flex-direction: column; width: 100%; }
        .btn-group .btn { margin-bottom: 0.5rem; }
    }
</style>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h2">🚀 SEO & Revenue Dashboard</h1>
            <p class="text-muted">Automated revenue optimization system - Running in background</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Google Search API Integration Section - NEW! -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-success shadow-lg">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fab fa-google me-2"></i>Google Search Intelligence - HYBRID (C# + AI)
                        <span class="badge bg-light text-success ms-2">⚡ NEW</span>
                    </h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-success mb-3">
                        <i class="fas fa-bolt"></i> <strong>Real-time Google Search API</strong> + <strong>AI-powered Python analysis</strong> for maximum SEO performance!
                    </div>
                    <div class="row g-3">
                        <div class="col-lg-3 col-md-6">
                            <a href="/admin/seo/google-keyword-research" class="btn btn-success btn-lg w-100">
                                <i class="fas fa-search me-2"></i>Keyword Research
                            </a>
                            <small class="text-muted d-block mt-2">Real Google Search results + related keywords</small>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <button class="btn btn-success btn-lg w-100" onclick="showTopicInsights()">
                                <i class="fas fa-lightbulb me-2"></i>Topic Insights
                            </button>
                            <small class="text-muted d-block mt-2">Get insights from Google Search data</small>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <button class="btn btn-success btn-lg w-100" onclick="showGoogleCompetitors()">
                                <i class="fas fa-chart-line me-2"></i>Competitor Analysis
                            </button>
                            <small class="text-muted d-block mt-2">Analyze top-ranking competitors</small>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <button class="btn btn-success btn-lg w-100" onclick="optimizeWithGoogle()">
                                <i class="fas fa-magic me-2"></i>Auto-Optimize
                            </button>
                            <small class="text-muted d-block mt-2">AI-powered optimization with Google data</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- Revenue Cards - Responsive -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="card metric-card revenue">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">💰 Total Revenue (Both Sites)</h6>
                            <h2 class="mb-0">$@Model.TotalRevenue.ToString("F2")</h2>
                            <small class="text-muted">Last 30 days</small>
                        </div>
                        <div class="text-success">
                            <i class="fas fa-dollar-sign fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card metric-card today">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">📊 Today's Revenue</h6>
                            <h2 class="mb-0">$@Model.TodayRevenue.ToString("F2")</h2>
                            <small class="text-muted">Updated daily at 2 AM UTC</small>
                        </div>
                        <div class="text-primary">
                            <i class="fas fa-calendar-day fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card metric-card pending">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">⏳ Pending</h6>
                            <h2 class="mb-0">@Model.PendingOptimizations</h2>
                            <small class="text-muted">Awaiting optimization</small>
                        </div>
                        <div class="text-warning">
                            <i class="fas fa-clock fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card metric-card completed">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">✅ Completed</h6>
                            <h2 class="mb-0">@Model.CompletedOptimizations</h2>
                            <small class="text-muted">Last 30 days</small>
                        </div>
                        <div class="text-info">
                            <i class="fas fa-check-circle fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue by Site Breakdown -->
    @if (Model.RevenueBySite.Any())
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-globe me-2"></i>Revenue by Site (Last 30 Days)</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var site in Model.RevenueBySite.OrderByDescending(s => s.Value))
                            {
                                var percentage = Model.TotalRevenue > 0 ? (site.Value / Model.TotalRevenue * 100) : 0;
                                <div class="col-md-6 mb-3">
                                    <div class="p-3 border rounded">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <h6 class="mb-0">
                                                <i class="fas fa-external-link-alt me-2 text-primary"></i>
                                                @site.Key
                                            </h6>
                                            <span class="badge bg-success">@percentage.ToString("F1")%</span>
                                        </div>
                                        <h3 class="text-success mb-0">$@site.Value.ToString("F2")</h3>
                                        <div class="progress mt-2" style="height: 8px;">
                                            <div class="progress-bar bg-success" role="progressbar" 
                                                 style="width: @percentage.ToString("F1")%" 
                                                 aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Navigation Tabs -->
    <div class="row mb-4">
        <div class="col">
            <ul class="nav nav-pills nav-fill flex-column flex-sm-row">
                <li class="nav-item">
                    <a class="nav-link active" href="@Url.Action("Dashboard")">
                        <i class="fas fa-home"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Users", "AdminManagement")">
                        <i class="fas fa-users"></i> Users
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Posts", "AdminManagement")">
                        <i class="fas fa-file-alt"></i> Posts
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Analytics", "AdminManagement")">
                        <i class="fas fa-chart-bar"></i> Analytics
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">🔧 SEO Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-6 col-md-3">
                            <a href="@Url.Action("OptimizationQueue")" class="btn btn-primary w-100">
                                <i class="fas fa-list"></i><br/>Queue
                            </a>
                        </div>
                        <div class="col-6 col-md-3">
                            <a href="@Url.Action("Revenue")" class="btn btn-success w-100">
                                <i class="fas fa-dollar-sign"></i><br/>Revenue
                            </a>
                        </div>
                        <div class="col-6 col-md-3">
                            <a href="@Url.Action("OptimizationHistory")" class="btn btn-info w-100">
                                <i class="fas fa-history"></i><br/>History
                            </a>
                        </div>
                        <div class="col-6 col-md-3">
                            <a href="@Url.Action("TrendingQueries")" class="btn btn-warning w-100">
                                <i class="fas fa-chart-line"></i><br/>Trending
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">🔄 Sync Data</h5>
                </div>
                <div class="card-body">
                    <form asp-action="SyncAdSense" method="post" class="mb-2">
                        <button type="submit" class="btn btn-outline-primary w-100">
                            <i class="fas fa-sync"></i> Sync AdSense
                        </button>
                    </form>
                    <form asp-action="SyncSearchConsole" method="post" class="mb-2">
                        <button type="submit" class="btn btn-outline-info w-100">
                            <i class="fas fa-search"></i> Sync Search Console
                        </button>
                    </form>
                    <form asp-action="SendTestEmail" method="post">
                        <button type="submit" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-envelope"></i> Test Email
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Earning Posts -->
    <div class="row">
        <div class="col">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">🏆 Top Earning Posts (Last 30 Days)</h5>
                </div>
                <div class="card-body">
                    @if (Model.TopEarningPosts != null && Model.TopEarningPosts.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Post Title</th>
                                        <th>Site</th>
                                        <th>Community</th>
                                        <th>Views</th>
                                        <th>Revenue</th>
                                        <th>RPM</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.TopEarningPosts.Count; i++)
                                    {
                                        var post = Model.TopEarningPosts[i];
                                        var badgeClass = i < 3 ? "success" : "primary";
                                        var siteBadgeClass = post.SiteDomain.Contains("gsmsharing") ? "warning" : "info";
                                        
                                        <tr>
                                            <td><span class="badge bg-@badgeClass">@(i + 1)</span></td>
                                            <td><strong>@post.Title</strong></td>
                                            <td><span class="badge bg-@siteBadgeClass">@post.SiteDomain</span></td>
                                            <td><small>r/@post.CommunitySlug</small></td>
                                            <td>@post.Views.ToString("N0")</td>
                                            <td><strong class="text-success">$@post.Earnings.ToString("F2")</strong></td>
                                            <td><span class="badge bg-info">$@post.RPM.ToString("F2")</span></td>
                                            <td>
                                                <a href="/r/@post.CommunitySlug/posts/@post.Slug" class="btn btn-sm btn-outline-primary" target="_blank">
                                                    <i class="fas fa-external-link-alt"></i> View
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> No revenue data available yet. Click "Sync AdSense" button above to fetch data.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- System Status -->
    <div class="row mt-4">
        <div class="col">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">⚙️ System Status</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Background Services:</h6>
                            <ul class="list-unstyled">
                                <li><span class="badge bg-success">●</span> Weekly Optimization (Sundays 2 AM)</li>
                                <li><span class="badge bg-success">●</span> Daily Data Sync (Daily 3 AM)</li>
                                <li><span class="badge bg-info">●</span> Revenue Tracking (Active)</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6>Integrations:</h6>
                            <ul class="list-unstyled">
                                <li><span class="badge bg-primary">✓</span> Google AdSense API</li>
                                <li><span class="badge bg-primary">✓</span> Google Search Console API</li>
                                <li><span class="badge bg-primary">✓</span> Python SEO Analyzer</li>
                                <li><span class="badge bg-success">🆕</span> Semrush API (Active)</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Competitor Analysis Modal -->
<div class="modal fade" id="competitorModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-chart-line me-2"></i>Competitor Analysis</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="competitorDomain" class="form-label">Competitor Domain</label>
                    <input type="text" class="form-control" id="competitorDomain" placeholder="example.com">
                </div>
                <button class="btn btn-primary" onclick="analyzeCompetitor()">
                    <i class="fas fa-search me-2"></i>Analyze Competitor
                </button>
                <div id="competitorResults" class="mt-4" style="display:none;">
                    <h6>Top Competitor Keywords:</h6>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Keyword</th>
                                    <th>Volume</th>
                                    <th>Difficulty</th>
                                    <th>Position</th>
                                    <th>CPC</th>
                                </tr>
                            </thead>
                            <tbody id="competitorKeywordsTable"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- URL Traffic Analysis Modal -->
<div class="modal fade" id="urlTrafficModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-globe me-2"></i>URL Traffic Analysis</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="trafficUrl" class="form-label">URL to Analyze</label>
                    <input type="url" class="form-control" id="trafficUrl" placeholder="https://example.com/page">
                </div>
                <button class="btn btn-primary" onclick="analyzeUrlTraffic()">
                    <i class="fas fa-search me-2"></i>Analyze URL
                </button>
                <div id="urlTrafficResults" class="mt-4" style="display:none;">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-body">
                                    <h6>Organic Traffic</h6>
                                    <h3 id="organicTraffic">--</h3>
                                    <p class="text-muted">Keywords: <span id="organicKeywords">--</span></p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-body">
                                    <h6>Paid Traffic</h6>
                                    <h3 id="paidTraffic">--</h3>
                                    <p class="text-muted">Keywords: <span id="paidKeywords">--</span></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-refresh every 5 minutes
        setTimeout(function() {
            location.reload();
        }, 300000);

        // Semrush Integration Functions
        function showCompetitorModal() {
            var modal = new bootstrap.Modal(document.getElementById('competitorModal'));
            modal.show();
        }

        function showUrlTrafficModal() {
            var modal = new bootstrap.Modal(document.getElementById('urlTrafficModal'));
            modal.show();
        }

        function analyzeCompetitor() {
            const domain = document.getElementById('competitorDomain').value;
            if (!domain) {
                alert('Please enter a competitor domain');
                return;
            }

            showLoading('Analyzing competitor...');
            
            fetch(`/admin/seo/api/competitor-analysis?domain=${encodeURIComponent(domain)}&limit=50`)
                .then(response => response.json())
                .then(data => {
                    hideLoading();
                    if (data.success) {
                        displayCompetitorResults(data.data);
                    } else {
                        alert('Error: ' + data.error);
                    }
                })
                .catch(error => {
                    hideLoading();
                    alert('Error analyzing competitor');
                    console.error(error);
                });
        }

        function displayCompetitorResults(keywords) {
            const tbody = document.getElementById('competitorKeywordsTable');
            tbody.innerHTML = keywords.map(k => `
                <tr>
                    <td><strong>${k.keyword}</strong></td>
                    <td>${k.searchVolume.toLocaleString()}</td>
                    <td><span class="badge ${getDifficultyBadge(k.difficulty)}">${k.difficulty}%</span></td>
                    <td>${k.position}</td>
                    <td>$${k.cpc}</td>
                </tr>
            `).join('');
            
            document.getElementById('competitorResults').style.display = 'block';
        }

        function analyzeUrlTraffic() {
            const url = document.getElementById('trafficUrl').value;
            if (!url) {
                alert('Please enter a URL');
                return;
            }

            showLoading('Analyzing URL traffic...');
            
            fetch(`/admin/seo/api/url-traffic?url=${encodeURIComponent(url)}`)
                .then(response => response.json())
                .then(data => {
                    hideLoading();
                    if (data.success) {
                        displayUrlTrafficResults(data.data);
                    } else {
                        alert('Error: ' + data.error);
                    }
                })
                .catch(error => {
                    hideLoading();
                    alert('Error analyzing URL');
                    console.error(error);
                });
        }

        function displayUrlTrafficResults(traffic) {
            document.getElementById('organicTraffic').textContent = traffic.organicTraffic.toLocaleString();
            document.getElementById('organicKeywords').textContent = traffic.organicKeywords.toLocaleString();
            document.getElementById('paidTraffic').textContent = traffic.paidTraffic.toLocaleString();
            document.getElementById('paidKeywords').textContent = traffic.paidKeywords.toLocaleString();
            
            document.getElementById('urlTrafficResults').style.display = 'block';
        }

        function getDifficultyBadge(difficulty) {
            if (difficulty < 30) return 'bg-success';
            if (difficulty < 60) return 'bg-warning';
            return 'bg-danger';
        }

        function showLoading(message) {
            // You can implement a better loading indicator
            console.log(message);
        }

        function hideLoading() {
            // Hide loading indicator
        }

        // ============================================
        // Google Search API Functions - NEW
        // ============================================

        function showGoogleKeywordResearch() {
            const query = prompt('Enter a keyword or topic to research:');
            if (!query) return;

            showLoading('Searching Google...');

            fetch(`/admin/seo/api/google-search?query=${encodeURIComponent(query)}&limit=10`)
                .then(response => response.json())
                .then(data => {
                    hideLoading();
                    if (data.success) {
                        displayGoogleSearchResults(data.data);
                    } else {
                        alert('Error: ' + data.error);
                    }
                })
                .catch(error => {
                    hideLoading();
                    alert('Error calling Google Search API');
                    console.error(error);
                });
        }

        function displayGoogleSearchResults(data) {
            let html = `
                <div class="modal fade" id="googleResultsModal" tabindex="-1">
                    <div class="modal-dialog modal-xl">
                        <div class="modal-content">
                            <div class="modal-header bg-success text-white">
                                <h5 class="modal-title"><i class="fab fa-google me-2"></i>Google Search Results: "${data.searchTerm}"</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="row">
                                    <div class="col-md-8">
                                        <h6 class="mb-3">Top Search Results (${data.totalResults})</h6>
                                        <div class="list-group">
                                            ${data.results.map(r => `
                                                <div class="list-group-item">
                                                    <div class="d-flex justify-content-between">
                                                        <h6 class="mb-1">${r.position}. ${r.title}</h6>
                                                        <small class="text-muted">${new URL(r.url).hostname}</small>
                                                    </div>
                                                    <p class="mb-1 text-muted small">${r.description}</p>
                                                    <small><a href="${r.url}" target="_blank">${r.url}</a></small>
                                                </div>
                                            `).join('')}
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <h6 class="mb-3">Related Keywords (${data.relatedKeywords.length})</h6>
                                        <div class="d-flex flex-wrap gap-2">
                                            ${data.relatedKeywords.map(k => `
                                                <span class="badge bg-success">${k}</span>
                                            `).join('')}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            const existingModal = document.getElementById('googleResultsModal');
            if (existingModal) existingModal.remove();

            document.body.insertAdjacentHTML('beforeend', html);
            new bootstrap.Modal(document.getElementById('googleResultsModal')).show();
        }

        function showTopicInsights() {
            const topic = prompt('Enter a topic to analyze:');
            if (!topic) return;

            showLoading('Getting topic insights from Google...');

            fetch(`/admin/seo/api/topic-insights?topic=${encodeURIComponent(topic)}`)
                .then(response => response.json())
                .then(data => {
                    hideLoading();
                    if (data.success) {
                        displayTopicInsights(data.data);
                    } else {
                        alert('Error: ' + data.error);
                    }
                })
                .catch(error => {
                    hideLoading();
                    alert('Error getting insights');
                    console.error(error);
                });
        }

        function displayTopicInsights(insights) {
            alert(`Topic: ${insights.topic}\n\n` +
                  `Related Keywords: ${insights.relatedKeywords.length}\n` +
                  `Top Domains: ${insights.topRankingDomains.join(', ')}\n` +
                  `Avg Title Length: ${insights.avgTitleLength}\n` +
                  `Avg Description: ${insights.avgDescriptionLength}\n\n` +
                  `Suggested Keywords:\n${insights.suggestedKeywords.join('\n')}`);
        }

        function showGoogleCompetitors() {
            const query = prompt('Enter a keyword to analyze competitors:');
            if (!query) return;

            showLoading('Analyzing competitors on Google...');

            fetch(`/admin/seo/api/google-competitors?query=${encodeURIComponent(query)}&limit=10`)
                .then(response => response.json())
                .then(data => {
                    hideLoading();
                    if (data.success) {
                        displayGoogleCompetitors(data.data);
                    } else {
                        alert('Error: ' + data.error);
                    }
                })
                .catch(error => {
                    hideLoading();
                    alert('Error analyzing competitors');
                    console.error(error);
                });
        }

        function displayGoogleCompetitors(competitors) {
            let html = `
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th>Domain</th>
                                <th>Title</th>
                                <th>Title Length</th>
                                <th>Desc Length</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${competitors.map(c => `
                                <tr>
                                    <td><span class="badge bg-primary">#${c.position}</span></td>
                                    <td>${c.domain}</td>
                                    <td>${c.title.substring(0, 50)}...</td>
                                    <td>${c.titleLength}</td>
                                    <td>${c.descriptionLength}</td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
            `;
            
            alert('Competitor analysis complete! Check console for details.');
            console.table(competitors);
        }

        function optimizeWithGoogle() {
            const postId = prompt('Enter Post ID to optimize with Google Search + AI:');
            if (!postId) return;

            showLoading('Optimizing with Google Search + AI...');

            fetch(`/admin/seo/api/google-optimize-post?postId=${postId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
                .then(response => response.json())
                .then(data => {
                    hideLoading();
                    if (data.success) {
                        alert(`✅ POST OPTIMIZED!\n\n` +
                              `Original Title: ${data.data.originalTitle}\n` +
                              `Optimized Title: ${data.data.optimizedTitle}\n\n` +
                              `SEO Score: ${data.data.seoScore}/100\n\n` +
                              `Google Keywords: ${data.data.googleRelatedKeywords.join(', ')}\n\n` +
                              `Top Competitors: ${data.data.topCompetitors.join(', ')}\n\n` +
                              `Improvements:\n${data.data.improvementsMade.join('\n')}`);
                        location.reload();
                    } else {
                        alert('Error: ' + data.error);
                    }
                })
                .catch(error => {
                    hideLoading();
                    alert('Error optimizing post');
                    console.error(error);
                });
        }
    </script>
}

