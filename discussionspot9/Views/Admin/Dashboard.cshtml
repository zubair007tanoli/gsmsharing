@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Admin Dashboard";
    ViewData["PageDescription"] = "Overview of your platform's key metrics and recent activity";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats Cards Row -->
<div class="row g-4 mb-4">
    <!-- Total Users Card -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-card-icon" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-card-content">
                <div class="stat-label">Total Users</div>
                <div class="stat-value" id="totalUsers">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
                <div class="stat-change" id="userGrowth">
                    <i class="fas fa-arrow-up"></i>
                    <span>--</span>
                    <small>vs last month</small>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Total Posts Card -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-card-icon" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <i class="fas fa-newspaper"></i>
            </div>
            <div class="stat-card-content">
                <div class="stat-label">Total Posts</div>
                <div class="stat-value" id="totalPosts">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
                <div class="stat-change" id="postGrowth">
                    <i class="fas fa-arrow-up"></i>
                    <span>--</span>
                    <small>vs last month</small>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Revenue Card -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-card-icon" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                <i class="fas fa-dollar-sign"></i>
            </div>
            <div class="stat-card-content">
                <div class="stat-label">Monthly Revenue</div>
                <div class="stat-value" id="monthlyRevenue">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
                <div class="stat-change" id="revenueGrowth">
                    <i class="fas fa-arrow-up"></i>
                    <span>--</span>
                    <small>vs last month</small>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Pending Reports Card -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-card-icon" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);">
                <i class="fas fa-flag"></i>
            </div>
            <div class="stat-card-content">
                <div class="stat-label">Pending Reports</div>
                <div class="stat-value text-danger" id="pendingReports">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
                <div class="stat-change">
                    <a href="/admin/manage/reports" class="btn btn-sm btn-outline-danger">Review Now</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <!-- Revenue Chart -->
    <div class="col-lg-8">
        <div class="chart-card">
            <div class="chart-card-header">
                <h5><i class="fas fa-chart-line me-2"></i>Revenue Trend (Last 30 Days)</h5>
                <div class="btn-group btn-group-sm">
                    <button type="button" class="btn btn-outline-primary active">30 Days</button>
                    <button type="button" class="btn btn-outline-primary">90 Days</button>
                    <button type="button" class="btn btn-outline-primary">1 Year</button>
                </div>
            </div>
            <div class="chart-card-body">
                <canvas id="revenueChart" height="80"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Post Types Distribution -->
    <div class="col-lg-4">
        <div class="chart-card">
            <div class="chart-card-header">
                <h5><i class="fas fa-chart-pie me-2"></i>Post Types</h5>
            </div>
            <div class="chart-card-body">
                <canvas id="postTypesChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Online Users and Stats Row -->
<div class="row g-4 mb-4">
    <!-- Online Users -->
    <div class="col-lg-4">
        <div class="chart-card">
            <div class="chart-card-header">
                <h5><i class="fas fa-circle text-success me-2"></i>Online Now</h5>
                <span class="badge bg-success" id="onlineCount">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </span>
            </div>
            <div class="chart-card-body" id="onlineUsersList" style="max-height: 400px; overflow-y: auto;">
                <div class="text-center py-4">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Post Types Distribution -->
    <div class="col-lg-4">
        <div class="chart-card">
            <div class="chart-card-header">
                <h5><i class="fas fa-chart-pie me-2"></i>Post Types</h5>
            </div>
            <div class="chart-card-body">
                <canvas id="postTypesChart" height="200"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Communities Chart -->
    <div class="col-lg-4">
        <div class="chart-card">
            <div class="chart-card-header">
                <h5><i class="fas fa-users me-2"></i>Communities</h5>
            </div>
            <div class="chart-card-body">
                <div class="stat-value text-center mb-3" id="totalCommunities">
                    <div class="spinner-border" role="status"></div>
                </div>
                <div class="text-center small text-muted">
                    Active communities on the platform
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Activity and Quick Actions Row -->
<div class="row g-4 mb-4">
    <!-- Recent Activity -->
    <div class="col-lg-8">
        <div class="activity-card">
            <div class="activity-header">
                <h5><i class="fas fa-stream me-2"></i>Recent Activity</h5>
                <a href="/admin/logs" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="activity-list" id="recentActivity">
                <div class="text-center py-4">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Quick Actions -->
    <div class="col-lg-4">
        <div class="quick-actions-card">
            <div class="quick-actions-header">
                <h5><i class="fas fa-bolt me-2"></i>Quick Actions</h5>
            </div>
            <div class="quick-actions-list">
                <a href="/admin/manage/reports" class="quick-action-item">
                    <div class="quick-action-icon" style="background: #fa709a;">
                        <i class="fas fa-flag"></i>
                    </div>
                    <div class="quick-action-content">
                        <div class="quick-action-title">Review Reports</div>
                        <div class="quick-action-meta"><span class="badge bg-danger" id="quickPendingReports">0</span> pending</div>
                    </div>
                    <i class="fas fa-chevron-right"></i>
                </a>
                
                <a href="/admin/seo/queue" class="quick-action-item">
                    <div class="quick-action-icon" style="background: #fee140;">
                        <i class="fas fa-tasks"></i>
                    </div>
                    <div class="quick-action-content">
                        <div class="quick-action-title">SEO Queue</div>
                        <div class="quick-action-meta"><span class="badge bg-warning" id="quickSeoQueue">0</span> pending</div>
                    </div>
                    <i class="fas fa-chevron-right"></i>
                </a>
                
                <a href="/admin/manage/users" class="quick-action-item">
                    <div class="quick-action-icon" style="background: #667eea;">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <div class="quick-action-content">
                        <div class="quick-action-title">Add New User</div>
                        <div class="quick-action-meta">Create admin account</div>
                    </div>
                    <i class="fas fa-chevron-right"></i>
                </a>
                
                <a href="/create" class="quick-action-item">
                    <div class="quick-action-icon" style="background: #ff4500;">
                        <i class="fas fa-plus-circle"></i>
                    </div>
                    <div class="quick-action-content">
                        <div class="quick-action-title">Create Post</div>
                        <div class="quick-action-meta">As administrator</div>
                    </div>
                    <i class="fas fa-chevron-right"></i>
                </a>
                
                <a href="/admin/database" class="quick-action-item">
                    <div class="quick-action-icon" style="background: #4facfe;">
                        <i class="fas fa-database"></i>
                    </div>
                    <div class="quick-action-content">
                        <div class="quick-action-title">Database Backup</div>
                        <div class="quick-action-meta">Last: 2 days ago</div>
                    </div>
                    <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

