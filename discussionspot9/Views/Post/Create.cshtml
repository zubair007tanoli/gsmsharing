@using discussionspot9.Helpers
@model discussionspot9.Models.ViewModels.CreativeViewModels.CreatePostViewModel
@{
    ViewData["Title"] = $"Create Post - r/{Model.CommunityName}";
    ViewData["Description"] = "Create engaging posts and automatically generate Web Stories for better SEO and reach";
    ViewData["Keywords"] = "create post, web stories, SEO, content creation, community";
}

<main class="container-fluid py-4">
    <div class="row">
        <!-- Main Form Column -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h1 class="h4 mb-0">
                        <i class="fas fa-edit me-2"></i>
                        @if (string.IsNullOrEmpty(Model.CommunityName))
                        {
                            <text>Create a post - Select Community</text>
                        }
                        else
                        {
                            <text>Create a post in r/@Model.CommunityName</text>
                        }
                    </h1>
                </div>
                <div class="card-body">
                    @if (string.IsNullOrEmpty(Model.CommunityName))
                    {
                        <!-- Community Selection Section -->
                        <div class="alert alert-info mb-4">
                            <h6 class="alert-heading">
                                <i class="fas fa-info-circle me-2"></i>Select a Community
                            </h6>
                            <p class="mb-3">Choose a community to post in:</p>
                            
                            @if (Model.UserCommunities != null && Model.UserCommunities.Any())
                            {
                                <div class="mb-3">
                                    <h6 class="text-primary">Your Communities</h6>
                                    <div class="row">
                                        @foreach (var community in Model.UserCommunities.Take(6))
                                        {
                                            <div class="col-md-4 mb-2">
                                                <a href="/r/@community.Slug/create" class="btn btn-outline-primary btn-sm w-100 text-start">
                                                    <i class="fas fa-users me-2"></i>r/@community.Slug
                                                    <small class="d-block text-muted">@community.MemberCount members</small>
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            
                            @if (Model.SuggestedCommunities != null && Model.SuggestedCommunities.Any())
                            {
                                <div class="mb-3">
                                    <h6 class="text-success">Popular Communities</h6>
                                    <div class="row">
                                        @foreach (var community in Model.SuggestedCommunities.Take(6))
                                        {
                                            <div class="col-md-4 mb-2">
                                                <a href="/r/@community.Slug/create" class="btn btn-outline-success btn-sm w-100 text-start">
                                                    <i class="fas fa-fire me-2"></i>r/@community.Slug
                                                    <small class="d-block text-muted">@community.MemberCount members</small>
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            
                            <div class="text-center">
                                <a href="/communities" class="btn btn-primary">
                                    <i class="fas fa-search me-2"></i>Browse All Communities
                                </a>
                            </div>
                        </div>
                    }
                    
                    @if (!string.IsNullOrEmpty(Model.CommunityName))
                    {
                        <!-- Post Type Tabs -->
                        <ul class="nav nav-tabs mb-4" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#textPost" type="button">
                                <i class="fas fa-align-left me-1"></i> Text
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#linkPost" type="button">
                                <i class="fas fa-link me-1"></i> Link
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#imagePost" type="button">
                                <i class="fas fa-image me-1"></i> Image
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#pollPost" type="button">
                                <i class="fas fa-poll me-1"></i> Poll
                            </button>
                        </li>
                    </ul>

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="CommunityId" />
                        <input type="hidden" asp-for="CommunityName" />
                        <input type="hidden" asp-for="CommunitySlug" />
                        <input type="hidden" asp-for="PostType" value="text" id="postTypeInput" />
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                        <!-- Title -->
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Title</label>
                            <input asp-for="Title" class="form-control" maxlength="300" required />
                            <div class="form-text">@Html.DisplayNameFor(m => m.Title) (max 300 characters)</div>
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <!-- Tab Content -->
                        <div class="tab-content mb-3">
                            <!-- Text Post -->
                            <div class="tab-pane fade show active" id="textPost">
                                <div class="mb-3">
                                    <label asp-for="Content" class="form-label">Text (optional)</label>
                                    <textarea asp-for="Content" class="form-control" rows="8"></textarea>
                                    <span asp-validation-for="Content" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Link Post -->
                            <div class="tab-pane fade" id="linkPost">
                                <div class="mb-3">
                                    <label asp-for="Url" class="form-label">URL</label>
                                    <input asp-for="Url" type="url" class="form-control" />
                                    <span asp-validation-for="Url" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Image Post -->
                            <div class="tab-pane fade" id="imagePost">
                                <div class="mb-3">
                                    <label class="form-label">Upload Image(s)</label>
                                    <input type="file" name="MediaFiles" class="form-control" accept="image/*,video/*" multiple id="mediaFilesInput" />
                                    <div class="form-text">Supported formats: JPG, PNG, GIF, MP4, WebM (max 20MB each). You can select multiple files.</div>
                                    <div id="selectedFiles" class="mt-2"></div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Or add Image URL(s)</label>
                                    <textarea name="MediaUrlsInput" class="form-control" rows="3" placeholder="https://example.com/image1.jpg&#10;https://example.com/image2.jpg" id="mediaUrlsInput"></textarea>
                                    <div class="form-text">Enter one URL per line for external images</div>
                                </div>
                            </div>

                            <!-- Poll Post -->
                            <div class="tab-pane fade" id="pollPost">
                                <div class="mb-3">
                                    <label asp-for="PollQuestion" class="form-label">Poll Question</label>
                                    <input asp-for="PollQuestion" class="form-control" placeholder="What is your question?" />
                                    <span asp-validation-for="PollQuestion" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="PollDescription" class="form-label">Description (optional)</label>
                                    <textarea asp-for="PollDescription" class="form-control" rows="2" placeholder="Add more details about your poll"></textarea>
                                </div>
                                <div id="pollOptions">
                                    <div class="mb-3">
                                        <label class="form-label">Options</label>
                                        <div class="poll-option mb-2">
                                            <input type="text" name="PollOptions" class="form-control" placeholder="Option 1" />
                                        </div>
                                        <div class="poll-option mb-2">
                                            <input type="text" name="PollOptions" class="form-control" placeholder="Option 2" />
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="addOption">
                                        <i class="fas fa-plus me-1"></i> Add Option
                                    </button>
                                </div>
                                <div class="mt-3">
                                    <div class="form-check">
                                        <input asp-for="AllowMultipleChoices" type="checkbox" class="form-check-input" />
                                        <label asp-for="AllowMultipleChoices" class="form-check-label"></label>
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <label asp-for="PollEndDate" class="form-label">Poll End Date (optional)</label>
                                    <input asp-for="PollEndDate" type="datetime-local" class="form-control" />
                                    <span asp-validation-for="PollEndDate" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Tags -->
                        <div class="mb-3">
                            <label asp-for="TagsInput" class="form-label">Tags</label>
                            <input asp-for="TagsInput" class="form-control" placeholder="tag1, tag2, tag3" />
                            <div class="form-text">Separate tags with commas</div>
                        </div>

                        <!-- Auto-Story Generation Options -->
                        <div class="card mb-4 border-success">
                            <div class="card-header bg-success text-white">
                                <h6 class="mb-0">
                                    <i class="fas fa-magic me-2"></i>Auto-Generate Web Story
                                    <small class="ms-2">Boost SEO & Reach</small>
                                </h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="autoGenerateStory" name="AutoGenerateStory" checked>
                                            <label class="form-check-label" for="autoGenerateStory">
                                                <strong>Generate Web Story</strong>
                                                <small class="d-block text-muted">Automatically create a Web Story from this post</small>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="useAIContent" name="UseAIContent" checked>
                                            <label class="form-check-label" for="useAIContent">
                                                <strong>AI-Enhanced Content</strong>
                                                <small class="d-block text-muted">Use AI to optimize story content</small>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Story Customization Options -->
                                <div id="storyOptions" class="mt-3">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label for="storyStyle" class="form-label">Story Style</label>
                                            <select class="form-select form-select-sm" id="storyStyle" name="StoryStyle">
                                                <option value="informative">📚 Informative</option>
                                                <option value="engaging">🎯 Engaging</option>
                                                <option value="tutorial">🔧 Tutorial</option>
                                                <option value="news">📰 News</option>
                                                <option value="entertainment">🎭 Entertainment</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="storyLength" class="form-label">Story Length</label>
                                            <select class="form-select form-select-sm" id="storyLength" name="StoryLength">
                                                <option value="short">⚡ Short (3-5 slides)</option>
                                                <option value="medium" selected>📖 Medium (6-10 slides)</option>
                                                <option value="long">📚 Long (11-15 slides)</option>
                                            </select>
                                        </div>
                                    </div>
                                    
                                    <div class="mt-3">
                                        <label for="storyKeywords" class="form-label">SEO Keywords (optional)</label>
                                        <input type="text" class="form-control form-control-sm" id="storyKeywords" name="StoryKeywords" 
                                               placeholder="Enter keywords separated by commas">
                                        <small class="form-text text-muted">Help AI generate better content for SEO</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Options -->
                        <div class="row mb-4">
                            <div class="col-4">
                                <div class="form-check">
                                    <input asp-for="IsNSFW" type="checkbox" class="form-check-input" />
                                    <label asp-for="IsNSFW" class="form-check-label">NSFW</label>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="form-check">
                                    <input asp-for="IsSpoiler" type="checkbox" class="form-check-input" />
                                    <label asp-for="IsSpoiler" class="form-check-label">Spoiler</label>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="enableComments" name="EnableComments" checked>
                                    <label class="form-check-label" for="enableComments">Allow Comments</label>
                                </div>
                            </div>
                        </div>

                        <!-- Submit -->
                        <div class="d-flex justify-content-between">
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-primary" id="ai-enhancement-btn">
                                    <i class="fas fa-robot me-1"></i>AI Enhancement
                                </button>
                                <a href="@Url.Community(Model.CommunitySlug)" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-1"></i> Post
                            </button>
                        </div>
                    </form>
                    }
                </div>
            </div>
        </div>
        
        <!-- SEO Assistant Sidebar Column -->
        <div class="col-lg-4">
            @await Html.PartialAsync("_SeoAssistant")
        </div>
    </div>
</main>

<!-- AI Enhancement Panel -->
@await Html.PartialAsync("~/Views/Shared/Components/AIEnhancement/AIEnhancementPanel.cshtml", Model)

@section Scripts {
    <script>
        // Handle tab switching and clear irrelevant fields
        document.querySelectorAll('[data-bs-toggle="tab"]').forEach(tab => {
            tab.addEventListener('shown.bs.tab', function (e) {
                const postType = e.target.textContent.trim().toLowerCase();
                document.getElementById('postTypeInput').value = postType;
                
                // Clear fields based on post type
                clearIrrelevantFields(postType);
            });
        });
        
        // Clear irrelevant fields when switching post types
        function clearIrrelevantFields(postType) {
            const contentField = document.querySelector('[name="Content"]');
            const urlField = document.querySelector('[name="Url"]');
            const pollQuestion = document.querySelector('[name="PollQuestion"]');
            const pollDescription = document.querySelector('[name="PollDescription"]');
            const pollOptions = document.querySelectorAll('[name="PollOptions"]');
            const pollEndDate = document.querySelector('[name="PollEndDate"]');
            const multipleChoices = document.querySelector('[name="AllowMultipleChoices"]');
            
            switch(postType) {
                case 'text':
                    // DON'T CLEAR - Users can add text + other content types
                    // Just log for debugging
                    console.log('📝 Text post type selected - keeping all other fields');
                    break;
                    
                case 'link':
                    // DON'T CLEAR - Users can add link + content + images
                    console.log('🔗 Link post type selected - keeping all other fields');
                    break;
                    
                case 'image':
                    // DON'T CLEAR - Users can add images + URL + content
                    console.log('📸 Image post type selected - keeping all other fields');
                    break;
                    
                case 'poll':
                    // DON'T CLEAR - Users can add poll + content + images
                    console.log('📊 Poll post type selected - keeping all other fields');
                    break;
            }
        }

        // File selection preview
        const mediaFilesInput = document.getElementById('mediaFilesInput');
        const selectedFilesDiv = document.getElementById('selectedFiles');
        
        if (mediaFilesInput && selectedFilesDiv) {
            mediaFilesInput.addEventListener('change', function(e) {
                const files = Array.from(e.target.files);
                
                if (files.length === 0) {
                    selectedFilesDiv.innerHTML = '';
                    return;
                }
                
                let html = '<div class="alert alert-info"><strong>📎 Selected Files:</strong><ul class="mb-0 mt-2">';
                files.forEach((file, index) => {
                    const sizeMB = (file.size / (1024 * 1024)).toFixed(2);
                    html += `<li><strong>${file.name}</strong> - ${sizeMB} MB (${file.type})</li>`;
                });
                html += '</ul></div>';
                
                selectedFilesDiv.innerHTML = html;
                console.log(`✅ ${files.length} file(s) selected for upload`);
            });
        }
        
        // Media URLs preview
        const mediaUrlsInput = document.getElementById('mediaUrlsInput');
        if (mediaUrlsInput) {
            mediaUrlsInput.addEventListener('blur', function() {
                const urls = this.value.split('\n').filter(url => url.trim().length > 0);
                if (urls.length > 0) {
                    console.log(`✅ ${urls.length} media URL(s) entered`);
                }
            });
        }
        
        // Add poll option
        let optionCount = 2;
        document.getElementById('addOption')?.addEventListener('click', function() {
            if (optionCount < 10) {
                optionCount++;
                const pollOptionsContainer = document.getElementById('pollOptions');
                const optionsDiv = pollOptionsContainer.querySelector('.mb-3');
                const newOption = document.createElement('div');
                newOption.className = 'poll-option mb-2';
                newOption.innerHTML = `<input type="text" name="PollOptions" class="form-control" placeholder="Option ${optionCount}" />`;
                optionsDiv.appendChild(newOption);
            }
        });

        // Auto-Story Generation Features
        document.addEventListener('DOMContentLoaded', function() {
            const autoGenerateCheckbox = document.getElementById('autoGenerateStory');
            const storyOptions = document.getElementById('storyOptions');
            
            // Toggle story options visibility
            function toggleStoryOptions() {
                if (autoGenerateCheckbox && storyOptions) {
                    if (autoGenerateCheckbox.checked) {
                        storyOptions.style.display = 'block';
                    } else {
                        storyOptions.style.display = 'none';
                    }
                }
            }
            
            if (autoGenerateCheckbox) {
                autoGenerateCheckbox.addEventListener('change', toggleStoryOptions);
                toggleStoryOptions(); // Initial state
            }
            
            // Auto-fill story keywords from post title
            const titleInput = document.querySelector('[name="Title"]');
            const keywordsInput = document.getElementById('storyKeywords');
            
            if (titleInput && keywordsInput) {
                titleInput.addEventListener('input', function() {
                    if (keywordsInput.value === '') {
                        // Extract potential keywords from title
                        const title = this.value.toLowerCase();
                        const keywords = title.split(' ')
                            .filter(word => word.length > 3)
                            .slice(0, 5)
                            .join(', ');
                        keywordsInput.value = keywords;
                    }
                });
            }
            
            // Story style recommendations based on post type
            const postTypeInput = document.getElementById('postTypeInput');
            const storyStyleSelect = document.getElementById('storyStyle');
            
            function updateStoryStyleRecommendation() {
                if (postTypeInput && storyStyleSelect) {
                    const postType = postTypeInput.value;
                    let recommendedStyle = 'informative';
                    
                    switch(postType) {
                        case 'text':
                            recommendedStyle = 'informative';
                            break;
                        case 'link':
                            recommendedStyle = 'news';
                            break;
                        case 'image':
                            recommendedStyle = 'engaging';
                            break;
                        case 'poll':
                            recommendedStyle = 'engaging';
                            break;
                    }
                    
                    storyStyleSelect.value = recommendedStyle;
                }
            }
            
            // Update story style when post type changes
            document.querySelectorAll('[data-bs-toggle="tab"]').forEach(tab => {
                tab.addEventListener('shown.bs.tab', updateStoryStyleRecommendation);
            });
            
            // Show story generation preview
            function showStoryPreview() {
                if (autoGenerateCheckbox && autoGenerateCheckbox.checked) {
                    const title = titleInput ? titleInput.value : '';
                    const style = storyStyleSelect ? storyStyleSelect.value : '';
                    const length = document.getElementById('storyLength') ? document.getElementById('storyLength').value : '';
                    
                    if (title) {
                        // Show preview notification
                        showNotification('Story will be generated automatically after posting!', 'success');
                    }
                }
            }
            
            // AI Enhancement Panel
            const aiEnhancementBtn = document.getElementById('ai-enhancement-btn');
            const aiPanel = document.getElementById('ai-enhancement-panel');
            
            if (aiEnhancementBtn && aiPanel) {
                aiEnhancementBtn.addEventListener('click', () => {
                    aiPanel.style.display = aiPanel.style.display === 'none' ? 'block' : 'none';
                });
            }
            
            // Enhanced form submission with debugging
            const form = document.querySelector('form');
            if (form) {
                form.addEventListener('submit', function(e) {
                    // Log what's being submitted for debugging
                    console.log('🚀 === FORM SUBMISSION DEBUG ===');
                    console.log('Title:', document.querySelector('[name="Title"]')?.value);
                    console.log('PostType:', document.querySelector('[name="PostType"]')?.value);
                    console.log('Content:', document.querySelector('[name="Content"]')?.value?.substring(0, 100));
                    console.log('Url:', document.querySelector('[name="Url"]')?.value);
                    
                    // Log media files
                    const mediaFiles = document.querySelector('[name="MediaFiles"]')?.files;
                    if (mediaFiles && mediaFiles.length > 0) {
                        console.log(`📎 Media Files: ${mediaFiles.length} file(s) selected`);
                        for (let i = 0; i < mediaFiles.length; i++) {
                            console.log(`  ${i + 1}. ${mediaFiles[i].name} (${(mediaFiles[i].size / 1024).toFixed(2)} KB)`);
                        }
                    } else {
                        console.log('📎 Media Files: None');
                    }
                    
                    // Log media URLs
                    const mediaUrls = document.querySelector('[name="MediaUrlsInput"]')?.value;
                    if (mediaUrls && mediaUrls.trim().length > 0) {
                        const urls = mediaUrls.split('\n').filter(u => u.trim().length > 0);
                        console.log(`🔗 Media URLs: ${urls.length} URL(s) entered`);
                        urls.forEach((url, i) => console.log(`  ${i + 1}. ${url.trim()}`));
                    } else {
                        console.log('🔗 Media URLs: None');
                    }
                    
                    console.log('===============================');
                    
                    // Show story preview if enabled
                    if (autoGenerateCheckbox && autoGenerateCheckbox.checked) {
                        showStoryPreview();
                    }
                });
            }
        });
        
        // Notification system
        function showNotification(message, type = 'info') {
            const notification = document.createElement('div');
            notification.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            notification.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
            notification.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(notification);
            
            // Auto-remove after 5 seconds
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.remove();
                }
            }, 5000);
        }
    </script>
}