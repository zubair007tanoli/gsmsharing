@model discussionspot9.Models.ViewModels.CreativeViewModels.PostListViewModel
@using discussionspot9.Helpers
@using discussionspot9.Extensions
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    ViewData["Title"] = "All Posts - DiscussionSpot";
    var currentSort = ViewData["CurrentSort"]?.ToString() ?? "hot";
    var currentTime = ViewData["CurrentTime"]?.ToString() ?? "all";
    var currentPage = ViewData["CurrentPage"] as int? ?? 1;
}

<link href="~/css/CustomStyles/All_Post_Style.css" rel="stylesheet" />

<div class="all-posts-container">
    <div class="container main-container">
        <div class="row">
            <!-- Left Sidebar -->
            <div class="col-lg-3">
                <!-- Left Sidebar Ad -->
                <div class="mb-3">
                    <partial name="_AdUnit_Side" />
                </div>
                
                <!-- Trending Communities -->
                <partial name="Partials/PostsPartial/_TrendingCommunities" model="Model.TrendingCommunities" />

                <!-- Ad Banner -->
                <div class="ad-banner">
                    <div class="mb-2"><small>Advertisement</small></div>
                    <div style="height: 250px; display: flex; align-items: center; justify-content: center; background: linear-gradient(45deg, #f0f0f0, #e0e0e0);">
                        <div class="text-center">
                            <i class="fas fa-ad fa-2x mb-2"></i>
                            <div>Your Ad Here</div>
                            <div><small>300x250</small></div>
                        </div>
                    </div>
                </div>

                <!-- Recent News/Updates -->
                <partial name="Partials/PostsPartial/_RecentUpdates" />
            </div>

            <!-- Main Content -->
            <div class="col-lg-6">
                <!-- Header Section with Sort Controls -->
                <div class="sidebar-card">
                    <div class="sidebar-content">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h1 class="h4 mb-0">All Posts</h1>
                            @if (SignInManager.IsSignedIn(User))
                            {
                                <a href="@Url.Action("Create", "Post")" class="btn btn-primary btn-sm">
                                    <i class="fas fa-plus"></i> Create Post
                                </a>
                            }
                        </div>

                        <div class="sort-controls">
                            <a href="@Url.Action("All", new { sort = "hot", time = currentTime })"
                               class="sort-btn @(currentSort == "hot" ? "active" : "")">
                                <i class="fas fa-fire"></i> Hot
                            </a>
                            <a href="@Url.Action("All", new { sort = "new", time = currentTime })"
                               class="sort-btn @(currentSort == "new" ? "active" : "")">
                                <i class="fas fa-clock"></i> New
                            </a>
                            <a href="@Url.Action("All", new { sort = "top", time = currentTime })"
                               class="sort-btn @(currentSort == "top" ? "active" : "")">
                                <i class="fas fa-arrow-up"></i> Top
                            </a>
                            <a href="@Url.Action("All", new { sort = "controversial", time = currentTime })"
                               class="sort-btn @(currentSort == "controversial" ? "active" : "")">
                                <i class="fas fa-comments"></i> Controversial
                            </a>

                            @if (currentSort == "top" || currentSort == "controversial")
                            {
                                <select class="form-select form-select-sm" style="width: auto;"
                                        onchange="window.location.href='@Url.Action("All", new { sort = currentSort })' + '&time=' + this.value">
                                    <option value="all" selected="@(currentTime == "all" ? "true" : "false")">All Time</option>
                                    <option value="today" selected="@(currentTime == "today" ? "true" : "false")">Today</option>
                                    <option value="week" selected="@(currentTime == "week" ? "true" : "false")">This Week</option>
                                    <option value="month" selected="@(currentTime == "month" ? "true" : "false")">This Month</option>
                                    <option value="year" selected="@(currentTime == "year" ? "true" : "false")">This Year</option>
                                </select>
                            }
                        </div>
                    </div>
                </div>

                <!-- Posts List -->
                <div class="posts-list">
                    @if (Model.Posts?.Any() == true)
                    {
                        var postIndex = 0;
                        @foreach (var post in Model.Posts)
                        {
                            postIndex++;
                            <partial name="Partials/PostsPartial/_PostCardEnhanced" model="post" />
                            
                            @* In-Feed Ad after every 3rd post *@
                            @if (postIndex % 3 == 0 && postIndex < Model.Posts.Count)
                            {
                                <div class="ad-in-feed my-3">
                                    <partial name="_AdUnit_InArticle" />
                                </div>
                            }
                        }
                    }
                    else
                    {
                        <div class="post-card">
                            <div class="post-content text-center py-5">
                                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                <h5 class="text-muted">No posts found</h5>
                                <p class="text-muted">Be the first to share something!</p>
                                @if (SignInManager.IsSignedIn(User))
                                {
                                    <a href="@Url.Action("Create", "Post")" class="btn btn-primary">
                                        <i class="fas fa-plus"></i> Create Post
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="pagination-container">
                        <nav aria-label="Page navigation">
                            <ul class="pagination">
                                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("All", new { sort = currentSort, time = currentTime, page = currentPage - 1 })">
                                        <span aria-hidden="true">&laquo;</span>
                                    </a>
                                </li>

                                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(Model.TotalPages, currentPage + 2); i++)
                                {
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("All", new { sort = currentSort, time = currentTime, page = i })">@i</a>
                                    </li>
                                }

                                <li class="page-item @(currentPage >= Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("All", new { sort = currentSort, time = currentTime, page = currentPage + 1 })">
                                        <span aria-hidden="true">&raquo;</span>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
            </div>

            <!-- Right Sidebar -->
            <div class="col-lg-3">
                <!-- Right Sidebar Ad: Sticky -->
                <div class="position-sticky mb-3" style="top: 80px;">
                    <partial name="_AdUnit_Side" />
                </div>
                
                <!-- Trending Topics -->
                <partial name="Partials/PostsPartial/_TrendingTopics" model="Model.TrendingTopics" />

                <!-- Ad Banner -->
                <div class="ad-banner">
                    <div class="mb-2"><small>Advertisement</small></div>
                    <div style="height: 250px; display: flex; align-items: center; justify-content: center; background: linear-gradient(45deg, #f0f0f0, #e0e0e0);">
                        <div class="text-center">
                            <i class="fas fa-ad fa-2x mb-2"></i>
                            <div>Your Ad Here</div>
                            <div><small>300x250</small></div>
                        </div>
                    </div>
                </div>

                <!-- Community Stats -->
                <partial name="Partials/PostsPartial/_CommunityStats" />

                <!-- About DiscussionSpot -->
                <div class="sidebar-card">
                    <div class="sidebar-header">
                        <i class="fas fa-info-circle"></i> About DiscussionSpot
                    </div>
                    <div class="sidebar-content">
                        <p class="small mb-3">Welcome to DiscussionSpot, your premier online forum for meaningful discussions across technology, gaming, science, and more.</p>
                        <div class="d-grid">
                            <a href="@Url.Action("About", "Home")" class="btn btn-outline-primary btn-sm">Learn More</a>
                        </div>
                    </div>
                </div>

                <!-- Newsletter -->
                <partial name="Partials/PostsPartial/_Newsletter" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/CustomJs/post-interactions.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize post interactions
            initializePostInteractions('@Url.Action("Vote", "Post")', '@Url.Action("Share", "Post")');

            // Initialize CSRF token for AJAX requests
            const csrfToken = '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)[1];
            window.csrfToken = csrfToken;
        });
    </script>
}