<main class="container-fluid py-3">
    <div class="row">
        <!-- Left Sidebar -->
        <div class="col-lg-2 d-none d-lg-block">
            <div class="sidebar">
                <!-- Popular Communities -->
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0">Popular Communities</h6>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a href="@Url.CreateCommunity()" class="btn btn-sm btn-outline-primary" title="Create Community">
                                    <i class="fas fa-plus"></i>
                                </a>
                            }
                        </div>
                        @if (ViewBag.PopularCommunities != null)
                        {
                            <div class="community-list">
                                @foreach (var community in ViewBag.PopularCommunities)
                                {
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="avatar avatar-sm me-2" style="background-color: @community.ThemeColor;">
                                            @community.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <div class="flex-grow-1">
                                            <a href="@Url.Community((string)community.Slug)" class="text-decoration-none">
                                                <div class="fw-bold small">r/@community.Name</div>
                                                <div class="text-muted small">@community.FormattedMemberCount members</div>
                                            </a>
                                        </div>
                                        @if (User.Identity?.IsAuthenticated == true)
                                        {
                                            <button class="btn btn-sm @(community.IsCurrentUserMember ? "btn-secondary" : "btn-outline-primary") join-btn" 
                                                    data-community-id="@community.CommunityId">
                                                @(community.IsCurrentUserMember ? "Joined" : "Join")
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                            <a href="@Url.Communities()" class="btn btn-link btn-sm w-100">View All</a>
                        }
                    </div>
                </div>

                <!-- Premium Promo -->
                <div class="card mb-3 bg-warning bg-opacity-10">
                    <div class="card-body text-center">
                        <i class="fas fa-crown text-warning mb-2"></i>
                        <h6>DiscussionSpot Premium</h6>
                        <p class="small">Get an ad-free experience with special benefits</p>
                        <a href="#" class="btn btn-warning btn-sm w-100">Try Premium</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Feed -->
        <div class="col-lg-7">
            <!-- Feed Header -->
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h1 class="h3 mb-0">All Posts</h1>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a href="@Url.Communities()" class="btn btn-primary btn-sm">
                                <i class="fas fa-plus me-1"></i>Create Post
                            </a>
                        }
                    </div>
                    
                    <!-- Sort Options -->
                    <div class="btn-group" role="group">
                        <a href="@Url.All("hot")" class="btn btn-sm @(currentSort == "hot" ? "btn-primary" : "btn-outline-secondary")">
                            <i class="fas fa-fire"></i> Hot
                        </a>
                        <a href="@Url.All("new")" class="btn btn-sm @(currentSort == "new" ? "btn-primary" : "btn-outline-secondary")">
                            <i class="fas fa-certificate"></i> New
                        </a>
                        <a href="@Url.All("top")" class="btn btn-sm @(currentSort == "top" ? "btn-primary" : "btn-outline-secondary")">
                            <i class="fas fa-arrow-up"></i> Top
                        </a>
                        <a href="@Url.All("controversial")" class="btn btn-sm @(currentSort == "controversial" ? "btn-primary" : "btn-outline-secondary")">
                            <i class="fas fa-bolt"></i> Controversial
                        </a>
                    </div>

                    @if (currentSort == "top")
                    {
                        <div class="btn-group ms-2" role="group">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="far fa-clock me-1"></i>@currentTime
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item @(currentTime == "day" ? "active" : "")" href="@Url.All("top")?time=day">Today</a></li>
                                <li><a class="dropdown-item @(currentTime == "week" ? "active" : "")" href="@Url.All("top")?time=week">This Week</a></li>
                                <li><a class="dropdown-item @(currentTime == "month" ? "active" : "")" href="@Url.All("top")?time=month">This Month</a></li>
                                <li><a class="dropdown-item @(currentTime == "year" ? "active" : "")" href="@Url.All("top")?time=year">This Year</a></li>
                                <li><a class="dropdown-item @(currentTime == "all" ? "active" : "")" href="@Url.All("top")?time=all">All Time</a></li>
                            </ul>
                        </div>
                    }
                </div>
            </div>

            <!-- Posts -->
            <div class="posts-list">
                @if (Model.Posts.Any())
                {
                    @foreach (var post in Model.Posts)
                    {
                        <partial name="Partials/PostsPartial/_PostCardReddit" model="post" />
                    
                    }

                    <!-- Pagination -->
                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Page navigation" class="mt-4">
                            <ul class="pagination justify-content-center">
                                @if (Model.CurrentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.All(currentSort)?time=@currentTime&page=@(Model.CurrentPage - 1)">Previous</a>
                                    </li>
                                }

                                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.All(currentSort)?time=@currentTime&page=@i">@i</a>
                                    </li>
                                }

                                @if (Model.CurrentPage < Model.TotalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.All(currentSort)?time=@currentTime&page=@(Model.CurrentPage + 1)">Next</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                }
                else
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No posts found</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Right Sidebar -->
        <div class="col-lg-3 d-none d-lg-block">
            <div class="sidebar">
                <!-- Today's Top Growing Communities -->
                @if (ViewBag.TrendingCommunities != null)
                {
                    <div class="card mb-3">
                        <div class="card-header">
                            <h6 class="mb-0">Today's Top Growing Communities</h6>
                        </div>
                        <div class="card-body">
                            @foreach (var community in ViewBag.TrendingCommunities)
                            {
                                <div class="d-flex align-items-center mb-3">
                                    <span class="badge bg-light text-dark me-2">@community.Rank</span>
                                    <div class="avatar avatar-sm me-2" style="background-color: @community.ThemeColor;">
                                        @community.Name.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="flex-grow-1">
                                        <a href="@Url.Community((string)community.Slug)" class="text-decoration-none">
                                            <div class="fw-bold small">r/@community.Name</div>
                                            <div class="text-success small">+@community.GrowthPercentage% today</div>
                                        </a>
                                    </div>
                                </div>
                            }
                            <a href="@Url.Communities(sort: "trending")" class="btn btn-link btn-sm w-100">View All</a>
                        </div>
                    </div>
                }

                <!-- Recent Activity -->
                @if (User.Identity?.IsAuthenticated == true && ViewBag.RecentActivity != null)
                {
                    <div class="card mb-3">
                        <div class="card-header">
                            <h6 class="mb-0">Recent Activity</h6>
                        </div>
                        <div class="card-body">
                            @foreach (var activity in ViewBag.RecentActivity)
                            {
                                <div class="d-flex align-items-start mb-3">
                                    <div class="avatar avatar-sm me-2" style="background-color: @activity.IconColor;">
                                        <i class="@activity.IconClass"></i>
                                    </div>
                                    <div>
                                        <div class="small">@activity.Description</div>
                                        <div class="text-muted small">@activity.TimeAgo</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Community Guidelines -->
                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0">DiscussionSpot Rules</h6>
                    </div>
                    <div class="card-body">
                        <ol class="small ps-3 mb-0">
                            <li>Remember the human</li>
                            <li>Behave like you would in real life</li>
                            <li>Look for the original source of content</li>
                            <li>Search for duplicates before posting</li>
                            <li>Read the community's rules</li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

