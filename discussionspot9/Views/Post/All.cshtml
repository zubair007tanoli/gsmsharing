@section Scripts {
    <script>
        // Voting functionality
        document.querySelectorAll('.vote-btn').forEach(button => {
            button.addEventListener('click', async function() {
                if (!@Html.Raw(User.Identity?.IsAuthenticated.ToString().ToLower() ?? "false")) {
                    window.location.href = '@Url.Login()';
                    return;
                }

                const postId = this.dataset.postId;
                const voteType = parseInt(this.dataset.voteType);
                const voteSection = this.closest('.vote-section');
                const countElement = voteSection.querySelector('.vote-count');
                const upvoteBtn = voteSection.querySelector('.upvote');
                const downvoteBtn = voteSection.querySelector('.downvote');

                try {
                    const response = await fetch('/Post/Vote', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        },
                        body: JSON.stringify({ postId: parseInt(postId), voteType })
                    });

                    const result = await response.json();
                    if (result.success) {
                        countElement.textContent = result.voteCount > 1000 ?
                            (result.voteCount / 1000).toFixed(1) + 'k' :
                            result.voteCount.toString();

                        upvoteBtn.classList.toggle('active', result.userVote === 1);
                        downvoteBtn.classList.toggle('active', result.userVote === -1);
                    }
                } catch (error) {
                    console.error('Voting error:', error);
                }
            });
        });
    </script>
}