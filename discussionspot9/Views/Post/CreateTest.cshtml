    function chunkify(text) {
        if (!text) return '';
        return text.split(/\n+/).map(p => p.trim()).filter(Boolean).map(p => {
            // Split long paragraphs into ~2-3 line chunks
            if (p.length > 240) {
                return p.match(/.{1,220}(\s|$)/g).join('\n\n');
            }
            return p;
        }).join('\n\n');
    }

    // Paragraph splitter that keeps basic HTML
    function splitIntoParas(htmlOrText) {
        if (!htmlOrText) return [];
        const tmp = document.createElement('div');
        tmp.innerHTML = htmlOrText;
        // If HTML contains block elements, split by them; else fall back to line breaks
        const blocks = tmp.querySelectorAll('p, div, li');
        if (blocks.length) {
            return Array.from(blocks).map(b => b.innerHTML);
        }
        const plain = tmp.textContent || '';
        return plain.split(/\n{2,}/).filter(p => p.trim().length);
    }

    // Clean HTML noise ( stray closing tags etc.) before rewrite
    function cleanHtmlForRewrite(htmlOrText) {
        if (!htmlOrText) return '';
        let text = htmlOrText;
        text = text.replace(/<\/?(strong|b|i|em)>\s*:/gi, ': ');
        text = text.replace(/<\/?(strong|b|i|em)>/gi, '');
        return text;
    }

    // Humanizing rewrite: grammar + cadence + light contractions (keeps meaning)
    function smartRewrite(text) {
        if (!text) return '';
        let t = text;
        const replacements = [
            [/in today's fast-paced world/gi, ''],
            [/in today's digital age/gi, ''],
            [/\bmoreover\b/gi, 'On top of that,'],
            [/\badditionally\b/gi, 'Also,'],
            [/\bfurthermore\b/gi, 'Plus,'],
            [/\butilize\b/gi, 'use'],
            [/\bapproximately\b/gi, 'about'],
            [/\bdue to the fact that\b/gi, 'because'],
            [/\bat this point in time\b/gi, 'now'],
            [/\bit is\b/gi, "it's"],
            [/\bdo not\b/gi, "don't"],
            [/\bdoes not\b/gi, "doesn't"],
            [/\bcan not\b/gi, "can't"],
            [/\bare not\b/gi, "aren't"],
            [/\bis not\b/gi, "isn't"],
            [/\bwill not\b/gi, "won't"]
        ];
        replacements.forEach(([pat, rep]) => {
            t = t.replace(pat, rep);
        });
        // Remove stray closing tags and double punctuation
        t = t.replace(/<\/?[^>]+>/g, '');
        t = t.replace(/:{2,}/g, ':');
        // Trim double spaces and tidy punctuation
        t = t.replace(/\s{2,}/g, ' ').trim();
        // Humanize cadence: split long sentences, keep meaning
        return humanizeCadence(t);
    }

    function humanizeCadence(text) {
        if (!text) return '';
        const sentences = text
            .replace(/([.!?])\s+/g, '$1|')
            .split('|')
            .map(s => s.trim())
            .filter(Boolean);

        const softened = sentences.map(s => {
            if (s.length <= 120) return s;
            // Split long sentences at commas or "and"
            const parts = s.split(/,| and /);
            if (parts.length > 1) {
                const trimmedParts = parts.map(p => p.trim()).filter(Boolean);
                return trimmedParts.join('. ');
            }
            return s;
        });

        return softened.join('. ').replace(/\.\./g, '.').trim();
    }

    function stripHtml(html) {
        const tmp = document.createElement('div');
        tmp.innerHTML = html || '';
        return tmp.textContent || tmp.innerText || '';
    }

