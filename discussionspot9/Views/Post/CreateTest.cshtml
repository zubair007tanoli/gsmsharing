@model discussionspot9.Models.ViewModels.CreativeViewModels.CreatePostViewModel
@{
    ViewData["Title"] = "Create New Post";
}
<style>
    /* Scoped styles for post creator to prevent conflicts */
    .post-creator-container * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .post-creator-container {
        font-family: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background-color: #DAE0E6;
        color: #1c1c1c;
        line-height: 1.4;
        font-size: 14px;
        min-height: 100vh;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* Dark mode compatibility */
    body.dark-mode .post-creator-container {
        background-color: #111827;
        color: #f9fafb;
    }

    /* Reddit-like Header */
    .post-creator-container .reddit-header {
        background: #fff;
        border-bottom: 1px solid #ccc;
        padding: 0;
        position: sticky;
        top: 0;
        z-index: 100;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .reddit-header {
        background: #111827;
        border-bottom-color: #374151;
    }

    .post-creator-container .header-content {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        padding: 0 20px;
        height: 48px;
    }

    .post-creator-container .reddit-logo {
        font-size: 20px;
        font-weight: bold;
        color: #FF4500;
        text-decoration: none;
        margin-right: 20px;
    }

    .post-creator-container .header-nav {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-left: auto;
    }

    .post-creator-container .header-btn {
        padding: 4px 16px;
        border: 1px solid #0079D3;
        background: transparent;
        color: #0079D3;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .header-btn {
        border-color: #818cf8;
        color: #818cf8;
    }

        body.dark-mode .post-creator-container .header-btn:hover {
            background: #818cf8;
            color: white;
        }

    .post-creator-container .header-btn.primary {
        background: #0079D3;
        color: white;
    }

    body.dark-mode .post-creator-container .header-btn.primary {
        background: #818cf8;
        border-color: #818cf8;
    }

    /* Main Layout */
    .post-creator-container .container-fluid.main-container {
        max-width: none;
        padding: 0 15px;
        margin: 20px auto;
        display: grid;
        grid-template-columns: 312px 1fr 312px;
        gap: 20px;
        padding: 0 20px;
    }

    /* Left Sidebar */
    .post-creator-container .left-sidebar {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .post-creator-container .sidebar-card {
        background: #fff;
        border: 1px solid #ccc;
        border-radius: 4px;
        overflow: hidden;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .sidebar-card {
        background: #1f2937;
        border-color: #4b5563;
    }

    .post-creator-container .sidebar-header {
        background: #f6f7f8;
        padding: 12px 16px;
        border-bottom: 1px solid #edeff1;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: #7c7c7c;
        letter-spacing: 0.5px;
        transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
    }

    body.dark-mode .post-creator-container .sidebar-header {
        background: rgba(0, 0, 0, 0.2);
        border-bottom-color: #4b5563;
        color: #d1d5db;
    }

    .post-creator-container .sidebar-content {
        padding: 16px;
    }

    .post-creator-container .community-search {
        position: relative;
        margin-bottom: 16px;
    }

    .post-creator-container .community-input {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #edeff1;
        border-radius: 4px;
        font-size: 14px;
        background: #f6f7f8;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .community-input {
        background: #374151;
        border-color: #4b5563;
        color: #f9fafb;
    }

        body.dark-mode .post-creator-container .community-input::placeholder {
            color: #9ca3af;
        }

    .post-creator-container .community-input:focus {
        outline: none;
        border-color: #0079D3;
        background: white;
    }

    body.dark-mode .post-creator-container .community-input:focus {
        border-color: #818cf8;
        background: #374151;
    }

    .post-creator-container .community-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: white;
        border: 1px solid #edeff1;
        border-top: none;
        border-radius: 0 0 4px 4px;
        max-height: 200px;
        overflow-y: auto;
        z-index: 10;
        display: none;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .community-dropdown {
        background: #1f2937;
        border-color: #4b5563;
    }

    .post-creator-container .community-item {
        padding: 8px 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: background-color 0.3s ease;
    }

        .post-creator-container .community-item:hover {
            background: #f6f7f8;
        }

    body.dark-mode .post-creator-container .community-item:hover {
        background: #374151;
    }

    .post-creator-container .community-icon {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #0079D3;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: bold;
    }

    body.dark-mode .post-creator-container .community-icon {
        background: #818cf8;
    }

    .post-creator-container .community-info h4 {
        font-size: 14px;
        font-weight: 500;
        margin: 0;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .community-info h4 {
        color: #f9fafb;
    }

    .post-creator-container .community-info p {
        font-size: 12px;
        color: #7c7c7c;
        margin: 0;
        line-height: 1.4;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .community-info p {
        color: #d1d5db;
    }

    .post-creator-container .rules-list {
        list-style: none;
    }

        .post-creator-container .rules-list li {
            padding: 12px 0;
            border-bottom: 1px solid #edeff1;
            font-size: 14px;
            line-height: 1.5;
            transition: border-color 0.3s ease, color 0.3s ease;
        }

    body.dark-mode .post-creator-container .rules-list li {
        border-bottom-color: #4b5563;
        color: #f9fafb;
    }

    .post-creator-container .rules-list li:last-child {
        border-bottom: none;
    }

    .post-creator-container .rule-number {
        font-weight: 600;
        color: #0079D3;
    }

    body.dark-mode .post-creator-container .rule-number {
        color: #818cf8;
    }

    /* Main Content */
    .post-creator-container .main-content {
        background: white;
        border: 1px solid #ccc;
        border-radius: 4px;
        overflow: hidden;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .main-content {
        background: #1f2937;
        border-color: #4b5563;
    }

    .post-creator-container .post-header {
        background: #f6f7f8;
        padding: 16px 20px;
        border-bottom: 1px solid #edeff1;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .post-header {
        background: rgba(0, 0, 0, 0.2);
        border-bottom-color: #4b5563;
    }

    .post-creator-container .post-title {
        font-size: 18px;
        font-weight: 500;
        margin: 0;
        color: #1c1c1c;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .post-title {
        color: #f9fafb;
    }

    .post-creator-container .breadcrumb {
        font-size: 12px;
        color: #7c7c7c;
        margin-top: 4px;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .breadcrumb {
        color: #d1d5db;
    }

    .post-creator-container .breadcrumb a {
        color: #0079D3;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .breadcrumb a {
        color: #818cf8;
    }

    /* Post Type Tabs */
    .post-creator-container .post-tabs {
        display: flex;
        background: white;
        border-bottom: 1px solid #edeff1;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .post-tabs {
        background: #1f2937;
        border-bottom-color: #4b5563;
    }

    .post-creator-container .post-tab {
        flex: 1;
        padding: 12px 16px;
        text-align: center;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        font-size: 14px;
        font-weight: 500;
        color: #7c7c7c;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    body.dark-mode .post-creator-container .post-tab {
        color: #d1d5db;
    }

    .post-creator-container .post-tab:hover {
        background: #f6f7f8;
        color: #1c1c1c;
    }

    body.dark-mode .post-creator-container .post-tab:hover {
        background: #374151;
        color: #f9fafb;
    }

    .post-creator-container .post-tab.active {
        color: #0079D3;
        border-bottom-color: #0079D3;
        background: white;
    }

    body.dark-mode .post-creator-container .post-tab.active {
        color: #818cf8;
        border-bottom-color: #818cf8;
        background: #1f2937;
    }

    .post-creator-container .post-tab i {
        font-size: 16px;
    }

    /* Form Content */
    .post-creator-container .form-container {
        padding: 20px;
    }

    .post-creator-container .form-group {
        margin-bottom: 16px;
    }

    .post-creator-container .form-label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: #1c1c1c;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .form-label {
        color: #f9fafb;
    }

    .post-creator-container .form-input,
    .post-creator-container .form-textarea,
    .post-creator-container .form-select {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #edeff1;
        border-radius: 4px;
        font-size: 14px;
        font-family: inherit;
        background: white;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .form-input,
    body.dark-mode .post-creator-container .form-textarea,
    body.dark-mode .post-creator-container .form-select {
        background: #374151;
        border-color: #4b5563;
        color: #f9fafb;
    }

        body.dark-mode .post-creator-container .form-input::placeholder,
        body.dark-mode .post-creator-container .form-textarea::placeholder {
            color: #9ca3af;
        }

    .post-creator-container .form-input:focus,
    .post-creator-container .form-textarea:focus,
    .post-creator-container .form-select:focus {
        outline: none;
        border-color: #0079D3;
    }

    body.dark-mode .post-creator-container .form-input:focus,
    body.dark-mode .post-creator-container .form-textarea:focus,
    body.dark-mode .post-creator-container .form-select:focus {
        border-color: #818cf8;
        box-shadow: 0 0 0 0.25rem rgba(129, 140, 248, 0.25);
    }

    .post-creator-container .form-textarea {
        min-height: 100px;
        resize: vertical;
    }

    .post-creator-container .char-count {
        font-size: 12px;
        color: #7c7c7c;
        text-align: right;
        margin-top: 4px;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .char-count {
        color: #d1d5db;
    }

    /* Content Sections */
    .post-creator-container .content-section {
        display: none;
    }

        .post-creator-container .content-section.active {
            display: block;
        }

    /* Rich Text Editor */
    .post-creator-container .editor-container {
        border: 1px solid #edeff1;
        border-radius: 4px;
        background: white;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .editor-container {
        border-color: #4b5563;
        background: #374151;
    }

    .post-creator-container .editor-toolbar {
        padding: 8px 12px;
        border-bottom: 1px solid #edeff1;
        background: #f6f7f8;
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .editor-toolbar {
        border-bottom-color: #4b5563;
        background: rgba(0, 0, 0, 0.2);
    }

    .post-creator-container .editor-btn {
        padding: 6px 8px;
        border: none;
        background: transparent;
        color: #7c7c7c;
        cursor: pointer;
        border-radius: 2px;
        font-size: 14px;
        transition: all 0.2s ease;
    }

    body.dark-mode .post-creator-container .editor-btn {
        color: #d1d5db;
    }

    .post-creator-container .editor-btn:hover {
        background: #edeff1;
        color: #1c1c1c;
    }

    body.dark-mode .post-creator-container .editor-btn:hover {
        background: #4b5563;
        color: #f9fafb;
    }

    .post-creator-container .editor-btn.active {
        background: #0079D3;
        color: white;
    }

    body.dark-mode .post-creator-container .editor-btn.active {
        background: #818cf8;
        color: white;
    }

    .post-creator-container .editor-content {
        padding: 12px;
        min-height: 120px;
        outline: none;
        font-size: 14px;
        line-height: 1.5;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .editor-content {
        color: #f9fafb;
    }

    .post-creator-container .editor-content:empty:before {
        content: "Text (optional)";
        color: #7c7c7c;
    }

    body.dark-mode .post-creator-container .editor-content:empty:before {
        color: #9ca3af;
    }

    /* File Upload */
    .post-creator-container .upload-area {
        border: 2px dashed #edeff1;
        border-radius: 4px;
        padding: 40px 20px;
        text-align: center;
        background: #f6f7f8;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    body.dark-mode .post-creator-container .upload-area {
        border-color: #4b5563;
        background: #374151;
    }

    .post-creator-container .upload-area:hover,
    .post-creator-container .upload-area.dragover {
        border-color: #0079D3;
        background: rgba(0, 121, 211, 0.05);
    }

    body.dark-mode .post-creator-container .upload-area:hover,
    body.dark-mode .post-creator-container .upload-area.dragover {
        border-color: #818cf8;
        background: rgba(129, 140, 248, 0.1);
    }

    .post-creator-container .upload-icon {
        font-size: 48px;
        color: #7c7c7c;
        margin-bottom: 12px;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .upload-icon {
        color: #d1d5db;
    }

    .post-creator-container .upload-text {
        font-size: 16px;
        color: #1c1c1c;
        margin-bottom: 4px;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .upload-text {
        color: #f9fafb;
    }

    .post-creator-container .upload-subtext {
        font-size: 12px;
        color: #7c7c7c;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .upload-subtext {
        color: #d1d5db;
    }

    /* Tags */
    .post-creator-container .tag-container {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 8px;
        border: 1px solid #edeff1;
        border-radius: 4px;
        background: white;
        min-height: 40px;
        align-items: center;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .tag-container {
        border-color: #4b5563;
        background: #374151;
    }

    .post-creator-container .tag {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 4px 8px;
        background: #0079D3;
        color: white;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 500;
    }

    body.dark-mode .post-creator-container .tag {
        background: #818cf8;
    }

    .post-creator-container .tag-remove {
        background: none;
        border: none;
        color: white;
        cursor: pointer;
        padding: 0;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
    }

        .post-creator-container .tag-remove:hover {
            background: rgba(255, 255, 255, 0.2);
        }

    .post-creator-container .tag-input {
        border: none;
        outline: none;
        background: transparent;
        flex: 1;
        min-width: 100px;
        font-size: 14px;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .tag-input {
        color: #f9fafb;
    }

        body.dark-mode .post-creator-container .tag-input::placeholder {
            color: #9ca3af;
        }

    /* Toggle Switch Styles - Bootstrap Style */
    .post-creator-container .toggle-switch {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 24px;
    }

        .post-creator-container .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .post-creator-container .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: .4s;
        border-radius: 24px;
    }

    body.dark-mode .post-creator-container .toggle-slider {
        background-color: #4b5563;
    }

    .post-creator-container .toggle-slider:before {
        position: absolute;
        content: "";
        height: 18px;
        width: 18px;
        left: 3px;
        bottom: 3px;
        background-color: white;
        transition: .4s;
        border-radius: 50%;
    }

    .post-creator-container .toggle-switch input:checked + .toggle-slider {
        background-color: #0079D3;
    }

    body.dark-mode .post-creator-container .toggle-switch input:checked + .toggle-slider {
        background-color: #818cf8;
    }

    .post-creator-container .toggle-switch input:checked + .toggle-slider:before {
        transform: translateX(20px);
    }

    /* Post Options - Display in rows */
    .post-creator-container .post-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid #edeff1;
        transition: border-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .post-options {
        border-top-color: #4b5563;
    }

    .post-creator-container .option-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        color: #1c1c1c;
        padding: 12px 16px;
        background: #f9f9f9;
        border: 1px solid #edeff1;
        border-radius: 6px;
        transition: all 0.2s ease;
    }

    body.dark-mode .post-creator-container .option-toggle {
        color: #f9fafb;
        background: #374151;
        border-color: #4b5563;
    }

    .post-creator-container .option-toggle:hover {
        background: #f0f0f0;
        border-color: #0079D3;
    }

    body.dark-mode .post-creator-container .option-toggle:hover {
        background: #4b5563;
        border-color: #818cf8;
    }

    .post-creator-container .option-toggle span {
        user-select: none;
        flex: 1;
    }

    /* Poll Settings - Display in rows */
    .post-creator-container .poll-settings {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 16px;
    }

        .post-creator-container .poll-settings .option-toggle {
            margin-bottom: 0;
        }

    /* Action Buttons */
    .post-creator-container .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        padding: 16px 20px;
        background: #f6f7f8;
        border-top: 1px solid #edeff1;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .form-actions {
        background: rgba(0, 0, 0, 0.2);
        border-top-color: #4b5563;
    }

    .post-creator-container .btn {
        padding: 8px 16px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s ease;
        border: none;
    }

    .post-creator-container .btn-primary {
        background: #0079D3;
        color: white;
    }

    body.dark-mode .post-creator-container .btn-primary {
        background: #818cf8;
    }

    .post-creator-container .btn-primary:hover {
        background: #0066b3;
    }

    body.dark-mode .post-creator-container .btn-primary:hover {
        background: #a5b4fc;
    }

    .post-creator-container .btn-secondary {
        background: transparent;
        color: #0079D3;
        border: 1px solid #0079D3;
    }

    body.dark-mode .post-creator-container .btn-secondary {
        color: #818cf8;
        border-color: #818cf8;
    }

    .post-creator-container .btn-secondary:hover {
        background: #0079D3;
        color: white;
    }

    body.dark-mode .post-creator-container .btn-secondary:hover {
        background: #818cf8;
        color: white;
    }

    .post-creator-container .btn-ghost {
        background: transparent;
        color: #7c7c7c;
        border: 1px solid #edeff1;
    }

    body.dark-mode .post-creator-container .btn-ghost {
        color: #d1d5db;
        border-color: #4b5563;
    }

    .post-creator-container .btn-ghost:hover {
        background: #f6f7f8;
        color: #1c1c1c;
    }

    body.dark-mode .post-creator-container .btn-ghost:hover {
        background: #374151;
        color: #f9fafb;
    }

    /* Right Sidebar */
    .post-creator-container .right-sidebar {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .post-creator-container .tips-list {
        list-style: none;
    }

        .post-creator-container .tips-list li {
            padding: 10px 0;
            font-size: 13px;
            color: #7c7c7c;
            display: flex;
            align-items: flex-start;
            gap: 8px;
            line-height: 1.4;
            transition: color 0.3s ease;
        }

    body.dark-mode .post-creator-container .tips-list li {
        color: #d1d5db;
    }

    .post-creator-container .tips-list i {
        color: #46D160;
        margin-top: 2px;
        font-size: 10px;
    }

    /* Poll Options */
    .post-creator-container .poll-options {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .post-creator-container .poll-option {
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .post-creator-container .poll-option input {
            flex: 1;
        }

    .post-creator-container .poll-remove {
        padding: 6px 8px;
        background: transparent;
        border: 1px solid #edeff1;
        color: #7c7c7c;
        border-radius: 4px;
        cursor: pointer;
        font-size: 12px;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .poll-remove {
        border-color: #4b5563;
        color: #d1d5db;
    }

    .post-creator-container .poll-remove:hover {
        background: #f6f7f8;
        border-color: #FF4500;
        color: #FF4500;
    }

    body.dark-mode .post-creator-container .poll-remove:hover {
        background: #374151;
        border-color: #FF4500;
        color: #FF4500;
    }

    .post-creator-container .add-option {
        align-self: flex-start;
        margin-top: 8px;
    }

    /* Community suggestions */
    .post-creator-container .community-suggestion {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid #edeff1;
        transition: border-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .community-suggestion {
        border-bottom-color: #4b5563;
    }

    .post-creator-container .community-suggestion:last-child {
        border-bottom: none;
    }

    .post-creator-container .suggestion-icon {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #0079D3;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: bold;
        flex-shrink: 0;
    }

    body.dark-mode .post-creator-container .suggestion-icon {
        background: #818cf8;
    }

    .post-creator-container .suggestion-info {
        flex: 1;
        min-width: 0;
    }

        .post-creator-container .suggestion-info h4 {
            font-size: 14px;
            font-weight: 600;
            margin: 0 0 2px 0;
            color: #1c1c1c;
            transition: color 0.3s ease;
        }

    body.dark-mode .post-creator-container .suggestion-info h4 {
        color: #f9fafb;
    }

    .post-creator-container .suggestion-info p {
        font-size: 12px;
        color: #7c7c7c;
        margin: 0;
        line-height: 1.3;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .suggestion-info p {
        color: #d1d5db;
    }

    .post-creator-container .suggestion-stats {
        font-size: 11px;
        color: #46D160;
        margin-top: 2px;
    }

    .post-creator-container .join-btn {
        padding: 4px 12px;
        background: #0079D3;
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s ease;
        flex-shrink: 0;
    }

    body.dark-mode .post-creator-container .join-btn {
        background: #818cf8;
    }

    .post-creator-container .join-btn:hover {
        background: #0066b3;
    }

    body.dark-mode .post-creator-container .join-btn:hover {
        background: #a5b4fc;
    }

    .post-creator-container .join-btn.joined {
        background: #46D160;
    }

    .post-creator-container .trending-badge {
        background: #FF4500;
        color: white;
        font-size: 10px;
        padding: 2px 6px;
        border-radius: 8px;
        font-weight: 600;
        margin-left: 4px;
    }

    .post-creator-container .new-badge {
        background: #46D160;
        color: white;
        font-size: 10px;
        padding: 2px 6px;
        border-radius: 8px;
        font-weight: 600;
        margin-left: 4px;
    }

    .post-creator-container .btn-create-community {
        background: none;
        border: 1px solid #0079D3;
        color: #0079D3;
        border-radius: 4px;
        padding: 4px 8px;
        cursor: pointer;
        font-size: 12px;
        transition: all 0.2s ease;
    }

    body.dark-mode .post-creator-container .btn-create-community {
        border-color: #818cf8;
        color: #818cf8;
    }

    .post-creator-container .btn-create-community:hover {
        background: #0079D3;
        color: white;
    }

    body.dark-mode .post-creator-container .btn-create-community:hover {
        background: #818cf8;
        color: white;
    }

    .post-creator-container .community-section-header {
        padding: 8px 12px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        color: #7c7c7c;
        background: #f6f7f8;
        border-bottom: 1px solid #edeff1;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .community-section-header {
        color: #d1d5db;
        background: rgba(0, 0, 0, 0.2);
        border-bottom-color: #4b5563;
    }

    .post-creator-container .ad-card {
        background: #f6f7f8;
        border: 1px solid #edeff1;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .ad-card {
        background: #374151;
        border-color: #4b5563;
    }

    .post-creator-container .ad-card .sidebar-header {
        font-size: 10px;
        color: #7c7c7c;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .ad-card .sidebar-header {
        color: #d1d5db;
    }

    /* AdSense responsive styles */
    .post-creator-container .adsbygoogle {
        display: block;
        min-height: 100px;
        background: #f0f0f0;
        transition: background-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .adsbygoogle {
        background: #4b5563;
    }

    /* Media preview styles */
    .post-creator-container .media-preview {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 8px;
    }

    .post-creator-container .media-item {
        position: relative;
        width: 100px;
        height: 100px;
        border-radius: 4px;
        overflow: hidden;
        background: #f6f7f8;
        transition: background-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .media-item {
        background: #374151;
    }

    .post-creator-container .media-item img,
    .post-creator-container .media-item video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .post-creator-container .media-remove {
        position: absolute;
        top: 4px;
        right: 4px;
        width: 20px;
        height: 20px;
        background: rgba(0, 0, 0, 0.7);
        color: white;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
    }

    /* SEO Section */
    .post-creator-container .seo-section {
        background: #f9f9f9;
        border: 1px solid #edeff1;
        border-radius: 4px;
        padding: 16px;
        margin-top: 16px;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .seo-section {
        background: #374151;
        border-color: #4b5563;
    }

    .post-creator-container .seo-section h3 {
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 12px;
        color: #1c1c1c;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .seo-section h3 {
        color: #f9fafb;
    }

    .post-creator-container .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    /* Full width SEO toggle */
    .post-creator-container #seoToggle {
        width: 100%;
        justify-content: center;
        font-size: 14px;
        padding: 12px 16px;
    }

    /* Improved guidelines design */
    .post-creator-container .guideline-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid #f0f0f0;
        transition: border-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .guideline-item {
        border-bottom-color: #4b5563;
    }

    .post-creator-container .guideline-item:last-child {
        border-bottom: none;
    }

    .post-creator-container .guideline-icon {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #0079D3, #00A8FF);
        color: white;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    body.dark-mode .post-creator-container .guideline-icon {
        background: linear-gradient(135deg, #818cf8, #a5b4fc);
    }

    .post-creator-container .guideline-content h4 {
        font-size: 13px;
        font-weight: 600;
        margin: 0 0 4px 0;
        color: #1c1c1c;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .guideline-content h4 {
        color: #f9fafb;
    }

    .post-creator-container .guideline-content p {
        font-size: 12px;
        color: #7c7c7c;
        margin: 0;
        line-height: 1.4;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .guideline-content p {
        color: #d1d5db;
    }

    /* News card styles */
    .post-creator-container .news-item {
        padding: 12px 0;
        border-bottom: 1px solid #f0f0f0;
        transition: border-color 0.3s ease;
    }

    body.dark-mode .post-creator-container .news-item {
        border-bottom-color: #4b5563;
    }

    .post-creator-container .news-item:last-child {
        border-bottom: none;
    }

    .post-creator-container .news-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }

    .post-creator-container .news-time {
        font-size: 11px;
        color: #7c7c7c;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .news-time {
        color: #d1d5db;
    }

    .post-creator-container .news-category {
        font-size: 10px;
        background: #0079D3;
        color: white;
        padding: 2px 6px;
        border-radius: 8px;
        font-weight: 600;
        text-transform: uppercase;
    }

    body.dark-mode .post-creator-container .news-category {
        background: #818cf8;
    }

    .post-creator-container .news-title {
        font-size: 13px;
        font-weight: 600;
        margin: 0 0 4px 0;
        color: #1c1c1c;
        line-height: 1.3;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .news-title {
        color: #f9fafb;
    }

    .post-creator-container .news-excerpt {
        font-size: 12px;
        color: #7c7c7c;
        margin: 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color 0.3s ease;
    }

    body.dark-mode .post-creator-container .news-excerpt {
        color: #d1d5db;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .post-creator-container .container-fluid.main-container

    {
        grid-template-columns: 1fr;
        max-width: 800px;
        margin: 0 auto;
    }

    .post-creator-container .left-sidebar,
    .post-creator-container .right-sidebar {
        display: none;
    }

    }

    @@media (max-width: 768px) {
        .post-creator-container .main-container

    {
        margin: 10px auto;
        padding: 0 10px;
    }

    .post-creator-container .post-tabs {
        overflow-x: auto;
    }

    .post-creator-container .post-tab {
        min-width: 80px;
        flex: none;
    }

    .post-creator-container .form-container {
        padding: 16px;
    }

    .post-creator-container .form-row {
        grid-template-columns: 1fr;
    }

    .post-creator-container .post-options,
    .post-creator-container .poll-settings {
        grid-template-columns: 1fr;
    }

    }

    /* Status Messages */
    .post-creator-container .status-message {
        position: fixed;
        top: 60px;
        right: 20px;
        padding: 12px 16px;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 500;
        z-index: 1000;
        display: none;
        animation: slideIn 0.3s ease;
        transition: all 0.3s ease;
    }

    body.dark-mode .post-creator-container .status-message {
        background: #1f2937;
        border: 1px solid #4b5563;
        color: #f9fafb;
    }

    .post-creator-container .status-message.success {
        background: #46D160;
        color: white;
    }

    .post-creator-container .status-message.error {
        background: #FF4500;
        color: white;
    }

    .post-creator-container .status-message.info {
        background: #0079D3;
        color: white;
    }

    body.dark-mode .post-creator-container .status-message.info {
        background: #818cf8;
    }

    @@keyframes slideIn {
        from

    {
        transform: translateX(100%);
        opacity: 0;
    }

    to {
        transform: translateX(0);
        opacity: 1;
    }

    }
</style>
<div class="post-creator-container">
    <div class="container-fluid main-container">
        <aside class="left-sidebar">
            <!-- Community selection (unchanged) -->
        </aside>

        <main class="main-content">
            <div class="post-header">
                <h1 class="post-title">Create a Post</h1>
                <div class="breadcrumb">
                    <a href="#">Home</a> / <a href="#">Submit</a> / Create Post
                </div>
            </div>

            <div class="form-container">
                <form id="postForm" method="post" enctype="multipart/form-data">
                    <!-- Hidden fields for initial data (Community & User IDs) -->
                    <input type="hidden" asp-for="CommunityId" id="communityId" />
                    <input type="hidden" asp-for="CommunityName" id="communityName" />
                    <input type="hidden" asp-for="CommunitySlug" id="communitySlug" />
                    <input type="hidden" asp-for="UserId" id="userId" value="current-user-id" />
                    <input type="hidden" asp-for="Status" id="statusInput" value="published" />

                    <!-- Post Type Selection -->
                    <div class="form-group mb-6 p-4 border rounded-lg shadow-sm bg-blue-50">
                        <label class="form-label mb-3">Choose Post Type(s):</label>
                        <div class="flex flex-wrap gap-4">
                            @foreach (PostContentTypes type in Enum.GetValues(typeof(PostContentTypes)))
                            {
                                if (type == PostContentTypes.None) continue; // Skip 'None'
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox"
                                           name="PostType"
                                           value="@((int)type)"
                                    @(Model.PostType.HasFlag(type) ? "checked" : "")
                                           class="form-checkbox h-5 w-5 text-blue-600 rounded post-type-checkbox"
                                           data-content-type="@type.ToString().ToLower()" />
                                    <span class="text-gray-700 font-medium">@type.ToString()</span>
                                </label>
                            }
                        </div>
                        <span asp-validation-for="PostType" class="text-red-500 text-sm mt-1"></span>
                    </div>

                    <!-- Title -->
                    <div class="form-group">
                        <label class="form-label" asp-for="Title"></label>
                        <input asp-for="Title" class="form-input" placeholder="An interesting title" maxlength="300" required />
                        <div class="char-count">
                            <span id="titleCount">0</span>/300
                        </div>
                        <span asp-validation-for="Title" class="text-red-500 text-sm mt-1"></span>
                    </div>

                    <!-- Content Sections -->
                    <div class="content-section" id="textContent" data-post-type="text">
                        <div class="form-group">
                            <label class="form-label" asp-for="Content"></label>
                            <div class="editor-container">
                                <div class="editor-toolbar">
                                    <button type="button" class="text-bold" title="Bold"><i class="fas fa-bold"></i></button>
                                    <button type="button" class="text-italic" title="Italic"><i class="fas fa-italic"></i></button>
                                    <button type="button" class="text-underline" title="Underline"><i class="fas fa-underline"></i></button>
                                    <button type="button" class="text-link" title="Link"><i class="fas fa-link"></i></button>
                                    <button type="button" class="text-quote" title="Quote"><i class="fas fa-quote-right"></i></button>
                                    <button type="button" class="text-code" title="Code"><i class="fas fa-code"></i></button>
                                    <button type="button" class="text-list-ul" title="Unordered List"><i class="fas fa-list-ul"></i></button>
                                    <button type="button" class="text-list-ol" title="Ordered List"><i class="fas fa-list-ol"></i></button>
                                </div>
                                <div class="editor-content" contenteditable="true" id="textEditor">@Model.Content</div>
                            </div>
                            <textarea asp-for="Content" id="contentHidden" style="display: none;"></textarea>
                            <span asp-validation-for="Content" class="text-red-500 text-sm mt-1"></span>
                        </div>
                    </div>

                    <div class="content-section" id="imageContent" data-post-type="image">
                        <div class="form-group">
                            <label class="form-label" asp-for="MediaFiles"></label>
                            <div class="upload-area" onclick="document.getElementById('mediaUpload').click()">
                                <p class="text-gray-500"><i class="fas fa-cloud-upload-alt text-2xl mb-2"></i></p>
                                <p class="text-gray-600 font-medium">Drag & drop images/videos here, or click to browse</p>
                                <p class="text-gray-500 text-sm">(Max 10MB per file, JPEG/PNG/GIF/MP4/WebM)</p>
                            </div>
                            <input asp-for="MediaFiles" id="mediaUpload" multiple accept="image/*,video/*" style="display: none;" />
                            <div class="media-preview grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 mt-4" id="mediaPreview">
                                @if (Model.MediaFiles != null)
                                {
                                    foreach (var mediaFile in Model.MediaFiles)
                                    {
                                        // In a real scenario, you'd show a preview of uploaded files if they persist after postback
                                        // For simplicity, this is client-side JS based.
                                    }
                                }
                            </div>
                            <span asp-validation-for="MediaFiles" class="text-red-500 text-sm mt-1"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label" asp-for="MediaCaption"></label>
                            <input asp-for="MediaCaption" class="form-input" placeholder="Add a caption to your media" />
                            <span asp-validation-for="MediaCaption" class="text-red-500 text-sm mt-1"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label" asp-for="MediaAltText"></label>
                            <input asp-for="MediaAltText" class="form-input" placeholder="Describe your media for screen readers" />
                            <span asp-validation-for="MediaAltText" class="text-red-500 text-sm mt-1"></span>
                        </div>
                    </div>

                    <div class="content-section" id="linkContent" data-post-type="link">
                        <div class="form-group">
                            <label class="form-label" asp-for="Url"></label>
                            <input asp-for="Url" class="form-input" id="linkUrl" placeholder="https://example.com" />
                            <span asp-validation-for="Url" class="text-red-500 text-sm mt-1"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="linkDescription">Link Description (Optional)</label>
                            <textarea asp-for="Content" class="form-textarea" id="linkDescription" rows="5" placeholder="Describe or comment on the link..."></textarea>
                            <span asp-validation-for="Content" class="text-red-500 text-sm mt-1"></span>
                        </div>
                    </div>

                    <div class="content-section" id="pollContent" data-post-type="poll">
                        <div class="form-group">
                            <label class="form-label" for="pollQuestion">Poll Question</label>
                            <textarea asp-for="Content" class="form-textarea" id="pollQuestion" rows="3" placeholder="What's your poll question?" required></textarea>
                            <span asp-validation-for="Content" class="text-red-500 text-sm mt-1"></span>
                        </div>

                        <!-- Poll Options Section (FIXED) -->
                        <div class="form-group mb-4 p-4 border rounded-lg shadow-sm bg-gray-50">
                            <label class="block text-gray-700 text-lg font-semibold mb-2">Poll Options</label>
                            <p class="text-gray-600 text-sm mb-4">Provide at least two options for your poll. You can add more as needed.</p>

                            <div id="pollOptionsContainer" class="space-y-3">
                                @{
                                    // Determine the initial count of options to render
                                    int initialPollOptionCount = Model.PollOptions != null && Model.PollOptions.Any() ? Model.PollOptions.Count : 2;
                                }
                                @for (int i = 0; i < initialPollOptionCount; i++)
                                {
                                    <div class="poll-option flex items-center space-x-2">
                                        <input type="text"
                                               name="PollOptions[@i].OptionText"
                                               id="PollOptions_@i__OptionText"
                                               value="@(Model.PollOptions != null && i < Model.PollOptions.Count ? Model.PollOptions[i].OptionText : "")"
                                               class="flex-1 px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500 shadow-sm poll-option-input"
                                               placeholder="Option @(i + 1)" required />
                                        @* Hidden input to preserve PollOptionId if editing existing options *@
                                        <input type="hidden" name="PollOptions[@i].PollOptionId"
                                               value="@(Model.PollOptions != null && i < Model.PollOptions.Count ? Model.PollOptions[i].PollOptionId : 0)" />
                                        <button type="button" class="poll-remove text-gray-500 hover:text-red-600 focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200" title="Remove option" @(initialPollOptionCount <= 2 ? "disabled" : "")>
                                            <i class="fas fa-times text-lg"></i>
                                        </button>
                                    </div>
                                }
                            </div>

                            <button type="button" class="btn btn-ghost add-option mt-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200" id="addPollOption">
                                <i class="fas fa-plus mr-2"></i> Add Option
                            </button>
                            <span asp-validation-for="PollOptions" class="text-red-500 text-sm mt-1"></span>
                        </div>

                        <div class="form-group mt-6">
                            <label class="form-label">Poll Settings</label>
                            <div class="poll-settings space-y-3">
                                <label class="flex items-center option-toggle">
                                    <input type="checkbox" asp-for="AllowMultipleChoices" class="form-checkbox h-5 w-5 text-blue-600 rounded toggle-checkbox" />
                                    <span class="ml-2 text-gray-700">Allow Multiple Choices</span>
                                </label>
                                <label class="flex items-center option-toggle">
                                    <input type="checkbox" asp-for="ShowResultsBeforeVoting" class="form-checkbox h-5 w-5 text-blue-600 rounded toggle-checkbox" />
                                    <span class="ml-2 text-gray-700">Show Results Before Voting</span>
                                </label>
                                <label class="flex items-center option-toggle">
                                    <input type="checkbox" asp-for="ShowResultsBeforeEnd" class="form-checkbox h-5 w-5 text-blue-600 rounded toggle-checkbox" />
                                    <span class="ml-2 text-gray-700">Show Results Before End</span>
                                </label>
                                <label class="flex items-center option-toggle">
                                    <input type="checkbox" asp-for="AllowAddingOptions" class="form-checkbox h-5 w-5 text-blue-600 rounded toggle-checkbox" />
                                    <span class="ml-2 text-gray-700">Allow Users to Add Options</span>
                                </label>
                            </div>
                        </div>

                        <div class="form-group mt-6">
                            <label asp-for="PollEndDate" class="block text-gray-700 text-lg font-semibold mb-2">Poll End Date (Optional)</label>
                            <input type="datetime-local" asp-for="PollEndDate" class="form-input mt-1 block w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500 shadow-sm" />
                            <span asp-validation-for="PollEndDate" class="text-red-500 text-sm mt-1"></span>
                        </div>
                    </div>

                    <!-- Tags Section -->
                    <div class="form-group mt-6">
                        <label class="form-label" asp-for="TagsInput"></label> @* Bind to TagsInput for input *@
                        <div class="tag-container" id="tagContainer">
                            @if (Model.Tags != null)
                            {
                                foreach (var tag in Model.Tags)
                                {
                                    <span class="tag">@tag <button type="button" class="tag-remove" data-tag="@tag"><i class="fas fa-times"></i></button></span>
                                }
                            }
                            <input type="text" class="tag-input" id="tagInput" placeholder="Add tags (press Enter)" />
                            <input type="hidden" asp-for="TagsInput" id="tagsInputHidden" /> @* Hidden input to store comma-separated tags *@
                        </div>
                        <span asp-validation-for="Tags" class="text-red-500 text-sm mt-1"></span>
                    </div>

                    <!-- NSFW and Spoiler Toggles -->
                    <div class="post-options mt-6">
                        <label class="option-toggle">
                            <span>NSFW</span>
                            <div class="toggle-switch">
                                <input asp-for="IsNSFW" type="checkbox" class="toggle-checkbox" />
                                <span class="toggle-slider"></span>
                            </div>
                        </label>
                        <label class="option-toggle">
                            <span>Spoiler</span>
                            <div class="toggle-switch">
                                <input asp-for="IsSpoiler" type="checkbox" class="toggle-checkbox" />
                                <span class="toggle-slider"></span>
                            </div>
                        </label>
                        <label class="option-toggle">
                            <span>Pin to Profile</span>
                            <div class="toggle-switch">
                                <input asp-for="IsPinned" type="checkbox" class="toggle-checkbox" />
                                <span class="toggle-slider"></span>
                            </div>
                        </label>
                        <label class="option-toggle">
                            <span>Lock Comments</span>
                            <div class="toggle-switch">
                                <input asp-for="IsLocked" type="checkbox" class="toggle-checkbox" />
                                <span class="toggle-slider"></span>
                            </div>
                        </label>
                    </div>

                    <!-- Publication Date -->
                    <div class="form-group mt-6">
                        <label asp-for="PublicationDate" class="block text-gray-700 text-lg font-semibold mb-2">Publication Date (Optional)</label>
                        <input type="datetime-local" asp-for="PublicationDate" class="form-input mt-1 block w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500 shadow-sm" />
                        <span asp-validation-for="PublicationDate" class="text-red-500 text-sm mt-1"></span>
                    </div>


                    <!-- SEO Section -->
                    <div class="form-group mt-6">
                        <button type="button" class="btn btn-ghost inline-flex items-center" id="seoToggle">
                            <i class="fas fa-chevron-right mr-2 transition-transform duration-200" id="seoToggleIcon"></i> Show SEO Settings
                        </button>
                    </div>

                    <div class="seo-section" id="seoSection" style="display: none;">
                        <h3 class="text-xl font-semibold mb-4 text-gray-800">Search Engine Optimization</h3>
                        <p class="text-gray-600 text-sm mb-4">Optimize your post for search engines and social media sharing.</p>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label" asp-for="MetaTitle"></label>
                                <input asp-for="MetaTitle" class="form-input" placeholder="Custom title for search engines" maxlength="200" />
                                <span asp-validation-for="MetaTitle" class="text-red-500 text-sm mt-1"></span>
                            </div>
                            <div class="form-group">
                                <label class="form-label" asp-for="CanonicalUrl"></label>
                                <input asp-for="CanonicalUrl" class="form-input" placeholder="https://example.com/canonical" />
                                <span asp-validation-for="CanonicalUrl" class="text-red-500 text-sm mt-1"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label" asp-for="MetaDescription"></label>
                            <textarea asp-for="MetaDescription" class="form-textarea" rows="3" placeholder="Brief description for search results" maxlength="500"></textarea>
                            <span asp-validation-for="MetaDescription" class="text-red-500 text-sm mt-1"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label" asp-for="Keywords"></label>
                            <input asp-for="Keywords" class="form-input" placeholder="Comma-separated keywords (e.g., tech, programming, AI)" maxlength="500" />
                            <span asp-validation-for="Keywords" class="text-red-500 text-sm mt-1"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label" asp-for="OgImage"></label>
                            <div class="upload-area" onclick="document.getElementById('ogImageUpload').click()">
                                <p class="text-gray-500"><i class="fas fa-image text-2xl mb-2"></i></p>
                                <p class="text-gray-600 font-medium">Upload a social media image (Open Graph / Twitter Card)</p>
                                <p class="text-gray-500 text-sm">(Max 5MB, JPEG/PNG recommended)</p>
                            </div>
                            <input asp-for="OgImage" id="ogImageUpload" accept="image/jpeg,image/png" style="display: none;" />
                            <div class="media-preview mt-4" id="ogImagePreview">
                                @if (Model.OgImage != null)
                                {
                                    <!-- In a real scenario, you might show a preview if the image persists after postback -->
                                }
                            </div>
                            <span asp-validation-for="OgImage" class="text-red-500 text-sm mt-1"></span>
                        </div>
                    </div>

                </form>
            </div>

            <div class="form-actions">
                <button type="button" class="btn btn-ghost" id="saveAsDraft">
                    <i class="fas fa-save mr-2"></i> Save Draft
                </button>
                <button type="button" class="btn btn-secondary" id="previewBtn">
                    <i class="fas fa-eye mr-2"></i> Preview
                </button>
                <button type="submit" class="btn btn-primary" id="submitPost" form="postForm">
                    <i class="fas fa-paper-plane mr-2"></i> Post
                </button>
            </div>
        </main>

        <aside class="right-sidebar">
            <!-- Right sidebar content (unchanged) -->
        </aside>
    </div>

    <div class="status-message" id="statusMessage">
        <span id="statusText">Status message</span>
    </div>
</div>

<script>
    // Global state
    let currentPostType = 'text';
    let selectedCommunity = null;
    let tags = [];
    let uploadedFiles = [];

    // Initialize dark mode from localStorage
    function initializeDarkMode() {
        const savedDarkMode = localStorage.getItem('darkMode');
        if (savedDarkMode === 'true') {
            document.body.classList.add('dark-mode');
        }
    }

    // Dark mode toggle functionality
    function toggleDarkMode() {
        document.body.classList.toggle('dark-mode');

        // Save preference to localStorage
        const isDarkMode = document.body.classList.contains('dark-mode');
        localStorage.setItem('darkMode', isDarkMode);

        showStatus('info', isDarkMode ? 'Dark mode enabled' : 'Light mode enabled');
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
        initializeDarkMode();
        initializeEventListeners();
        generateSlug();

        // Initialize AdSense
        if (typeof adsbygoogle !== 'undefined') {
            (adsbygoogle = window.adsbygoogle || []).push({});
        }
    });

    function initializeEventListeners() {
        // Post type tabs
        document.querySelectorAll('.post-tab').forEach(tab => {
            tab.addEventListener('click', handleTabClick);
        });

        // Community search and selection
        const communitySearch = document.getElementById('communitySearch');
        const communityDropdown = document.getElementById('communityDropdown');

        communitySearch.addEventListener('focus', () => {
            communityDropdown.style.display = 'block';
        });

        communitySearch.addEventListener('input', handleCommunitySearch);

        document.querySelectorAll('.community-item').forEach(item => {
            item.addEventListener('click', handleCommunitySelect);
        });

        // Title and slug generation
        document.getElementById('title').addEventListener('input', function(e) {
            updateCharCount(e.target, 'titleCount', 300);
            generateSlug();
        });

        // Tag input
        document.getElementById('tagInput').addEventListener('keypress', handleTagInput);

        // Poll options
        document.getElementById('addPollOption').addEventListener('click', addPollOption);

        // Media upload
        document.getElementById('mediaUpload').addEventListener('change', handleMediaUpload);

        // Form submission
        document.getElementById('postForm').addEventListener('submit', handleFormSubmit);

        // Editor content sync
        document.getElementById('textEditor').addEventListener('input', syncEditorContent);

        // Click outside to close dropdowns
        document.addEventListener('click', handleOutsideClick);

        // Save as draft
        document.getElementById('saveAsDraft').addEventListener('click', function() {
            document.querySelector('input[name="Status"]')?.remove();
            const statusInput = document.createElement('input');
            statusInput.type = 'hidden';
            statusInput.name = 'Status';
            statusInput.value = 'draft';
            document.getElementById('postForm').appendChild(statusInput);

            showStatus('info', 'Saving as draft...');
            setTimeout(() => {
                showStatus('success', 'Draft saved successfully!');
            }, 1000);
        });

        // Preview
        document.getElementById('previewBtn').addEventListener('click', function() {
            showStatus('info', 'Opening preview...');
        });

        // SEO Toggle
        document.getElementById('seoToggle').addEventListener('click', function() {
            const seoSection = document.getElementById('seoSection');
            const isVisible = seoSection.style.display !== 'none';
            seoSection.style.display = isVisible ? 'none' : 'block';
            this.innerHTML = isVisible ?
                '<i class="fas fa-chevron-down"></i> Show SEO Settings' :
                '<i class="fas fa-chevron-up"></i> Hide SEO Settings';
        });

        // Toggle switches
        document.querySelectorAll('.toggle-switch').forEach(toggle => {
            toggle.addEventListener('click', function() {
                const checkbox = this.querySelector('input[type="checkbox"]');
                checkbox.checked = !checkbox.checked;
            });
        });
    }

    function handleTabClick(e) {
        e.preventDefault();

        // Remove active class from all tabs
        document.querySelectorAll('.post-tab').forEach(tab => {
            tab.classList.remove('active');
        });

        // Hide all content sections
        document.querySelectorAll('.content-section').forEach(section => {
            section.classList.remove('active');
        });

        // Add active class to clicked tab
        e.currentTarget.classList.add('active');
        currentPostType = e.currentTarget.getAttribute('data-type');
        document.getElementById('postType').value = currentPostType;

        // Show corresponding content section
        const targetSection = document.getElementById(currentPostType + 'Content');
        if (targetSection) {
            targetSection.classList.add('active');
        }

        // Update required fields based on post type
        updateRequiredFields();
    }

    function updateRequiredFields() {
        // Reset all required fields
        document.querySelectorAll('[required]').forEach(field => {
            if (field.id !== 'title' && field.id !== 'communitySearch') {
                field.removeAttribute('required');
            }
        });

        // Set required fields based on post type
        switch(currentPostType) {
            case 'image':
                document.getElementById('mediaUpload').setAttribute('required', 'required');
                break;
            case 'link':
                document.getElementById('linkUrl').setAttribute('required', 'required');
                break;
            case 'poll':
                document.querySelectorAll('.poll-option-input').forEach(input => {
                    input.setAttribute('required', 'required');
                });
                break;
        }
    }

    function handleCommunitySearch(e) {
        const searchTerm = e.target.value.toLowerCase();
        const communityItems = document.querySelectorAll('.community-item');

        communityItems.forEach(item => {
            const communityName = item.querySelector('h4').textContent.toLowerCase();
            if (communityName.includes(searchTerm)) {
                item.style.display = 'flex';
            } else {
                item.style.display = 'none';
            }
        });
    }

    function handleCommunitySelect(e) {
        const communityItem = e.currentTarget;
        const communityName = communityItem.querySelector('h4').textContent;
        const communitySlug = communityItem.getAttribute('data-slug');
        const communityId = communityItem.getAttribute('data-id');

        selectedCommunity = {
            id: communityId,
            name: communityName,
            slug: communitySlug
        };

        document.getElementById('communityId').value = communityId;
        document.getElementById('communitySlug').value = communitySlug;
        document.getElementById('communitySearch').value = communityName;
        document.getElementById('communityDropdown').style.display = 'none';

        document.getElementById('rulesHeader').innerHTML = `<i class="fas fa-shield-alt"></i> ${communityName} Rules`;

        showStatus('success', `Selected ${communityName}`);
    }

    function updateCharCount(input, counterId, maxLength) {
        const current = input.value.length;
        document.getElementById(counterId).textContent = current;

        const counter = document.getElementById(counterId);
        if (current > maxLength * 0.9) {
            counter.style.color = '#f59e0b';
        } else {
            counter.style.color = '#7c7c7c';
        }

        if (current >= maxLength) {
            counter.style.color = '#ef4444';
        }
    }

    function generateSlug() {
        const title = document.getElementById('title').value;
        const slug = title
            .toLowerCase()
            .replace(/[^a-z0-9\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .trim('-');
        document.getElementById('slug').value = slug;
    }

    function handleTagInput(e) {
        if (e.key === 'Enter' && e.target.value.trim() !== '') {
            e.preventDefault();

            if (tags.length < 5) {
                const tagText = e.target.value.trim();

                if (!tags.includes(tagText)) {
                    tags.push(tagText);

                    const tagElement = document.createElement('div');
                    tagElement.className = 'tag';
                    tagElement.innerHTML = `
                        ${tagText}
                        <button type="button" class="tag-remove" onclick="removeTag('${tagText}', this)">
                            <i class="fas fa-times"></i>
                        </button>
                        <input type="hidden" name="TagNames" value="${tagText}" />
                    `;

                    const container = document.getElementById('tagContainer');
                    container.insertBefore(tagElement, e.target);
                    e.target.value = '';
                }
            } else {
                showStatus('warning', 'Maximum 5 tags allowed');
            }
        }
    }

    function removeTag(tagText, button) {
        const index = tags.indexOf(tagText);
        if (index > -1) {
            tags.splice(index, 1);
        }
        button.parentElement.remove();
    }

    function addPollOption() {
        const pollOptions = document.getElementById('pollOptions');
        const optionCount = pollOptions.children.length;

        if (optionCount < 6) {
            const newOption = document.createElement('div');
            newOption.className = 'poll-option';
            newOption.innerHTML = `
                <input type="text" class="form-input poll-option-input" name="PollOptions" placeholder="Option ${optionCount + 1}" required>
                <button type="button" class="poll-remove" onclick="removePollOption(this)">
                    <i class="fas fa-times"></i>
                </button>
            `;

            pollOptions.appendChild(newOption);
            updatePollRemoveButtons();
        } else {
            showStatus('warning', 'Maximum 6 poll options allowed');
        }
    }

    function removePollOption(button) {
        const pollOptions = document.getElementById('pollOptions');
        if (pollOptions.children.length > 2) {
            button.parentElement.remove();
            updatePollRemoveButtons();
        }
    }

    function updatePollRemoveButtons() {
        const pollOptions = document.getElementById('pollOptions');
        const removeButtons = pollOptions.querySelectorAll('.poll-remove');

        removeButtons.forEach((button, index) => {
            if (pollOptions.children.length <= 2) {
                button.disabled = true;
            } else {
                button.disabled = false;
            }
        });
    }

    function handleMediaUpload(e) {
        const files = Array.from(e.target.files);
        const preview = document.getElementById('mediaPreview');

        files.forEach(file => {
            if (file.size > 10 * 1024 * 1024) {
                showStatus('error', `File ${file.name} is too large. Maximum size is 10MB.`);
                return;
            }

            const mediaItem = document.createElement('div');
            mediaItem.className = 'media-item';

            if (file.type.startsWith('image/')) {
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                mediaItem.appendChild(img);
            } else if (file.type.startsWith('video/')) {
                const video = document.createElement('video');
                video.src = URL.createObjectURL(file);
                video.controls = true;
                mediaItem.appendChild(video);
            }

            const removeBtn = document.createElement('button');
            removeBtn.className = 'media-remove';
            removeBtn.innerHTML = '<i class="fas fa-times"></i>';
            removeBtn.onclick = () => mediaItem.remove();

            mediaItem.appendChild(removeBtn);
            preview.appendChild(mediaItem);
        });
    }

    function syncEditorContent() {
        const editorContent = document.getElementById('textEditor').innerHTML;
        document.getElementById('contentHidden').value = editorContent;
    }

    function handleFormSubmit(e) {
        e.preventDefault();

        // Validate required fields
        if (!selectedCommunity) {
            showStatus('error', 'Please select a community');
            return;
        }

        const title = document.getElementById('title').value.trim();
        if (!title) {
            showStatus('error', 'Please enter a title');
            return;
        }

        // Sync editor content
        syncEditorContent();

        showStatus('info', 'Publishing post...');

        // Here you would submit the form to your server
        setTimeout(() => {
            showStatus('success', 'Post published successfully!');
        }, 2000);
    }

    function handleOutsideClick(e) {
        const communityDropdown = document.getElementById('communityDropdown');
        const communitySearch = document.getElementById('communitySearch');

        if (!communitySearch.contains(e.target) && !communityDropdown.contains(e.target)) {
            communityDropdown.style.display = 'none';
        }
    }

    function showStatus(type, message) {
        const statusMessage = document.getElementById('statusMessage');
        const statusText = document.getElementById('statusText');

        statusMessage.className = `status-message ${type}`;
        statusText.textContent = message;
        statusMessage.style.display = 'block';

        setTimeout(() => {
            statusMessage.style.display = 'none';
        }, 3000);
    }

    function joinCommunity(button, communitySlug) {
        if (button.classList.contains('joined')) {
            button.textContent = 'Join';
            button.classList.remove('joined');
            showStatus('info', 'Left community');
        } else {
            button.textContent = 'Joined';
            button.classList.add('joined');
            showStatus('success', 'Joined community!');
        }
    }

    function showCreateCommunityModal() {
        showStatus('info', 'Opening create community modal...');
        // Here you would open a modal for creating a new community
    }
</script>