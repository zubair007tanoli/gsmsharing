                            <div class="form-group">
                                <label class="form-label" asp-for="PollEndDate">Poll End Date (Optional)</label>
                                <input asp-for="PollEndDate" type="datetime-local" class="form-input">
                            </div>
                        </div>

                        <!-- Tags -->
                        <div class="form-group">
                            <label class="form-label">Tags</label>
                            <div class="tag-container" id="tagContainer">
                                <input type="text" class="tag-input" id="tagInput" placeholder="Add tags (press Enter)">
                            </div>
                            <div style="font-size: 12px; color: #7c7c7c; margin-top: 4px;">Add up to 5 tags to help categorize your post</div>
                        </div>

                        <!-- SEO Toggle -->
                        <button type="button" class="btn btn-ghost" id="seoToggle" style="width: 100%; margin-bottom: 16px;">
                            <i class="fas fa-chevron-down"></i> Show SEO Settings
                        </button>

                        <!-- SEO Section -->
                        <div class="seo-section" id="seoSection">
