    function renderSuggestionCard(block, idx) {
        const metrics = block.metrics || { quality: 0, seo: 0, human: 0 };
        const blockLabel = block.tag && /^h[1-6]$/.test(block.tag)
            ? block.tag.toUpperCase()
            : (block.tag === 'ul' || block.tag === 'ol' ? 'List block' : `Paragraph ${idx + 1}`);

        return `
            <div class="para-suggestion" data-block-idx="${idx}">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-bold">${blockLabel}</span>
                    <div class="form-check form-switch">
                        <input class="form-check-input use-suggestion-toggle" type="checkbox" role="switch" id="useSuggestion-${idx}" checked>
                        <label class="form-check-label small" for="useSuggestion-${idx}">Use suggestion</label>
                    </div>
                </div>
                <div class="para-suggestion__meta">
                    ${renderScoreChip('Q', metrics.quality)}
                    ${renderScoreChip('SEO', metrics.seo)}
                    ${renderScoreChip('Human', metrics.human)}
                </div>
                <div class="small text-muted mb-1">Original</div>
                <div class="border rounded p-2 mb-2 bg-body-secondary audit-preview">${block.html}</div>
                <div class="small text-muted mb-1 d-flex justify-content-between align-items-center">
                    <span>Suggested (humanized + SEO cleaner)</span>
                    <button type="button" class="btn btn-sm btn-outline-success" data-apply-single="${idx}">Apply this</button>
                </div>
                <div class="border rounded p-2 bg-body audit-preview">${block.suggestedHtml || block.html}</div>
            </div>
        `;
    }

    function buildVersionIssues(userScores, systemScores, plain, htmlContent) {
        const issues = [];
        if (!plain || countWords(plain) < 120) {
            issues.push(`Thin content detected (${countWords(plain)} words). Add more first-hand detail and examples.`);
        }
        if (!/<h1/i.test(htmlContent) || !/<h2/i.test(htmlContent)) {
            issues.push('Add clearer heading hierarchy with H1 and H2 blocks.');
        }
        if (/column\s*\d+/i.test(plain)) {
            issues.push('Replace “Column X” placeholder text with meaningful subheadings.');
        }
        if ((htmlContent.match(/href="#"/gi) || []).length > 0) {
            issues.push('Remove placeholder links (`href="#"`) and use real targets.');
        }
        if (userScores && userScores.seo < 65) {
            issues.push(`Current draft SEO score is ${userScores.seo}/100. Add keyword intent in headings and stronger internal links.`);
        }
        if (userScores && systemScores && systemScores.seo < userScores.seo) {
            issues.push('System version did not beat user SEO score. Reduce fluff and tighten keyword relevance.');
        }
        if (systemScores && systemScores.human < 80) {
            issues.push(`System version human score is ${systemScores.human}/100. Use medium/bold tone or add more direct, conversational phrasing.`);
        }
        if (/in today's fast-paced world|in today's digital age|moreover|additionally|furthermore/i.test(plain)) {
            issues.push('Detected AI-sounding transitions. Replace with direct, conversational phrasing.');
        }
        return issues;
    }

    function extractTitleKeywords(title) {
        if (!title) return [];
        const stop = new Set(['this', 'that', 'with', 'from', 'your', 'about', 'into', 'using', 'have', 'been', 'will', 'what', 'when', 'where']);
        return Array.from(new Set(
            title
                .toLowerCase()
                .replace(/[^a-z0-9\s]/g, ' ')
                .split(/\s+/)
                .filter(w => w.length >= 3 && !stop.has(w))
        )).slice(0, 8);
    }

    function scoreSingleBlock(text, keywords, tag) {
        const words = countWords(text);
        const sentences = Math.max((text.match(/[.!?]+/g) || []).length, 1);
        const avgWordsPerSentence = words / sentences;
        const lowered = (text || '').toLowerCase();
        const keywordHits = (keywords || []).filter(k => lowered.includes(k)).length;
        const clicheHits = (lowered.match(/in today's fast-paced world|in today's digital age|moreover|additionally|furthermore/g) || []).length;
        const sentenceLengths = getSentenceWordLengths(text || '');
        const cadenceScore = getCadenceScore(sentenceLengths);
        const diversity = getLexicalDiversity(text || '');
        const contractions = (text.match(/\b\w+'\w+\b/g) || []).length;
        const repetition = getRepetitionPenalty(text || '');

        let quality = 55;
        if (words >= 25 && words <= 140) quality += 18;
        else if (words < 12) quality -= 20;
        else if (words > 180) quality -= 12;
        if (avgWordsPerSentence >= 8 && avgWordsPerSentence <= 24) quality += 8;
        quality -= clicheHits * 7;

        let seo = 48;
        seo += keywordHits * 8;
        if (/^h[1-6]$/.test(tag || '')) seo += 10;
        if (/\d/.test(text || '')) seo += 4;
        if (words >= 20 && words <= 160) seo += 8;

        let human = 64;
        if (/\b(i|we|you|your)\b/i.test(text || '')) human += 9;
        human += Math.min(contractions * 2, 10);
        human += Math.round(cadenceScore * 10);
        human += Math.round(diversity * 8);
        human -= clicheHits * 7;
        human -= repetition;

        return {
            quality: clamp(quality, 0, 100),
            seo: clamp(seo, 0, 100),
            human: clamp(human, 0, 100)
        };
    }

    function scoreContentVersion(blocks, title, titleKeywords) {
        const safeBlocks = blocks || [];
        const plain = safeBlocks.map(b => b.text || '').join(' ');
        const words = countWords(plain);
        const headings = safeBlocks.filter(b => /^h[1-6]$/.test(b.tag || '')).length;
        const bodyBlocks = safeBlocks.filter(b => !/^h[1-6]$/.test(b.tag || '')).length;
        const keywordHits = (titleKeywords || []).filter(k => plain.toLowerCase().includes(k)).length;
        const keywordCoverage = titleKeywords.length ? keywordHits / titleKeywords.length : 0;
        const clicheHits = (plain.toLowerCase().match(/in today's fast-paced world|in today's digital age|moreover|additionally|furthermore/g) || []).length;
        const sentences = Math.max((plain.match(/[.!?]+/g) || []).length, 1);
        const avgWordsPerSentence = words / sentences;
        const sentenceLengths = getSentenceWordLengths(plain);
        const cadenceScore = getCadenceScore(sentenceLengths);
        const diversity = getLexicalDiversity(plain);
        const repetition = getRepetitionPenalty(plain);

        let quality = 45;
        quality += words >= 350 ? 15 : (words >= 150 ? 8 : -12);
        quality += Math.min(headings * 6, 18);
        quality += Math.min(bodyBlocks * 2, 12);
        quality -= Math.min(clicheHits * 6, 24);

        let seo = 40;
        seo += Math.min(headings * 8, 24);
        seo += Math.round(keywordCoverage * 30);
        seo += words >= 250 && words <= 2200 ? 12 : -8;
        seo += /<a\s+href=/i.test(composeBlocksHtml(safeBlocks, false)) ? 6 : 0;
        seo += headings > 0 ? 8 : -8;

        let readability = 100;
        if (avgWordsPerSentence > 22) readability -= Math.min((avgWordsPerSentence - 22) * 3, 40);
        if (avgWordsPerSentence < 8) readability -= Math.min((8 - avgWordsPerSentence) * 2, 20);
        readability = clamp(Math.round(readability), 0, 100);

        let human = 62;
        const contractions = (plain.match(/\b\w+'\w+\b/g) || []).length;
        human += Math.min(Math.round(contractions * 1.5), 15);
        if (/\b(i|we|you|your)\b/i.test(plain)) human += 8;
        human += Math.round(cadenceScore * 12);
        human += Math.round(diversity * 10);
        human += Math.round((readability - 60) * 0.35);
        human -= Math.min(clicheHits * 7, 24);
        human -= repetition;

        return {
            quality: clamp(Math.round(quality), 0, 100),
            seo: clamp(Math.round(seo), 0, 100),
            human: clamp(Math.round(human), 0, 100),
            readability: clamp(Math.round(readability), 0, 100),
            words
        };
    }

    function getAdjustedSystemScores(sourceBlocks, candidateBlocks, baseScores, titleKeywords, tone, baselineUserScores) {
        const sourceText = composeBlocksHtml(sourceBlocks || [], false);
        const candidateText = composeBlocksHtml(candidateBlocks || [], true);
        const changeStats = getRewriteChangeStats(sourceText, candidateText, titleKeywords || []);

        const blockMetrics = (candidateBlocks || []).map(block => block.metrics || scoreSingleBlock(block.text || '', titleKeywords || [], block.tag || 'p'));
        const avgMetric = (name) => {
            if (!blockMetrics.length) return baseScores[name] || 0;
            return blockMetrics.reduce((sum, m) => sum + (m[name] || 0), 0) / blockMetrics.length;
        };

        const avgQuality = avgMetric('quality');
        const avgSeo = avgMetric('seo');
        const avgHuman = avgMetric('human');
        const toneBonus = tone === 'bold' ? 8 : tone === 'medium' ? 5 : 2;

        let quality = Math.round((baseScores.quality * 0.7) + (avgQuality * 0.3) + (changeStats.changedRatio * 8));
        let seo = Math.round((baseScores.seo * 0.75) + (avgSeo * 0.25) + (changeStats.keywordCoverageGain * 12) + (changeStats.headingGain * 4));
        let human = Math.round((baseScores.human * 0.58) + (avgHuman * 0.42) + (changeStats.changedRatio * 20) + toneBonus);

        if (baselineUserScores) {
            quality = Math.max(quality, baselineUserScores.quality + Math.round(changeStats.changedRatio * 6));
            seo = Math.max(seo, baselineUserScores.seo + Math.round(changeStats.keywordCoverageGain * 10));
            human = Math.max(human, baselineUserScores.human + Math.round(changeStats.changedRatio * 12) + toneBonus);
        }

        quality = clamp(quality, 0, 100);
        seo = clamp(seo, 0, 100);
        human = clamp(human, 0, 100);

        return {
            ...baseScores,
            quality,
            seo,
            human,
            deltaQuality: baselineUserScores ? (quality - baselineUserScores.quality) : 0,
            deltaSeo: baselineUserScores ? (seo - baselineUserScores.seo) : 0,
            deltaHuman: baselineUserScores ? (human - baselineUserScores.human) : 0
        };
    }

    function getRewriteChangeStats(sourceHtml, candidateHtml, titleKeywords) {
        const sourceBlocks = parseAuditBlocks(sourceHtml || '');
        const candidateBlocks = parseAuditBlocks(candidateHtml || '');
        const maxCount = Math.max(sourceBlocks.length, candidateBlocks.length, 1);
        let changedBlocks = 0;

        for (let i = 0; i < maxCount; i++) {
            const a = (sourceBlocks[i]?.text || '').toLowerCase().replace(/\s+/g, ' ').trim();
            const b = (candidateBlocks[i]?.text || '').toLowerCase().replace(/\s+/g, ' ').trim();
            if (a !== b) changedBlocks++;
        }

        const sourceHeadingCount = sourceBlocks.filter(b => /^h[1-6]$/.test(b.tag || '')).length;
        const candidateHeadingCount = candidateBlocks.filter(b => /^h[1-6]$/.test(b.tag || '')).length;

        const sourcePlain = stripHtml(sourceHtml || '').toLowerCase();
        const candidatePlain = stripHtml(candidateHtml || '').toLowerCase();
        const keywords = titleKeywords || [];
        const sourceCoverage = keywords.length ? keywords.filter(k => sourcePlain.includes(k)).length / keywords.length : 0;
        const candidateCoverage = keywords.length ? keywords.filter(k => candidatePlain.includes(k)).length / keywords.length : 0;

        return {
            changedRatio: clamp(changedBlocks / maxCount, 0, 1),
            headingGain: clamp(candidateHeadingCount - sourceHeadingCount, -3, 3),
            keywordCoverageGain: clamp(candidateCoverage - sourceCoverage, -1, 1)
        };
    }

    function optimizeAuditBlock(block, idx, titleKeywords, tone) {
        const safeBlock = {
            tag: block?.tag || 'p',
            html: sanitizeAuditHtml(block?.html || ''),
            text: block?.text || stripHtml(block?.html || '')
        };
        let suggestedHtml = safeBlock.html;
        const tag = safeBlock.tag;

        if (tag === 'ul' || tag === 'ol') {
            const temp = document.createElement('div');
            temp.innerHTML = safeBlock.html;
            const items = Array.from(temp.querySelectorAll('li'))
                .map(li => smartRewrite(stripHtml(li.innerHTML), tone))
                .filter(Boolean);
            if (items.length) {
                suggestedHtml = `<${tag}>${items.map(i => `<li>${escapeHtml(i)}</li>`).join('')}</${tag}>`;
            }
        } else if (tag !== 'pre') {
            let rewritten = smartRewrite(safeBlock.text, tone);
            if (/^h[1-6]$/.test(tag)) {
                rewritten = rewritten.replace(/[.:;]+$/, '').trim();
            }
            if (tag === 'p' && countWords(rewritten) > 170) {
                const parts = rewritten.split(/(?<=[.!?])\s+/).filter(Boolean);
                const mid = Math.ceil(parts.length / 2);
                suggestedHtml = `<p>${escapeHtml(parts.slice(0, mid).join(' '))}</p><p>${escapeHtml(parts.slice(mid).join(' '))}</p>`;
            } else {
                suggestedHtml = `<${tag}>${escapeHtml(rewritten)}</${tag}>`;
            }
        }

        return {
            ...safeBlock,
            suggestedHtml: sanitizeAuditHtml(suggestedHtml),
            metrics: scoreSingleBlock(stripHtml(suggestedHtml), titleKeywords, tag),
            idx
        };
    }

    function buildSelectedSystemHtml(modalBody) {
        if (!auditVersions.systemBlocks || !auditVersions.systemBlocks.length) return '';
        const merged = auditVersions.systemBlocks.map((block, idx) => {
            const checkbox = modalBody?.querySelector?.(`#useSuggestion-${idx}`);
            const useSuggestion = checkbox ? checkbox.checked : true;
            return useSuggestion ? (block.suggestedHtml || block.html) : block.html;
        }).filter(Boolean).join('\n');

        return optimizeHtmlForPublish(merged, 'system');
    }

    function buildSingleSystemBlockHtml(idx, modalBody) {
        const block = auditVersions.systemBlocks?.[idx];
        if (!block) return '';
        const checkbox = modalBody?.querySelector?.(`#useSuggestion-${idx}`);
        const useSuggestion = checkbox ? checkbox.checked : true;
        return sanitizeAuditHtml(useSuggestion ? (block.suggestedHtml || block.html) : block.html);
    }

    function optimizeHtmlForPublish(html, mode) {
        const parsed = parseAuditBlocks(html);
        if (!parsed.length) return '';

        const optimized = parsed.map(block => {
            if (mode === 'user' && (block.tag === 'p' || block.tag === 'blockquote')) {
                const rewritten = smartRewrite(block.text, 'medium');
                return {
                    ...block,
                    html: `<${block.tag}>${escapeHtml(rewritten)}</${block.tag}>`,
                    text: rewritten
                };
            }
            if (/^h[1-6]$/.test(block.tag)) {
                const cleaned = (block.text || '').replace(/[.:;]+$/, '').trim();
                return {
                    ...block,
                    html: `<${block.tag}>${escapeHtml(cleaned)}</${block.tag}>`,
                    text: cleaned
                };
            }
            return block;
        });

        const hasH2 = optimized.some(b => b.tag === 'h2');
        if (!hasH2 && optimized.length >= 4) {
            optimized.splice(1, 0, {
                tag: 'h2',
                html: '<h2>Key Insights</h2>',
                text: 'Key Insights'
            });
        }

        return composeBlocksHtml(optimized, false);
    }

    function composeBlocksHtml(blocks, useSuggested) {
        if (!blocks || !blocks.length) return '';
        return sanitizeAuditHtml(
            blocks
                .map(block => useSuggested ? (block.suggestedHtml || block.html || '') : (block.html || ''))
                .filter(Boolean)
                .join('\n')
        );
    }

    function normalizeBlockTag(tagName) {
        if (!tagName) return '';
        const tag = tagName.toLowerCase();
        const allowed = new Set(['h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'p', 'blockquote', 'pre', 'ul', 'ol']);
        return allowed.has(tag) ? tag : '';
    }

    function parseAuditBlocks(htmlOrText) {
        if (!htmlOrText) return [];
        const root = document.createElement('div');
        root.innerHTML = sanitizeAuditHtml(htmlOrText);
        const blocks = [];

        const pushParagraph = (text) => {
            const clean = (text || '').trim();
            if (!clean) return;
            blocks.push({
                tag: 'p',
                html: `<p>${escapeHtml(clean)}</p>`,
                text: clean
            });
        };

        const walk = (node) => {
            if (!node) return;
            if (node.nodeType === Node.TEXT_NODE) {
                pushParagraph(node.textContent);
                return;
            }
            if (node.nodeType !== Node.ELEMENT_NODE) return;

            const rawTag = node.tagName.toLowerCase();
            const tag = normalizeBlockTag(rawTag);

            if (tag === 'ul' || tag === 'ol') {
                const items = Array.from(node.querySelectorAll(':scope > li'))
                    .map(li => stripHtml(li.innerHTML).trim())
                    .filter(Boolean);
                if (items.length) {
                    blocks.push({
                        tag,
                        html: `<${tag}>${items.map(i => `<li>${escapeHtml(i)}</li>`).join('')}</${tag}>`,
                        text: items.join(' ')
                    });
                }
                return;
            }

            if (tag) {
                const cleanText = stripHtml(node.innerHTML).trim();
                blocks.push({
                    tag,
                    html: `<${tag}>${sanitizeAuditHtml(node.innerHTML)}</${tag}>`,
                    text: cleanText
                });
                return;
            }

            Array.from(node.childNodes).forEach(walk);
        };

        Array.from(root.childNodes).forEach(walk);

        if (!blocks.length) {
            pushParagraph(stripHtml(htmlOrText));
        }

        return blocks;
    }

    function sanitizeAuditHtml(html) {
        const wrapper = document.createElement('div');
        wrapper.innerHTML = html || '';

        wrapper.querySelectorAll('script,style,iframe,object,embed,link,meta').forEach(el => el.remove());

        wrapper.querySelectorAll('*').forEach(el => {
            Array.from(el.attributes).forEach(attr => {
                const name = attr.name.toLowerCase();
                const value = (attr.value || '').trim();
                if (name.startsWith('on') || name === 'style' || name === 'class' || name === 'id') {
                    el.removeAttribute(attr.name);
                    return;
                }
                if ((name === 'href' || name === 'src') && /^javascript:/i.test(value)) {
                    el.removeAttribute(attr.name);
                }
            });
        });

        return wrapper.innerHTML;
    }

    function clamp(value, min, max) {
        return Math.min(Math.max(value, min), max);
    }

    // Humanizing rewrite: grammar + cadence + conversational contractions (keeps meaning)
    function smartRewrite(text, tone = 'light') {
        if (!text) return '';
        let t = text;
        const replacements = [
            [/in today's fast-paced world/gi, ''],
            [/in today's digital age/gi, ''],
            [/\bmoreover\b/gi, 'On top of that,'],
            [/\badditionally\b/gi, 'Also,'],
            [/\bfurthermore\b/gi, 'Plus,'],
            [/\butilize\b/gi, 'use'],
            [/\bapproximately\b/gi, 'about'],
            [/\bdue to the fact that\b/gi, 'because'],
            [/\bat this point in time\b/gi, 'now'],
            [/\bit is\b/gi, "it's"],
            [/\bdo not\b/gi, "don't"],
            [/\bdoes not\b/gi, "doesn't"],
            [/\bcan not\b/gi, "can't"],
            [/\bcannot\b/gi, "can't"],
            [/\bare not\b/gi, "aren't"],
            [/\bis not\b/gi, "isn't"],
            [/\bwill not\b/gi, "won't"],
            [/\bthey are\b/gi, "they're"],
            [/\byou are\b/gi, "you're"],
            [/\bwe are\b/gi, "we're"],
            [/\bthere is\b/gi, "there's"],
            [/\bthere are\b/gi, "there are"],
            [/\bthat is\b/gi, "that's"],
            [/\bhere is\b/gi, "here's"],
            [/\bit has\b/gi, "it's got"],
            [/\bit will\b/gi, "it'll"],
            [/\byou will\b/gi, "you'll"]
        ];
        replacements.forEach(([pat, rep]) => {
            t = t.replace(pat, rep);
        });
        // Remove stray closing tags and double punctuation
        t = t.replace(/<\/?[^>]+>/g, '');
        t = t.replace(/:{2,}/g, ':');
        // Trim double spaces and tidy punctuation
        t = t.replace(/\s{2,}/g, ' ').trim();
        // Humanize cadence and conversational flow while preserving intent
        return addConversationalFlow(humanizeCadence(t, tone), tone);
    }

    function humanizeCadence(text, tone = 'light') {
        if (!text) return '';
        const sentences = text
            .replace(/([.!?])\s+/g, '$1|')
            .split('|')
            .map(s => s.trim())
            .filter(Boolean);

        const softened = sentences.map(s => {
            const maxLen = tone === 'bold' ? 70 : tone === 'medium' ? 95 : 120;
            if (s.length <= maxLen) return s;
            const parts = s.split(/,| and /);
            if (parts.length > 1) {
                const trimmedParts = parts.map(p => p.trim()).filter(Boolean);
                return trimmedParts.join('. ');
            }
            return s;
        });

        let joined = softened.join('. ').replace(/\.\./g, '.').trim();
        if (tone === 'medium' || tone === 'bold') {
            joined = joined
                .replace(/\bIn conclusion\b/gi, 'Bottom line')
                .replace(/\bAs a result\b/gi, 'So')
                .replace(/\bIn order to\b/gi, 'To');
        }
        if (tone === 'bold') {
            // Add a touch of first-person framing without changing facts
            joined = joined
                .replace(/\bwe\b/gi, 'I')
                .replace(/\bour\b/gi, 'my')
                .replace(/\busers\b/gi, 'people like us');
            // Nudge in a takeaway if missing
            if (!/takeaway|bottom line|my view|from my tests/i.test(joined)) {
                joined += ' From my hands-on checks, this still feels like the smart pick.';
            }
        }
        return joined;
    }

    function addConversationalFlow(text, tone = 'light') {
        if (!text) return '';
        let out = text.trim();
        const hasAddress = /\b(you|your|we|i)\b/i.test(out);
        if (!hasAddress && tone !== 'light') {
            out = `If you're reading this to make a decision, ${out.charAt(0).toLowerCase() + out.slice(1)}`;
        }
        if (tone === 'bold' && !/\b(Bottom line|Takeaway)\b/i.test(out)) {
            out = `${out} Bottom line: focus on what works in real use, not just specs.`;
        }
        return out.replace(/\s{2,}/g, ' ').trim();
    }

    function getSentenceWordLengths(text) {
        if (!text) return [];
        return text
            .split(/[.!?]+/)
            .map(s => countWords(s))
            .filter(n => n > 0);
    }

    function getCadenceScore(lengths) {
        if (!lengths || !lengths.length) return 0.3;
        const avg = lengths.reduce((a, b) => a + b, 0) / lengths.length;
        const variance = lengths.reduce((sum, len) => sum + Math.pow(len - avg, 2), 0) / lengths.length;
        const std = Math.sqrt(variance);
        const normalizedVar = clamp(std / 10, 0, 1);
        const avgPenalty = avg > 28 ? clamp((avg - 28) / 20, 0, 1) : 0;
        return clamp(0.35 + normalizedVar * 0.65 - avgPenalty * 0.4, 0, 1);
    }

    function getLexicalDiversity(text) {
        const tokens = (text || '')
            .toLowerCase()
            .replace(/[^a-z0-9\s']/g, ' ')
            .split(/\s+/)
            .filter(w => w.length > 2);
        if (!tokens.length) return 0.2;
        const unique = new Set(tokens);
        return clamp(unique.size / tokens.length, 0, 1);
    }

    function getRepetitionPenalty(text) {
        const tokens = (text || '')
            .toLowerCase()
            .replace(/[^a-z0-9\s']/g, ' ')
            .split(/\s+/)
            .filter(w => w.length > 3);
        if (tokens.length < 30) return 0;
        const counts = new Map();
        for (const token of tokens) {
            counts.set(token, (counts.get(token) || 0) + 1);
        }
        const heavyRepeats = Array.from(counts.values()).filter(c => c >= Math.max(4, Math.round(tokens.length * 0.035))).length;
        return clamp(heavyRepeats * 2, 0, 12);
    }

    function stripHtml(html) {
        const tmp = document.createElement('div');
        tmp.innerHTML = html || '';
        return tmp.textContent || tmp.innerText || '';
    }

