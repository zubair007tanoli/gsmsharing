                                <span>NSFW</span>
                                <div class="toggle-switch">
                                    <input asp-for="IsNSFW" type="checkbox">
                                    <span class="toggle-slider"></span>
                                </div>
                            </label>
                            <label class="option-toggle">
                                <span>Spoiler</span>
                                <div class="toggle-switch">
                                    <input asp-for="IsSpoiler" type="checkbox">
                                    <span class="toggle-slider"></span>
                                </div>
                            </label>
                            <label class="option-toggle">
                                <span>Pin Post</span>
                                <div class="toggle-switch">
                                    <input asp-for="IsPinned" type="checkbox">
                                    <span class="toggle-slider"></span>
                                </div>
                            </label>
                            <label class="option-toggle">
                                <span>Lock Comments</span>
                                <div class="toggle-switch">
                                    <input asp-for="IsLocked" type="checkbox">
                                    <span class="toggle-slider"></span>
                                </div>
                            </label>
                        </div>
                    </form>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="button" class="btn btn-ghost" id="saveAsDraft">
                        <i class="fas fa-save"></i> Save Draft
                    </button>
                    <button type="button" class="btn btn-secondary" id="previewBtn">
                        <i class="fas fa-eye"></i> Preview
                    </button>
                    <button type="button" class="btn btn-primary" id="submitPost">
                        <i class="fas fa-paper-plane"></i> Post
                    </button>
                </div>
            </div>
        </main>

        <!-- Right Sidebar -->
        <aside class="right-sidebar">
            <!-- DEBUG PANEL (Remove after testing) -->
            @await Html.PartialAsync("_SeoAssistantDebug")
            
            <!-- SEO ASSISTANT - NEW! -->
            @await Html.PartialAsync("_SeoAssistant")
            
            <!-- AI Content Audit (side-by-side user vs system suggestions) -->
            <div class="card" style="margin-top: 20px;">
                <div class="card-header d-flex align-items-center justify-content-between bg-body-secondary text-body">
