                                        <button type="button" class="poll-remove" disabled>
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                    <div class="poll-option">
                                        <input type="text" class="form-input poll-option-input" name="PollOptions" placeholder="Option 2" required>
                                        <button type="button" class="poll-remove" disabled>
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                                <button type="button" class="add-option" id="addPollOption">
                                    <i class="fas fa-plus"></i> Add option
