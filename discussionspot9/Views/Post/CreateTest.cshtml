    function applySingleParagraph(idx) {
        const temp = document.createElement('div');
        temp.innerHTML = auditVersions.systemHtml || '';
        const block = temp.querySelector(`.para-suggestion[data-idx="${idx}"]`);
        if (!block) return;
        const suggested = block.querySelector('.border.rounded.p-2.bg-body')?.innerHTML || '';
        const original = block.querySelector('.border.rounded.p-2.mb-2')?.innerHTML || '';
        const useSuggested = block.querySelector(`#useSuggestion-${idx}`)?.checked ?? true;
        const fragment = useSuggested ? suggested : original;
        if (!fragment) return;

        // Update only the corresponding paragraph in the editor
        snapshotEditor();

        if (window.contentQuill) {
            const quillHtml = window.contentQuill.root.innerHTML;
            const tempEditor = document.createElement('div');
            tempEditor.innerHTML = quillHtml;
            const paras = tempEditor.querySelectorAll('p, div');
            if (paras[idx]) {
                paras[idx].innerHTML = fragment;
            } else {
                const p = document.createElement('p');
                p.innerHTML = fragment;
                tempEditor.appendChild(p);
            }
            const newHtml = tempEditor.innerHTML;
            window.contentQuill.root.innerHTML = newHtml;
            const textarea = document.getElementById('contentTextarea');
            if (textarea) textarea.value = newHtml;
            highlightEditor();
            showStatus('success', `Paragraph ${parseInt(idx, 10) + 1} applied to editor`);
        }

        const undoBtn = document.getElementById('undoApplyBtn');
        if (undoBtn) undoBtn.disabled = !lastAppliedHtml;
    }

