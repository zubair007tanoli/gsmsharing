    let mediaUrls = [];

    function addMediaUrl() {
        const input = document.getElementById('mediaUrlInput');
        const url = input.value.trim();
        
        if (!url) {
            showStatus('error', 'Please enter a URL');
            return;
        }
        
        // Basic URL validation
        if (!url.startsWith('http://') && !url.startsWith('https://')) {
            showStatus('error', 'URL must start with http:// or https://');
            return;
        }
        
        // Check if already added
        if (mediaUrls.includes(url)) {
            showStatus('warning', 'This URL has already been added');
            return;
        }
        
        // Add to array
        mediaUrls.push(url);
        
        // Create hidden input for form submission
        const hiddenInput = document.createElement('input');
        hiddenInput.type = 'hidden';
        hiddenInput.name = 'MediaUrls';
        hiddenInput.value = url;
        hiddenInput.id = `mediaUrl_${mediaUrls.length}`;
        document.getElementById('postForm').appendChild(hiddenInput);
        
        // Display the added URL
        const urlDisplay = document.createElement('div');
        urlDisplay.className = 'alert alert-info d-flex justify-content-between align-items-center mb-2';
        urlDisplay.innerHTML = `
            <span><i class="fas fa-link"></i> ${url}</span>
            <button type="button" class="btn btn-sm btn-danger" onclick="removeMediaUrl('${url}', ${mediaUrls.length})">
                <i class="fas fa-times"></i>
            </button>
        `;
        document.getElementById('addedMediaUrls').appendChild(urlDisplay);
        
        // Clear input
        input.value = '';
        
        showStatus('success', 'Image URL added successfully');
        console.log('✅ Media URL added:', url);
    }

    function removeMediaUrl(url, index) {
        // Remove from array
        mediaUrls = mediaUrls.filter(u => u !== url);
        
        // Remove hidden input
        const hiddenInput = document.getElementById(`mediaUrl_${index}`);
        if (hiddenInput) {
            hiddenInput.remove();
        }
        
        // Re-render the display
        const container = document.getElementById('addedMediaUrls');
        container.innerHTML = '';
        
        mediaUrls.forEach((u, i) => {
            const urlDisplay = document.createElement('div');
            urlDisplay.className = 'alert alert-info d-flex justify-content-between align-items-center mb-2';
            urlDisplay.innerHTML = `
                <span><i class="fas fa-link"></i> ${u}</span>
                <button type="button" class="btn btn-sm btn-danger" onclick="removeMediaUrl('${u}', ${i + 1})">
                    <i class="fas fa-times"></i>
                </button>
            `;
            container.appendChild(urlDisplay);
        });
        
        showStatus('info', 'Image URL removed');
    }

