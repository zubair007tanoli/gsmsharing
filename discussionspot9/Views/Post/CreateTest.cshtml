        return `<span class="audit-score-chip">${label}: ${sign}${n}</span>`;
    }

    function formatVersionSummary(scores, label) {
        if (!scores) return `${label} • no score available`;
        return `${label} • Q ${scores.quality}/100 • SEO ${scores.seo}/100 • Human ${scores.human}/100 • ${scores.words} words`;
