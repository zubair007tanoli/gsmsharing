    function wireAuditButton() {
        const btn = document.getElementById('runAuditBtn');
        if (btn) {
            btn.addEventListener('click', () => {
                runContentAudit();
                showVersionModal('user');
            });
        }
        const tone = document.getElementById('toneSelect');
        if (tone) {
            humanizeTone = tone.value;
            tone.addEventListener('change', () => {
                humanizeTone = tone.value;
                runContentAudit();
            });
        }
    }

    function wireVersionButtons() {
        const modalUserBtn = document.getElementById('modalUserBtn');
        const modalSystemBtn = document.getElementById('modalSystemBtn');
        if (modalUserBtn) modalUserBtn.addEventListener('click', () => showVersionModal('user'));
        if (modalSystemBtn) modalSystemBtn.addEventListener('click', () => showVersionModal('system'));
        const applyBtn = document.getElementById('applyVersionBtn');
        if (applyBtn) applyBtn.addEventListener('click', () => applyVersionToEditor());
        const undoBtn = document.getElementById('undoApplyBtn');

        // Delegate single-paragraph apply inside modal
        const modalBody = document.getElementById('versionModalBody');
        if (modalBody) {
            modalBody.addEventListener('click', (e) => {
