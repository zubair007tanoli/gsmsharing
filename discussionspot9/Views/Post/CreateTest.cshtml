    function escapeHtml(text) {
        if (!text) return '';
        return text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function renderScoreChip(label, value) {
        return `<span class="audit-score-chip">${label}: ${Math.round(value || 0)}</span>`;
    }

    function renderDeltaChip(label, value) {
        const n = Math.round(value || 0);
