    function determineActualPostType() {
        // Check what content is actually present
        const hasContent = document.getElementById('contentTextarea')?.value?.trim().length > 0;
        
        // Check if URL field has a value
        const hasUrl = document.getElementById('linkUrl')?.value?.trim().length > 0;
        
        const hasPollOptions = getPollOptionValues().filter(o => o.trim()).length >= 2;
        const hasMediaFiles = document.getElementById('mediaUpload')?.files?.length > 0;
        const hasMediaUrls = mediaUrls.length > 0;
        
        console.log('📊 Content Detection:');
        console.log('  - Content:', hasContent);
        console.log('  - URL:', hasUrl);
        console.log('  - Poll:', hasPollOptions);
        console.log('  - Media Files:', hasMediaFiles);
        console.log('  - Media URLs:', hasMediaUrls);
        
        // Priority: Poll > Image/Video > Link > Text
        // This matches user intent based on what they added
        if (hasPollOptions) {
            console.log('  → Detected as POLL post');
            return 'poll';
        }
        
        if (hasMediaFiles || hasMediaUrls) {
            console.log('  → Detected as IMAGE post');
            return 'image';
        }
        
        if (hasUrl) {
            console.log('  → Detected as LINK post');
            return 'link';
        }
        
        console.log('  → Detected as TEXT post');
        return 'text';
    }
    
