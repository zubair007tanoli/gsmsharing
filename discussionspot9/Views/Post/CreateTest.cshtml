    function runContentAudit() {
        const title = (document.getElementById('title')?.value || '').trim();
        const htmlContent = window.contentQuill
            ? window.contentQuill.root.innerHTML
            : (document.getElementById('contentTextarea')?.value || '');

        const plain = stripHtml(htmlContent);
        const wordCount = countWords(plain);
        const issues = [];

        if (wordCount < 1000) {
            issues.push(`Thin content detected (${wordCount} words). Add first-hand details, comparisons, and testing notes.`);
        }

        const cliches = [
            "in today's fast-paced world",
            "in today's digital age",
            "moreover",
            "additionally",
            "furthermore"
        ];
        if (containsAny(plain.toLowerCase(), cliches)) {
            issues.push("Intro uses AI-sounding clichés. Swap for varied, conversational openers.");
        }

        if (/column\s*1/i.test(plain) || /column\s*2/i.test(plain) || /colum\s*2/i.test(plain)) {
            issues.push("Remove placeholder text like “column 1 / column 2” and replace with real subheadings or bullets.");
        }

        if (!/<h1/i.test(htmlContent) || !/<h2/i.test(htmlContent)) {
            issues.push("Add clear H1 and supporting H2/H3 structure for scannability.");
        }

        if (!/application\/ld\+json/i.test(htmlContent)) {
            issues.push("Missing JSON-LD Article/Person schema.");
        }

        if (!/author bio/i.test(plain) && !/about the author/i.test(plain)) {
            issues.push("Add an Author Bio with first-hand experience and profile link.");
        }

        if ((htmlContent.match(/href="#"/gi) || []).length > 0) {
            issues.push("Found placeholder links (href=\"#\"). Replace or remove.");
        }

        const auditIssues = document.getElementById('auditIssues');
        if (auditIssues) {
            if (issues.length) {
                auditIssues.style.display = 'block';
                auditIssues.className = 'alert alert-warning';
                auditIssues.innerHTML = '<strong>Needs work:</strong><ul style="margin:6px 0 0 18px;">' +
                    issues.map(i => `<li>${i}</li>`).join('') + '</ul>';
            } else {
                auditIssues.style.display = 'block';
                auditIssues.className = 'alert alert-success';
                auditIssues.textContent = 'Looks solid. Run the read-aloud test to confirm it flows naturally.';
            }
        }

        const userPane = document.getElementById('userVersion');
        if (userPane) {
            userPane.classList.remove('muted');
            userPane.textContent = plain || 'No content found. Start typing to generate a preview.';
        }

        const systemPane = document.getElementById('systemVersion');
        if (systemPane) {
            const improved = buildSystemVersion(title, plain, htmlContent);
            systemPane.classList.remove('muted');
            systemPane.innerHTML = improved;
            auditVersions.systemHtml = improved;
            auditVersions.systemPlain = stripHtml(improved);
        }

        auditVersions.userHtml = htmlContent || (document.getElementById('contentTextarea')?.value || '');
        auditVersions.userPlain = plain;
    }

    function buildSystemVersion(title, plain, originalHtml) {
        const cleanTitle = title || 'Add a specific, benefit-driven headline';
        const intro = humanizeIntro(plain);
        const cleanedHtml = cleanHtmlForRewrite(originalHtml || plain);
        const paragraphs = splitIntoParas(cleanedHtml);

        const improvedParas = paragraphs.map((p, idx) => {
            const trimmed = p.trim();
            if (!trimmed) return '';
            const improved = smartRewrite(trimmed);
            return `
                <div class="para-suggestion" data-idx="${idx}">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-bold">Paragraph ${idx + 1}</span>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="useSuggestion-${idx}" checked>
                            <label class="form-check-label small" for="useSuggestion-${idx}">Use suggestion</label>
                        </div>
                    </div>
                    <div class="small text-muted mb-1">Original</div>
                    <div class="border rounded p-2 mb-2 bg-body-secondary">${trimmed}</div>
                    <div class="small text-muted mb-1 d-flex justify-content-between align-items-center">
                        <span>Suggested (grammar/clarity only)</span>
                        <button type="button" class="btn btn-sm btn-outline-success" data-apply-single="${idx}">Apply this</button>
                    </div>
                    <div class="border rounded p-2 bg-body">${improved}</div>
                </div>
            `;
        }).join('');

        return [
            `<h1 style="margin:0 0 6px 0;">${cleanTitle}</h1>`,
            `<p>${intro}</p>`,
            `<h2>Paragraph-level suggestions</h2>`,
            `<div class="audit-pane__body" style="border:1px solid #e1e5e9;">${improvedParas || 'No content to review yet.'}</div>`,
            `<div class="alert alert-secondary mt-3 mb-0" role="alert">Toggle “Use suggestion” per paragraph. “Use this version” will apply only the selected suggestions.</div>`
        ].join('');
    }

    function humanizeIntro(text) {
        if (!text) return "Lead with what you actually saw, measured, or felt. Keep it under 3 lines.";
        let intro = text.trim().split(/[.!?]/)[0] || text.slice(0, 180);
        intro = intro.replace(/in today's fast-paced world/gi, "The kicker is");
        intro = intro.replace(/in today's digital age/gi, "Right now");
        intro = intro.replace(/\bMoreover\b/gi, "On top of that");
        intro = intro.replace(/\bAdditionally\b/gi, "Another angle");
        return intro;
    }

