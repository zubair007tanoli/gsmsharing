    function applyVersionToEditor() {
        const applyBtn = document.getElementById('applyVersionBtn');
        if (!applyBtn) return;
        const kind = applyBtn.dataset.version || 'user';
        let html = kind === 'system' ? auditVersions.systemHtml : auditVersions.userHtml;

        // For system version, merge selected suggestions back into a single HTML string
        if (kind === 'system') {
            const temp = document.createElement('div');
            temp.innerHTML = auditVersions.systemHtml || '';
            const suggestions = Array.from(temp.querySelectorAll('.para-suggestion'));
            const merged = suggestions.map(s => {
                const idx = s.dataset.idx;
                const useSuggestion = s.querySelector(`#useSuggestion-${idx}`)?.checked ?? true;
                const suggested = s.querySelector('.border.rounded.p-2.bg-body')?.innerHTML || '';
                const original = s.querySelector('.border.rounded.p-2.mb-2')?.innerHTML || '';
                return useSuggestion ? suggested : original;
            }).filter(Boolean);
            html = merged.map(p => `<p>${p}</p>`).join('');
