    function runContentAudit() {
        const title = (document.getElementById('title')?.value || '').trim();
        const rawHtml = window.contentQuill
            ? window.contentQuill.root.innerHTML
            : (document.getElementById('contentTextarea')?.value || '');
        const htmlContent = sanitizeAuditHtml(rawHtml || '');
        const plain = stripHtml(htmlContent);
        const titleKeywords = extractTitleKeywords(title);

        const userBlocks = parseAuditBlocks(htmlContent);
        const userScores = scoreContentVersion(userBlocks, title, titleKeywords);
        const systemVersion = buildSystemVersion(title, userBlocks, titleKeywords, userScores);

        const auditIssues = document.getElementById('auditIssues');
        if (auditIssues) {
            const issues = buildVersionIssues(userScores, systemVersion.scores, plain, htmlContent);
            if (issues.length) {
                auditIssues.style.display = 'block';
                auditIssues.className = 'alert alert-warning';
                auditIssues.innerHTML = '<strong>Needs work:</strong><ul style="margin:6px 0 0 18px;">' +
                    issues.map(i => `<li>${i}</li>`).join('') + '</ul>';
            } else {
                auditIssues.style.display = 'block';
                auditIssues.className = 'alert alert-success';
                auditIssues.textContent = 'Audit passed: structure, readability, and SEO signals look publish-ready.';
            }
        }

        const userPane = document.getElementById('userVersion');
        if (userPane) {
            userPane.classList.remove('muted');
            userPane.innerHTML = renderVersionPreview('User draft', userBlocks, userScores);
        }

        const systemPane = document.getElementById('systemVersion');
        if (systemPane) {
            systemPane.classList.remove('muted');
            systemPane.innerHTML = systemVersion.html;
        }

        auditVersions.userHtml = htmlContent || (document.getElementById('contentTextarea')?.value || '');
        auditVersions.userPlain = plain;
        auditVersions.userBlocks = userBlocks;
        auditVersions.userScores = userScores;
        auditVersions.systemHtml = systemVersion.html;
        auditVersions.systemPlain = systemVersion.plain;
        auditVersions.systemBlocks = systemVersion.blocks;
        auditVersions.systemScores = systemVersion.scores;
    }

    function buildSystemVersion(title, sourceBlocks, titleKeywords, baselineUserScores) {
        const cleanTitle = title || 'Add a specific, benefit-driven headline';
        const toneCandidates = getToneCandidates(humanizeTone);
        let best = null;

        for (const tone of toneCandidates) {
            const candidateBlocks = (sourceBlocks || []).map((block, idx) =>
                optimizeAuditBlock(block, idx, titleKeywords, tone)
            );
            const candidateHtml = composeBlocksHtml(candidateBlocks, true);
            const candidateBaseScores = scoreContentVersion(parseAuditBlocks(candidateHtml), cleanTitle, titleKeywords);
            const candidateScores = getAdjustedSystemScores(
                sourceBlocks || [],
                candidateBlocks,
                candidateBaseScores,
                titleKeywords,
                tone,
                baselineUserScores
            );

            if (!best || candidateScores.human > best.scores.human) {
                best = {
                    tone,
                    blocks: candidateBlocks,
                    mergedHtml: candidateHtml,
                    scores: candidateScores
                };
            }

            if (candidateScores.human >= targetHumanScore) {
                break;
            }
        }

        const optimizedBlocks = best?.blocks || [];
        const mergedSystemHtml = best?.mergedHtml || '';
        const scores = best?.scores || scoreContentVersion([], cleanTitle, titleKeywords);
        const effectiveTone = best?.tone || humanizeTone;
        const cards = optimizedBlocks.map((block, idx) => renderSuggestionCard(block, idx)).join('');

        const html = [
            `<h1 style="margin:0 0 6px 0;">${escapeHtml(cleanTitle)}</h1>`,
            `<p>${escapeHtml(humanizeIntro(stripHtml(mergedSystemHtml)))}</p>`,
            `<div class="audit-summary-bar">`,
            renderScoreChip('Quality', scores.quality),
            renderScoreChip('SEO', scores.seo),
            renderScoreChip('Human', scores.human),
            renderScoreChip('Words', scores.words),
            renderDeltaChip('ΔQ', scores.deltaQuality || 0),
            renderDeltaChip('ΔSEO', scores.deltaSeo || 0),
            renderDeltaChip('ΔHuman', scores.deltaHuman || 0),
            `<span class="audit-score-chip">Tone: ${escapeHtml(effectiveTone)}</span>`,
            `</div>`,
            `<h2>Paragraph-level suggestions</h2>`,
            `<div class="audit-pane__body" style="border:1px solid #e1e5e9;">${cards || 'No content to review yet.'}</div>`,
            `<div class="alert alert-secondary mt-3 mb-0" role="alert">Use toggles to pick per-paragraph suggestions. “Use this version” keeps headings and structure.</div>`
        ].join('');

        return {
            html,
            plain: stripHtml(mergedSystemHtml),
            blocks: optimizedBlocks,
            scores
        };
    }

    function getToneCandidates(startTone) {
        const order = ['light', 'medium', 'bold'];
        const startIndex = Math.max(order.indexOf(startTone), 0);
        const forward = order.slice(startIndex);
        const previous = order.slice(0, startIndex).reverse();
        return [...forward, ...previous];
    }

    function humanizeIntro(text) {
        if (!text) return "Lead with what you actually saw, measured, or felt. Keep it under 3 lines.";
        let intro = text.trim().split(/[.!?]/)[0] || text.slice(0, 180);
        intro = intro.replace(/in today's fast-paced world/gi, "The kicker is");
        intro = intro.replace(/in today's digital age/gi, "Right now");
        intro = intro.replace(/\bMoreover\b/gi, "On top of that");
        intro = intro.replace(/\bAdditionally\b/gi, "Another angle");
        return intro;
    }

    function showVersionModal(kind) {
        const modalEl = document.getElementById('versionModal');
        const body = document.getElementById('versionModalBody');
        const meta = document.getElementById('versionModalMeta');
        const label = document.getElementById('versionModalLabel');
        const applyBtn = document.getElementById('applyVersionBtn');
        const modalUserBtn = document.getElementById('modalUserBtn');
        const modalSystemBtn = document.getElementById('modalSystemBtn');
        const undoBtn = document.getElementById('undoApplyBtn');

        if (!modalEl || !body || !label || !applyBtn) return;

        if (modalUserBtn && modalSystemBtn) {
            modalUserBtn.classList.toggle('active', kind === 'user');
            modalSystemBtn.classList.toggle('active', kind === 'system');
        }

        let html = '';
        let summary = '';
        if (kind === 'system') {
            html = auditVersions.systemHtml || 'Run audit to generate system version.';
            summary = formatVersionSummary(auditVersions.systemScores, 'System version');
            applyBtn.dataset.version = 'system';
        } else {
            html = renderVersionPreview('User draft', auditVersions.userBlocks, auditVersions.userScores);
            summary = formatVersionSummary(auditVersions.userScores, 'User version');
            applyBtn.dataset.version = 'user';
        }

        body.innerHTML = html;
        label.textContent = kind === 'system' ? 'System-updated version' : 'User version';
        meta.textContent = summary;

        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();

        if (undoBtn) {
            undoBtn.disabled = !lastAppliedHtml;
        }
    }

    function applyVersionToEditor() {
        const applyBtn = document.getElementById('applyVersionBtn');
        if (!applyBtn) return;
        const kind = applyBtn.dataset.version || 'user';
        let html = '';

        snapshotEditor();

        if (kind === 'system') {
            html = buildSelectedSystemHtml(document.getElementById('versionModalBody'));
        } else {
            html = optimizeHtmlForPublish(auditVersions.userHtml || '', 'user');
        }

        html = sanitizeAuditHtml(html);

        if (window.contentQuill && html) {
            window.contentQuill.root.innerHTML = html;
            const textarea = document.getElementById('contentTextarea');
            if (textarea) textarea.value = html;
            showStatus('success', `${kind === 'system' ? 'System' : 'User'} version applied with formatting + SEO cleanup`);
            highlightEditor();
        } else if (html) {
            const textarea = document.getElementById('contentTextarea');
            if (textarea) {
                textarea.value = html;
                showStatus('success', `${kind === 'system' ? 'System' : 'User'} version applied with formatting + SEO cleanup`);
            }
        } else {
            showStatus('error', 'No content to apply. Run audit first.');
            return;
        }

        const modalEl = document.getElementById('versionModal');
        if (modalEl) {
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            modal.hide();
        }

        const undoBtn = document.getElementById('undoApplyBtn');
        if (undoBtn) undoBtn.disabled = !lastAppliedHtml;
    }

    function applySingleParagraph(idx) {
        const blockIndex = parseInt(idx, 10);
        if (Number.isNaN(blockIndex)) return;
        const selectedHtml = buildSingleSystemBlockHtml(blockIndex, document.getElementById('versionModalBody'));
        if (!selectedHtml) return;

        snapshotEditor();

        const existingHtml = window.contentQuill
            ? window.contentQuill.root.innerHTML
            : (document.getElementById('contentTextarea')?.value || '');
        const existingBlocks = parseAuditBlocks(existingHtml);

        if (existingBlocks[blockIndex]) {
            existingBlocks[blockIndex].html = selectedHtml;
            existingBlocks[blockIndex].text = stripHtml(selectedHtml);
        } else {
            existingBlocks.push({
                tag: 'p',
                html: selectedHtml,
                text: stripHtml(selectedHtml)
            });
        }

        const newHtml = composeBlocksHtml(existingBlocks, false);

        if (window.contentQuill) {
            window.contentQuill.root.innerHTML = newHtml;
            const textarea = document.getElementById('contentTextarea');
            if (textarea) textarea.value = newHtml;
            highlightEditor();
            showStatus('success', `Paragraph ${blockIndex + 1} applied with formatting preserved`);
        } else {
            const textarea = document.getElementById('contentTextarea');
            if (textarea) {
                textarea.value = newHtml;
                showStatus('success', `Paragraph ${blockIndex + 1} applied`);
            }
        }

        const undoBtn = document.getElementById('undoApplyBtn');
        if (undoBtn) undoBtn.disabled = !lastAppliedHtml;
    }

    function snapshotEditor() {
        if (window.contentQuill) {
            lastAppliedHtml = window.contentQuill.root.innerHTML;
        } else {
            const textarea = document.getElementById('contentTextarea');
            lastAppliedHtml = textarea?.value || '';
        }
    }

    function undoLastApply() {
        if (!lastAppliedHtml) return;
        if (window.contentQuill) {
            window.contentQuill.root.innerHTML = lastAppliedHtml;
        }
        const textarea = document.getElementById('contentTextarea');
        if (textarea) textarea.value = lastAppliedHtml;
        showStatus('info', 'Reverted to previous content');
        lastAppliedHtml = '';
        const undoBtn = document.getElementById('undoApplyBtn');
        if (undoBtn) undoBtn.disabled = true;
    }

