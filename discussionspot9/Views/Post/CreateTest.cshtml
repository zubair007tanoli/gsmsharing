                <div class="btn-group btn-group-sm mb-3" role="group">
                    <button type="button" class="btn btn-outline-secondary active" id="modalUserBtn">User version</button>
                    <button type="button" class="btn btn-outline-success" id="modalSystemBtn">System version</button>
                </div>
                <div id="versionModalBody" class="text-body"></div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <div class="text-muted small" id="versionModalMeta"></div>
                <div>
                    <button type="button" class="btn btn-outline-secondary me-2" id="undoApplyBtn" disabled>Undo last apply</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="applyVersionBtn">Use this version</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Global state
    let currentPostType = 'text';
    let selectedCommunity = null;
    let tags = [];
    let auditVersions = {
        userHtml: '',
        systemHtml: '',
        userPlain: '',
        systemPlain: '',
        userBlocks: [],
        systemBlocks: [],
        userScores: null,
        systemScores: null
    };
    let lastAppliedHtml = '';
    let humanizeTone = 'medium';
    const targetHumanScore = 90;

    // Initialize when DOM is loaded
    document.addEventListener('DOMContentLoaded', function() {
        initializeEventListeners();
        loadCommunityData();
        loadPersistedCommunitySelection();
        wireAuditButton();
        wireVersionButtons();
    });

    function initializeEventListeners() {
        // Post type tabs
        document.querySelectorAll('.post-tab').forEach(tab => {
            tab.addEventListener('click', handleTabClick);
        });

        // Community search and selection
        const communitySearch = document.getElementById('communitySearch');
        const communityDropdown = document.getElementById('communityDropdown');

        communitySearch.addEventListener('focus', () => {
            communityDropdown.style.display = 'block';
            loadCommunityDropdown();
        });

        communitySearch.addEventListener('input', handleCommunitySearch);

        // Static community items
        document.querySelectorAll('.community-item').forEach(item => {
            item.addEventListener('click', handleCommunitySelect);
        });
        wireJoinCommunityButtons();

        // Title character count
        document.getElementById('title').addEventListener('input', function(e) {
            updateCharCount(e.target, 'titleCount', 300);
        });

        // Tag input
        document.getElementById('tagInput').addEventListener('keypress', handleTagInput);

        // Poll options
        document.getElementById('addPollOption').addEventListener('click', addPollOption);

        // Form submission
        document.getElementById('submitPost').addEventListener('click', () => handleFormSubmit(false));
        document.getElementById('saveAsDraft').addEventListener('click', () => handleFormSubmit(true));

        // SEO Toggle
        document.getElementById('seoToggle').addEventListener('click', toggleSeoSection);

        // Click outside to close dropdowns
        document.addEventListener('click', handleOutsideClick);
    }

    function handleTabClick(e) {
        e.preventDefault();

        // Remove active class from all tabs
        document.querySelectorAll('.post-tab').forEach(tab => {
            tab.classList.remove('active');
        });

        // Hide all content sections
        document.querySelectorAll('.content-section').forEach(section => {
            section.classList.remove('active');
        });

        // Add active class to clicked tab
        e.currentTarget.classList.add('active');
        currentPostType = e.currentTarget.getAttribute('data-type');
        document.getElementById('postType').value = currentPostType;

        // Show corresponding content section
        const targetSection = document.getElementById(currentPostType + 'Content');
        if (targetSection) {
            targetSection.classList.add('active');
        }
    }

    function loadCommunityData() {
        // Data from server-side model
        const userCommunities = @Html.Raw(Json.Serialize(userCommunities));
        const suggestedCommunities = @Html.Raw(Json.Serialize(suggestedCommunities));

        // window.allCommunities = [...userCommunities, ...suggestedCommunities];
         window.allCommunities = [...userCommunities];
    }

    function loadPersistedCommunitySelection() {
        try {
            const stored = localStorage.getItem('selectedCommunity');
            if (stored) {
                const community = JSON.parse(stored);
                selectedCommunity = community;
                
                // Update form fields
                document.getElementById('communityId').value = community.id;
                document.getElementById('communityName').value = community.name;
                document.getElementById('communitySlug').value = community.slug;
                document.getElementById('communitySearch').value = `r/${community.title}`;
                
                // Update page title
                const pageTitle = document.querySelector('.card-header h1');
                if (pageTitle) {
                    pageTitle.textContent = `Create a Post in r/${community.title}`;
                }
                
                console.log('Restored community selection:', community.title);
            }
        } catch (ex) {
            console.warn('Failed to load persisted community selection:', ex);
        }
    }

    function loadCommunityDropdown() {
        const dropdown = document.getElementById('communityDropdown');
        const searchTerm = document.getElementById('communitySearch').value.toLowerCase();

        const filteredCommunities = window.allCommunities.filter(community =>
            community.title.toLowerCase().includes(searchTerm) ||
            community.name.toLowerCase().includes(searchTerm)
        );

        dropdown.innerHTML = '';

        if (filteredCommunities.length === 0) {
            dropdown.innerHTML = '<div style="padding: 16px; text-align: center; color: #7c7c7c;">No communities found. Please Join or Create One</div>';
            return;
        }

        filteredCommunities.forEach(community => {
            const item = document.createElement('div');
            item.className = 'community-item';
            item.setAttribute('data-community-id', community.communityId);
            item.setAttribute('data-community-name', community.name);
            item.setAttribute('data-community-slug', community.slug);
            item.setAttribute('data-community-title', community.title);

            item.innerHTML = `
                <div class="community-icon">${community.title.charAt(0).toUpperCase()}</div>
                <div class="community-info">
                    <h4>r/${community.title}</h4>
                    <p>${community.memberCount.toLocaleString()} members</p>
                </div>
            `;

            item.addEventListener('click', handleCommunitySelect);
            dropdown.appendChild(item);
        });
    }

    function handleCommunitySearch(e) {
        loadCommunityDropdown();
    }

    function handleCommunitySelect(e) {
        const communityItem = e.currentTarget;
        const communityId = communityItem.getAttribute('data-community-id');
        const communityName = communityItem.getAttribute('data-community-name');
        const communitySlug = communityItem.getAttribute('data-community-slug');
        const communityTitle = communityItem.getAttribute('data-community-title');

        selectedCommunity = {
            id: communityId,
            name: communityName,
            slug: communitySlug,
            title: communityTitle
        };

        // Update all form fields
        document.getElementById('communityId').value = communityId;
        document.getElementById('communityName').value = communityName;
        document.getElementById('communitySlug').value = communitySlug;
        document.getElementById('communitySearch').value = `r/${communityTitle}`;
        document.getElementById('communityDropdown').style.display = 'none';

        // Update the page title to show selected community
        const pageTitle = document.querySelector('.card-header h1');
        if (pageTitle) {
            pageTitle.textContent = `Create a Post in r/${communityTitle}`;
        }

        // Store in localStorage for persistence
        localStorage.setItem('selectedCommunity', JSON.stringify(selectedCommunity));

        showStatus('success', `Selected ${communityTitle}`);
    }

    function wireJoinCommunityButtons() {
        document.querySelectorAll('.join-community-btn').forEach(btn => {
            btn.addEventListener('click', async (event) => {
                event.preventDefault();
                event.stopPropagation();

                const communityId = parseInt(btn.dataset.communityId || '0', 10);
                if (!communityId) {
                    showStatus('error', 'Invalid community selected');
                    return;
                }

                if (btn.dataset.loading === '1') {
                    return;
                }

                const originalText = btn.textContent;
                btn.dataset.loading = '1';
                btn.disabled = true;
                btn.textContent = 'Joining...';

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const response = await fetch('/api/community/togglemembership', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest',
                            ...(token ? { 'RequestVerificationToken': token } : {})
                        },
                        body: JSON.stringify({ communityId })
                    });

                    const result = await response.json();
                    if (!response.ok || !result?.success) {
                        throw new Error(result?.message || 'Unable to join community right now');
                    }

                    const isMember = !!result.data;
                    btn.textContent = isMember ? 'Joined' : 'Join';
                    btn.classList.toggle('btn-secondary', !isMember);
                    btn.classList.toggle('btn-primary', isMember);
                    showStatus('success', isMember ? 'Community joined successfully' : 'Community left successfully');
                } catch (error) {
                    btn.textContent = originalText || 'Join';
                    showStatus('error', error.message || 'Failed to join community');
                } finally {
                    btn.dataset.loading = '0';
                    btn.disabled = false;
                }
            });
        });
    }

    function updateCharCount(input, counterId, maxLength) {
        const current = input.value.length;
        document.getElementById(counterId).textContent = current;

        const counter = document.getElementById(counterId);
        if (current > maxLength * 0.9) {
            counter.style.color = '#f59e0b';
        } else {
            counter.style.color = '#7c7c7c';
        }

        if (current >= maxLength) {
            counter.style.color = '#ef4444';
        }
    }

    function handleTagInput(e) {
        if (e.key === 'Enter' && e.target.value.trim() !== '') {
            e.preventDefault();

            if (tags.length < 5) {
                const tagText = e.target.value.trim();

                if (!tags.includes(tagText)) {
                    tags.push(tagText);

                    const tagElement = document.createElement('div');
                    tagElement.className = 'tag';
                    tagElement.innerHTML = `
                        ${tagText}
                        <button type="button" class="tag-remove" onclick="removeTag('${tagText}', this)">
                            <i class="fas fa-times"></i>
                        </button>
                    `;

                    const container = document.getElementById('tagContainer');
                    container.insertBefore(tagElement, e.target);
                    e.target.value = '';

                    // Update hidden input
                    document.getElementById('tagsInputHidden').value = tags.join(',');
                }
            } else {
                showStatus('error', 'Maximum 5 tags allowed');
            }
        }
    }

    function removeTag(tagText, button) {
        const index = tags.indexOf(tagText);
        if (index > -1) {
            tags.splice(index, 1);
        }
        button.parentElement.remove();
        document.getElementById('tagsInputHidden').value = tags.join(',');
    }

    function addPollOption() {
        const pollOptions = document.getElementById('pollOptions');
        const optionCount = pollOptions.children.length;

        if (optionCount < 6) {
            const newOption = document.createElement('div');
            newOption.className = 'poll-option';
            newOption.innerHTML = `
                <input type="text" class="form-input poll-option-input" name="PollOptions" placeholder="Option ${optionCount + 1}" required>
                <button type="button" class="poll-remove" onclick="removePollOption(this)">
                    <i class="fas fa-times"></i>
                </button>
            `;

            pollOptions.appendChild(newOption);
            updatePollRemoveButtons();
        } else {
            showStatus('error', 'Maximum 6 poll options allowed');
        }
    }

    function removePollOption(button) {
        const pollOptions = document.getElementById('pollOptions');
        if (pollOptions.children.length > 2) {
            button.parentElement.remove();
            updatePollRemoveButtons();
        }
    }

    function updatePollRemoveButtons() {
