@model discussionspot9.Models.ViewModels.CreativeViewModels.PostListViewModel
@using discussionspot9.Helpers
@{
    ViewData["Title"] = "All Posts - DiscussionSpot";
    var currentSort = ViewData["CurrentSort"]?.ToString() ?? "hot";
    var currentTime = ViewData["CurrentTime"]?.ToString() ?? "all";
}

<main class="container py-4">
    <div class="row">
        <div class="col-lg-8">
            <!-- Header Section -->
            <div class="card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <h1 class="h3 mb-0">All Posts</h1>
                        <div class="d-flex gap-2">
                            <!-- Sort Dropdown -->
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-sort me-1"></i>
                                    @currentSort
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item @(currentSort == "hot" ? "active" : "")" href="@Url.All("hot")">Hot</a></li>
                                    <li><a class="dropdown-item @(currentSort == "new" ? "active" : "")" href="@Url.All("new")">New</a></li>
                                    <li><a class="dropdown-item @(currentSort == "top" ? "active" : "")" href="@Url.All("top")">Top</a></li>
                                    <li><a class="dropdown-item @(currentSort == "controversial" ? "active" : "")" href="@Url.All("controversial")">Controversial</a></li>
                                </ul>
                            </div>

                            @if (currentSort == "top")
                            {
                                <!-- Time Filter -->
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        <i class="far fa-clock me-1"></i>
                                        @currentTime
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item @(currentTime == "day" ? "active" : "")" href="@Url.All("top")?time=day">Today</a></li>
                                        <li><a class="dropdown-item @(currentTime == "week" ? "active" : "")" href="@Url.All("top")?time=week">This Week</a></li>
                                        <li><a class="dropdown-item @(currentTime == "month" ? "active" : "")" href="@Url.All("top")?time=month">This Month</a></li>
                                        <li><a class="dropdown-item @(currentTime == "year" ? "active" : "")" href="@Url.All("top")?time=year">This Year</a></li>
                                        <li><a class="dropdown-item @(currentTime == "all" ? "active" : "")" href="@Url.All("top")?time=all">All Time</a></li>
                                    </ul>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Posts List -->
            <div class="posts-list">
                @if (Model.Posts.Any())
                {
                    @foreach (var post in Model.Posts)
                    {
                        <partial name="Partials/PostsPartial/_PostCard" model="post" />
                    }

                    <!-- Pagination -->
                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Page navigation" class="mt-4">
                            <ul class="pagination justify-content-center">
                                @if (Model.CurrentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.All(currentSort)?time=@currentTime&page=@(Model.CurrentPage - 1)">Previous</a>
                                    </li>
                                }

                                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.All(currentSort)?time=@currentTime&page=@i">@i</a>
                                    </li>
                                }

                                @if (Model.CurrentPage < Model.TotalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.All(currentSort)?time=@currentTime&page=@(Model.CurrentPage + 1)">Next</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                        <p class="text-muted">No posts found</p>
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="sidebar">
                <!-- Create Post -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="card mb-4">
                        <div class="card-body text-center">
                            <a href="@Url.Communities()" class="btn btn-primary w-100">
                                <i class="fas fa-plus me-2"></i>Create Post
                            </a>
                            <p class="small text-muted mt-2 mb-0">Choose a community first</p>
                        </div>
                    </div>
                }

                <!-- Trending Communities -->
                @if (Model.TrendingCommunities?.Any() == true)
                {
                    <div class="card mb-4">
                        <div class="card-header">
                            <h2 class="h5 mb-0">Trending Communities</h2>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled mb-0">
                                @foreach (var community in Model.TrendingCommunities.Take(5))
                                {
                                    <li class="mb-3">
                                        <a href="@Url.Community(community.Slug)" class="text-decoration-none">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span>r/@community.Name</span>
                                                <span class="badge bg-success">+@community.GrowthPercentage%</span>
                                            </div>
                                            <small class="text-muted">@community.MemberCount.ToString("N0") members</small>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <!-- About -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="h5 mb-0">About DiscussionSpot</h2>
                    </div>
                    <div class="card-body">
                        <p class="small mb-2">Welcome to DiscussionSpot, your premier online forum for meaningful discussions.</p>
                        <a href="/about" class="btn btn-sm btn-outline-primary w-100">Learn More</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>