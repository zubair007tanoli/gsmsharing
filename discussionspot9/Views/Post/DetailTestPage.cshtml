@using discussionspot9.Helpers
@using discussionspot9.Models.ViewModels.PollViewModels

@model discussionspot9.Models.ViewModels.CreativeViewModels.PostDetailPageViewModelCopy

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = $"{Model.Post.Title} | r/{Model.Post.CommunitySlug} | DiscussionSpot";
    
    // SEO Meta Tags
    var excerpt = Model.Post.Content != null && Model.Post.Content.Length > 155 
        ? Model.Post.Content.Substring(0, 155) + "..." 
        : Model.Post.Content ?? "Join the discussion on DiscussionSpot";
    var tags = Model.Post.Tags != null && Model.Post.Tags.Any() 
        ? string.Join(", ", Model.Post.Tags) 
        : $"{Model.Post.CommunityName}, discussion, forum";
    var postUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/r/{Model.Post.CommunitySlug}/post/{Model.Post.Slug}";
    var imageUrl = Model.Post.Media != null && Model.Post.Media.Any(m => m.MediaType == "image")
        ? Model.Post.Media.First(m => m.MediaType == "image").Url
        : $"{Context.Request.Scheme}://{Context.Request.Host}/images/default-og-image.png";
}


<!-- SEO Meta Tags -->
@section MetaTags {
    <!-- Primary Meta Tags -->
    <meta name="title" content="@ViewData["Title"]" />
    <meta name="description" content="@excerpt" />
    <meta name="keywords" content="@tags" />
    <meta name="author" content="@Model.Post.AuthorDisplayName" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="@postUrl" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content="@postUrl" />
    <meta property="og:title" content="@Model.Post.Title" />
    <meta property="og:description" content="@excerpt" />
    <meta property="og:image" content="@imageUrl" />
    <meta property="og:site_name" content="DiscussionSpot" />
    <meta property="article:published_time" content="@Model.Post.CreatedAt.ToString("o")" />
    <meta property="article:author" content="@Model.Post.AuthorDisplayName" />
    <meta property="article:section" content="@Model.Post.CommunityName" />
    @if (Model.Post.Tags != null && Model.Post.Tags.Any())
    {
        foreach (var tag in Model.Post.Tags)
        {
            <meta property="article:tag" content="@tag" />
        }
    }
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="@postUrl" />
    <meta name="twitter:title" content="@Model.Post.Title" />
    <meta name="twitter:description" content="@excerpt" />
    <meta name="twitter:image" content="@imageUrl" />
    <meta name="twitter:creator" content="@@@Model.Post.AuthorDisplayName" />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "DiscussionForumPosting",
        "@@id": "@postUrl",
        "headline": "@Model.Post.Title",
        "description": "@excerpt",
        "author": {
            "@@type": "Person",
            "name": "@Model.Post.AuthorDisplayName",
            "url": "@Model.Post.AuthorUrl"
        },
        "datePublished": "@Model.Post.CreatedAt.ToString("o")",
        "dateModified": "@Model.Post.UpdatedAt.ToString("o")",
        "interactionStatistic": [
            {
                "@@type": "InteractionCounter",
                "interactionType": "https://schema.org/CommentAction",
                "userInteractionCount": @Model.Post.CommentCount
            },
            {
                "@@type": "InteractionCounter",
                "interactionType": "https://schema.org/LikeAction",
                "userInteractionCount": @Model.Post.UpvoteCount
            }
        ],
        "image": "@imageUrl",
        "url": "@postUrl",
        "discussionUrl": "@postUrl",
        "articleSection": "@Model.Post.CommunityName",
        "keywords": "@tags"
    }
    </script>
}

<!-- # Java Scripts -->
@section HeadScripts {
    <link href="~/css/detail-test-page.css" rel="stylesheet" />
    <link href="~/css/link-preview.css" rel="stylesheet" />
    <!-- Quill Editor CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
    <!-- Quill Mention CSS for @@ mentions -->
    <link href="https://cdn.jsdelivr.net/npm/quill-mention@4.0.0/dist/quill.mention.min.css" rel="stylesheet" />
    <style>
        /* Ensure reply forms are hidden by default */
        .reply-form {
            display: none;
            margin-top: 1rem;
        }
        
        .reply-form:not(.d-none) {
            display: block;
        }
        
        /* Theme toggle support */
        [data-theme="dark"] .detail-test-page {
            background-color: var(--bg-secondary);
        }
        
        [data-theme="light"] .detail-test-page {
            background-color: var(--bg-secondary);
        }

        /* Link preview improvements */
        .link-preview-card {
            border: 1px solid #e9ecef;
            overflow: hidden;
        }
        .link-preview-image-wrapper {
            background: #f8f9fa;
        }
        .link-preview-img {
            object-fit: cover;
            width: 100%;
            height: 100%;
        }
        .clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
}

<!-- #endregion -->

<div class="detail-test-page">
    <div class="container-fluid" style="max-width: 1400px; padding: 20px;">
        <div class="row g-4">
            <!-- Left Sidebar - Hidden on mobile/tablet -->
            <div class="col-xl-3 col-lg-3 d-none d-lg-block left-sidebar">
                <!-- Trending Topics and Latest News -->
                @await Component.InvokeAsync("LeftSideBar")
            </div>

            <!-- Main Content Column - Full width on mobile -->
            <div class="col-xl-6 col-lg-9 col-md-12 col-sm-12">
              
                <input type="hidden" id="pagePostId" value="@Model.Post.PostId" />
                <input type="hidden" id="isAuthenticated" value="@User.Identity.IsAuthenticated.ToString().ToLower()" />

                <!-- Post Container -->
                <div class="post-container">
                    <div class="post-header">
                        <div class="post-meta">
                            @* Assuming AuthorInitials and ToAvatarColor are C# extension methods/helpers *@
                            <div class="user-avatar small" style="background-color:@(Model.Post.AuthorDisplayName.ToAvatarColor());">@Model.Post.AuthorInitials</div>
                            <a href="@(Model.Post.Url ?? $"https://discussionspot.com/r/{Model.CommunitySlug}")">r/@Model.Post.CommunitySlug</a>
                            <span>•</span>
                            <span>Posted by <a href="@Model.Post.AuthorUrl">u/@Model.Post.AuthorDisplayName</a></span>
                            <span>•</span>
                            @* Assuming ToTimeAgo is a C# extension method/helper *@
                            <span>@Html.TimeAgo(Model.Post.CreatedAt)</span>
                        </div>
                        <h1 class="post-title">@Model.Post.Title</h1>
                        <div class="d-flex flex-wrap gap-2" style="max-width: 100%; margin-top: 0.75rem;">
                            @foreach (var tag in Model.Post.Tags)
                            {
                                <span class="badge bg-primary post-tag-badge">@tag</span>
                            }
                            @* Category name can also be displayed, assuming it's part of the community or directly on the post *@
                            <span class="badge bg-secondary post-tag-badge">@Model.Post.CommunityName</span>
                        </div>
                    </div>

                    <div class="post-content">
                        @* Render Text Content if present *@
                        @if (!string.IsNullOrWhiteSpace(Model.Post.Content))
                        {
                            <div class="post-text" id="postContent">
                                @Html.Raw(Model.Post.Content) @* Use Html.Raw if your content contains HTML markup from a rich text editor *@
                            </div>
                        }

                        @* Render Image Gallery if images are present in Media list *@
                        @if (Model.Post.Media != null && Model.Post.Media.Any(m => m.MediaType == "image"))
                        {
                            <div class="image-gallery">
                                <h5>Image Gallery</h5>
                                <div class="gallery-container">
                                    @foreach (var mediaItem in Model.Post.Media.Where(m => m.MediaType == "image"))
                                    {
                                        <div class="gallery-item">
                                            <img src="@mediaItem.Url" alt="@mediaItem.Caption">
                                        </div>
                                    }
                                </div>
                                @if (Model.Post.Media.Any(m => !string.IsNullOrEmpty(m.Caption)))
                                {
                                    <div class="image-caption">Images: @string.Join(", ", Model.Post.Media.Where(m => m.MediaType == "image" && !string.IsNullOrEmpty(m.Caption)).Select(m => m.Caption))</div>
                                }
                            </div>
                        }

                        @* Render Video Embed if videos are present in Media list or Model.Url is a video link *@
                        @if (Model.Post.Media != null && Model.Post.Media.Any(m => m.MediaType == "video"))
                        {
                            @foreach (var videoItem in Model.Post.Media.Where(m => m.MediaType == "video"))
                            {
                                <div class="video-embed">
                                    <h5>Video Demonstration</h5>
                                    <div class="video-container">
                                        <div class="video-overlay" id="videoOverlay-@videoItem.MediaId">
                                            @* Unique ID for each video overlay *@
                                            <div class="play-button">
                                                <i class="fas fa-play"></i>
                                            </div>
                                        </div>
                                        <img src="@(videoItem.ThumbnailUrl ?? "https://placehold.co/800x450/cccccc/333333?text=Video+Thumbnail")" alt="Video Thumbnail" style="width:100%">
                                        @* The actual video iframe/embed will be loaded by JS after clicking overlay *@
                                        <input type="hidden" id="videoSource-@videoItem.MediaId" value="@videoItem.Url" />
                                    </div>
                                </div>
                            }
                        }

                        @* Render Link Preview if link data is present *@
                        @if (!string.IsNullOrWhiteSpace(Model.Post.Url) && !string.IsNullOrWhiteSpace(Model.Post.Url))
                        {
                            <div class="card link-preview-card mb-4">
                                <a href="@Model.Post.Url" class="text-decoration-none text-reset" target="_blank" rel="noopener noreferrer">
                                    <div class="row g-0">
                                        <div class="col-md-4">
                                            <div class="ratio ratio-16x9 link-preview-image-wrapper">
                                                <img src="@(Model.Post.LinkModel.ThumbnailUrl ?? "https://placehold.co/800x450/cccccc/333333?text=Link+Preview")" class="img-fluid rounded-start link-preview-img" alt="Link Thumbnail">
                                            </div>
                                        </div>
                                        <div class="col-md-8">
                                            <div class="card-body">
                                                <h5 class="card-title text-truncate">@Model.Post.LinkModel.Title</h5>
                                                <p class="card-text text-muted mb-2 clamp-2">@Model.Post.LinkModel.Description</p>
                                                <div class="small text-muted text-truncate">
                                                    <i class="fas fa-link me-1"></i>
                                                    <span>@Model.Post.LinkModel.Url</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }

                        <!-- DetailTestPage.cshtml -->
                        @if (Model.Post.HasPoll && Model.Post.Poll != null)
                        {
                            @* @await Html.PartialAsync("Partials/V1/_PostPoll", Model.Post.Poll) *@
                            @await Component.InvokeAsync("Poll", new { postId = Model.Post.PostId })
                        }
                    </div>

                    <div class="post-actions">
             @* <div class="vote-buttons">                          
                            <button class="vote-btn upvote @(Model.Post.CurrentUserVote == 1 ? "active" : "")" id="upvoteBtn-@Model.Post.PostId" data-post-id="@Model.Post.PostId" data-vote-type="1">
                                <i class="fas fa-arrow-up"></i>
                            </button>
                            <span class="vote-count" id="voteCount-@Model.Post.PostId">@Model.Post.Score</span>
                            <button class="vote-btn downvote @(Model.Post.CurrentUserVote == -1 ? "active" : "")" id="downvoteBtn-@Model.Post.PostId" data-post-id="@Model.Post.PostId" data-vote-type="-1">
                                <i class="fas fa-arrow-down"></i>
                            </button>                            
                        </div> *@
                        <div class="vote-buttons">
                            <button class="vote-btn upvote @(Model.Post.CurrentUserVote == 1 ? "active" : "")"
                                    id="upvoteBtn-@Model.Post.PostId"
                                    data-post-id="@Model.Post.PostId"
                                    data-vote-type="1"
                                    title="Upvote">
                                <i class="fas fa-arrow-up"></i>
                            </button>
                            <div class="vote-counts-display">
                                <span class="upvote-number" id="upvoteCount-@Model.Post.PostId">@Model.Post.UpvoteCount</span>
                                <span class="vote-separator">•</span>
                                <span class="downvote-number" id="downvoteCount-@Model.Post.PostId">@Model.Post.DownvoteCount</span>
                            </div>
                            <button class="vote-btn downvote @(Model.Post.CurrentUserVote == -1 ? "active" : "")"
                                    id="downvoteBtn-@Model.Post.PostId"
                                    data-post-id="@Model.Post.PostId"
                                    data-vote-type="-1"
                                    title="Downvote">
                                <i class="fas fa-arrow-down"></i>
                            </button>
                        </div>
                      @* <div class="vote-buttons">
                            <button class="vote-btn upvote @(Model.Post.CurrentUserVote == 1 ? "active" : "")"
                                    id="upvoteBtn-@Model.Post.PostId"
                                    data-post-id="@Model.Post.PostId"
                                    data-vote-type="1">
                                <i class="fas fa-arrow-up"></i>
                            </button>
                            <span class="upvote-count" id="upvoteCount-@Model.Post.PostId">@Model.Post.UpvoteCount</span>
                            <span class="downvote-count" id="downvoteCount-@Model.Post.PostId">@Model.Post.DownvoteCount</span>
                            <!-- Optional: You can keep a net score if desired, or remove it if only up/down counts are needed -->
                            <span class="total-score" id="totalScore-@Model.Post.PostId">@Model.Post.Score</span>
                            <button class="vote-btn downvote @(Model.Post.CurrentUserVote == -1 ? "active" : "")"
                                    id="downvoteBtn-@Model.Post.PostId"
                                    data-post-id="@Model.Post.PostId"
                                    data-vote-type="-1">
                                <i class="fas fa-arrow-down"></i>
                            </button>
                        </div> *@
                        <div class="action-buttons ms-auto">
                            <button class="action-btn">
                                <i class="fas fa-comment"></i>
                                <span>Comments (@Model.Post.CommentCount)</span>
                            </button>
                            @await Html.PartialAsync("_ShareButtonsUnified", new ViewDataDictionary(ViewData) {
                                { "ShareTitle", Model.Post.Title },
                                { "ShareDescription", excerpt },
                                { "ShareUrl", postUrl },
                                { "ShareImage", imageUrl },
                                { "ShareType", "post" },
                                { "ContentId", Model.Post.PostId.ToString() },
                                { "ShareVariant", "simple" }
                            })
                            <button class="action-btn" id="saveBtn-@Model.Post.PostId" data-post-id="@Model.Post.PostId" data-issaved="@Model.Post.IsSavedByUser.ToString().ToLower()">
                                <i class="fas fa-bookmark @(Model.Post.IsSavedByUser ? "text-primary" : "")"></i>
                                <span>@(Model.Post.IsSavedByUser ? "Saved" : "Save")</span>
                            </button>
                            <button class="action-btn">
                                <i class="fas fa-flag"></i>
                                <span>Report</span>
                            </button>
                        </div>
                    </div>
                </div>
                <!-- Toast container for notifications -->
                <div id="toast-container" class="position-fixed top-0 end-0 p-3" style="z-index: 1055;"></div>

                <!-- Main Comment Form -->
                <div class="main-comment-form">
                    <h3>Add a Comment</h3>
                    <div class="d-flex gap-3 mb-3 align-items-start">
                        @* User avatar *@
                        <div class="user-avatar" style="background-color: @(User.Identity?.IsAuthenticated == true ? (User.Identity.Name ?? "Anonymous").ToAvatarColor() : "gray")">
                            @(User.Identity?.IsAuthenticated == true ? (User.Identity.Name ?? "Anonymous").ToInitials() : "U")
                        </div>

                        <div class="flex-grow-1">
                            <!-- Typing indicators -->
                            <div id="typing-indicators" class="mb-2"></div>

                            <!-- Quill Editor Container -->
                            <div class="comment-editor-container">
                                <div id="mainCommentEditor"></div>
                            </div>
                            <!-- Hidden textarea to store HTML content -->
                            <textarea id="mainCommentContent" style="display: none;"></textarea>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-secondary" id="clearMainComment">Clear</button>
                        <button class="btn btn-primary" id="submitMainComment" data-post-id="@Model.Post.PostId">
                            <i class="fas fa-paper-plane me-1"></i>Comment
                        </button>
                    </div>
                </div>
           
                <!-- Comment Section - Render as a ViewComponent -->
                @await Component.InvokeAsync("CommentList", new { postId = Model.Post.PostId })
            </div>

            <!-- Right Sidebar - Hidden on mobile/tablet, shown on xl screens -->
            <div class="col-xl-3 d-none d-xl-block right-sidebar">
                @* Render Community Info View Component with actual data *@
                @await Component.InvokeAsync("CommunityInfo", new { community = Model.Community })

                @* Render Right Sidebar with dynamic data *@
                @await Component.InvokeAsync("RightSidebar", new { currentPostId = Model.Post.PostId, communitySlug = Model.Post.CommunitySlug })
            </div> <!-- Closes right-sidebar -->
        </div> <!-- Closes row -->
    </div> <!-- Closes container-fluid -->
</div> <!-- Closes post-detail-page -->

@* Include Login Prompt Modal *@
<partial name="Partials/_LoginPromptModal" />

@section Scripts {
    <!-- Include SignalR and your script -->
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <!-- Quill Editor JS -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <!-- Quill Mention JS for @@ mentions -->
    <script src="https://cdn.jsdelivr.net/npm/quill-mention@4.0.0/dist/quill.mention.min.js"></script>
    <script src="~/js/SignalR_Script/Post_Script_Real_Time_Fix.js"></script>
    
    <script>
        // Initialize Quill editor after DOM is loaded
        document.addEventListener('DOMContentLoaded', function() {
            // Clean up post content formatting
            const postContent = document.getElementById('postContent');
            if (postContent) {
                // Remove empty paragraphs and excessive line breaks
                const paragraphs = postContent.querySelectorAll('p');
                paragraphs.forEach(p => {
                    const text = p.textContent.trim();
                    if (!text || text === '') {
                        p.remove();
                    }
                });
                
                // Remove excessive line breaks
                const content = postContent.innerHTML;
                const cleanedContent = content
                    .replace(/<br\s*\/?>\s*<br\s*\/?>/gi, '<br>') // Replace multiple <br> with single
                    .replace(/<p>\s*<\/p>/gi, '') // Remove empty paragraphs
                    .replace(/<p>\s*<br\s*\/?>\s*<\/p>/gi, '') // Remove paragraphs with only <br>
                    .replace(/\s+/g, ' ') // Replace multiple spaces with single space
                    .trim();
                
                postContent.innerHTML = cleanedContent;
            }
            
            // Position share dropdown correctly
            const shareDropdown = document.querySelector('.share-dropdown');
            if (shareDropdown) {
                const shareBtn = shareDropdown.querySelector('.action-btn');
                const shareMenu = shareDropdown.querySelector('.share-dropdown-menu');
                
                if (shareBtn && shareMenu) {
                    shareDropdown.addEventListener('mouseenter', function() {
                        const btnRect = shareBtn.getBoundingClientRect();
                        shareMenu.style.top = (btnRect.bottom + 8) + 'px';
                        shareMenu.style.left = (btnRect.left - (shareMenu.offsetWidth / 2) + (btnRect.width / 2)) + 'px';
                    });
                }
            }
            // Configure Quill with toolbar options
            const toolbarOptions = [
                ['bold', 'italic', 'underline', 'strike'],        // toggled buttons
                ['blockquote', 'code-block', 'link'],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                [{ 'header': [1, 2, 3, false] }],
                ['clean']                                         // remove formatting button
            ];

            // ============================================
            // @@ MENTION CONFIGURATION
            // ============================================
            // Get unique commenters from the page (only users who commented on this post)
            function getCommentersFromPage() {
                const commenters = new Map(); // Use Map to avoid duplicates
                
                // Find all comment authors on the page
                const commentAuthors = document.querySelectorAll('.comment-author');
                
                commentAuthors.forEach(authorEl => {
                    const authorName = authorEl.textContent.trim();
                    const avatar = authorEl.previousElementSibling; // Get the avatar element
                    const initials = avatar?.textContent.trim() || authorName.substring(0, 2).toUpperCase();
                    
                    if (authorName && !commenters.has(authorName)) {
                        commenters.set(authorName, {
                            id: authorName.toLowerCase().replace(/\s+/g, '_'),
                            value: authorName,
                            displayName: authorName,
                            initials: initials
                        });
                    }
                });
                
                return Array.from(commenters.values());
            }

            const mentionModule = {
                allowedChars: /^[A-Za-z0-9_\-\sÀ-ÖØ-öø-ÿ]*$/,
                mentionDenotationChars: [String.fromCharCode(64)], // @@ symbol (ASCII 64)
                source: function(searchTerm, renderList, mentionChar) {
                    console.log('🔍 Searching commenters for:', searchTerm);
                    
                    // Get all commenters from the page
                    const allCommenters = getCommentersFromPage();
                    console.log('📋 All commenters:', allCommenters);
                    
                    if (searchTerm.length === 0) {
                        // Show all commenters if no search term
                        renderList(allCommenters.slice(0, 10), searchTerm);
                        return;
                    }

                    // Filter commenters by search term
                    const searchLower = searchTerm.toLowerCase();
                    const filtered = allCommenters.filter(user => 
                        user.displayName.toLowerCase().includes(searchLower) ||
                        user.value.toLowerCase().includes(searchLower)
                    );
                    
                    console.log('✅ Found commenters:', filtered);
                    renderList(filtered.slice(0, 10), searchTerm);
                },
                renderItem: function(item, searchTerm) {
                    const atSymbol = String.fromCharCode(64);
                    return `<div class="mention-item"><div class="mention-avatar" style="background-color: #4f46e5;">${item.initials}</div><div class="mention-info"><div class="mention-name">${item.displayName}</div><div class="mention-username">${atSymbol}${item.value}</div></div></div>`;
                },
                onSelect: function(item, insertItem) {
                    console.log('✅ User selected:', item);
                    insertItem(item);
                }
            };

            // Initialize the main comment editor with @@ mention
            window.mainCommentQuill = new Quill('#mainCommentEditor', {
                theme: 'snow',
                modules: {
                    toolbar: toolbarOptions,
                    mention: mentionModule
                },
                placeholder: 'What are your thoughts? Use @@ to mention users...'
            });

            // Clear button functionality
            const clearBtn = document.getElementById('clearMainComment');
            if (clearBtn) {
                clearBtn.addEventListener('click', function() {
                    window.mainCommentQuill.setText('');
                });
            }

            // Update hidden textarea when editor content changes
            window.mainCommentQuill.on('text-change', function() {
                const content = window.mainCommentQuill.root.innerHTML;
                document.getElementById('mainCommentContent').value = content;
            });
            
            // NOTE: Poll voting is handled by Post_Script_Real_Time_Fix.js via SignalR
            // The castPollVote method in that script handles all poll interactions
            
            // Handle save button click
            const saveBtn = document.getElementById('saveBtn-@Model.Post.PostId');
            if (saveBtn) {
                saveBtn.addEventListener('click', async function() {
                    const postId = this.getAttribute('data-post-id');
                    const isCurrentlySaved = this.getAttribute('data-issaved') === 'true';
                    
                    try {
                        const response = await fetch('/Post/ToggleSave', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                            },
                            body: JSON.stringify({ postId: parseInt(postId) })
                        });
                        
                        const result = await response.json();
                        
                        if (result.success) {
                            // Update button state
                            const icon = this.querySelector('i');
                            const text = this.querySelector('span');
                            
                            if (result.isSaved) {
                                icon.classList.add('text-primary');
                                text.textContent = 'Saved';
                                this.setAttribute('data-issaved', 'true');
                            } else {
                                icon.classList.remove('text-primary');
                                text.textContent = 'Save';
                                this.setAttribute('data-issaved', 'false');
                            }
                            
                            // Show success message
                            showToast('success', result.isSaved ? 'Post saved!' : 'Post unsaved!');
                        } else {
                            showToast('error', result.message || 'Failed to save post');
                        }
                    } catch (error) {
                        console.error('Error saving post:', error);
                        showToast('error', 'An error occurred while saving the post');
                    }
                });
            }
            
            // Toast notification function
            function showToast(type, message) {
                const toastContainer = document.getElementById('toast-container');
                if (!toastContainer) return;
                
                const toast = document.createElement('div');
                toast.className = `toast align-items-center text-white bg-${type === 'success' ? 'success' : 'danger'} border-0`;
                toast.setAttribute('role', 'alert');
                toast.innerHTML = `
                    <div class="d-flex">
                        <div class="toast-body">${message}</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                `;
                
                toastContainer.appendChild(toast);
                
                const bsToast = new bootstrap.Toast(toast);
                bsToast.show();
                
                // Remove toast element after it's hidden
                toast.addEventListener('hidden.bs.toast', () => {
                    toast.remove();
                });
            }
        });

        // ============================================
        // COMMENT SORTING
        // ============================================
        document.addEventListener('DOMContentLoaded', function() {
            const sortBtn = document.getElementById('commentSortBtn');
            const sortMenu = document.getElementById('sortDropdownMenu');
            const currentSortText = document.getElementById('currentSort');
            const sortOptions = document.querySelectorAll('.sort-option');
            const commentList = document.querySelector('.comment-list');

            if (!sortBtn || !sortMenu) return;

            // Toggle dropdown
            sortBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                sortMenu.classList.toggle('show');
                sortBtn.classList.toggle('active');
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (!sortBtn.contains(e.target) && !sortMenu.contains(e.target)) {
                    sortMenu.classList.remove('show');
                    sortBtn.classList.remove('active');
                }
            });

            // Handle sort option click
            sortOptions.forEach(option => {
                option.addEventListener('click', function(e) {
                    e.preventDefault();
                    const sortType = this.dataset.sort;
                    const sortLabel = this.textContent.trim();
                    
                    console.log('Sorting comments by:', sortType);
                    currentSortText.textContent = sortLabel;
                    
                    // Sort comments
                    sortComments(sortType);
                    
                    // Close dropdown
                    sortMenu.classList.remove('show');
                    sortBtn.classList.remove('active');
                });
            });

            function sortComments(sortType) {
                if (!commentList) return;

                const comments = Array.from(commentList.children);
                
                comments.sort((a, b) => {
                    const aVoteCount = parseInt(a.querySelector('.comment-vote-count')?.textContent || '0');
                    const bVoteCount = parseInt(b.querySelector('.comment-vote-count')?.textContent || '0');
                    const aUpvotes = parseInt(a.querySelector('.comment-upvote-number')?.textContent || '0');
                    const bUpvotes = parseInt(b.querySelector('.comment-upvote-number')?.textContent || '0');
                    const aTime = new Date(a.querySelector('.comment-time')?.getAttribute('data-time') || 0);
                    const bTime = new Date(b.querySelector('.comment-time')?.getAttribute('data-time') || 0);

                    switch(sortType) {
                        case 'best':
                            // Best = highest upvotes
                            return bUpvotes - aUpvotes;
                        case 'top':
                            // Top = highest net score
                            return bVoteCount - aVoteCount;
                        case 'new':
                            // New = most recent first
                            return bTime - aTime;
                        case 'old':
                            // Old = oldest first
                            return aTime - bTime;
                        default:
                            return 0;
                    }
                });

                // Re-append sorted comments
                comments.forEach(comment => commentList.appendChild(comment));
                
                console.log(`✅ Comments sorted by ${sortType}`);
            }
        });
    </script>
