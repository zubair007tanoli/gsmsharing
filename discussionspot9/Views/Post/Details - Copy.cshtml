@model discussionspot9.Models.ViewModels.CreativeViewModels.PostDetailPageViewModel
@using discussionspot9.Helpers
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    ViewData["Title"] = $"{Model.Post.Title} - DiscussionSpot";
}

<main class="container py-4">
    <div class="row">
        <div class="col-lg-8">
            <!-- Post Card -->
            <article class="card post-detail mb-4">
                <div class="card-body">
                    <!-- Post Header -->
                    <div class="post-header mb-3">
                        <div class="d-flex align-items-center mb-2">
                            <a href="@Url.Community(Model.Post.CommunitySlug)" class="text-decoration-none me-2">
                                <span class="badge bg-primary">r/@Model.Post.CommunityName</span>
                            </a>
                            <span class="text-muted small">
                                Posted by
                                <a href="@Model.Post.AuthorUrl" class="text-decoration-none">u/@Model.Post.AuthorDisplayName</a>
                                <span>@Model.Post.TimeAgo</span>
                            </span>
                        </div>

                        <!-- Awards Display -->
                        @if (Model.Post.Awards?.Any() == true)
                        {
                            <div class="post-awards mb-2">
                                @foreach (var award in Model.Post.Awards.GroupBy(a => a.AwardId))
                                {
                                    <span class="award-badge" data-bs-toggle="tooltip" title="@award.First().AwardName">
                                        <img src="@award.First().IconUrl" alt="@award.First().AwardName" height="24" />
                                        @if (award.Count() > 1)
                                        {
                                            <span class="award-count">@award.Count()</span>
                                        }
                                    </span>
                                }
                            </div>
                        }

                        <h1 class="h3">@Model.Post.Title</h1>

                        @if (Model.Post.Tags.Any())
                        {
                            <div class="post-tags mt-2">
                                @foreach (var tag in Model.Post.Tags)
                                {
                                    <span class="badge bg-light text-dark me-1">@tag</span>
                                }
                            </div>
                        }
                    </div>

                    <!-- Post Content Based on Type -->
                    <div class="post-content mb-4">
                        @switch (Model.Post.PostType)
                        {
                            case "text":
                                @Html.Raw(Model.Post.Content)
                                break;

                            case "link":
                                <div class="link-preview-card mb-3">
                                    <a href="@Model.Post.Url" target="_blank" class="d-flex text-decoration-none">
                                        @if (!string.IsNullOrEmpty(Model.Post.LinkPreviewImage))
                                        {
                                            <img src="@Model.Post.LinkPreviewImage" alt="Preview" class="link-preview-image" />
                                        }
                                        <div class="link-preview-content">
                                            <h6>@(Model.Post.PostUrl ?? Model.Post.Url)</h6>
                                            @if (!string.IsNullOrEmpty(Model.Post.LinkPreviewDescription))
                                            {
                                                <p class="text-muted small">@Model.Post.LinkPreviewDescription</p>
                                            }
                                            <span class="link-domain">@Model.Post.LinkDomain</span>
                                        </div>
                                    </a>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.Post.Content))
                                {
                                    @Html.Raw(Model.Post.Content)
                                }
                                break;

                            case "image":
                                @if (Model.Post.Media?.Any() == true)
                                {
                                    <div class="post-images @(Model.Post.Media.Count > 1 ? "image-gallery" : "")">
                                        @foreach (var media in Model.Post.Media.Where(m => m.MediaType == "image"))
                                        {
                                            <div class="image-container">
                                                <img src="@media.Url" alt="@media.Caption" class="img-fluid mb-3"
                                                     data-bs-toggle="modal" data-bs-target="#imageModal"
                                                     data-image-url="@media.Url" />
                                                @if (!string.IsNullOrEmpty(media.Caption))
                                                {
                                                    <p class="image-caption text-muted small">@media.Caption</p>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(Model.Post.Content))
                                {
                                    @Html.Raw(Model.Post.Content)
                                }
                                break;

                            case "poll":
                                @if (Model.Post.Poll != null)
                                {
                                    <div class="poll-container mb-3" data-post-id="@Model.Post.PostId">
                                        <form id="pollForm">
                                            @foreach (var option in Model.Post.Poll.Options)
                                            {
                                                <div class="poll-option mb-2">
                                                    <div class="d-flex align-items-center">
                                                        @if (Model.Post.Poll.AllowMultipleChoices)
                                                        {
                                                            <input type="checkbox" class="form-check-input me-2"
                                                                   name="pollOptions" value="@option.PollOptionId"
                                                                   @(option.IsUserSelection ? "checked" : "")
                                                                   @(Model.Post.Poll.HasUserVoted ? "disabled" : "") />
                                                        }
                                                        else
                                                        {
                                                            <input type="radio" class="form-check-input me-2"
                                                                   name="pollOption" value="@option.PollOptionId"
                                                                   @(option.IsUserSelection ? "checked" : "")
                                                                   @(Model.Post.Poll.HasUserVoted ? "disabled" : "") />
                                                        }
                                                        <label class="flex-grow-1">@option.OptionText</label>
                                                        @if (Model.Post.Poll.ShowResultsBeforeVoting || Model.Post.Poll.HasUserVoted)
                                                        {
                                                            <span class="poll-votes">@option.VoteCount votes (@option.VotePercentage%)</span>
                                                        }
                                                    </div>
                                                    @if (Model.Post.Poll.ShowResultsBeforeVoting || Model.Post.Poll.HasUserVoted)
                                                    {
                                                        <div class="progress mt-1" style="height: 20px;">
                                                            <div class="progress-bar" style="width: @option.VotePercentage%">
                                                                @option.VotePercentage%
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            @if (!Model.Post.Poll.HasUserVoted && SignInManager.IsSignedIn(User))
                                            {
                                                <button type="submit" class="btn btn-primary mt-3">Vote</button>
                                            }
                                            @if (Model.Post.Poll.EndDate.HasValue)
                                            {
                                                <p class="text-muted small mt-2">
                                                    Poll ends @Model.Post.Poll.EndDate.Value.ToString("MMM dd, yyyy")
                                                </p>
                                            }
                                        </form>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(Model.Post.Content))
                                {
                                    @Html.Raw(Model.Post.Content)
                                }
                                break;
                        }
                    </div>

                    <!-- Post Actions -->
                    <div class="post-actions d-flex align-items-center gap-3 border-top pt-3">
                        <div class="vote-buttons d-flex align-items-center gap-2">
                            <button class="btn btn-sm btn-outline-secondary vote-btn upvote @(Model.Post.CurrentUserVote == 1 ? "active" : "")"
                                    data-post-id="@Model.Post.PostId" data-vote-type="1">
                                <i class="fas fa-arrow-up"></i>
                            </button>
                            <span class="vote-count fw-bold">@Model.Post.Score</span>
                            <button class="btn btn-sm btn-outline-secondary vote-btn downvote @(Model.Post.CurrentUserVote == -1 ? "active" : "")"
                                    data-post-id="@Model.Post.PostId" data-vote-type="-1">
                                <i class="fas fa-arrow-down"></i>
                            </button>
                        </div>

                        <button class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-comment me-1"></i> @Model.Post.FormattedCommentCount Comments
                        </button>

                        <button class="btn btn-sm btn-outline-secondary award-btn" data-bs-toggle="modal" data-bs-target="#awardModal">
                            <i class="fas fa-award me-1"></i> Award
                        </button>

                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="fas fa-share me-1"></i> Share
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item share-btn" href="#" data-platform="copy"><i class="fas fa-link me-2"></i>Copy Link</a></li>
                                <li><a class="dropdown-item share-btn" href="#" data-platform="facebook"><i class="fab fa-facebook me-2"></i>Facebook</a></li>
                                <li><a class="dropdown-item share-btn" href="#" data-platform="twitter"><i class="fab fa-twitter me-2"></i>Twitter</a></li>
                                <li><a class="dropdown-item share-btn" href="#" data-platform="reddit"><i class="fab fa-reddit me-2"></i>Reddit</a></li>
                            </ul>
                        </div>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <button class="btn btn-sm btn-outline-secondary save-btn @(Model.Post.IsSavedByUser ? "saved" : "")"
                                    data-post-id="@Model.Post.PostId">
                                <i class="@(Model.Post.IsSavedByUser ? "fas" : "far") fa-bookmark me-1"></i>
                                @(Model.Post.IsSavedByUser ? "Saved" : "Save")
                            </button>
                        }

                        @if (Model.Post.IsCurrentUserAuthor)
                        {
                            <div class="ms-auto">
                                <a href="#" class="btn btn-sm btn-outline-secondary me-1">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <form asp-action="Delete" asp-controller="Post" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="postId" value="@Model.Post.PostId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this post?')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </article>

            <!-- Comments Section (unchanged) -->
            <!-- ... existing comments code ... -->
        </div>

        <!-- Sidebar (unchanged) -->
        <!-- ... existing sidebar code ... -->
    </div>
</main>

<!-- Award Modal -->
<div class="modal fade" id="awardModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Give Award</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Award selection will be loaded here via AJAX -->
            </div>
        </div>
    </div>
</div>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body p-0">
                <img src="" class="img-fluid w-100" id="modalImage" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/CustomJs/Post_Detail.js"></script>
    <script>
        // Poll voting
        document.getElementById('pollForm')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const postId = @Model.Post.PostId;
            const optionIds = [...document.querySelectorAll('input[name="pollOptions"]:checked, input[name="pollOption"]:checked')]
                .map(input => parseInt(input.value));

            const response = await fetch('/Post/VotePoll', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ postId, optionIds })
            });

            const result = await response.json();
            if (result.success) location.reload();
        });

        // Save post
        document.querySelector('.save-btn')?.addEventListener('click', async function() {
            const postId = this.dataset.postId;
            const response = await fetch('/Post/ToggleSave', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ postId })
            });

            const result = await response.json();
            if (result.success) {
                this.classList.toggle('saved');
                const icon = this.querySelector('i');
                icon.classList.toggle('fas');
                icon.classList.toggle('far');
                this.innerHTML = `<i class="${icon.className} me-1"></i>${result.isSaved ? 'Saved' : 'Save'}`;
            }
        });

        // Image modal
        document.querySelectorAll('[data-bs-target="#imageModal"]').forEach(img => {
            img.addEventListener('click', function() {
                document.getElementById('modalImage').src = this.dataset.imageUrl;
            });
        });
    </script>
}