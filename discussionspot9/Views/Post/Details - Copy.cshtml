@model discussionspot9.Models.ViewModels.CreativeViewModels.PostDetailPageViewModelCopy
@using discussionspot9.Helpers
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    ViewData["Title"] = $"{Model.Post.Title} - DiscussionSpot";
}


<main class="container-fluid py-4">
    <div class="row">
        <!-- Left Sidebar - Ads -->
        <div class="col-lg-2 col-md-3 d-none d-md-block">
            <div class="sticky-ad">
                <!-- Vertical Banner Ad -->
                <div class="ad-container mb-3">
                    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-YOUR_PUBLISHER_ID"
                            crossorigin="anonymous"></script>
                    <!-- Vertical Banner -->
                    <ins class="adsbygoogle"
                         style="display:block"
                         data-ad-client="ca-pub-YOUR_PUBLISHER_ID"
                         data-ad-slot="YOUR_AD_SLOT_ID"
                         data-ad-format="auto"
                         data-full-width-responsive="true"></ins>
                    <script>
                        (adsbygoogle = window.adsbygoogle || []).push({});
                    </script>
                </div>
                
                <!-- Square Ad -->
                <div class="ad-container mb-3">
                    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-YOUR_PUBLISHER_ID"
                            crossorigin="anonymous"></script>
                    <!-- Square Ad -->
                    <ins class="adsbygoogle"
                         style="display:block"
                         data-ad-client="ca-pub-YOUR_PUBLISHER_ID"
                         data-ad-slot="YOUR_SQUARE_AD_SLOT_ID"
                         data-ad-format="square"></ins>
                    <script>
                        (adsbygoogle = window.adsbygoogle || []).push({});
                    </script>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-6 col-md-6">
            <!-- Top Banner Ad -->
            <div class="ad-container mb-4">
                <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-YOUR_PUBLISHER_ID"
                        crossorigin="anonymous"></script>
                <!-- Horizontal Banner -->
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-YOUR_PUBLISHER_ID"
                     data-ad-slot="YOUR_BANNER_AD_SLOT_ID"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
                <script>
                    (adsbygoogle = window.adsbygoogle || []).push({});
                </script>
            </div>

            <!-- Post Card -->
            <article class="card post-detail mb-4">
                <div class="card-body">
                    <!-- Post Header -->
                    <div class="post-header mb-3">
                        <div class="d-flex align-items-center mb-2">
                            <a href="@Url.Community(Model.Post.CommunitySlug)" class="text-decoration-none me-2">
                                <span class="badge bg-primary">r/@Model.Post.CommunityName</span>
                            </a>
                            <span class="text-muted small">
                                Posted by
                                <a href="@Model.Post.AuthorUrl" class="text-decoration-none">u/@Model.Post.AuthorDisplayName</a>
                                <span>@Model.Post.TimeAgo</span>
                            </span>
                        </div>

                        <!-- Awards Display -->
                        @if (Model.Post.Awards?.Any() == true)
                        {
                            <div class="post-awards mb-2">
                                @foreach (var award in Model.Post.Awards.GroupBy(a => a.AwardId))
                                {
                                    <span class="award-badge" data-bs-toggle="tooltip" title="@award.First().AwardName">
                                        <img src="@award.First().IconUrl" alt="@award.First().AwardName" height="24" />
                                        @if (award.Count() > 1)
                                        {
                                            <span class="award-count">@award.Count()</span>
                                        }
                                    </span>
                                }
                            </div>
                        }

                        <h1 class="h3">@Model.Post.Title</h1>

                        @if (Model.Post.Tags.Any())
                        {
                            <div class="post-tags mt-2">
                                @foreach (var tag in Model.Post.Tags)
                                {
                                    <span class="badge bg-light text-dark me-1">@tag</span>
                                }
                            </div>
                        }
                    </div>

                    <!-- Post Content Based on Type -->
                    <div class="post-content mb-4">
                        @switch (Model.Post.PostType)
                        {
                            case "text":
                                @Html.Raw(Model.Post.Content)
                                break;

                            case "link":
                                <div class="link-preview-card mb-3">
                                    <a href="@Model.Post.Url" target="_blank" class="d-flex text-decoration-none">
                                        @if (!string.IsNullOrEmpty(Model.Post.LinkPreviewImage))
                                        {
                                            <img src="@Model.Post.LinkPreviewImage" alt="Preview" class="link-preview-image" />
                                        }
                                        <div class="link-preview-content">
                                            <h6>@(Model.Post.PostUrl ?? Model.Post.Url)</h6>
                                            @if (!string.IsNullOrEmpty(Model.Post.LinkPreviewDescription))
                                            {
                                                <p class="text-muted small">@Model.Post.LinkPreviewDescription</p>
                                            }
                                        </div>
                                    </a>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.Post.Content))
                                {
                                    @Html.Raw(Model.Post.Content)
                                }
                                break;

                            case "image":
                                @if (Model.Post.Media?.Any() == true)
                                {
                                    <div class="post-images @(Model.Post.Media.Count > 1 ? "image-gallery" : "")">
                                        @foreach (var media in Model.Post.Media.Where(m => m.MediaType == "image"))
                                        {
                                            <div class="image-container">
                                                <img src="@media.Url" alt="@media.Caption" class="img-fluid mb-3"
                                                     data-bs-toggle="modal" data-bs-target="#imageModal"
                                                     data-image-url="@media.Url" />
                                                @if (!string.IsNullOrEmpty(media.Caption))
                                                {
                                                    <p class="image-caption text-muted small">@media.Caption</p>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(Model.Post.Content))
                                {
                                    @Html.Raw(Model.Post.Content)
                                }
                                break;

                            case "poll":
                                @if (Model.Post.Poll != null)
                                {
                                    <div class="poll-container" data-post-id="@Model.Post.PostId">
                                        <h5 class="mb-3"><i class="fas fa-poll me-2"></i>Poll</h5>
                                        <!-- Poll logic here -->
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(Model.Post.Content))
                                {
                                    @Html.Raw(Model.Post.Content)
                                }
                                break;

                            default:
                                <div class="text-center py-5 text-muted">
                                    <i class="fas fa-comments fa-3x mb-3"></i>
                                    <p>No content available for this post type.</p>
                                </div>
                                break;
                        }
                    </div>

                    <!-- In-Content Ad -->
                    <div class="native-ad mb-4">
                        <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-YOUR_PUBLISHER_ID"
                                crossorigin="anonymous"></script>
                        <!-- In-Article Ad -->
                        <ins class="adsbygoogle"
                             style="display:block; text-align:center;"
                             data-ad-layout="in-article"
                             data-ad-format="fluid"
                             data-ad-client="ca-pub-YOUR_PUBLISHER_ID"
                             data-ad-slot="YOUR_IN_ARTICLE_AD_SLOT_ID"></ins>
                        <script>
                            (adsbygoogle = window.adsbygoogle || []).push({});
                        </script>
                    </div>

                    <!-- Post Actions -->
                    <div class="post-actions d-flex align-items-center gap-3 border-top pt-3">
                        <div class="vote-buttons d-flex align-items-center gap-2">
                            <button class="btn btn-sm btn-outline-secondary vote-btn upvote @(Model.Post.CurrentUserVote == 1 ? "active" : "")"
                                    data-post-id="@Model.Post.PostId" data-vote-type="1">
                                <i class="fas fa-arrow-up"></i>
                            </button>
                            <span class="vote-count fw-bold">@Model.Post.Score</span>
                            <button class="btn btn-sm btn-outline-secondary vote-btn downvote @(Model.Post.CurrentUserVote == -1 ? "active" : "")"
                                    data-post-id="@Model.Post.PostId" data-vote-type="-1">
                                <i class="fas fa-arrow-down"></i>
                            </button>
                        </div>

                        <button class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-comment me-1"></i> @Model.Post.FormattedCommentCount Comments
                        </button>

                        <button class="btn btn-sm btn-outline-secondary award-btn" data-bs-toggle="modal" data-bs-target="#awardModal">
