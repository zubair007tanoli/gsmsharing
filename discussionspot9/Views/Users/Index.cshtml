@model List<discussionspot9.Controllers.SimpleUser>

@{
    ViewData["Title"] = "Members";
}

<div class="container mt-4">
    <h1 class="h3 mb-3"><i class="fas fa-users me-2"></i>Members</h1>
    <div class="row g-3">
        @foreach (var u in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <a class="card h-100 text-decoration-none" href="/Profile?userId=@u.UserId">
                    <div class="card-body d-flex align-items-center gap-2">
                        <img src="@(u.AvatarUrl ?? "/images/default-avatar.png")" alt="@u.DisplayName" class="rounded-circle" style="width:42px;height:42px;object-fit:cover;" />
                        <div>
                            <div class="fw-semibold">@u.DisplayName @if (u.IsVerified) { <i class="fas fa-check-circle text-primary"></i> }</div>
                            <div class="text-muted small"><i class="fas fa-star me-1 text-warning"></i>@u.Karma</div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>


