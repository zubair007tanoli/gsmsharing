@model discussionspot9.Models.ViewModels.ChatViewModels.ChatInboxViewModel
@{
    ViewData["Title"] = "Messages - DiscussionSpot";
    
    // Ensure user is authenticated
    if (!User.Identity?.IsAuthenticated ?? true)
    {
        Context.Response.Redirect("/Account/Auth");
        return;
    }
}

<link href="~/css/chat.css" rel="stylesheet" />
<link href="~/css/chat-pages.css" rel="stylesheet" />

<div class="chat-pages-container">
    <div class="container py-4">
        <div class="row">
            <!-- Chat Inbox Sidebar -->
            <div class="col-lg-4 col-md-5 mb-4">
                <div class="chat-inbox-sidebar">
                    <div class="chat-inbox-header">
                        <h2><i class="fas fa-comments me-2"></i>Messages</h2>
                        <a asp-action="CreateRoom" class="btn btn-primary btn-sm">
                            <i class="fas fa-plus me-1"></i>Create Room
                        </a>
                    </div>

                    <!-- Tabs -->
                    <div class="chat-inbox-tabs">
                        <button class="chat-tab active" data-tab="direct" onclick="switchChatInboxTab('direct')">
                            <i class="fas fa-user me-1"></i>Direct
                            @if (Model.UnreadCount > 0)
                            {
                                <span class="badge bg-danger ms-1">@Model.UnreadCount</span>
                            }
                        </button>
                        <button class="chat-tab" data-tab="rooms" onclick="switchChatInboxTab('rooms')">
                            <i class="fas fa-users me-1"></i>Rooms
                        </button>
                    </div>

                    <!-- Direct Messages List -->
                    <div id="directMessagesList" class="chat-inbox-list">
                        @if (Model.DirectChats != null && Model.DirectChats.Any())
                        {
                            @foreach (var chat in Model.DirectChats)
                            {
                                <a asp-action="Direct" asp-route-userId="@chat.UserId" class="chat-inbox-item">
                                    <div class="chat-inbox-avatar" style="background: @GetColorFromName(chat.DisplayName)">
                                        @GetInitials(chat.DisplayName)
                                        @if (chat.Status == "online")
                                        {
                                            <span class="online-dot"></span>
                                        }
                                    </div>
                                    <div class="chat-inbox-content">
                                        <div class="chat-inbox-name">@chat.DisplayName</div>
                                        @if (chat.LastMessage != null)
                                        {
                                            <div class="chat-inbox-preview">@chat.LastMessage.Content</div>
                                            <div class="chat-inbox-time">@chat.LastMessage.TimeAgo</div>
                                        }
                                    </div>
                                    @if (chat.UnreadCount > 0)
                                    {
                                        <span class="chat-unread-badge">@chat.UnreadCount</span>
                                    }
                                </a>
                            }
                        }
                        else
                        {
                            <div class="chat-empty-state">
                                <i class="far fa-comment-dots"></i>
                                <p>No direct messages yet</p>
                                <small>Start a conversation with someone!</small>
                            </div>
                        }
                    </div>

                    <!-- Rooms List -->
                    <div id="roomsList" class="chat-inbox-list" style="display: none;">
                        @if (Model.ChatRooms != null && Model.ChatRooms.Any())
                        {
                            @foreach (var room in Model.ChatRooms)
                            {
                                <a asp-action="Room" asp-route-roomId="@room.ChatRoomId" class="chat-inbox-item">
                                    <div class="chat-inbox-avatar" style="background: @GetColorFromName(room.Name)">
                                        @GetInitials(room.Name)
                                    </div>
                                    <div class="chat-inbox-content">
                                        <div class="chat-inbox-name">
                                            @room.Name
                                            @if (room.IsPublic)
                                            {
                                                <i class="fas fa-globe text-muted ms-1" style="font-size: 0.7rem;"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-lock text-muted ms-1" style="font-size: 0.7rem;"></i>
                                            }
                                        </div>
                                        <div class="chat-inbox-preview">
                                            <i class="fas fa-users" style="font-size: 0.7rem;"></i> @room.MemberCount members
                                        </div>
                                    </div>
                                    @if (room.UnreadCount > 0)
                                    {
                                        <span class="chat-unread-badge">@room.UnreadCount</span>
                                    }
                                </a>
                            }
                        }
                        else
                        {
                            <div class="chat-empty-state">
                                <i class="far fa-comments"></i>
                                <p>No chat rooms yet</p>
                                <a asp-action="CreateRoom" class="btn btn-primary btn-sm mt-2">Create Your First Room</a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="col-lg-8 col-md-7">
                <div class="chat-welcome-panel">
                    <div class="chat-welcome-icon">
                        <i class="fas fa-comments"></i>
                    </div>
                    <h3>Select a conversation</h3>
                    <p class="text-muted">Choose a chat from the sidebar to start messaging, or create a new chat room to bring people together.</p>
                    <a asp-action="CreateRoom" class="btn btn-primary mt-3">
                        <i class="fas fa-plus me-2"></i>Create Chat Room
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function switchChatInboxTab(tabName) {
        // Update active tab
        document.querySelectorAll('.chat-inbox-tabs .chat-tab').forEach(tab => {
            tab.classList.remove('active');
        });
        event.target.closest('.chat-tab').classList.add('active');

        // Show appropriate list
        document.getElementById('directMessagesList').style.display = tabName === 'direct' ? 'block' : 'none';
        document.getElementById('roomsList').style.display = tabName === 'rooms' ? 'block' : 'none';
    }
</script>

@functions {
    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper();
        return name.Substring(0, Math.Min(2, name.Length)).ToUpper();
    }

    private string GetColorFromName(string name)
    {
        var colors = new[] { "#0079d3", "#ff4500", "#46d160", "#ffa500", "#7c7c7c", "#0056b3", "#8b5cf6", "#ec4899" };
        int hash = 0;
        foreach (char c in name)
        {
            hash = c + ((hash << 5) - hash);
        }
        return colors[Math.Abs(hash) % colors.Length];
    }
}

