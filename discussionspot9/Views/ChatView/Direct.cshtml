@model discussionspot9.Models.ViewModels.ChatViewModels.DirectChatPageViewModel
@{
    ViewData["Title"] = $"Chat with {Model.UserName} - DiscussionSpot";
}

<link href="~/css/chat.css" rel="stylesheet" />
<link href="~/css/chat-pages.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>

<div class="chat-pages-container">
    <div class="container py-4">
        <div class="row">
            <!-- Back to Inbox -->
            <div class="col-12 mb-3">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-arrow-left me-2"></i>Back to Messages
                </a>
            </div>

            <!-- Chat Window -->
            <div class="col-lg-8 offset-lg-2">
                <div class="chat-page-window">
                    <!-- Chat Header -->
                    <div class="chat-page-header">
                        <div class="chat-page-user-info">
                            <div class="chat-page-avatar" style="background: @GetColorFromName(Model.UserName ?? "User")">
                                @GetInitials(Model.UserName ?? "User")
                            </div>
                            <div>
                                <h4 class="mb-0">@Model.UserName</h4>
                                <small class="text-muted" id="userStatus">
                                    <i class="fas fa-circle text-success" style="font-size: 0.5rem;"></i> Online
                                </small>
                            </div>
                        </div>
                    </div>

                    <!-- Messages Area -->
                    <div class="chat-page-messages" id="chatMessages">
                        @if (Model.Messages != null && Model.Messages.Any())
                        {
                            @foreach (var message in Model.Messages.OrderBy(m => m.SentAt))
                            {
                                <div class="chat-message @(message.IsMine ? "mine" : "")">
                                    <div class="chat-message-avatar">@GetInitials(message.SenderName)</div>
                                    <div class="chat-message-content">
                                        <div class="chat-message-bubble">
                                            <p class="chat-message-text">@Html.Raw(Html.Encode(message.Content).Replace("\n", "<br>"))</p>
                                        </div>
                                        <div class="chat-message-time">@message.FormattedTime</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="chat-empty-messages">
                                <p>No messages yet. Start the conversation!</p>
                            </div>
                        }
                    </div>

                    <!-- Typing Indicator -->
                    <div class="chat-typing-indicator" id="typingIndicator" style="display: none;">
                        <div class="typing-dots">
                            <span class="typing-dot"></span>
                            <span class="typing-dot"></span>
                            <span class="typing-dot"></span>
                        </div>
                        <span>@Model.UserName is typing...</span>
                    </div>

                    <!-- Input Area -->
                    <div class="chat-page-input">
                        <div class="chat-input-wrapper">
                            <input type="text" class="chat-input" id="messageInput" placeholder="Type a message..." autocomplete="off" />
                            <button class="chat-send-btn" id="sendBtn" onclick="sendMessage()">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/chat/chat-service.js"></script>
<script src="~/js/chat/chat-controller.js"></script>
<script src="~/js/chat/chat-ui.js"></script>

<script>
    let chatController = null;
    const otherUserId = '@Model.UserId';

    document.addEventListener('DOMContentLoaded', async function() {
        // Initialize chat
        chatController = new ChatController();
        await chatController.initialize();
        
        // Load this conversation
        await chatController.loadChatHistory(otherUserId);

        // Setup input handlers
        const input = document.getElementById('messageInput');
        input.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        input.addEventListener('input', function() {
            if (chatController) {
                chatController.handleTyping();
            }
        });
    });

    function sendMessage() {
        const input = document.getElementById('messageInput');
        const message = input.value.trim();
        
        if (message && chatController) {
            chatController.sendMessage(message);
            input.value = '';
        }
    }

    // Helper functions
    function getRandomColor() {
        const colors = ['#0079d3', '#ff4500', '#46d160', '#ffa500', '#7c7c7c', '#0056b3'];
        return colors[Math.floor(Math.random() * colors.length)];
    }
</script>

<style>
    .chat-page-window {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        display: flex;
        flex-direction: column;
        height: calc(100vh - 200px);
        overflow: hidden;
    }

    .chat-page-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #edeff1;
        background: #f6f7f8;
    }

    .chat-page-user-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .chat-page-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #0079d3;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .chat-page-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        background: #fafafa;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .chat-page-input {
        padding: 1rem 1.5rem;
        border-top: 1px solid #edeff1;
        background: white;
    }

    .chat-empty-messages {
        text-align: center;
        padding: 3rem;
        color: #7c7c7c;
    }
</style>

@functions {
    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper();
        return name.Substring(0, Math.Min(2, name.Length)).ToUpper();
    }

    private string GetColorFromName(string name)
    {
        var colors = new[] { "#0079d3", "#ff4500", "#46d160", "#ffa500", "#7c7c7c", "#0056b3", "#8b5cf6", "#ec4899" };
        int hash = 0;
        foreach (char c in name)
        {
            hash = c + ((hash << 5) - hash);
        }
        return colors[Math.Abs(hash) % colors.Length];
    }
}

