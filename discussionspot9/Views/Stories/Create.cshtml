@model discussionspot9.Models.ViewModels.CreativeViewModels.CreateStoryViewModel
@{
    ViewData["Title"] = "Create New Story - DiscussionSpot";
    ViewData["Description"] = "Create engaging web stories with our advanced story creation tools.";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <!-- Header -->
            <div class="story-create-header text-center py-4 mb-4">
                <h1 class="display-5 fw-bold text-primary mb-3">
                    <i class="fas fa-book-open me-3"></i>Create New Story
                </h1>
                <p class="lead text-muted">Transform your content into engaging visual stories</p>
            </div>

            <!-- Create Form -->
            <div class="row justify-content-center">
                <div class="col-lg-8 col-xl-6">
                    <div class="card shadow-lg border-0">
                        <div class="card-body p-4">
                            <form asp-action="Create" method="post" id="create-story-form">
                                <div class="mb-4">
                                    <label asp-for="Title" class="form-label fw-bold">
                                        <i class="fas fa-heading me-2 text-primary"></i>Story Title
                                    </label>
                                    <input asp-for="Title" class="form-control form-control-lg" 
                                           placeholder="Enter your story title..." required>
                                            <span asp-validation-for="Title" class="text-danger"></span>
                                    <div class="form-text">Choose a compelling title that captures your audience's attention</div>
                                        </div>

                                <div class="mb-4">
                                    <label asp-for="Description" class="form-label fw-bold">
                                        <i class="fas fa-align-left me-2 text-primary"></i>Story Description
                                    </label>
                                    <textarea asp-for="Description" class="form-control" rows="4" 
                                              placeholder="Describe what your story is about..."></textarea>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                    <div class="form-text">Provide a brief description of your story content</div>
                                </div>

                                <!-- AI Settings -->
                                <div class="ai-settings-section mb-4">
                                    <h5 class="fw-bold text-primary mb-3">
                                        <i class="fas fa-robot me-2"></i>AI Enhancement Settings
                                    </h5>
                                    
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label asp-for="Style" class="form-label fw-bold">Story Style</label>
                                            <select asp-for="Style" class="form-select">
                                                <option value="informative">Informative</option>
                                                <option value="engaging">Engaging</option>
                                                <option value="visual">Visual</option>
                                                <option value="dynamic">Dynamic</option>
                                                <option value="educational">Educational</option>
                                                <option value="entertaining">Entertaining</option>
                                            </select>
                                            <div class="form-text">Choose the style that best fits your content</div>
                                </div>

                                        <div class="col-md-6 mb-3">
                                            <label asp-for="Length" class="form-label fw-bold">Story Length</label>
                                            <select asp-for="Length" class="form-select">
                                                <option value="short">Short (3-5 slides)</option>
                                                <option value="medium">Medium (6-10 slides)</option>
                                                <option value="long">Long (11+ slides)</option>
                                            </select>
                                            <div class="form-text">Select the desired length for your story</div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                        <label asp-for="Keywords" class="form-label fw-bold">Keywords (Optional)</label>
                                        <input asp-for="Keywords" class="form-control" 
                                               placeholder="Enter keywords separated by commas...">
                                        <div class="form-text">Add relevant keywords to help with SEO and discovery</div>
                        </div>

                                            <div class="row">
                                                <div class="col-md-6">
                                            <div class="form-check form-switch">
                                                <input asp-for="UseAI" class="form-check-input" type="checkbox" checked>
                                                <label asp-for="UseAI" class="form-check-label fw-bold">
                                                    Use AI Enhancement
                                                                </label>
                                                <div class="form-text">Let AI optimize your story content</div>
                        </div>
                    </div>

                                        <div class="col-md-6">
                                            <div class="form-check form-switch">
                                                <input asp-for="AutoGenerate" class="form-check-input" type="checkbox" checked>
                                                <label asp-for="AutoGenerate" class="form-check-label fw-bold">
                                                    Auto-Generate Slides
                                        </label>
                                                <div class="form-text">Automatically create slides from your content</div>
                                </div>
                                </div>
                            </div>
                        </div>

                                <!-- Action Buttons -->
                                <div class="d-flex gap-3 justify-content-center">
                                    <button type="submit" class="btn btn-primary btn-lg px-5">
                                        <i class="fas fa-magic me-2"></i>Create Story
                                    </button>
                                    <a href="/stories" class="btn btn-outline-secondary btn-lg px-4">
                                        <i class="fas fa-arrow-left me-2"></i>Back to Stories
                                    </a>
                            </div>
                            </form>
                            </div>
                        </div>
                    </div>
                </div>

            <!-- Features Section -->
            <div class="features-preview mt-5">
                <div class="row">
                    <div class="col-lg-4 mb-4">
                        <div class="feature-card text-center h-100">
                            <div class="feature-icon mb-3">
                                <i class="fas fa-mobile-alt fa-3x text-primary"></i>
                            </div>
                            <h5>Mobile Optimized</h5>
                            <p class="text-muted">Your stories will look perfect on all devices</p>
                        </div>
                    </div>
                    <div class="col-lg-4 mb-4">
                        <div class="feature-card text-center h-100">
                            <div class="feature-icon mb-3">
                                <i class="fas fa-robot fa-3x text-success"></i>
                            </div>
                            <h5>AI Powered</h5>
                            <p class="text-muted">Our AI helps create engaging content automatically</p>
                        </div>
                    </div>
                    <div class="col-lg-4 mb-4">
                        <div class="feature-card text-center h-100">
                            <div class="feature-icon mb-3">
                                <i class="fas fa-share-alt fa-3x text-warning"></i>
                            </div>
                            <h5>Easy Sharing</h5>
                            <p class="text-muted">Share your stories across social media platforms</p>
                        </div>
                        </div>
                    </div>
                </div>
        </div>
    </div>
</div>

<style>
.story-create-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 15px;
    margin-bottom: 2rem;
}

.feature-card {
    padding: 2rem;
    border-radius: 15px;
    background: white;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: transform 0.3s ease;
    border: 1px solid #e9ecef;
}

.feature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}

.ai-settings-section {
    background: #f8f9fa;
    border-radius: 10px;
    padding: 1.5rem;
    border: 1px solid #e9ecef;
}

.form-control:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
}

.btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    transition: all 0.3s ease;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
}

<style>
@@media (max-width: 768px) {
    .story-create-header h1 {
        font-size: 2rem;
    }
    
    .feature-card {
        padding: 1.5rem;
    }
}
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
document.addEventListener('DOMContentLoaded', function() {
            // Auto-generate description based on title
    const titleInput = document.querySelector('input[name="Title"]');
    const descriptionInput = document.querySelector('textarea[name="Description"]');
    
        titleInput.addEventListener('input', function() {
                if (!descriptionInput.value.trim()) {
                    descriptionInput.placeholder = `A story about ${this.value}...`;
                }
            });

            // Form validation
            const form = document.getElementById('create-story-form');
            form.addEventListener('submit', function(e) {
                const title = titleInput.value.trim();
                if (!title) {
                e.preventDefault();
                    titleInput.focus();
                    titleInput.classList.add('is-invalid');
                    return false;
        }
    });
});
</script>
}