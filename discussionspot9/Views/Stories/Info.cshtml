@{
    ViewData["Title"] = "Web Stories - Learn More";
    ViewData["Description"] = "Learn about Web Stories and how to create engaging visual content that captivates your audience.";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <!-- Hero Section -->
            <div class="hero-section text-center py-5 mb-5">
                <div class="container">
                    <h1 class="display-4 fw-bold text-primary mb-4">Web Stories</h1>
                    <p class="lead mb-4">Create engaging visual stories that captivate your audience and boost your content's reach</p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="/stories/create" class="btn btn-primary btn-lg">
                            <i class="fas fa-plus me-2"></i>Create Your First Story
                        </a>
                        <a href="/stories/editor" class="btn btn-outline-primary btn-lg">
                            <i class="fas fa-edit me-2"></i>Try Visual Editor
                        </a>
                    </div>
                </div>
            </div>

            <!-- Features Section -->
            <div class="features-section py-5">
                <div class="container">
                    <h2 class="text-center mb-5">Why Choose Web Stories?</h2>
                    <div class="row">
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="feature-card text-center h-100">
                                <div class="feature-icon mb-3">
                                    <i class="fas fa-mobile-alt fa-3x text-primary"></i>
                                </div>
                                <h4>Mobile-First Design</h4>
                                <p class="text-muted">Stories are optimized for mobile viewing, ensuring your content looks great on any device.</p>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="feature-card text-center h-100">
                                <div class="feature-icon mb-3">
                                    <i class="fas fa-search fa-3x text-success"></i>
                                </div>
                                <h4>SEO Optimized</h4>
                                <p class="text-muted">Built-in SEO features help your stories rank higher in search results and reach more people.</p>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="feature-card text-center h-100">
                                <div class="feature-icon mb-3">
                                    <i class="fas fa-chart-line fa-3x text-warning"></i>
                                </div>
                                <h4>Higher Engagement</h4>
                                <p class="text-muted">Visual stories generate 3x more engagement than traditional text posts.</p>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="feature-card text-center h-100">
                                <div class="feature-icon mb-3">
                                    <i class="fas fa-robot fa-3x text-info"></i>
                                </div>
                                <h4>AI-Powered</h4>
                                <p class="text-muted">Our AI helps you create better content with automatic optimization and suggestions.</p>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="feature-card text-center h-100">
                                <div class="feature-icon mb-3">
                                    <i class="fas fa-palette fa-3x text-danger"></i>
                                </div>
                                <h4>Visual Editor</h4>
                                <p class="text-muted">Create stunning stories with our drag-and-drop visual editor and templates.</p>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="feature-card text-center h-100">
                                <div class="feature-icon mb-3">
                                    <i class="fas fa-share-alt fa-3x text-secondary"></i>
                                </div>
                                <h4>Easy Sharing</h4>
                                <p class="text-muted">Share your stories across social media platforms with one click.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- How It Works Section -->
            <div class="how-it-works-section py-5 bg-light">
                <div class="container">
                    <h2 class="text-center mb-5">How It Works</h2>
                    <div class="row">
                        <div class="col-lg-3 col-md-6 mb-4">
                            <div class="step-card text-center">
                                <div class="step-number">1</div>
                                <h5>Create Content</h5>
                                <p class="text-muted">Write your post or upload media content that you want to turn into a story.</p>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-4">
                            <div class="step-card text-center">
                                <div class="step-number">2</div>
                                <h5>AI Enhancement</h5>
                                <p class="text-muted">Our AI analyzes your content and suggests improvements for better engagement.</p>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-4">
                            <div class="step-card text-center">
                                <div class="step-number">3</div>
                                <h5>Visual Editor</h5>
                                <p class="text-muted">Use our visual editor to customize your story with templates, colors, and effects.</p>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-4">
                            <div class="step-card text-center">
                                <div class="step-number">4</div>
                                <h5>Publish & Share</h5>
                                <p class="text-muted">Publish your story and share it across social media platforms for maximum reach.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Templates Section -->
            <div class="templates-section py-5">
                <div class="container">
                    <h2 class="text-center mb-5">Story Templates</h2>
                    <div class="row">
                        <div class="col-lg-3 col-md-6 mb-4">
                            <div class="template-card">
                                <div class="template-preview news-template"></div>
                                <h5>News Template</h5>
                                <p class="text-muted">Perfect for news articles and updates</p>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-4">
                            <div class="template-card">
                                <div class="template-preview tutorial-template"></div>
                                <h5>Tutorial Template</h5>
                                <p class="text-muted">Great for step-by-step guides</p>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-4">
                            <div class="template-card">
                                <div class="template-preview story-template"></div>
                                <h5>Story Template</h5>
                                <p class="text-muted">Ideal for personal stories and experiences</p>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-4">
                            <div class="template-card">
                                <div class="template-preview promotion-template"></div>
                                <h5>Promotion Template</h5>
                                <p class="text-muted">Perfect for marketing and promotions</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CTA Section -->
            <div class="cta-section py-5 bg-primary text-white">
                <div class="container text-center">
                    <h2 class="mb-4">Ready to Create Your First Story?</h2>
                    <p class="lead mb-4">Join thousands of creators who are already using Web Stories to engage their audience.</p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="/stories/create" class="btn btn-light btn-lg">
                            <i class="fas fa-plus me-2"></i>Get Started Now
                        </a>
                        <a href="/stories" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-eye me-2"></i>View Examples
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.hero-section {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.feature-card {
    padding: 2rem;
    border-radius: 10px;
    background: white;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: transform 0.3s ease;
}

.feature-card:hover {
    transform: translateY(-5px);
}

.feature-icon {
    margin-bottom: 1rem;
}

.step-card {
    padding: 2rem 1rem;
}

.step-number {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #007bff;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: bold;
    margin: 0 auto 1rem;
}

.template-card {
    text-align: center;
    padding: 1.5rem;
    border-radius: 10px;
    background: white;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: transform 0.3s ease;
    cursor: pointer;
}

.template-card:hover {
    transform: translateY(-5px);
}

.template-preview {
    width: 100%;
    height: 120px;
    border-radius: 8px;
    margin-bottom: 1rem;
}

.news-template { 
    background: linear-gradient(45deg, #ff6b6b, #ffa500); 
}

.tutorial-template { 
    background: linear-gradient(45deg, #4ecdc4, #44a08d); 
}

.story-template { 
    background: linear-gradient(45deg, #667eea, #764ba2); 
}

.promotion-template { 
    background: linear-gradient(45deg, #f093fb, #f5576c); 
}

.cta-section {
    background: linear-gradient(135deg, #007bff, #0056b3);
}

@@media (max-width: 768px) {
    .hero-section h1 {
        font-size: 2.5rem;
    }
    
    .feature-card {
        padding: 1.5rem;
    }
}
</style>
