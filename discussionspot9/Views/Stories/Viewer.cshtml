    width: 0%;
    transition: width 0.1s linear;
    border-radius: 0 3px 3px 0;
}

.progress-indicators {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10001;
}

.progress-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    transition: all 0.3s ease;
    cursor: pointer;
}

.progress-indicator.active {
    background: white;
    transform: scale(1.2);
}

.story-content {
    flex: 1;
    position: relative;
    overflow: hidden;
}

.story-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
