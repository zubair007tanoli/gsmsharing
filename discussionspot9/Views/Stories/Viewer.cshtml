    }
    
    .close-btn {
        top: 1rem;
        right: 1rem;
        width: 45px;
        height: 45px;
        padding: 0.75rem;
    }
}

/* Tablet Responsive */
@@media (min-width: 769px) and (max-width: 1024px) {
    .story-info {
        max-width: calc(100% - 250px);
        right: 90px;
    }
    
    .slide-content {
