@model discussionspot9.Models.Domain.Story
@{
    ViewData["Title"] = Model.Title;
    ViewData["Description"] = Model.MetaDescription ?? Model.Description ?? $"Read {Model.Title} on DiscussionSpot";
    ViewData["CanonicalUrl"] = Model.CanonicalUrl ?? Url.Action("Viewer", "Stories", new { slug = Model.Slug }, Context.Request.Scheme);
    var ampUrl = Url.Action("Amp", "Stories", new { slug = Model.Slug }, Context.Request.Scheme);
    var hero = Model.Slides?.OrderBy(s => s.OrderIndex).Select(s => s.MediaUrl).FirstOrDefault() ?? "/Assets/Logo_Auth.png";
}

@functions {
    public static string StripHtml(string input)
    {
        if (string.IsNullOrEmpty(input))
            return string.Empty;
            
        // Remove HTML tags using regex
        return System.Text.RegularExpressions.Regex.Replace(input, "<.*?>", string.Empty).Trim();
    }
    
    public static bool IsVideoFile(string url)
    {
        if (string.IsNullOrEmpty(url)) return false;
        var extension = System.IO.Path.GetExtension(url).ToLower();
        return extension == ".mp4" || extension == ".webm" || extension == ".mov" || extension == ".avi";
    }
}

@section Head {
<link rel="amphtml" href="@ampUrl" />
<link rel="preload" as="image" href="@hero" />
}

<!-- Story Viewer Container -->
<div id="story-viewer" class="story-viewer-container">
    <!-- Enhanced Progress Bar -->
    <div class="story-progress">
        <div class="progress-bar" id="progress-bar"></div>
        <div class="progress-indicators" id="progress-indicators"></div>
    </div>

    <!-- Story Content -->
    <div class="story-content" id="story-content">
        @if (Model.Slides != null && Model.Slides.Any())
        {
            @foreach (var slide in Model.Slides.OrderBy(s => s.OrderIndex))
            {
                <div class="story-slide" data-duration="@slide.Duration" data-slide-type="@slide.SlideType">
                    @if (slide.SlideType == "media" && !string.IsNullOrEmpty(slide.MediaUrl))
                    {
                        <div class="slide-media">
                            @if (IsVideoFile(slide.MediaUrl))
                            {
                                <video class="slide-video" autoplay muted loop>
                                    <source src="@slide.MediaUrl" type="video/mp4">
                                    Your browser does not support the video tag.
                                </video>
                            }
                            else if (!string.IsNullOrEmpty(slide.MediaUrl))
                            {
                                <img class="slide-image" 
                                     src="@slide.MediaUrl" 
                                     alt="@(slide.Caption ?? slide.Headline ?? "Story slide")" 
                                     loading="@(slide.OrderIndex <= 1 ? "eager" : "lazy")"
                                     decoding="async"
                                     onerror="this.style.opacity='0.5';" />
                            }
                        </div>
                    }
                    
                    <div class="slide-content card-bottom align-@(slide.Alignment?.ToLower() ?? "center")" style="background-color: @slide.BackgroundColor; color: @slide.TextColor; font-size: @slide.FontSize;">
                        @if (!string.IsNullOrEmpty(slide.Headline))
                        {
                            <h1 class="slide-headline">@StripHtml(slide.Headline)</h1>
                        }
                        @if (!string.IsNullOrEmpty(slide.Text))
                        {
                            <div class="slide-text">@Html.Raw(StripHtml(slide.Text))</div>
                        }
                        @if (!string.IsNullOrEmpty(slide.Caption))
                        {
                            <p class="slide-caption">@StripHtml(slide.Caption)</p>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="story-slide active">
                <div class="slide-content">
                    <h1 class="slide-headline">No slides available</h1>
                    <p class="slide-text">This story doesn't have any slides to display.</p>
                </div>
            </div>
        }
    </div>

    <!-- Enhanced Navigation Controls -->
    <div class="story-controls">
        <button class="control-btn prev-btn" id="prev-btn" title="Previous Slide">
            <i class="fas fa-chevron-left"></i>
        </button>
        
        <div class="control-center">
            <button class="control-btn play-pause-btn" id="play-pause-btn" title="Play/Pause">
                <i class="fas fa-pause"></i>
            </button>
            <div class="slide-counter">
                <span id="current-slide">1</span> / <span id="total-slides">@(Model.Slides?.Count ?? 0)</span>
            </div>
            <div class="slide-timer">
                <span id="slide-timer">0</span>s
            </div>
        </div>
        
        <button class="control-btn next-btn" id="next-btn" title="Next Slide">
            <i class="fas fa-chevron-right"></i>
        </button>
    </div>

    <!-- Enhanced Story Info -->
    <div class="story-info">
        <div class="story-meta">
            <div class="story-header">
                <h2 class="story-title">@Model.Title</h2>
                <div class="story-actions">
                    @if (Model.Post != null)
                    {
                        <a href="/r/@Model.Post.Community.Slug/posts/@Model.Post.Slug" class="action-btn" title="View Original Post">
                            <i class="fas fa-external-link-alt"></i>
                        </a>
                    }
                    <button class="action-btn" id="share-btn" title="Share Story">
                        <i class="fas fa-share"></i>
                    </button>
                    <button class="action-btn" id="like-btn" title="Like Story">
                        <i class="fas fa-heart"></i>
                    </button>
                    <button class="action-btn" id="bookmark-btn" title="Bookmark Story">
                        <i class="fas fa-bookmark"></i>
                    </button>
                </div>
            </div>
            <div class="story-author">
                <div class="author-info">
                    <span class="author-name">@(Model.User?.UserName ?? "Unknown")</span>
                    <span class="story-date">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="story-description">@Model.Description</p>
            }
            <div class="story-stats">
                <span class="stat-item">
                    <i class="fas fa-eye"></i>
                    <span id="view-count">@Model.ViewCount</span>
                </span>
                <span class="stat-item">
                    <i class="fas fa-heart"></i>
                    <span id="like-count">0</span>
                </span>
            </div>
        </div>
    </div>

    <!-- Enhanced Close Button -->
    <button class="close-btn" id="close-btn" title="Close Story">
        <i class="fas fa-times"></i>
    </button>
</div>

<!-- Story Viewer Styles -->
<style>
.story-viewer-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: #000;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.story-progress {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 6px;
    background: rgba(255, 255, 255, 0.2);
    z-index: 10000;
    backdrop-filter: blur(10px);
}

.progress-bar {
    height: 100%;
