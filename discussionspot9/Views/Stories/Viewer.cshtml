}

.slide-caption {
    font-size: clamp(0.9rem, 2vw, 1.1rem);
    opacity: 0.95;
    margin: 0 auto;
    padding: 0 1rem;
    max-width: 80%;
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.9);
