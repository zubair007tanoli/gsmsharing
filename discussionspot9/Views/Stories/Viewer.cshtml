/* Ensure empty/broken images are handled */
.slide-image[src=""],
.slide-image:not([src]),
.slide-image[src="undefined"],
.slide-image[src="null"] {
    opacity: 0.5;
}

/* Handle image load errors */
.slide-image::before {
    content: '';
