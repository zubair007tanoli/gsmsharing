<!-- Story Viewer JavaScript -->
<script src="~/js/stories/story-utils.js"></script>
<script>
// Initialize story viewer when DOM is ready
document.addEventListener('DOMContentLoaded', function() {
    console.log('🎬 Story Viewer initializing...');
    
    // Check if story-utils.js loaded properly
    if (typeof window.storyViewer === 'undefined') {
        console.warn('⚠️ story-utils.js not loaded, using fallback');
        initializeFallbackViewer();
    } else {
        console.log('✅ Story viewer loaded from story-utils.js');
    }
});

function initializeFallbackViewer() {
    const slides = document.querySelectorAll('.story-slide');
    const totalSlides = slides.length;
    let currentSlide = 0;
    let isPlaying = true;
    let slideTimer = null;
    
    console.log(`📊 Found ${totalSlides} slides`);
    
    // Show first slide
    if (totalSlides > 0) {
        showSlide(0);
        startSlideTimer();
    }
    
    // Navigation buttons
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const playPauseBtn = document.getElementById('play-pause-btn');
    const closeBtn = document.getElementById('close-btn');
    
    // Event listeners
    if (prevBtn) {
        prevBtn.addEventListener('click', () => {
            console.log('⬅️ Previous slide');
            prevSlide();
        });
    }
    
    if (nextBtn) {
        nextBtn.addEventListener('click', () => {
            console.log('➡️ Next slide');
            nextSlide();
        });
    }
    
    if (playPauseBtn) {
        playPauseBtn.addEventListener('click', () => {
            console.log('⏯️ Toggle play/pause');
            togglePlayPause();
        });
    }
    
    if (closeBtn) {
        closeBtn.addEventListener('click', () => {
            console.log('❌ Close viewer');
            closeViewer();
        });
    }
    
    // Keyboard navigation
    document.addEventListener('keydown', function(e) {
        switch(e.key) {
            case 'ArrowRight':
            case ' ':
                e.preventDefault();
                nextSlide();
                break;
            case 'ArrowLeft':
                e.preventDefault();
                prevSlide();
                break;
            case 'Escape':
                closeViewer();
                break;
        }
    });
    
    // Touch/swipe navigation
    let startX = 0;
    let startY = 0;
    
    const storyViewer = document.getElementById('story-viewer');
    if (storyViewer) {
        storyViewer.addEventListener('touchstart', (e) => {
            startX = e.touches[0].clientX;
            startY = e.touches[0].clientY;
        }, { passive: true });
        
        storyViewer.addEventListener('touchend', (e) => {
            const endX = e.changedTouches[0].clientX;
            const endY = e.changedTouches[0].clientY;
            const diffX = startX - endX;
            const diffY = startY - endY;
            
            // Only handle horizontal swipes
            if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 50) {
                if (diffX > 0) {
                    nextSlide(); // Swipe left - next slide
                } else {
                    prevSlide(); // Swipe right - previous slide
                }
            }
        }, { passive: true });
    }
    
    function showSlide(index) {
        if (index < 0 || index >= totalSlides) return;
        
        // Hide all slides
        slides.forEach((slide, i) => {
            slide.classList.toggle('active', i === index);
        });
        
        currentSlide = index;
        console.log(`📍 Showing slide ${index + 1}/${totalSlides}`);
        
        // Update counter
        const currentSlideSpan = document.getElementById('current-slide');
        if (currentSlideSpan) {
            currentSlideSpan.textContent = index + 1;
        }
        
        // Update progress indicators
        const indicators = document.querySelectorAll('.progress-indicator');
        indicators.forEach((indicator, i) => {
            indicator.classList.toggle('active', i <= index);
            indicator.classList.toggle('current', i === index);
        });
        
        // Handle video autoplay
        handleMediaPlayback(slides[index]);
    }
    
    function handleMediaPlayback(slide) {
        // Pause all videos
        document.querySelectorAll('.story-slide video').forEach(video => {
            video.pause();
        });
        
        // Play video in current slide
        const video = slide.querySelector('video');
        if (video) {
            video.currentTime = 0;
            video.play().catch(e => console.warn('Video autoplay failed:', e));
        }
        
        // Handle image loading
        const images = slide.querySelectorAll('.slide-image');
        const slideIndex = Array.from(slides).indexOf(slide);
        const storySlide = slide;
        
        console.log(`🖼️ Slide ${slideIndex + 1}: Found ${images.length} images`);
        
        images.forEach((img, idx) => {
            console.log(`  Image ${idx + 1}: src="${img.src}", complete=${img.complete}, naturalWidth=${img.naturalWidth}`);
            
            // Set loading attribute for better performance
            if (!img.hasAttribute('loading')) {
                img.setAttribute('loading', slideIndex <= 1 ? 'eager' : 'lazy');
            }
            
            // Force image to be visible immediately
            img.style.opacity = '1';
            img.style.display = 'block';
            img.style.width = '100%';
            img.style.height = '100%';
            img.style.objectFit = 'cover';
            img.style.objectPosition = 'center';
            
            // Handle image load errors - use background as fallback
            img.addEventListener('error', function() {
                console.warn(`❌ Image ${idx + 1} failed to load:`, this.src);
                const slideMedia = this.closest('.slide-media');
                
                // Hide broken image
                this.style.display = 'none';
                
                // Set background image on parent elements as fallback
                if (slideMedia && this.src) {
                    console.log(`  Setting background on .slide-media: ${this.src}`);
                    slideMedia.style.backgroundImage = `url('${this.src}')`;
                    slideMedia.style.backgroundSize = 'cover';
                    slideMedia.style.backgroundPosition = 'center';
                    slideMedia.style.backgroundRepeat = 'no-repeat';
                }
                
                if (storySlide && this.src) {
                    console.log(`  Setting background on .story-slide: ${this.src}`);
                    storySlide.style.backgroundImage = `url('${this.src}')`;
                    storySlide.style.backgroundSize = 'cover';
                    storySlide.style.backgroundPosition = 'center';
                    storySlide.style.backgroundRepeat = 'no-repeat';
                }
            });
            
            // Ensure image is visible when loaded
            img.addEventListener('load', function() {
                console.log(`✅ Image ${idx + 1} loaded successfully:`, this.src);
                this.style.opacity = '1';
                this.style.display = 'block';
            });
            
            // Check if image is already loaded
            if (img.complete) {
                if (img.naturalWidth > 0) {
                    console.log(`✅ Image ${idx + 1} already loaded:`, img.src);
                    img.style.opacity = '1';
                    img.style.display = 'block';
                } else {
                    console.warn(`⚠️ Image ${idx + 1} complete but naturalWidth is 0:`, img.src);
                }
            }
        });
        
        // Also check for background images on slide elements
        const slideBg = window.getComputedStyle(storySlide).backgroundImage;
        if (slideBg && slideBg !== 'none') {
            console.log(`  Slide has background image: ${slideBg}`);
        }
    }
    
    function nextSlide() {
        if (currentSlide < totalSlides - 1) {
            clearSlideTimer();
            showSlide(currentSlide + 1);
            if (isPlaying) startSlideTimer();
        } else {
            // Restart from beginning
            clearSlideTimer();
            showSlide(0);
        }
    }
    
    function prevSlide() {
        if (currentSlide > 0) {
            clearSlideTimer();
            showSlide(currentSlide - 1);
            if (isPlaying) startSlideTimer();
        }
    }
    
    function togglePlayPause() {
        isPlaying = !isPlaying;
        const icon = playPauseBtn?.querySelector('i');
        
        if (isPlaying) {
            icon?.setAttribute('class', 'fas fa-pause');
            startSlideTimer();
        } else {
            icon?.setAttribute('class', 'fas fa-play');
            clearSlideTimer();
        }
    }
    
    function startSlideTimer() {
        clearSlideTimer();
        const currentSlideElement = slides[currentSlide];
        const duration = parseInt(currentSlideElement?.dataset.duration) || 5000;
        
        slideTimer = setTimeout(() => {
            nextSlide();
        }, duration);
    }
    
    function clearSlideTimer() {
        if (slideTimer) {
            clearTimeout(slideTimer);
            slideTimer = null;
        }
    }
    
    function closeViewer() {
        clearSlideTimer();
        
        // Pause all videos
        document.querySelectorAll('.story-slide video').forEach(video => {
            video.pause();
        });
        
        // Go back or redirect
        if (window.history.length > 1) {
            window.history.back();
        } else {
            window.location.href = '/stories';
        }
    }
    
    // Initialize progress indicators
    const indicatorsContainer = document.getElementById('progress-indicators');
    if (indicatorsContainer && totalSlides > 0) {
        indicatorsContainer.innerHTML = '';
        for (let i = 0; i < totalSlides; i++) {
            const indicator = document.createElement('div');
            indicator.className = 'progress-indicator';
            indicator.addEventListener('click', () => {
                clearSlideTimer();
                showSlide(i);
                if (isPlaying) startSlideTimer();
            });
            indicatorsContainer.appendChild(indicator);
        }
    }
    
    // Story info toggle functionality
    const storyInfo = document.getElementById('story-info');
    const storyInfoToggle = document.getElementById('story-info-toggle');
    const storyInfoClose = document.getElementById('story-info-close');
    
    if (storyInfoToggle) {
        storyInfoToggle.addEventListener('click', (e) => {
            e.stopPropagation();
            storyInfo?.classList.toggle('expanded');
            console.log('📋 Story info toggled');
        });
    }
    
    if (storyInfoClose) {
        storyInfoClose.addEventListener('click', (e) => {
            e.stopPropagation();
            storyInfo?.classList.remove('expanded');
            console.log('📋 Story info closed');
        });
    }
    
    // Close story info when clicking outside
    document.addEventListener('click', (e) => {
        if (storyInfo && storyInfo.classList.contains('expanded')) {
            const clickedInside = storyInfo.contains(e.target);
            if (!clickedInside && e.target !== storyInfoToggle) {
                storyInfo.classList.remove('expanded');
            }
        }
    });
}
</script>
