@model discussionspot9.Models.ViewModels.CreativeViewModels.StoriesIndexViewModel

@{
    ViewData["Title"] = "AMP Stories";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="/css/stories.css" />
<link rel="stylesheet" href="/css/stories-index.css" />

<div class="stories-page">
    <!-- Stories Navigation Bar -->
    <nav class="navbar navbar-expand-lg stories-navbar bg-white border-bottom sticky-top" style="z-index: 1020;">
        <div class="container-fluid" style="max-width: 1400px;">
            <div class="navbar-brand d-flex align-items-center">
                <i class="fas fa-bolt text-warning fs-4 me-2"></i>
                <span class="fw-bold">AMP Stories</span>
            </div>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#storiesNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="storiesNavbar">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Query["status"].ToString() == "" || Context.Request.Query["status"].ToString() == "all" ? "active" : "")" href="/stories">
                            <i class="fas fa-th-large me-1"></i>All Stories
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Query["status"].ToString() == "published" ? "active" : "")" href="/stories?status=published">
                            <i class="fas fa-check-circle me-1"></i>Published
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Query["status"].ToString() == "draft" ? "active" : "")" href="/stories?status=draft">
                            <i class="fas fa-edit me-1"></i>Drafts
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="createDropdown" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-plus-circle me-1"></i>Create
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/stories/editor">
                                <i class="fas fa-palette me-2"></i>Visual Editor
                            </a></li>
                            <li><a class="dropdown-item" href="/stories/create">
                                <i class="fas fa-magic me-2"></i>Create with AI
                            </a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/stories/help">
                                <i class="fas fa-question-circle me-2"></i>Help & Tutorials
                            </a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="infoDropdown" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-info-circle me-1"></i>About AMP
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="https://amp.dev/documentation/components/amp-story/" target="_blank" rel="noopener">
                                <i class="fas fa-external-link-alt me-2"></i>AMP Stories Documentation
                            </a></li>
                            <li><a class="dropdown-item" href="https://validator.ampproject.org/" target="_blank" rel="noopener">
                                <i class="fas fa-check-circle me-2"></i>AMP Validator
                            </a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/stories/guidelines">
                                <i class="fas fa-book me-2"></i>Content Guidelines
                            </a></li>
                        </ul>
                    </li>
                </ul>
                
                <div class="d-flex align-items-center gap-2">
                    <div class="stats-badge">
                        <span class="badge bg-primary">
                            <i class="fas fa-layer-group me-1"></i>@Model.TotalStories Stories
                        </span>
                    </div>
                    <a href="/stories/editor" class="btn btn-primary btn-sm">
                        <i class="fas fa-plus me-1"></i>New Story
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid" style="max-width: 1400px; padding: 20px;">
        <div class="row">
            <div class="col-12">
                <div class="stories-header">
                    <div class="container-fluid p-0">
                        <div class="row g-3 align-items-center">
                            <div class="col-12 col-lg-4">
                                <div class="d-flex align-items-start gap-2">
                                    <i class="fas fa-bolt text-warning fs-3 mt-1"></i>
                                    <div>
                                        <h1 class="fw-bold mb-1">AMP Stories</h1>
                                        <p class="text-muted mb-2">Create, preview, and share AMP‑optimized web stories</p>
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <span class="badge bg-warning text-dark"><i class="fas fa-bolt me-1"></i> AMP Optimized</span>
                                            <span class="text-muted small">Tip: Use View AMP for production preview</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-4">
                                <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center gap-2">
                                    <div class="btn-group" role="group" aria-label="Filter stories">
                                        <a href="?page=1&status=all" class="btn btn-sm btn-outline-secondary @((Context.Request.Query["status"].ToString() == "all" || string.IsNullOrEmpty(Context.Request.Query["status"].ToString())) ? "active" : "")">
                                            <i class="fas fa-list me-1"></i>All
                                        </a>
                                        <a href="?page=1&status=published" class="btn btn-sm btn-outline-secondary @(Context.Request.Query["status"].ToString() == "published" ? "active" : "")">
                                            <i class="fas fa-check-circle me-1"></i>Published
                                        </a>
                                        <a href="?page=1&status=draft" class="btn btn-sm btn-outline-secondary @(Context.Request.Query["status"].ToString() == "draft" ? "active" : "")">
                                            <i class="fas fa-edit me-1"></i>Drafts
                                        </a>
                                    </div>
                                    <div class="ms-lg-auto d-flex align-items-center gap-2">
                                        <div class="stats-card mb-0">
                                            <div class="stat-number">@Model.TotalStories</div>
                                            <div class="stat-label">Total</div>
                                        </div>
                                        <div class="btn-group" role="group">
                                            <a href="/stories/editor" class="btn btn-primary">
                                                <i class="fas fa-palette me-2"></i>Create Visually
                                            </a>
                                            <a href="/stories/create" class="btn btn-outline-primary">
                                                <i class="fas fa-magic me-2"></i>Create with AI
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-4">
                                <div class="d-flex justify-content-lg-end">
                                    <ins class="adsbygoogle"
                                         style="display:block; min-width:300px; width:100%; height:90px; background:#f8f9fa; border:1px dashed #e0e4e9; border-radius:10px"
                                         data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
                                         data-ad-slot="0000000000"
                                         data-ad-format="horizontal"
                                         data-full-width-responsive="true"></ins>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="stories-strip card-style" style="margin: 1rem 0 1.5rem;">
                    <button class="stories-nav left" type="button" onclick="storiesStrip.scrollBy(-1)">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <div id="storiesTrack" class="stories-track stories-track-cards">
                        @if (Model.Stories.Any())
                        {
                            foreach (var story in Model.Stories)
                            {
                                var thumbTitle = story.Title?.Length > 48 ? story.Title.Substring(0,48)+"…" : story.Title;
                                var thumbImage = !string.IsNullOrEmpty(story.PosterImageUrl) ? story.PosterImageUrl : "/Assets/Logo_Auth.png";
                                <button class="story-tile story-card-tile reveal" type="button" data-story-slug="@story.Slug" data-story-title="@story.Title" data-author="@story.CommunityName" data-posturl="/stories/viewer/@story.Slug" title="@story.Title">
                                    <div class="story-card-thumb" style="background-image: url('@thumbImage'); background-size: cover; background-position: center;">
                                        <div class="story-card-overlay">
                                            <span class="badge bg-warning text-dark"><i class="fas fa-bolt me-1"></i>AMP</span>
                                        </div>
                                    </div>
                                    <div class="story-card-caption">@thumbTitle</div>
                                </button>
                            }
                        }
                    </div>
                    <button class="stories-nav right" type="button" onclick="storiesStrip.scrollBy(1)">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model.Stories.Any())
            {
                <div class="stories-grid">
                    @foreach (var story in Model.Stories)
                    {
                        <div class="story-card-wrapper reveal">
                            <div class="story-card">
                                <div class="story-thumbnail">
                                    <div class="story-preview">
                                        @if (!string.IsNullOrEmpty(story.PosterImageUrl))
                                        {
                                            <div class="preview-slide" style="background-image: url('@story.PosterImageUrl'); background-size: cover; background-position: center;">
                                                <div class="preview-overlay"></div>
                                                <div class="preview-content">
                                                    <div class="d-flex justify-content-center mb-2">
                                                        <span class="badge bg-warning text-dark"><i class="fas fa-bolt me-1"></i>AMP</span>
                                                    </div>
                                                    <h3 class="preview-title">@story.Title</h3>
                                                    @{
                                                        var plainDesc = System.Text.RegularExpressions.Regex.Replace(story.Description ?? "", "<.*?>", string.Empty);
                                                        var truncatedDesc = plainDesc.Length > 50 ? plainDesc.Substring(0, 50) + "..." : plainDesc;
                                                    }
                                                    <p class="preview-description">@truncatedDesc</p>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="preview-slide" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                                <div class="preview-content">
                                                    <div class="d-flex justify-content-center mb-2">
                                                        <span class="badge bg-warning text-dark"><i class="fas fa-bolt me-1"></i>AMP</span>
                                                    </div>
                                                    <h3 class="preview-title">@story.Title</h3>
                                                    @{
                                                        var plainDesc2 = System.Text.RegularExpressions.Regex.Replace(story.Description ?? "", "<.*?>", string.Empty);
                                                        var truncatedDesc2 = plainDesc2.Length > 50 ? plainDesc2.Substring(0, 50) + "..." : plainDesc2;
                                                    }
                                                    <p class="preview-description">@truncatedDesc2</p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="story-overlay">
                                        <div class="story-actions">
                                            <a href="/stories/amp/@story.Slug" target="_blank" rel="noopener" class="btn btn-light btn-sm play-btn" title="View AMP">
                                                <i class="fas fa-bolt"></i>
                                            </a>
                                            <a href="/stories/viewer/@story.Slug" class="btn btn-outline-light btn-sm" title="Open Viewer">
                                                <i class="fas fa-play"></i>
                                            </a>
                                        </div>
                                        <div class="story-status">
                                            <span class="badge bg-@(story.Status == "published" ? "success" : "warning")">@story.Status</span>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="story-content">
                                    <div class="story-header">
                                        <h5 class="story-title">@story.Title</h5>
                                        <div class="story-meta">
                                            <span class="meta-item">
                                                <i class="fas fa-images"></i>
                                                @story.SlideCount slides
                                            </span>
                                            <span class="meta-item">
                                                <i class="fas fa-clock"></i>
                                                @story.CreatedAt.ToString("MMM dd, yyyy")
                                            </span>
                                        </div>
                                    </div>
                                    
                                    <p class="story-description">@Html.Raw(story.Description ?? "No description available")</p>
                                    
                                    @if (!string.IsNullOrEmpty(story.PostSlug))
                                    {
                                        <div class="source-post-link mb-2">
                                            <small class="text-info">
                                                <i class="fas fa-link me-1"></i>
                                                <a href="/r/@story.CommunitySlug/posts/@story.PostSlug" class="text-decoration-none">
                                                    View Original Post
                                                </a>
                                            </small>
                                        </div>
                                    }
                                    
                                    <div class="story-footer">
                                        <div class="story-actions-full">
                                            <a href="/stories/amp/@story.Slug" target="_blank" rel="noopener" class="btn btn-warning btn-sm text-dark">
                                                <i class="fas fa-bolt me-1"></i>View AMP
                                            </a>
                                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="navigator.clipboard.writeText(window.location.origin + '/stories/amp/@story.Slug')">
                                                <i class="fas fa-link me-1"></i>Copy AMP Link
                                            </button>
                                            <a href="https://validator.ampproject.org/#url=@($"{Context.Request.Scheme}://{Context.Request.Host}/stories/amp/{story.Slug}")" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm">
                                                <i class="fas fa-check-circle me-1"></i>Validate
                                            </a>
                                            <span class="ms-auto"></span>
                                            <a href="/stories/viewer/@story.Slug" class="btn btn-primary btn-sm">
                                                <i class="fas fa-play me-1"></i>Open Viewer
                                            </a>
                                            <a href="/stories/editor/@story.StoryId" class="btn btn-success btn-sm">
                                                <i class="fas fa-palette me-1"></i>Visual Editor
                                            </a>
                                            <a href="/stories/@story.Slug/edit" class="btn btn-outline-secondary btn-sm">
                                                <i class="fas fa-edit me-1"></i>Edit
                                            </a>
                                            <div class="dropdown">
                                                <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                                    <i class="fas fa-ellipsis-v"></i>
                                                </button>
                                                <ul class="dropdown-menu">
                                                    <li><a class="dropdown-item" href="/stories/details/@story.Slug"><i class="fas fa-info-circle me-2"></i>Details</a></li>
                                                    <li><a class="dropdown-item" href="/stories/amp/@story.Slug"><i class="fas fa-mobile-alt me-2"></i>AMP Version</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <form method="post" action="/stories/@story.Slug/delete" class="d-inline" 
                                                              onsubmit="return confirm('Are you sure you want to delete this story?')">
                                                            <button type="submit" class="dropdown-item text-danger">
                                                                <i class="fas fa-trash me-2"></i>Delete
                                                            </button>
                                                        </form>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Enhanced Pagination -->
                @if (Model.TotalPages > 1)
                {
                    var statusFilter = Context.Request.Query["status"].ToString();
                    var queryString = string.IsNullOrEmpty(statusFilter) ? "" : $"&status={statusFilter}";
                    
                    <div class="pagination-wrapper">
                        <div class="pagination-info">
                            <span class="text-muted">
                                Showing <strong>@((Model.CurrentPage - 1) * 10 + 1)</strong> - <strong>@(Math.Min(Model.CurrentPage * 10, Model.TotalStories))</strong> 
                                of <strong>@Model.TotalStories</strong> stories
                            </span>
                            <span class="page-indicator">
                                Page <strong>@Model.CurrentPage</strong> of <strong>@Model.TotalPages</strong>
                            </span>
                        </div>
                        
                        <nav aria-label="Stories pagination" class="pagination-nav">
                            <ul class="pagination pagination-lg justify-content-center">
                                <!-- First Page -->
                                @if (Model.CurrentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="?page=1@queryString" aria-label="First page" title="First page">
                                            <i class="fas fa-angle-double-left"></i>
                                        </a>
                                    </li>
                                }
                                
                                <!-- Previous Page -->
                                @if (Model.CurrentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="?page=@(Model.CurrentPage - 1)@queryString" aria-label="Previous page">
                                            <i class="fas fa-chevron-left"></i> Previous
                                        </a>
                                    </li>
                                }
                                
                                <!-- Page Numbers -->
                                @{
                                    int startPage = Math.Max(1, Model.CurrentPage - 2);
                                    int endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                                    
                                    // Show ellipsis if needed
                                    if (startPage > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="?page=1@queryString">1</a>
                                        </li>
                                        @if (startPage > 2)
                                        {
                                            <li class="page-item disabled">
                                                <span class="page-link">...</span>
                                            </li>
                                        }
                                    }
                                    
                                    // Show page numbers
                                    for (int i = startPage; i <= endPage; i++)
                                    {
                                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                            <a class="page-link" href="?page=@i@queryString">@i</a>
                                        </li>
                                    }
                                    
                                    // Show ellipsis if needed
                                    if (endPage < Model.TotalPages)
                                    {
                                        @if (endPage < Model.TotalPages - 1)
                                        {
                                            <li class="page-item disabled">
                                                <span class="page-link">...</span>
                                            </li>
                                        }
                                        <li class="page-item">
                                            <a class="page-link" href="?page=@Model.TotalPages@queryString">@Model.TotalPages</a>
                                        </li>
                                    }
                                }
                                
                                <!-- Next Page -->
                                @if (Model.CurrentPage < Model.TotalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="?page=@(Model.CurrentPage + 1)@queryString" aria-label="Next page">
                                            Next <i class="fas fa-chevron-right"></i>
                                        </a>
                                    </li>
                                }
                                
                                <!-- Last Page -->
                                @if (Model.CurrentPage < Model.TotalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="?page=@Model.TotalPages@queryString" aria-label="Last page" title="Last page">
                                            <i class="fas fa-angle-double-right"></i>
                                        </a>
                                    </li>
                                }
                            </ul>
                            
                            <!-- Quick Jump -->
                            <div class="pagination-jump">
                                <label for="pageJump" class="text-muted small me-2">Go to page:</label>
                                <input type="number" id="pageJump" class="form-control form-control-sm d-inline-block" 
                                       style="width: 80px;" min="1" max="@Model.TotalPages" 
                                       value="@Model.CurrentPage" 
                                       placeholder="Page">
                                <button class="btn btn-sm btn-outline-primary ms-2" onclick="goToPage()" title="Go to page">
                                    <i class="fas fa-arrow-right"></i>
                                </button>
                            </div>
                        </nav>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-content">
                        <div class="empty-state-icon">
                            <i class="fas fa-bolt"></i>
                        </div>
                        <h3 class="empty-state-title">No AMP Stories Yet</h3>
                        <p class="empty-state-description">
                            Create eye‑catching AMP web stories that load instantly and look great everywhere.
                        </p>
                        <div class="empty-state-actions">
                            <a href="/stories/editor" class="btn btn-primary btn-lg">
                                <i class="fas fa-palette me-2"></i>Create Story Visually
                            </a>
                            <a href="/stories/create" class="btn btn-outline-primary btn-lg">
                                <i class="fas fa-magic me-2"></i>Create with AI
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div id="storiesPlayerModal" class="stories-modal" aria-hidden="true">
        <div class="stories-modal-backdrop" onclick="storiesPlayer.close()"></div>
        <div class="stories-modal-content">
            <div class="stories-stage">
                <div class="stories-header">
                    <div id="storiesProgress" class="stories-progress"></div>
                    <div class="stories-titlebar">
                        <div class="actions">
                            <a id="storiesOpenPage" class="btn-open" href="#" target="_blank" rel="noopener">Open</a>
                        </div>
                        <div id="storiesTitle" class="title"></div>
                    </div>
                </div>
                <div id="storiesStage" class="stories-canvas" role="region" aria-label="Story stage"></div>
                <div class="stories-bottom-controls">
                    <div id="storiesDots" class="stories-dots" aria-label="Slides"></div>
                    <a id="storiesOpenPageBottom" class="btn-open" href="#" target="_blank" rel="noopener">Open</a>
                </div>
                <button class="stories-close" type="button" onclick="storiesPlayer.close()">
                    <i class="fas fa-times"></i>
                </button>
                <div class="tap-zone tap-left" onclick="storiesPlayer.prev()"></div>
                <div class="tap-zone tap-right" onclick="storiesPlayer.next()"></div>
            </div>
        </div>
    </div>
</div>

<script defer src="/js/stories.js"></script>
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
<script>(adsbygoogle=window.adsbygoogle||[]).push({});</script>

<script>
    function goToPage() {
        const pageInput = document.getElementById('pageJump');
        const page = parseInt(pageInput.value);
        const maxPage = @Model.TotalPages;
        const statusFilter = '@(Context.Request.Query["status"].ToString())';
        const queryString = statusFilter ? `&status=${statusFilter}` : '';
        
        if (page >= 1 && page <= maxPage) {
            window.location.href = `?page=${page}${queryString}`;
        } else {
            alert(`Please enter a page number between 1 and ${maxPage}`);
            pageInput.focus();
        }
    }
    
    // Handle Enter key in page jump input
    document.addEventListener('DOMContentLoaded', function() {
        const pageJump = document.getElementById('pageJump');
        if (pageJump) {
            pageJump.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    goToPage();
                }
            });
        }
        
        // Add active state styling to filter buttons
        const filterButtons = document.querySelectorAll('.btn-group[aria-label="Filter stories"] .btn');
        filterButtons.forEach(btn => {
            btn.addEventListener('click', function() {
                filterButtons.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
            });
        });
    });
</script>