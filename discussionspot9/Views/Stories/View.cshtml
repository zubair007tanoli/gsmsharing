@model discussionspot9.Models.Domain.Story
@{
    ViewData["Title"] = Model.Title;
    ViewData["Description"] = Model.MetaDescription ?? Model.Description ?? $"Read {Model.Title} on DiscussionSpot";
}

<!-- Structured Data for SEO -->
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "Article",
    "headline": "@Model.Title",
    "description": "@ViewData["Description"]",
    "image": "@Model.PosterImageUrl",
    "author": {
        "@@type": "Person",
        "name": "@Model.User?.UserName"
    },
    "publisher": {
        "@@type": "Organization",
        "name": "@(Model.PublisherName ?? "DiscussionSpot")",
        "logo": {
            "@@type": "ImageObject",
            "url": "@(Model.PublisherLogo ?? Url.Content("~/favicon.ico"))"
        }
    },
    "datePublished": "@Model.PublishedAt?.ToString("yyyy-MM-ddTHH:mm:ssZ")",
    "dateModified": "@Model.UpdatedAt.ToString("yyyy-MM-ddTHH:mm:ssZ")",
    "mainEntityOfPage": {
        "@@type": "WebPage",
        "@@id": "@ViewData["CanonicalUrl"]"
    },
    "articleSection": "Web Stories",
    "wordCount": @Model.SlideCount,
    "timeRequired": "PT@(TimeSpan.FromMilliseconds(Model.TotalDuration).TotalSeconds)S"
}
</script>

<div class="story-viewer-container">
    <!-- Story Viewer -->
    <div id="story-viewer" class="story-viewer">
        <div class="story-header">
            <div class="story-progress">
                <div class="progress-bar" id="progress-bar"></div>
            </div>
            <div class="story-controls">
                <button id="pause-btn" class="control-btn">
                    <i class="fas fa-pause"></i>
                </button>
                <button id="close-btn" class="control-btn">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>

        <div class="story-content">
            <div id="story-slides" class="story-slides">
                <!-- Slides will be loaded dynamically -->
            </div>
        </div>

        <div class="story-navigation">
            <button id="prev-btn" class="nav-btn">
                <i class="fas fa-chevron-left"></i>
            </button>
            <button id="next-btn" class="nav-btn">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </div>

    <!-- Story Info Panel -->
    <div class="story-info-panel">
        <div class="story-meta">
            <h1 class="story-title">@Model.Title</h1>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="story-description">@Model.Description</p>
            }
            <div class="story-stats">
                <span class="stat">
                    <i class="fas fa-eye"></i> @Model.ViewCount views
                </span>
                <span class="stat">
                    <i class="fas fa-images"></i> @Model.SlideCount slides
                </span>
                <span class="stat">
                    <i class="fas fa-clock"></i> @TimeSpan.FromMilliseconds(Model.TotalDuration).ToString(@"mm\:ss")
                </span>
            </div>
        </div>

        <!-- AdSense Ad Unit -->
        <div class="ad-container">
            <div class="ad-unit">
                <!-- Google AdSense Ad -->
                <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5934633595595089"
                        crossorigin="anonymous"></script>
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-5934633595595089"
                     data-ad-slot="1234567891"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
                <script>
                    (adsbygoogle = window.adsbygoogle || []).push({});
                </script>
            </div>
        </div>

        <!-- Related Stories -->
        <div class="related-stories">
            <h3>More Stories</h3>
            <div id="related-stories-list">
                <!-- Related stories will be loaded here -->
            </div>
        </div>
    </div>
</div>

<!-- Story Data (Hidden) -->
<script type="application/json" id="story-data">
@Html.Raw(Json.Serialize(new {
    storyId = Model.StoryId,
    title = Model.Title,
    slug = Model.Slug,
    description = Model.Description,
    totalDuration = Model.TotalDuration,
    slideCount = Model.SlideCount,
    slides = Model.Slides.OrderBy(s => s.OrderIndex).Select(s => new {
        storySlideId = s.StorySlideId,
        caption = s.Caption,
        headline = s.Headline,
        text = s.Text,
        duration = s.Duration,
        slideType = s.SlideType,
        backgroundColor = s.BackgroundColor,
        textColor = s.TextColor,
        fontSize = s.FontSize,
        alignment = s.Alignment,
        media = s.Media != null ? new {
            url = s.Media.Url,
            thumbnailUrl = s.Media.ThumbnailUrl,
            mediaType = s.Media.MediaType,
            width = s.Media.Width,
            height = s.Media.Height
        } : null
    })
}))
</script>

<style>
.story-viewer-container {
    display: flex;
    min-height: 100vh;
    background: #000;
}

.story-viewer {
    flex: 1;
    position: relative;
    background: #000;
    overflow: hidden;
}

.story-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 20px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.7), transparent);
}

.story-progress {
    width: 100%;
    height: 3px;
    background: rgba(255,255,255,0.3);
    border-radius: 2px;
    margin-bottom: 20px;
}

.progress-bar {
    height: 100%;
    background: #fff;
    border-radius: 2px;
    width: 0%;
    transition: width 0.1s linear;
}

.story-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.control-btn {
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    padding: 8px 12px;
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.2s;
}

.control-btn:hover {
    background: rgba(255,255,255,0.3);
}

.story-content {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
}

.story-slides {
    position: relative;
    width: 100%;
    height: 100%;
}

.story-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.story-slide.active {
    opacity: 1;
}

.story-slide img,
.story-slide video {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
}

.story-slide-content {
    text-align: center;
    color: white;
    padding: 20px;
    max-width: 80%;
}

.story-slide h2 {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1rem;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
}

.story-slide p {
    font-size: 1.2rem;
    line-height: 1.5;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.7);
}

.story-navigation {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    pointer-events: none;
}

.nav-btn {
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    padding: 12px 16px;
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.2s;
    pointer-events: auto;
}

.nav-btn:hover {
    background: rgba(255,255,255,0.3);
}

.story-info-panel {
    width: 350px;
    background: #fff;
    padding: 20px;
    overflow-y: auto;
}

.story-title {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
    color: #333;
}

.story-description {
    color: #666;
    margin-bottom: 1rem;
    line-height: 1.5;
}

.story-stats {
    display: flex;
    gap: 15px;
    margin-bottom: 20px;
}

.stat {
    display: flex;
    align-items: center;
    gap: 5px;
    color: #666;
    font-size: 0.9rem;
}

.ad-container {
    margin: 20px 0;
    padding: 20px;
    background: #f8f9fa;
    border-radius: 8px;
    text-align: center;
}

.ad-unit {
    min-height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.related-stories h3 {
    font-size: 1.2rem;
    margin-bottom: 15px;
    color: #333;
}

@@media (max-width: 768px) {
    .story-viewer-container {
        flex-direction: column;
    }
    
    .story-info-panel {
        width: 100%;
        order: -1;
    }
    
    .story-viewer {
        height: 60vh;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const storyData = JSON.parse(document.getElementById('story-data').textContent);
    const viewer = document.getElementById('story-viewer');
    const slidesContainer = document.getElementById('story-slides');
    const progressBar = document.getElementById('progress-bar');
    const pauseBtn = document.getElementById('pause-btn');
    const closeBtn = document.getElementById('close-btn');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    
    let currentSlide = 0;
    let isPlaying = true;
    let progressInterval;
    let slideTimeout;
    
    // Initialize story
    function initStory() {
        // Create slides
        storyData.slides.forEach((slide, index) => {
            const slideElement = document.createElement('div');
            slideElement.className = 'story-slide';
            slideElement.dataset.index = index;
            
            if (slide.media) {
                if (slide.media.mediaType === 'video') {
                    const video = document.createElement('video');
                    video.src = slide.media.url;
                    video.autoplay = false;
                    video.muted = true;
                    video.loop = false;
                    slideElement.appendChild(video);
                } else {
                    const img = document.createElement('img');
                    img.src = slide.media.url;
                    img.alt = slide.caption || '';
                    slideElement.appendChild(img);
                }
            }
            
            if (slide.headline || slide.text) {
                const content = document.createElement('div');
                content.className = 'story-slide-content';
                content.style.backgroundColor = slide.backgroundColor || 'transparent';
                content.style.color = slide.textColor || 'white';
                content.style.fontSize = slide.fontSize || '1rem';
                content.style.textAlign = slide.alignment || 'center';
                
                if (slide.headline) {
                    const h2 = document.createElement('h2');
                    h2.textContent = slide.headline;
                    content.appendChild(h2);
                }
                
                if (slide.text) {
                    const p = document.createElement('p');
                    p.textContent = slide.text;
                    content.appendChild(p);
                }
                
                slideElement.appendChild(content);
            }
            
            slidesContainer.appendChild(slideElement);
        });
        
        showSlide(0);
        startProgress();
    }
    
    function showSlide(index) {
        const slides = document.querySelectorAll('.story-slide');
        slides.forEach(slide => slide.classList.remove('active'));
        
        if (slides[index]) {
            slides[index].classList.add('active');
        }
    }
    
    function nextSlide() {
        if (currentSlide < storyData.slides.length - 1) {
            currentSlide++;
            showSlide(currentSlide);
            startProgress();
        } else {
            // Story ended
            pauseStory();
        }
    }
    
    function prevSlide() {
        if (currentSlide > 0) {
            currentSlide--;
            showSlide(currentSlide);
            startProgress();
        }
    }
    
    function startProgress() {
        clearInterval(progressInterval);
        clearTimeout(slideTimeout);
        
        if (!isPlaying) return;
        
        const slide = storyData.slides[currentSlide];
        const duration = slide.duration || 5000;
        const progressStep = 100 / (duration / 100);
        let progress = 0;
        
        progressInterval = setInterval(() => {
            if (!isPlaying) return;
            
            progress += progressStep;
            progressBar.style.width = progress + '%';
            
            if (progress >= 100) {
                clearInterval(progressInterval);
                nextSlide();
            }
        }, 100);
        
        slideTimeout = setTimeout(() => {
            if (isPlaying) {
                nextSlide();
            }
        }, duration);
    }
    
    function pauseStory() {
        isPlaying = false;
        clearInterval(progressInterval);
        clearTimeout(slideTimeout);
        pauseBtn.innerHTML = '<i class="fas fa-play"></i>';
    }
    
    function playStory() {
        isPlaying = true;
        pauseBtn.innerHTML = '<i class="fas fa-pause"></i>';
        startProgress();
    }
    
    // Event listeners
    pauseBtn.addEventListener('click', () => {
        if (isPlaying) {
            pauseStory();
        } else {
            playStory();
        }
    });
    
    closeBtn.addEventListener('click', () => {
        window.location.href = '/stories';
    });
    
    prevBtn.addEventListener('click', () => {
        prevSlide();
    });
    
    nextBtn.addEventListener('click', () => {
        nextSlide();
    });
    
    // Touch/swipe support
    let startX = 0;
    let startY = 0;
    
    viewer.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
    });
    
    viewer.addEventListener('touchend', (e) => {
        const endX = e.changedTouches[0].clientX;
        const endY = e.changedTouches[0].clientY;
        const diffX = startX - endX;
        const diffY = startY - endY;
        
        if (Math.abs(diffX) > Math.abs(diffY)) {
            if (diffX > 50) {
                nextSlide();
            } else if (diffX < -50) {
                prevSlide();
            }
        }
    });
    
    // Keyboard support
    document.addEventListener('keydown', (e) => {
        switch(e.key) {
            case 'ArrowLeft':
                prevSlide();
                break;
            case 'ArrowRight':
                nextSlide();
                break;
            case ' ':
                e.preventDefault();
                if (isPlaying) {
                    pauseStory();
                } else {
                    playStory();
                }
                break;
        }
    });
    
    // Initialize
    initStory();
});
</script>
