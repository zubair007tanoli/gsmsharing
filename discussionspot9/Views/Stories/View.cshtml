@model discussionspot9.Models.Domain.Story
@{
    ViewData["Title"] = Model.Title;
    ViewData["Description"] = Model.Description ?? $"Read {Model.Title} on DiscussionSpot";
    ViewData["CanonicalUrl"] = Url.Action("ViewStory", "Stories", new { slug = Model.Slug }, Context.Request.Scheme);
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <!-- Story Header -->
            <div class="story-header text-center py-4 mb-4">
                <div class="container">
                    <h1 class="display-4 fw-bold text-primary mb-3">@Model.Title</h1>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="lead text-muted mb-4">@Model.Description</p>
                    }
                    <div class="story-meta d-flex justify-content-center align-items-center gap-4 text-muted">
                        <span><i class="fas fa-user me-2"></i>@(Model.User?.UserName ?? "Unknown")</span>
                        <span><i class="fas fa-calendar me-2"></i>@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                        <span><i class="fas fa-images me-2"></i>@(Model.Slides?.Count ?? 0) slides</span>
            </div>
            </div>
        </div>

            <!-- Story Content -->
        <div class="story-content">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        @if (Model.Slides != null && Model.Slides.Any())
                        {
                            <div class="story-slides-container">
                                @foreach (var slide in Model.Slides.OrderBy(s => s.OrderIndex))
                                {
                                    <div class="story-slide-card mb-4">
                                        <div class="slide-content" style="background: @slide.BackgroundColor; color: @slide.TextColor; text-align: @slide.Alignment;">
                                            @if (!string.IsNullOrEmpty(slide.Headline))
                                            {
                                                <h2 class="slide-headline">@slide.Headline</h2>
                                            }
                                            @if (!string.IsNullOrEmpty(slide.Text))
                                            {
                                                <p class="slide-text">@slide.Text</p>
                                            }
                                            @if (!string.IsNullOrEmpty(slide.Caption))
                                            {
                                                <p class="slide-caption">@slide.Caption</p>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(slide.MediaUrl))
                                        {
                                            <div class="slide-media">
                                                @if (IsVideoFile(slide.MediaUrl))
                                                {
                                                    <video class="slide-video" controls>
                                                        <source src="@slide.MediaUrl" type="video/mp4">
                                                        Your browser does not support the video tag.
                                                    </video>
                                                }
                                                else
                                                {
                                                    <img class="slide-image" src="@slide.MediaUrl" alt="@slide.Caption" />
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-images fa-3x text-muted mb-3"></i>
                                <h4 class="text-muted">No slides available</h4>
                                <p class="text-muted">This story doesn't have any slides yet.</p>
                            </div>
                        }
                    </div>
            </div>
        </div>

            <!-- Story Actions -->
            <div class="story-actions text-center py-4">
                <div class="btn-group" role="group">
                    <a href="/stories/viewer/@Model.Slug" class="btn btn-primary btn-lg">
                        <i class="fas fa-play me-2"></i>View as Story
                    </a>
                    <a href="/stories/@Model.Slug/edit" class="btn btn-outline-primary btn-lg">
                        <i class="fas fa-edit me-2"></i>Edit Story
                    </a>
                    <button class="btn btn-outline-secondary btn-lg" onclick="shareStory()">
                        <i class="fas fa-share-alt me-2"></i>Share
            </button>
        </div>
    </div>

            <!-- Related Stories -->
            <div class="related-stories mt-5">
                <div class="container">
                    <h3 class="text-center mb-4">More Stories</h3>
                    <div class="row">
                        <!-- This would be populated with related stories -->
                        <div class="col-lg-4 mb-4">
                            <div class="card h-100">
                                <div class="card-body text-center">
                                    <i class="fas fa-plus fa-2x text-muted mb-3"></i>
                                    <h5>Create Your Own Story</h5>
                                    <p class="text-muted">Start creating engaging visual stories today</p>
                                    <a href="/stories/create" class="btn btn-primary">Get Started</a>
                                </div>
            </div>
        </div>
            </div>
        </div>
            </div>
        </div>
    </div>
</div>

<style>
.story-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 15px;
    margin-bottom: 2rem;
}

.story-slide-card {
    background: white;
    border-radius: 15px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    overflow: hidden;
    transition: transform 0.3s ease;
}

.story-slide-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}

.slide-content {
    padding: 2rem;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.slide-headline {
    font-size: 2rem;
    font-weight: bold;
    margin-bottom: 1rem;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
}

.slide-text {
    font-size: 1.2rem;
    line-height: 1.6;
    margin-bottom: 1rem;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
}

.slide-caption {
    font-size: 1rem;
    opacity: 0.8;
    font-style: italic;
}

.slide-media {
    width: 100%;
    height: 300px;
    overflow: hidden;
}

.slide-video,
.slide-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.story-actions {
    background: #f8f9fa;
    border-radius: 15px;
    margin: 2rem 0;
}

.btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    transition: all 0.3s ease;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
}

<style>
@@media (max-width: 768px) {
    .story-header h1 {
        font-size: 2rem;
    }
    
    .slide-content {
        padding: 1.5rem;
    }
    
    .slide-headline {
    font-size: 1.5rem;
    }
    
    .slide-text {
        font-size: 1rem;
    }
}
</style>

<script>
function shareStory() {
    if (navigator.share) {
        navigator.share({
            title: '@Model.Title',
            text: '@Model.Description',
            url: window.location.href
        });
                } else {
        // Fallback to copying URL
        navigator.clipboard.writeText(window.location.href).then(function() {
            alert('Story URL copied to clipboard!');
        });
    }
}
</style>
</script>

@functions {
    private bool IsVideoFile(string url)
    {
        var videoExtensions = new[] { ".mp4", ".webm", ".ogg", ".avi", ".mov" };
        return videoExtensions.Any(ext => url.ToLower().EndsWith(ext));
    }
}