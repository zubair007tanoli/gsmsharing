@model discussionspot9.Models.Domain.Story
@{
    Layout = null;
    ViewData["Title"] = Model.Title;
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    string MakeAbsolute(string? url) {
        if (string.IsNullOrWhiteSpace(url)) return string.Empty;
        if (url.StartsWith("http://") || url.StartsWith("https://")) return url;
        if (url.StartsWith("/")) return baseUrl + url;
        return baseUrl + "/" + url;
    }
}

<!DOCTYPE html>
<html ⚡ lang="en">
<head>
    <meta charset="utf-8">
    <script async src="https://cdn.ampproject.org/v0.js"></script>
    <meta name="viewport" content="width=device-width,minimum-scale=1,initial-scale=1">
    <title>@Model.Title</title>
    <link rel="canonical" href="@Url.Action("Viewer", "Stories", new { slug = Model.Slug }, Context.Request.Scheme)">
    <meta name="description" content="@System.Net.WebUtility.HtmlEncode(Model.MetaDescription ?? Model.Description ?? $"Read {Model.Title} on DiscussionSpot")">
    <meta name="keywords" content="@(Model.MetaKeywords ?? ExtractKeywords(Model.Title))">
    <meta name="author" content="@(Model.User?.UserName ?? "DiscussionSpot")">
    <meta property="og:type" content="article">
    <meta property="og:title" content="@System.Net.WebUtility.HtmlEncode(Model.Title)">
    <meta property="og:description" content="@System.Net.WebUtility.HtmlEncode(Model.MetaDescription ?? Model.Description ?? $"Read {Model.Title} on DiscussionSpot")">
    <meta property="og:image" content="@MakeAbsolute(Model.Slides?.OrderBy(s => s.OrderIndex).Select(s => s.MediaUrl).FirstOrDefault() ?? "/Assets/Logo_Auth.png")">
    <meta property="og:url" content="@Url.Action("Amp", "Stories", new { slug = Model.Slug }, Context.Request.Scheme)">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@System.Net.WebUtility.HtmlEncode(Model.Title)">
    <meta name="twitter:description" content="@System.Net.WebUtility.HtmlEncode(Model.MetaDescription ?? Model.Description ?? $"Read {Model.Title} on DiscussionSpot")">
    <meta name="twitter:image" content="@MakeAbsolute(Model.Slides?.OrderBy(s => s.OrderIndex).Select(s => s.MediaUrl).FirstOrDefault() ?? "/Assets/Logo_Auth.png")">
    
    <!-- Preload hero media -->
    @{ 
        var hero = Model.Slides?.OrderBy(s => s.OrderIndex)
            .Where(s => !string.IsNullOrEmpty(s.MediaUrl) && !IsVideoFile(s.MediaUrl))
            .Select(s => MakeAbsolute(s.MediaUrl))
            .FirstOrDefault() ?? MakeAbsolute("/Assets/Logo_Auth.png");
    }
    <link rel="preload" as="image" href="@hero">
    
    <!-- Preload next 2 slides for better performance -->
    @if (Model.Slides != null && Model.Slides.Any())
    {
        var nextSlides = Model.Slides.OrderBy(s => s.OrderIndex).Skip(1).Take(2);
        foreach (var slide in nextSlides)
        {
            if (!string.IsNullOrEmpty(slide.MediaUrl) && !IsVideoFile(slide.MediaUrl))
            {
                <link rel="preload" as="image" href="@MakeAbsolute(slide.MediaUrl)">
            }
        }
    }
    
    <!-- AMP Story Required -->
    <script async custom-element="amp-story" src="https://cdn.ampproject.org/v0/amp-story-1.0.js"></script>
    
    <!-- AMP Story Bookend -->
    <script async custom-element="amp-story-bookend" src="https://cdn.ampproject.org/v0/amp-story-bookend-1.0.js"></script>
    
    <!-- AMP Story Grid Layer -->
    <script async custom-element="amp-story-grid-layer" src="https://cdn.ampproject.org/v0/amp-story-grid-layer-1.0.js"></script>
    
    <!-- AMP Story Page Attachment -->
    <script async custom-element="amp-story-page-attachment" src="https://cdn.ampproject.org/v0/amp-story-page-attachment-1.0.js"></script>

    <!-- AMP Analytics -->
    <script async custom-element="amp-analytics" src="https://cdn.ampproject.org/v0/amp-analytics-0.1.js"></script>

    <style amp-boilerplate>body{-webkit-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-moz-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-ms-animation:-amp-start 8s steps(1,end) 0s 1 normal both;animation:-amp-start 8s steps(1,end) 0s 1 normal both}@@-webkit-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@@-moz-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@@-ms-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@@-o-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@@keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}</style><noscript><style amp-boilerplate>body{-webkit-animation:none;-moz-animation:none;-ms-animation:none;animation:none}</style></noscript>
    
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "Article",
      "@@id": "@Url.Action("Amp", "Stories", new { slug = Model.Slug }, Context.Request.Scheme)",
      "headline": "@System.Text.Json.JsonSerializer.Serialize(Model.Title ?? "")",
      "description": "@System.Text.Json.JsonSerializer.Serialize(Model.Description ?? Model.MetaDescription ?? $"Read {Model.Title} on DiscussionSpot")",
      "datePublished": "@Model.CreatedAt.ToString("o")",
      "dateModified": "@Model.UpdatedAt.ToString("o")",
      "author": {
        "@@type": "Person",
        "name": "@(Model.User?.UserName ?? "DiscussionSpot")",
        "url": "@($"{Context.Request.Scheme}://{Context.Request.Host}/user/{Model.User?.UserName ?? ""}")"
      },
      "publisher": {
        "@@type": "Organization",
        "name": "@(Model.PublisherName ?? "DiscussionSpot")",
        "logo": {
          "@@type": "ImageObject",
          "url": "@($"{Context.Request.Scheme}://{Context.Request.Host}/Assets/Logo_Auth.png")"
        }
      },
      "mainEntityOfPage": {
        "@@type": "WebPage",
        "@@id": "@Url.Action("Viewer", "Stories", new { slug = Model.Slug }, Context.Request.Scheme)"
      },
      "image": [
        @{
            var imageUrls = Model.Slides != null && Model.Slides.Any()
                ? Model.Slides.OrderBy(s => s.OrderIndex)
                    .Where(s => !string.IsNullOrEmpty(s.MediaUrl) && !IsVideoFile(s.MediaUrl))
                    .Select(s => MakeAbsolute(s.MediaUrl))
                    .Take(5)
                    .ToList()
                : new List<string>();
            
            if (!imageUrls.Any())
            {
                imageUrls.Add(MakeAbsolute("/Assets/Logo_Auth.png"));
            }
            
            var imageJson = System.Text.Json.JsonSerializer.Serialize(imageUrls);
            @Html.Raw(imageJson.Replace("[", "").Replace("]", "")) // Remove array brackets, keep commas
        }
      ],
      "keywords": "@(Model.MetaKeywords ?? ExtractKeywords(Model.Title))",
      "articleSection": "@(Model.Community?.Title ?? "General")",
      "inLanguage": "en-US",
      "isAccessibleForFree": true,
      "copyrightYear": "@DateTime.Now.Year",
      "copyrightHolder": {
        "@@type": "Organization",
        "name": "DiscussionSpot"
      }
    }
    </script>

    <!-- AMP Custom Styles - Inline for AMP validation -->
    <style amp-custom>
        /* AMP-specific styles - isolated from global CSS */
        html[amp], html[amp] body {
            height: 100%;
            margin: 0;
            padding: 0;
            overflow: hidden;
        }
        
        amp-story {
            font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            height: 100vh;
            width: 100vw;
            background: #000;
        }
        
        amp-story-page {
            background: #000;
        }
        
        .story-page {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            width: 100%;
            height: 100%;
        }
        
        amp-story-page .story-headline {
            font-size: clamp(1.5rem, 4vw, 2.5rem);
            font-weight: 700;
            color: #ffffff;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5), 0 0 20px rgba(0, 0, 0, 0.3);
            text-align: center;
            margin: 1rem 0;
            padding: 0 1rem;
            line-height: 1.2;
            word-wrap: break-word;
            max-width: 100%;
        }
        
        amp-story-page .story-text {
            font-size: clamp(1rem, 3vw, 1.5rem);
            color: #ffffff;
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5), 0 0 15px rgba(0, 0, 0, 0.3);
            text-align: center;
            line-height: 1.6;
            margin: 0.75rem 0;
            padding: 0 1rem;
            word-wrap: break-word;
            max-width: 100%;
        }
        
        amp-story-page .story-caption {
            font-size: clamp(0.875rem, 2vw, 1rem);
            color: rgba(255, 255, 255, 0.85);
            text-align: center;
            font-style: italic;
            margin: 0.5rem 0;
            padding: 0 1rem;
            opacity: 0.9;
        }
        
        amp-story-page .gradient-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.0) 50%);
            pointer-events: none;
            z-index: 1;
        }
        
        amp-story-page amp-img,
        amp-story-page amp-img img {
            object-fit: cover;
        }
        
        amp-story-page amp-video,
        amp-story-page amp-video video {
            object-fit: cover;
        }
        
        amp-story-grid-layer {
            padding: 0;
        }
        
        amp-story-grid-layer[template="vertical"] {
            padding: 0 1rem;
            align-items: center;
            justify-content: center;
        }
        
        @@media (max-width: 414px) {
            amp-story-page .story-headline {
                font-size: 1.5rem;
                margin: 0.75rem 0;
            }
            
            amp-story-page .story-text {
                font-size: 1rem;
                margin: 0.5rem 0;
            }
            
            amp-story-page .story-caption {
                font-size: 0.875rem;
            }
        }
    </style>
</head>
<body>
    @{
        var firstSlideImage = Model.Slides?.OrderBy(s => s.OrderIndex)
            .Where(s => !string.IsNullOrEmpty(s.MediaUrl) && !IsVideoFile(s.MediaUrl))
            .Select(s => MakeAbsolute(s.MediaUrl))
            .FirstOrDefault() ?? $"{Context.Request.Scheme}://{Context.Request.Host}/Assets/Logo_Auth.png";
        var publisherLogo = MakeAbsolute(Model.PublisherLogo) ?? $"{Context.Request.Scheme}://{Context.Request.Host}/Assets/Logo_Auth.png";
    }
    <amp-story standalone="standalone" 
               title="@System.Net.WebUtility.HtmlEncode(Model.Title)"
               publisher="@(Model.PublisherName ?? "DiscussionSpot")"
               publisher-logo-src="@publisherLogo"
               poster-portrait-src="@firstSlideImage"
               poster-landscape-src="@firstSlideImage"
               poster-square-src="@firstSlideImage"
               theme-color="#667eea">
        
        @{
            // CRITICAL: Determine correct post URL for internal linking
            var defaultPostUrl = Model.Post != null 
                ? $"/r/{Model.Post.Community?.Slug}/posts/{Model.Post.Slug}"
                : "";
            var orderedSlides = Model.Slides?.OrderBy(s => s.OrderIndex).ToList() ?? new List<discussionspot9.Models.Domain.StorySlide>();
            var maxOrderIndex = orderedSlides.Any() ? orderedSlides.Max(s => s.OrderIndex) : -1;
        }
        
        @if (Model.Slides != null && Model.Slides.Any())
        {
            @foreach (var slide in orderedSlides)
            {
                var isLastSlide = slide.OrderIndex == maxOrderIndex;
                var isCta = slide.SlideType == "cta";
                var isLink = slide.MediaType == "internal_link" || slide.MediaType == "external_link";
                var linkUrl = "";
                
                // Determine link URL for CTA or link slides
                if (isLink || isCta)
                {
                    if (slide.MediaType == "internal_link" && !string.IsNullOrEmpty(slide.MediaUrl))
                    {
                        // Fix wrong URL format if present
                        var mediaUrl = slide.MediaUrl;
                        if (mediaUrl.Contains("/post/") && !mediaUrl.Contains("/posts/"))
                        {
                            // Fix: /post/communitySlug/postSlug -> /r/communitySlug/posts/postSlug
                            var parts = mediaUrl.Replace("/post/", "/").Split('/');
                            if (parts.Length >= 3)
                            {
                                mediaUrl = $"/r/{parts[1]}/posts/{string.Join("/", parts.Skip(2))}";
                            }
                        }
                        
                        // Always use correct format from Model.Post if available
                        if (!string.IsNullOrEmpty(defaultPostUrl))
                        {
                            linkUrl = defaultPostUrl;
                        }
                        else
                        {
                            linkUrl = mediaUrl.StartsWith("http") ? mediaUrl : mediaUrl;
                        }
                    }
                    else if (slide.MediaType == "external_link" && !string.IsNullOrEmpty(slide.MediaUrl))
                    {
                        linkUrl = slide.MediaUrl;
                    }
                    else if (!string.IsNullOrEmpty(defaultPostUrl))
                    {
                        linkUrl = defaultPostUrl;
                    }
                }
                
                // If last slide and no link, add post link
                if (isLastSlide && string.IsNullOrEmpty(linkUrl) && !string.IsNullOrEmpty(defaultPostUrl))
                {
                    linkUrl = defaultPostUrl;
                    isCta = true;
                }
                
                var src = MakeAbsolute(slide.MediaUrl);
                <amp-story-page id="page-@slide.OrderIndex">
                    <amp-story-grid-layer template="fill">
                        @if (!string.IsNullOrEmpty(slide.MediaUrl) && !isLink)
                        {
                            @if (IsVideoFile(slide.MediaUrl))
                            {
                                <amp-video autoplay loop muted layout="fill" poster="@src">
                                    <source src="@src" type="video/mp4">
                                </amp-video>
                            }
                            else
                            {
                                <amp-img src="@src" layout="fill" alt="@slide.Caption" loading="lazy"></amp-img>
                            }
                        }
                        else
                        {
                            <div class="story-page"></div>
                        }
                    </amp-story-grid-layer>
                    
                    <amp-story-grid-layer template="vertical">
                        <div class="gradient-overlay"></div>
                        @if (!string.IsNullOrEmpty(slide.Headline))
                        {
                            <h1 class="story-headline">@slide.Headline</h1>
                        }
                        @if (!string.IsNullOrEmpty(slide.Text))
                        {
                            <p class="story-text">@StripHtml(slide.Text)</p>
                        }
                        @if (!string.IsNullOrEmpty(slide.Caption))
                        {
                            <p class="story-caption">@slide.Caption</p>
                        }
                    </amp-story-grid-layer>
                    
                    @* CRITICAL: Add CTA link for CTA slides, link slides, or last slide *@
                    @* Use amp-story-page-outlink for external links (opens in new tab) *@
                    @if ((isCta || isLink || isLastSlide) && !string.IsNullOrEmpty(linkUrl))
                    {
                        @if (slide.MediaType == "external_link" || linkUrl.StartsWith("http"))
                        {
                            <amp-story-page-outlink layout="nodisplay">
                                <a href="@linkUrl" target="_blank" rel="noopener">
                                    @(isLink && slide.MediaType == "external_link" ? "Visit Link" : "View Original Post")
                                </a>
                            </amp-story-page-outlink>
                        }
                        else
                        {
                            @* For internal links, use page attachment (swipe up) - make URL absolute *@
                            @* CRITICAL: amp-story-page-attachment must have a single root element with proper HTML structure *@
                            var absoluteLinkUrl = linkUrl.StartsWith("http") ? linkUrl : $"{Context.Request.Scheme}://{Context.Request.Host}{linkUrl}";
                            var attachmentTitle = isLink && slide.MediaType == "external_link" ? "Visit External Link" : "View Original Post";
                            var attachmentText = isLink && slide.MediaType == "external_link" 
                                ? (slide.MediaUrl ?? "Visit link") 
                                : (Model.Post != null ? $"Read the full discussion: {Model.Post.Title}" : "Read more on DiscussionSpot");
                            <amp-story-page-attachment layout="nodisplay" href="@absoluteLinkUrl" theme="dark">
                                <h1>@attachmentTitle</h1>
                                <p>@attachmentText</p>
                            </amp-story-page-attachment>
                        }
                    }
                </amp-story-page>
            }
        }
        else
        {
            <amp-story-page id="page-1">
                <amp-story-grid-layer template="fill">
                    <div class="story-page"></div>
                </amp-story-grid-layer>
                <amp-story-grid-layer template="vertical">
                    <h1 class="story-headline">@Model.Title</h1>
                    <p class="story-text">@(Model.Description ?? "Welcome to this story!")</p>
                </amp-story-grid-layer>
            </amp-story-page>
        }
        
        @* CRITICAL: amp-analytics must come BEFORE amp-story-bookend *@
        <amp-analytics type="googleanalytics">
          <script type="application/json">
          {
            "vars": { "account": "UA-XXXXX-Y" },
            "triggers": {
              "storyStart": { "on": "story-page-visible", "request": "pageview" },
              "storyAdvance": { "on": "story-next", "request": "event", "vars": { "eventCategory": "Story", "eventAction": "Next" } },
              "storyEnd": { "on": "story-end", "request": "event", "vars": { "eventCategory": "Story", "eventAction": "Complete" } }
            }
          }
          </script>
        </amp-analytics>

        @* CRITICAL: amp-story-bookend MUST be the LAST child of amp-story *@
        <amp-story-bookend layout="nodisplay">
            <script type="application/json">
            {
                "bookendVersion": "v1.0",
                "shareProviders": [
                    { "provider": "facebook" },
                    { "provider": "twitter" }
                ],
                "components": @(ViewBag.BookendComponents ?? "[]")
            }
            </script>
        </amp-story-bookend>
    </amp-story>
</body>
</html>

@functions {
    private bool IsVideoFile(string url)
    {
        var videoExtensions = new[] { ".mp4", ".webm", ".ogg", ".avi", ".mov" };
        return videoExtensions.Any(ext => url.ToLower().EndsWith(ext));
    }
    
    private string ExtractKeywords(string title)
    {
        if (string.IsNullOrEmpty(title)) return "web story, discussion";
        
        var keywords = title.ToLowerInvariant()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Where(word => word.Length > 3)
            .Take(5)
            .ToList();
            
        if (!keywords.Any()) return "web story, discussion";
        
        return string.Join(", ", keywords);
    }
    
    public static string StripHtml(string input)
    {
        if (string.IsNullOrEmpty(input))
            return string.Empty;
            
        // Remove HTML tags using regex
        return System.Text.RegularExpressions.Regex.Replace(input, "<.*?>", string.Empty).Trim();
    }
}