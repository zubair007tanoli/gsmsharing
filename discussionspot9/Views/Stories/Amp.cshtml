@model discussionspot9.Models.Domain.Story
@{
    Layout = null;
    ViewData["Title"] = Model.Title;
}

<!DOCTYPE html>
<html amp>
<head>
    <meta charset="utf-8">
    <script async src="https://cdn.ampproject.org/v0.js"></script>
    <title>@Model.Title</title>
    <link rel="canonical" href="@Url.Action("ViewStory", "Stories", new { slug = Model.Slug }, Context.Request.Scheme)">
    <meta name="viewport" content="width=device-width,minimum-scale=1,initial-scale=1">
    <meta name="description" content="@(Model.Description ?? $"Read {Model.Title} on DiscussionSpot")">
    
    <!-- AMP Story Required -->
    <script async custom-element="amp-story" src="https://cdn.ampproject.org/v0/amp-story-1.0.js"></script>
    
    <!-- AMP Story Bookend -->
    <script async custom-element="amp-story-bookend" src="https://cdn.ampproject.org/v0/amp-story-bookend-1.0.js"></script>
    
    <!-- AMP Story Grid Layer -->
    <script async custom-element="amp-story-grid-layer" src="https://cdn.ampproject.org/v0/amp-story-grid-layer-1.0.js"></script>
    
    <!-- AMP Story Page Attachment -->
    <script async custom-element="amp-story-page-attachment" src="https://cdn.ampproject.org/v0/amp-story-page-attachment-1.0.js"></script>
    
    <style amp-custom>
        amp-story {
            font-family: 'Roboto', sans-serif;
        }
        
        .story-page {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        
        .story-headline {
            font-size: 2.5rem;
            font-weight: bold;
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
            text-align: center;
            margin: 2rem 0;
        }
        
        .story-text {
            font-size: 1.5rem;
            color: white;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
            text-align: center;
            line-height: 1.6;
            margin: 1rem 0;
        }
        
        .story-caption {
            font-size: 1rem;
            color: rgba(255,255,255,0.8);
            text-align: center;
            font-style: italic;
            margin: 1rem 0;
        }
        
        .story-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .story-video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
    </style>
</head>
<body>
    <amp-story standalone 
               title="@Model.Title"
               publisher="DiscussionSpot"
               publisher-logo-src="@($"{Context.Request.Scheme}://{Context.Request.Host}/Assets/Logo_Auth.png")"
               poster-portrait-src="@($"{Context.Request.Scheme}://{Context.Request.Host}/Assets/Logo_Auth.png")">
        
        @if (Model.Slides != null && Model.Slides.Any())
        {
            @foreach (var slide in Model.Slides.OrderBy(s => s.OrderIndex))
            {
                <amp-story-page id="page-@slide.OrderIndex">
                    <amp-story-grid-layer template="fill">
                        @if (slide.Media != null && !string.IsNullOrEmpty(slide.Media.Url))
                        {
                            @if (IsVideoFile(slide.Media.Url))
                            {
                                <amp-video autoplay loop width="720" height="1280" poster="@slide.Media.Url">
                                    <source src="@slide.Media.Url" type="video/mp4">
                                </amp-video>
                            }
                            else
                            {
                                <amp-img src="@slide.Media.Url" width="720" height="1280" layout="fill" alt="@slide.Caption"></amp-img>
                            }
                        }
                        else
                        {
                            <div class="story-page" style="background: @slide.BackgroundColor;"></div>
                        }
                    </amp-story-grid-layer>
                    
                    <amp-story-grid-layer template="vertical">
                        @if (!string.IsNullOrEmpty(slide.Headline))
                        {
                            <h1 class="story-headline">@slide.Headline</h1>
                        }
                        @if (!string.IsNullOrEmpty(slide.Text))
                        {
                            <p class="story-text">@slide.Text</p>
                        }
                        @if (!string.IsNullOrEmpty(slide.Caption))
                        {
                            <p class="story-caption">@slide.Caption</p>
                        }
                    </amp-story-grid-layer>
                </amp-story-page>
            }
        }
        else
        {
            <amp-story-page id="page-1">
                <amp-story-grid-layer template="fill">
                    <div class="story-page"></div>
                </amp-story-grid-layer>
                <amp-story-grid-layer template="vertical">
                    <h1 class="story-headline">@Model.Title</h1>
                    <p class="story-text">@(Model.Description ?? "Welcome to this story!")</p>
                </amp-story-grid-layer>
            </amp-story-page>
        }
        
        <!-- Story Bookend -->
        <amp-story-bookend layout="nodisplay">
            <script type="application/json">
            {
                "bookendVersion": "v1.0",
                "shareProviders": [
                    {
                        "provider": "facebook",
                        "appId": "your-facebook-app-id"
                    },
                    {
                        "provider": "twitter"
                    }
                ],
                "components": [
                    {
                        "type": "heading",
                        "text": "More Stories"
                    },
                    {
                        "type": "small",
                        "title": "Create Your Own Story",
                        "url": "/stories/create",
                        "image": "@($"{Context.Request.Scheme}://{Context.Request.Host}/Assets/Logo_Auth.png")"
                    }
                ]
            }
            </script>
        </amp-story-bookend>
    </amp-story>
</body>
</html>

@functions {
    private bool IsVideoFile(string url)
    {
        var videoExtensions = new[] { ".mp4", ".webm", ".ogg", ".avi", ".mov" };
        return videoExtensions.Any(ext => url.ToLower().EndsWith(ext));
    }
}