@{
    ViewData["Title"] = "Explore Stories";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0"><i class="fas fa-book-open me-2"></i>Explore Stories</h1>
        <a class="btn btn-primary" href="/stories/create"><i class="fas fa-plus me-2"></i>Create Story</a>
    </div>

    <div class="row g-3">
        @foreach (var item in (IEnumerable<dynamic>)ViewBag.Items)
        {
            <div class="col-md-4 col-lg-3">
                <a class="card h-100 text-decoration-none" href="/stories/viewer/@item.Slug">
                    <div class="ratio ratio-9x16 bg-light">
                        <img src="@(item.Cover ?? "/images/story-placeholder-9x16.png")" class="w-100 h-100" style="object-fit: cover;" alt="@item.Title" />
                    </div>
                    <div class="card-body">
                        <div class="small text-muted">by @item.Author</div>
                        <div class="fw-semibold text-truncate">@item.Title</div>
                    </div>
                </a>
            </div>
        }
    </div>

    <div class="d-flex justify-content-center mt-4">
        @if ((bool)ViewBag.HasMore)
        {
            <a class="btn btn-outline-secondary" href="/stories/explore?page=@(((int)ViewBag.Page) + 1)">Load more</a>
        }
    </div>
</div>


