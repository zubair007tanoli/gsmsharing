@{
    ViewData["Title"] = "Advertise With Us - DiscussionSpot";
}

<div class="container my-5">
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <h1 class="display-4 mb-4">Advertise With Us</h1>
            <p class="lead mb-5">Reach millions of engaged users across diverse communities on DiscussionSpot.</p>
            
            <div class="row mb-5">
                <div class="col-md-4 text-center mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <i class="fas fa-users fa-3x text-primary mb-3"></i>
                            <h3 class="h5">Engaged Audience</h3>
                            <p class="text-muted">Connect with highly engaged users actively participating in discussions.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 text-center mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <i class="fas fa-bullseye fa-3x text-primary mb-3"></i>
                            <h3 class="h5">Targeted Reach</h3>
                            <p class="text-muted">Target specific communities and interests for maximum impact.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 text-center mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <i class="fas fa-chart-line fa-3x text-primary mb-3"></i>
                            <h3 class="h5">Measurable Results</h3>
                            <p class="text-muted">Track performance with detailed analytics and insights.</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card shadow-sm mb-5">
                <div class="card-body p-5">
                    <h2 class="h3 mb-4">Advertising Options</h2>
                    
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <h3 class="h5"><i class="fas fa-rectangle-ad text-primary me-2"></i>Display Ads</h3>
                            <p>Banner and sidebar advertisements prominently displayed throughout the platform.</p>
                        </div>
                        <div class="col-md-6 mb-4">
                            <h3 class="h5"><i class="fas fa-newspaper text-primary me-2"></i>Sponsored Posts</h3>
                            <p>Native advertising that blends seamlessly with organic content in community feeds.</p>
                        </div>
                        <div class="col-md-6 mb-4">
                            <h3 class="h5"><i class="fas fa-crown text-primary me-2"></i>Community Partnerships</h3>
                            <p>Sponsor entire communities to build brand awareness within targeted audiences.</p>
                        </div>
                        <div class="col-md-6 mb-4">
                            <h3 class="h5"><i class="fas fa-video text-primary me-2"></i>Video Ads</h3>
                            <p>Engage users with video advertisements in high-traffic areas.</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card shadow-sm">
                <div class="card-body p-5">
                    <h2 class="h3 mb-4">Get Started</h2>
                    <p class="mb-4">Interested in advertising on DiscussionSpot? Contact our advertising team to discuss your goals and create a custom campaign.</p>
                    
                    <form action="#" method="post" class="needs-validation" novalidate>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="company" class="form-label">Company Name</label>
                                <input type="text" class="form-control" id="company" name="company" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="email" class="form-label">Email Address</label>
                                <input type="email" class="form-control" id="email" name="email" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="budget" class="form-label">Monthly Budget</label>
                                <select class="form-select" id="budget" name="budget" required>
                                    <option value="">Select budget range...</option>
                                    <option value="< $1,000">< $1,000</option>
                                    <option value="$1,000 - $5,000">$1,000 - $5,000</option>
                                    <option value="$5,000 - $10,000">$5,000 - $10,000</option>
                                    <option value="$10,000+">$10,000+</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="adType" class="form-label">Advertising Type</label>
                                <select class="form-select" id="adType" name="adType" required>
                                    <option value="">Select ad type...</option>
                                    <option value="Display Ads">Display Ads</option>
                                    <option value="Sponsored Posts">Sponsored Posts</option>
                                    <option value="Community Partnership">Community Partnership</option>
                                    <option value="Video Ads">Video Ads</option>
                                    <option value="Not Sure">Not Sure - Need Consultation</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="message" class="form-label">Tell us about your campaign</label>
                            <textarea class="form-control" id="message" name="message" rows="4" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg">Request Information</button>
                    </form>
                    
                    <hr class="my-4">
                    
                    <p class="text-muted mb-0">
                        <i class="fas fa-envelope me-2"></i>
                        Or email us directly at: <a href="mailto:advertising@discussionspot.com">advertising@discussionspot.com</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

