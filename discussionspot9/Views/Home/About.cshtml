@{
    ViewData["Title"] = "About Us - DiscussionSpot";
}

<div class="container my-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="display-4 mb-4">About DiscussionSpot</h1>
            
            <div class="card shadow-sm mb-4">
                <div class="card-body p-5">
                    <h2 class="h3 mb-3">Our Mission</h2>
                    <p class="lead">
                        DiscussionSpot is a community-driven platform where knowledge meets community. We believe in creating a space where people can freely share ideas, learn from each other, and build meaningful connections.
                    </p>
                    
                    <h2 class="h3 mt-5 mb-3">What We Offer</h2>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-start">
                                <i class="fas fa-users fa-2x text-primary me-3"></i>
                                <div>
                                    <h3 class="h5">Diverse Communities</h3>
                                    <p>Join communities focused on technology, gaming, entertainment, and more.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-start">
                                <i class="fas fa-comments fa-2x text-primary me-3"></i>
                                <div>
                                    <h3 class="h5">Rich Discussions</h3>
                                    <p>Engage in meaningful conversations with like-minded people.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-start">
                                <i class="fas fa-dollar-sign fa-2x text-primary me-3"></i>
                                <div>
                                    <h3 class="h5">Earn from Content</h3>
                                    <p>Get rewarded for your contributions and quality content.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-start">
                                <i class="fas fa-shield-alt fa-2x text-primary me-3"></i>
                                <div>
                                    <h3 class="h5">Safe Environment</h3>
                                    <p>Moderated communities ensure respectful and productive discussions.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="text-center mt-5">
                        <a href="/account/auth" class="btn btn-primary btn-lg">Join Our Community</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

