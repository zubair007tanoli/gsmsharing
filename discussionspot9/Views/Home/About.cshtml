@{
    ViewData["Title"] = "About Us - DiscussionSpot";
}

<div class="container my-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="display-4 mb-4">About DiscussionSpot</h1>

            <div class="card shadow-sm mb-4">
                <div class="card-body p-5">
                    <h2 class="h3 mb-3">Our Mission</h2>
                    <p class="lead">
                        Welcome to <strong>DiscussionSpot</strong>, a digital hub dedicated to honest, community-driven technology discussions. Founded in 2024, our mission is to bridge the gap between breaking tech news and the real-world experience of the users who use it every day.
                    </p>
                    <p class="text-muted">
                        We are a team of tech enthusiasts, developers, and students passionate about the digital landscape. From troubleshooting legacy hardware to debating the latest iOS updates, we believe the real value lies in the conversation, not just the headlines.
                    </p>

                    <h2 class="h3 mt-5 mb-3">What We Offer</h2>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-start">
                                <i class="fas fa-laptop-code fa-2x text-primary me-3"></i>
                                <div>
                                    <h3 class="h5">Tech & Dev Communities</h3>
                                    <p>Join focused groups on Web Development, iOS Updates, Legacy Hardware, and Gaming.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-start">
                                <i class="fas fa-comments fa-2x text-primary me-3"></i>
                                <div>
                                    <h3 class="h5">Real-World Solutions</h3>
                                    <p>Don't just read the news. Discuss fixes, workarounds, and actual performance reviews.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-start">
                                <i class="fas fa-dollar-sign fa-2x text-primary me-3"></i>
                                <div>
                                    <h3 class="h5">Value for Creators</h3>
                                    <p>We believe in value. Get rewarded for contributing high-quality guides and helpful answers.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-start">
                                <i class="fas fa-shield-alt fa-2x text-primary me-3"></i>
                                <div>
                                    <h3 class="h5">Safe Environment</h3>
                                    <p>A strictly moderated space free from spam and abuse, ensuring respectful dialogue.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-5">
                        <h4 class="h5 mb-3">Ready to join the discussion?</h4>
                        <a href="/account/auth" class="btn btn-primary btn-lg">Join Our Community</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>