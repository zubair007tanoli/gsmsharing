@{
    ViewData["Title"] = "Frequently Asked Questions - DiscussionSpot";
}

<div class="container my-5">
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <h1 class="display-4 mb-4">Frequently Asked Questions</h1>
            
            <div class="accordion" id="faqAccordion">
                <!-- General Questions -->
                <div class="accordion-item">
                    <h2 class="accordion-header" id="heading1">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapse1">
                            What is DiscussionSpot?
                        </button>
                    </h2>
                    <div id="collapse1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            DiscussionSpot is a community-driven platform where people can join discussions on various topics including technology, gaming, entertainment, and more. Users can create posts, comment, vote, and earn from their contributions.
                        </div>
                    </div>
                </div>
                
                <div class="accordion-item">
                    <h2 class="accordion-header" id="heading2">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse2">
                            How do I create an account?
                        </button>
                    </h2>
                    <div id="collapse2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Click on the "Join Free - Start Earning" button at the top of the page or go to /account/auth. You can register using email or sign in with your Google account for faster registration.
                        </div>
                    </div>
                </div>
                
                <div class="accordion-item">
                    <h2 class="accordion-header" id="heading3">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse3">
                            How do I create a post?
                        </button>
                    </h2>
                    <div id="collapse3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            First, join or browse to a community that interests you. Then click the "Create Post" button. You can create text posts, share links, upload images, or create polls.
                        </div>
                    </div>
                </div>
                
                <div class="accordion-item">
                    <h2 class="accordion-header" id="heading4">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse4">
                            How does earning work on DiscussionSpot?
                        </button>
                    </h2>
                    <div id="collapse4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Users can earn through ad revenue sharing on their popular posts, receiving awards from other users, and participating in premium content creation. The more engagement your posts receive, the more you can potentially earn.
                        </div>
                    </div>
                </div>
                
                <div class="accordion-item">
                    <h2 class="accordion-header" id="heading5">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse5">
                            What are communities?
                        </button>
                    </h2>
                    <div id="collapse5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Communities (prefixed with r/) are topic-specific spaces where users gather to discuss particular subjects. Each community has its own rules, moderators, and culture. You can join multiple communities based on your interests.
                        </div>
                    </div>
                </div>
                
                <div class="accordion-item">
                    <h2 class="accordion-header" id="heading6">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse6">
                            How do I report inappropriate content?
                        </button>
                    </h2>
                    <div id="collapse6" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Click the report button on any post or comment that violates our community guidelines. Our moderation team will review reports within 24 hours. You can also contact community moderators directly.
                        </div>
                    </div>
                </div>
                
                <div class="accordion-item">
                    <h2 class="accordion-header" id="heading7">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse7">
                            Can I delete my account?
                        </button>
                    </h2>
                    <div id="collapse7" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Yes, you can delete your account from your account settings. Please note that this action is irreversible and all your posts and comments will be anonymized.
                        </div>
                    </div>
                </div>
                
                <div class="accordion-item">
                    <h2 class="accordion-header" id="heading8">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse8">
                            Is DiscussionSpot free?
                        </button>
                    </h2>
                    <div id="collapse8" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Yes! DiscussionSpot is completely free to use. We offer optional premium features for users who want additional functionality, but all core features are available to everyone at no cost.
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card mt-5 bg-light">
                <div class="card-body text-center p-5">
                    <h2 class="h4 mb-3">Still have questions?</h2>
                    <p class="mb-3">Can't find what you're looking for? Get in touch with our support team.</p>
                    <a href="/home/contact" class="btn btn-primary">Contact Support</a>
                </div>
            </div>
        </div>
    </div>
</div>

