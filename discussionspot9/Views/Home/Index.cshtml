@model discussionspot9.Models.ViewModels.HomePage.HomePageViewModel
@using System.Text.RegularExpressions
@using discussionspot9.Helpers
@{
    ViewData["Title"] = "Home - DiscussionSpot";
}

<main class="container py-4">
    <section class="welcome-section text-center mb-4">
        <h1>Welcome to DiscussionSpot</h1>
        <p class="lead">Join the conversation and connect with our community</p>
    </section>

    <section class="ad-banner mb-4">
        <div class="ad-container">
            <p class="ad-label">Advertisement</p>
            <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5934633595595089"
                    crossorigin="anonymous"></script>
            <!-- discussionspotHead -->
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-5934633595595089"
                 data-ad-slot="3578533723"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>
                (adsbygoogle = window.adsbygoogle || []).push({});
            </script>          
        </div>
    </section>

    @if (Model?.RandomPosts?.Any() == true)
    {
        <!-- Random Posts Section -->
        <section class="random-posts-section mb-4">
            <div class="section-header d-flex justify-content-between align-items-center mb-3">
                <h2>Random Discussions</h2>
                <a asp-action="All" asp-controller="Post" class="view-all">View all</a>
            </div>

            <div class="row">
                @foreach (var post in Model.RandomPosts)
                {
                    <div class="col-md-6 col-lg-3 mb-3">
                        <div class="card h-100 random-post-card">
                            <div class="card-body">
                                <div class="post-tags mb-2">
                                    <span class="post-tag @post.CategoryCssClass">@post.CategoryName</span>
                                </div>
                                <h3 class="card-title h5">
                                    <a asp-route="community_posts"
                                       asp-route-communitySlug="@post.CommunitySlug"
                                       asp-route-postSlug="@post.Slug">
                                        @post.Title
                                    </a>
                                </h3>
                                <div class="post-meta">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar avatar-sm me-2">@post.AuthorInitials</div>
                                        <span class="small">@post.AuthorDisplayName</span>
                                    </div>
                                    <div class="mt-2 small text-muted">
                                        <i class="fas fa-comment me-1"></i> @post.CommentCount replies
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
           
            </div>
            <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5934633595595089"
                    crossorigin="anonymous"></script>
            <!-- discussionspotHead -->
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-5934633595595089"
                 data-ad-slot="3578533723"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>
                (adsbygoogle = window.adsbygoogle || []).push({});
            </script>
        </section>
    }

    <div class="row">
        <div class="col-lg-8">
            @if (Model?.Categories?.Any() == true)
            {
                <!-- Categories Section -->
                <section class="categories-section mb-4">
                    <div class="section-header d-flex justify-content-between align-items-center mb-3">
                        <h2>Categories</h2>
                        <a asp-route="categories_list" class="view-all">View all</a>
                    </div>

                    <div class="row">
                        @foreach (var category in Model.Categories)
                        {
                            <div class="col-md-6 mb-3">
                                <a asp-controller="Category"
                                   asp-action="CategoryDetails"
                                   asp-route-slug="@category.Slug"
                                   class="card category-card h-100">
                                    <div class="card-body d-flex">
                                        <div class="category-icon me-3">
                                            <i class="@category.IconClass"></i>
                                        </div>
                                        <div class="category-content">
                                            <h3 class="h5 mb-1">@category.Name</h3>
                                            <p class="small text-muted mb-2">@category.Description</p>
                                            <div class="category-meta">
                                                <span class="topic-count">@category.FormattedTopicCount topics</span>
                                                <div class="category-stats mt-1">
                                                    <span class="small text-muted me-3">
                                                        <i class="fas fa-file-alt me-1"></i> @category.FormattedPostCount posts
                                                    </span>
                                                    @if (category.IsActiveNow)
                                                    {
                                                        <span class="small text-muted">
                                                            <i class="fas fa-user-clock me-1"></i> Active now
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="small text-muted">
                                                            <i class="fas fa-clock me-1"></i> @category.LastActivityText
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (Model?.RecentPosts?.Any() == true)
            {
                <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5934633595595089"
                        crossorigin="anonymous"></script>
                <!-- discussionspotHead -->
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-5934633595595089"
                     data-ad-slot="3578533723"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
                <script>
                    (adsbygoogle = window.adsbygoogle || []).push({});
                </script>
                <!-- Recent Discussions Section -->
                <section class="recent-posts-section mb-4">
                    <div class="section-header d-flex justify-content-between align-items-center mb-3">
                        <h2>Recent Discussions</h2>
                        <a href="@Url.All(sort: "recent")" class="view-all">View all</a>
                    </div>

                    <div class="posts-list">
                        @foreach (var post in Model.RecentPosts)
                        {
                            <div class="card post-item mb-3">
                                <div class="card-body d-flex">
                                    <div class="post-votes text-center me-3">
                                        <span class="vote-count @post.VoteCountCssClass">@post.FormattedVoteCount</span>
                                        <span class="vote-label small text-muted">votes</span>
                                    </div>
                                    <div class="post-content">
                                        <div class="post-tags mb-2">
                                            <span class="post-tag @post.CategoryCssClass">@post.CategoryName</span>
                                            @if (post.IsPinned)
                                            {
                                                <span class="badge bg-primary">Pinned</span>
                                            }
                                            @if (post.IsLocked)
                                            {
                                                <span class="badge bg-secondary">Locked</span>
                                            }
                                        </div>
                                        <h3 class="post-title h5">
                                            <a href="@post.PostUrl">@post.Title</a>
                                        </h3>
                                        @{
                                            // Remove ALL HTML tags from content
                                            var plainText = Regex.Replace(post.Excerpt ?? "", "<.*?>", string.Empty);
                                        }
                                        <p class="post-excerpt text-muted small">@plainText</p>
                                        <div class="post-meta d-flex justify-content-between align-items-center">
                                            <div class="post-author d-flex align-items-center">
                                                <div class="avatar avatar-sm me-2">@post.AuthorInitials</div>
                                                <a href="@post.AuthorUrl" class="small">@post.AuthorDisplayName</a>
                                            </div>
                                            <div class="post-stats small text-muted">
                                                <span class="me-2">
                                                    <i class="fas fa-comment me-1"></i> @post.FormattedCommentCount
                                                </span>
                                                <span class="me-2">
                                                    <i class="fas fa-eye me-1"></i> @post.FormattedViewCount
                                                </span>
                                                <span>
                                                    <i class="fas fa-clock me-1"></i> @post.TimeAgo
                                                </span>
                                            </div>
                                        </div>
                                        @if (post.HasTags)
                                        {
                                            <div class="post-tags-list mt-2">
                                                @foreach (var tag in post.DisplayTags)
                                                {
                                                    <span class="badge bg-light text-dark me-1">@tag</span>
                                                }
                                                @if (post.HasMoreTags)
                                                {
                                                    <span class="badge bg-light text-dark">+@(post.Tags.Count - 3)</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
            <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5934633595595089"
                    crossorigin="anonymous"></script>
            <!-- discussionspotHead -->
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-5934633595595089"
                 data-ad-slot="3578533723"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>
                (adsbygoogle = window.adsbygoogle || []).push({});
            </script>
        </div>

        <div class="col-lg-4">
            <!-- Sidebar -->
            <div class="sidebar home-sidebar">
                <!-- Latest News Section -->
                <div class="card mb-4 modern-news-card">
                    <div class="card-header bg-primary text-white">
                        <h2 class="h5 mb-0"><i class="fas fa-newspaper me-2"></i>Latest News</h2>
                    </div>
                    <div class="card-body p-2">
                        <div class="news-item">
                            <span class="news-category tech">Tech</span>
                            <div class="news-title">Revolutionary AI Model Achieves Human-Level Performance</div>
                            <div class="news-meta">
                                <i class="fas fa-clock"></i> 2 hours ago
                            </div>
                        </div>
                        <div class="news-item">
                            <span class="news-category gaming">Gaming</span>
                            <div class="news-title">New Gaming Console Breaks Pre-order Records</div>
                            <div class="news-meta">
                                <i class="fas fa-clock"></i> 4 hours ago
                            </div>
                        </div>
                        <div class="news-item">
                            <span class="news-category programming">Programming</span>
                            <div class="news-title">Open Source Framework Simplifies Development</div>
                            <div class="news-meta">
                                <i class="fas fa-clock"></i> 6 hours ago
                            </div>
                        </div>
                    </div>
                </div>

                @if (Model?.Sidebar?.HasTrendingTopics == true)
                {
                    <!-- Trending Topics Section -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h2 class="h5 mb-0">Trending Topics</h2>
                        </div>
                        <div class="card-body">
                            <div class="trending-topics">
                                @foreach (var topic in Model.Sidebar.TrendingTopics)
                                {
                                    <div class="trending-topic mb-3 pb-3 border-bottom">
                                        <div class="topic-tags mb-2">
                                            <span class="post-tag @topic.CategoryCssClass">@topic.CategoryName</span>
                                            @if (topic.IsHot)
                                            {
                                                <span class="topic-status hot">Hot</span>
                                            }
                                        </div>
                                        <h3 class="h6">
                                            <a href="@topic.PostUrl">@topic.ShortTitle</a>
                                        </h3>
                                        <div class="topic-meta small text-muted">
                                            <span>
                                                <i class="fas fa-comment me-1"></i> @topic.FormattedReplyCount replies
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
                <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5934633595595089"
                        crossorigin="anonymous"></script>
                <!-- discussionSide -->
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-5934633595595089"
                     data-ad-slot="7326207040"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
                <script>
                    (adsbygoogle = window.adsbygoogle || []).push({});
                </script>
                @if (Model?.Sidebar?.HasOnlineUsers == true)
                {
                    <!-- Online Users Section -->
                    <div class="card mb-4">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h2 class="h5 mb-0">Online Now</h2>
                            <span class="badge bg-success">@Model.Sidebar.OnlineUsers.TotalOnline users</span>
                        </div>
                        <div class="card-body">
                            <div class="online-users-section">
                                @if (Model.Sidebar.OnlineUsers.HasVisibleUsers)
                                {
                                    <div class="active-users mb-3">
                                        <div class="d-flex flex-wrap gap-2 mb-2">
                                            @foreach (var user in Model.Sidebar.OnlineUsers.VisibleUsers)
                                            {
                                                <div class="user-avatar-wrapper" data-bs-toggle="tooltip" title="@user.TooltipText">
                                                    <div class="user-avatar">@user.Initials</div>
                                                    <span class="status-indicator @user.StatusIndicatorClass"></span>
                                                </div>
                                            }
                                            @if (Model.Sidebar.OnlineUsers.HasHiddenUsers)
                                            {
                                                <div class="user-avatar more-users" data-bs-toggle="modal" data-bs-target="#onlineUsersModal">
                                                    @Model.Sidebar.OnlineUsers.HiddenUsersText
                                                </div>
                                            }
                                        </div>
                                        <div class="small text-muted">
                                            <i class="fas fa-chart-line me-1"></i>
                                            Peak today: @Model.Sidebar.OnlineUsers.PeakToday users at @Model.Sidebar.OnlineUsers.PeakTimeText
                                        </div>
                                    </div>
                                }
                                <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5934633595595089"
                                        crossorigin="anonymous"></script>
                                <!-- discussionSide -->
                                <ins class="adsbygoogle"
                                     style="display:block"
                                     data-ad-client="ca-pub-5934633595595089"
                                     data-ad-slot="7326207040"
                                     data-ad-format="auto"
                                     data-full-width-responsive="true"></ins>
                                <script>
                                    (adsbygoogle = window.adsbygoogle || []).push({});
                                </script>
                                @if (Model.Sidebar.OnlineUsers.HasActiveCategories)
                                {
                                    <div class="active-now">
                                        <h6 class="text-muted mb-2">Currently Active In:</h6>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var category in Model.Sidebar.OnlineUsers.ActiveCategories)
                                            {
                                                <a href="@Url.Communities()" class="active-category">
                                                    <i class="fas fa-folder me-1"></i>
                                                    @category.Key <span class="small">(@category.Value)</span>
                                                </a>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                @if (Model?.Sidebar?.HasForumStats == true)
                {
                    <!-- Forum Stats Section -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h2 class="h5 mb-0">Forum Stats</h2>
                        </div>
                        <div class="card-body">
                            <ul class="stats-list list-unstyled mb-0">
                                @foreach (var stat in Model.Sidebar.ForumStats.StatItems)
                                {
                                    <li class="d-flex align-items-center mb-2">
                                        <i class="@stat.IconClass me-2 text-primary"></i>
                                        @stat.Value @stat.Label.ToLower()
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }
                <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5934633595595089"
                        crossorigin="anonymous"></script>
                <!-- discussionSide -->
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-5934633595595089"
                     data-ad-slot="7326207040"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
                <script>
                    (adsbygoogle = window.adsbygoogle || []).push({});
                </script>
                @if (Model?.Sidebar?.HasNewMembers == true)
                {
                    <!-- New Members Section -->
                    <div class="card">
                        <div class="card-header">
                            <h2 class="h5 mb-0">New Members</h2>
                        </div>
                        <div class="card-body">
                            <ul class="list-group list-group-flush">
                                @foreach (var member in Model.Sidebar.NewMembers)
                                {
                                    <li class="list-group-item px-0 py-2 d-flex align-items-center">
                                        <div class="avatar me-3">@member.Initials</div>
                                        <div>
                                            <div>
                                                <a href="@member.ProfileUrl">@member.DisplayName</a>
                                                @if (member.IsVerified)
                                                {
                                                    <i class="fas fa-check-circle text-primary ms-1" data-bs-toggle="tooltip" title="Verified"></i>
                                                }
                                            </div>
                                            <small class="text-muted">@member.JoinDateAgo</small>
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</main>