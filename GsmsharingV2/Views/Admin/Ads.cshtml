@model IEnumerable<GsmsharingV2.Models.NewSchema.ClassifiedAd>
@{
    ViewData["Title"] = "Manage Classified Ads";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="fas fa-shopping-cart me-2"></i>Classified Ads</h2>
            <p class="text-muted mb-0">Manage all classified advertisements</p>
        </div>
        <a href="@Url.Action("AdEdit")" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>New Ad
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Views</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ad in Model)
                        {
                            <tr>
                                <td>@ad.AdID</td>
                                <td>
                                    <strong>@(ad.Title?.Length > 50 ? ad.Title.Substring(0, 50) + "..." : ad.Title)</strong>
                                    @if (!string.IsNullOrEmpty(ad.Brand))
                                    {
                                        <br><small class="text-muted">@ad.Brand @ad.Model</small>
                                    }
                                </td>
                                <td>@(ad.Category?.CategoryName ?? "N/A")</td>
                                <td>@ad.Price @ad.Currency</td>
                                <td>
                                    <span class="badge bg-@(ad.Status == "Active" ? "success" : ad.Status == "Sold" ? "warning" : "secondary")">
                                        @ad.Status
                                    </span>
                                </td>
                                <td>@ad.ViewCount</td>
                                <td>@ad.CreatedDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <a href="@Url.Action("AdDetails", new { id = ad.AdID })" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="@Url.Action("AdEdit", new { id = ad.AdID })" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="AdDelete" asp-route-id="@ad.AdID" method="post" class="d-inline" onsubmit="return confirm('Are you sure?');">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            @if (ViewBag.TotalCount > ViewBag.PageSize)
            {
                <nav>
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= Math.Ceiling((double)ViewBag.TotalCount / ViewBag.PageSize); i++)
                        {
                            <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Ads", new { page = i })">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

