@{
    ViewData["Title"] = "GSMSharing - Mobile & IT Blog | Affiliate Marketing";
    var categories = ViewBag.Categories as IEnumerable<GsmsharingV2.Models.Category> ?? new List<GsmsharingV2.Models.Category>();
    var featuredPosts = ViewBag.FeaturedPosts as IEnumerable<GsmsharingV2.Models.Post> ?? new List<GsmsharingV2.Models.Post>();
    var recentPosts = ViewBag.RecentPosts as IEnumerable<GsmsharingV2.Models.Post> ?? new List<GsmsharingV2.Models.Post>();
}

<div class="mb-4">
    <div class="gs-soft p-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <div>
                <h1 class="h3 gs-page-title mb-1">Mobile &amp; IT Solutions</h1>
                <p class="gs-kicker mb-0">Articles and guides with the redesigned GSMSharing theme.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/Posts" class="btn btn-primary"><i class="fas fa-book-open me-2"></i>Read Articles</a>
                <a href="/Posts/Create" class="btn btn-outline-primary"><i class="fas fa-pen me-2"></i>Write Article</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        @if (featuredPosts.Any())
        {
            var featured = featuredPosts.First();
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong><i class="fas fa-star me-2 text-primary"></i>Featured</strong>
                    <a class="btn btn-sm btn-outline-primary" href="/r/@(featured.Community?.Slug ?? "gsmsharing")/posts/@featured.Slug">Open</a>
                </div>
                <div class="card-body">
                    <h2 class="h5 mb-2">
                        <a href="/r/@(featured.Community?.Slug ?? "gsmsharing")/posts/@featured.Slug">@featured.Title</a>
                    </h2>
                    <p class="text-muted mb-0">@(featured.Content?.Length > 220 ? featured.Content.Substring(0, 220) + "..." : featured.Content)</p>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <strong><i class="fas fa-newspaper me-2 text-primary"></i>Latest Articles</strong>
            </div>
            <div class="card-body">
                @foreach (var post in recentPosts.Take(12))
                {
                    <div class="py-2 @(post != recentPosts.Last() ? "border-bottom" : "")">
                        <div class="fw-semibold">
                            <a href="/r/@(post.Community?.Slug ?? "gsmsharing")/posts/@post.Slug">@post.Title</a>
                        </div>
                        <div class="text-muted small d-flex flex-wrap gap-3">
                            <span><i class="fas fa-clock me-1"></i>@GetTimeAgo(post.CreatedAt)</span>
                            <span><i class="fas fa-eye me-1"></i>@(post.ViewCount ?? 0)</span>
                            <span><i class="fas fa-comments me-1"></i>@(post.Comments?.Count ?? 0)</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <aside class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header"><strong><i class="fas fa-layer-group me-2 text-primary"></i>Categories</strong></div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var c in categories.Take(12))
                    {
                        <a class="btn btn-sm btn-outline-primary" href="/category/@c.Slug">@c.Name</a>
                    }
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><strong><i class="fas fa-info-circle me-2 text-primary"></i>About</strong></div>
            <div class="card-body">
                <p class="text-muted mb-0">Blog-style reading experience with the new GSMSharing theme.</p>
            </div>
        </div>
    </aside>
</div>

@functions {
    private string GetTimeAgo(DateTime? date)
    {
        if (date == null) return "just now";

        var timeSpan = DateTime.UtcNow - date.Value;

        if (timeSpan.TotalSeconds < 60)
            return $"{(int)timeSpan.TotalSeconds}s ago";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalDays < 30)
            return $"{(int)timeSpan.TotalDays}d ago";
        if (timeSpan.TotalDays < 365)
            return $"{(int)(timeSpan.TotalDays / 30)}mo ago";

        return $"{(int)(timeSpan.TotalDays / 365)}y ago";
    }
}
