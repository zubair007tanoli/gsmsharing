                }
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4 col-xl-3">
                <div class="reddit-sidebar">
                    <!-- Top Communities -->
                    <div class="sidebar-card mb-3">
                        <div class="sidebar-header">
