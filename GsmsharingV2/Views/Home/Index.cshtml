                    </div>

                    <!-- Create Post Card -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="sidebar-card mb-3">
                            <div class="sidebar-content p-3 text-center">
                                <a href="/Posts/Create" class="btn btn-primary w-100">
                                    <i class="fas fa-plus-circle me-2"></i>Create Post
