@{
    ViewData["Title"] = "GSMSharing - Mobile & IT Blog | Affiliate Marketing";
    var categories = ViewBag.Categories as IEnumerable<GsmsharingV2.Models.Category> ?? new List<GsmsharingV2.Models.Category>();
    var postsByCategory = ViewBag.PostsByCategory as Dictionary<GsmsharingV2.Models.Category, IEnumerable<GsmsharingV2.Models.Post>> ?? new Dictionary<GsmsharingV2.Models.Category, IEnumerable<GsmsharingV2.Models.Post>>();
    var recentPosts = ViewBag.RecentPosts as IEnumerable<GsmsharingV2.Models.Post> ?? new List<GsmsharingV2.Models.Post>();
    var recentBlogs = ViewBag.RecentBlogs as IEnumerable<GsmsharingV2.Models.MobilePost> ?? new List<GsmsharingV2.Models.MobilePost>();
    var recentForums = ViewBag.RecentForums as IEnumerable<GsmsharingV2.Models.ForumThread> ?? new List<GsmsharingV2.Models.ForumThread>();
    var featuredProducts = ViewBag.FeaturedProducts as IEnumerable<GsmsharingV2.Models.AffiliationProduct> ?? new List<GsmsharingV2.Models.AffiliationProduct>();
    var recentBlogComments = ViewBag.RecentBlogComments as IEnumerable<GsmsharingV2.Models.BlogComment> ?? new List<GsmsharingV2.Models.BlogComment>();
    var recentProductReviews = ViewBag.RecentProductReviews as IEnumerable<GsmsharingV2.Models.ProductReview> ?? new List<GsmsharingV2.Models.ProductReview>();
}

<div class="mb-4">
    <div class="gs-soft p-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <div>
                <h1 class="h3 gs-page-title mb-1">GSMSharing</h1>
                <p class="gs-kicker mb-0">A cleaner, faster redesign for blogs, forums, and posts.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-primary" href="/Posts/Create"><i class="fas fa-plus-circle me-2"></i>Create Post</a>
                <a class="btn btn-outline-primary" href="/Forum"><i class="fas fa-comments me-2"></i>Forums</a>
                <a class="btn btn-outline-primary" href="/Blog/Blogs"><i class="fas fa-blog me-2"></i>Blog</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger" role="alert">
                <strong><i class="fas fa-exclamation-triangle me-2"></i>Error Loading Data</strong>
                <div class="mt-2">@ViewBag.ErrorMessage</div>
                <div class="mt-2"><small>Try the <a href="/Diagnostics">Diagnostics</a> page.</small></div>
            </div>
        }

        <div class="card mb-4">
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <span class="text-muted fw-semibold">Explore:</span>
                    <a href="/" class="btn btn-sm btn-primary"><i class="fas fa-fire me-1"></i>Hot</a>
                    <a href="/?sort=new" class="btn btn-sm btn-outline-primary"><i class="fas fa-clock me-1"></i>New</a>
                    <a href="/?sort=top" class="btn btn-sm btn-outline-primary"><i class="fas fa-trophy me-1"></i>Top</a>
                    <span class="text-muted ms-2">|</span>
                    @foreach (var category in categories.Take(6))
                    {
                        <a href="/category/@category.Slug" class="btn btn-sm btn-outline-primary">
                            <i class="@(category.IconClass ?? "fas fa-folder") me-1"></i>@category.Name
                        </a>
                    }
                </div>
            </div>
        </div>

        @if (recentBlogs.Any())
        {
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <strong><i class="fas fa-blog me-2 text-primary"></i>Latest Blog Posts</strong>
                        <div class="text-muted small">Recent articles from the blog</div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="/Blog/Blogs">View all</a>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        @foreach (var blog in recentBlogs.Take(3))
                        {
                            <div class="col-md-4">
                                <div class="gs-soft p-3 h-100">
                                    <div class="fw-bold mb-2">
                                        <a href="/Blog/Details/@blog.BlogId">@(blog.Title?.Length > 60 ? blog.Title.Substring(0, 60) + "..." : blog.Title)</a>
                                    </div>
                                    <div class="text-muted small mb-2">@GetTimeAgo(blog.CreationDate)</div>
                                    <div class="text-muted small">Views: @(blog.views ?? 0)</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @if (recentForums.Any())
        {
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <strong><i class="fas fa-comments me-2 text-primary"></i>Active Forum Discussions</strong>
                        <div class="text-muted small">Join the conversation</div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="/Forum">View all</a>
                </div>
                <div class="card-body">
                    @foreach (var forum in recentForums.Take(6))
                    {
                        <div class="py-2 @(forum != recentForums.Last() ? "border-bottom" : "")">
                            <div class="fw-semibold">
                                <a href="/Forum/Details/@forum.UserFourmID">@forum.Title</a>
                            </div>
                            <div class="text-muted small d-flex flex-wrap gap-3">
                                <span><i class="fas fa-user me-1"></i>@(forum.User?.UserName ?? "Anonymous")</span>
                                <span><i class="fas fa-eye me-1"></i>@(forum.Views ?? 0)</span>
                                <span><i class="fas fa-clock me-1"></i>@GetTimeAgo(forum.CreationDate)</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (postsByCategory.Any())
        {
            @foreach (var categoryPosts in postsByCategory.Take(3))
            {
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong><i class="@(categoryPosts.Key.IconClass ?? "fas fa-folder") me-2 text-primary"></i>@categoryPosts.Key.Name</strong>
                        <a class="btn btn-sm btn-outline-primary" href="/category/@categoryPosts.Key.Slug">View</a>
                    </div>
                    <div class="card-body">
                        @foreach (var post in categoryPosts.Value.Take(5))
                        {
                            <div class="py-2 @(post != categoryPosts.Value.Last() ? "border-bottom" : "")">
                                <div class="fw-semibold">
                                    <a href="/r/@(post.Community?.Slug ?? "gsmsharing")/posts/@post.Slug">@post.Title</a>
                                </div>
                                <div class="text-muted small d-flex flex-wrap gap-3">
                                    <span><i class="fas fa-user me-1"></i>@(post.User?.UserName ?? "User")</span>
                                    <span><i class="fas fa-eye me-1"></i>@(post.ViewCount ?? 0)</span>
                                    <span><i class="fas fa-clock me-1"></i>@GetTimeAgo(post.CreatedAt)</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else if (recentPosts.Any())
        {
            <div class="card mb-4">
                <div class="card-header"><strong><i class="fas fa-newspaper me-2 text-primary"></i>Recent Posts</strong></div>
                <div class="card-body">
                    @foreach (var post in recentPosts.Take(10))
                    {
                        <div class="py-2 @(post != recentPosts.Last() ? "border-bottom" : "")">
                            <div class="fw-semibold">
                                <a href="/r/@(post.Community?.Slug ?? "gsmsharing")/posts/@post.Slug">@post.Title</a>
                            </div>
                            <div class="text-muted small">@GetTimeAgo(post.CreatedAt)</div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <aside class="col-lg-4">
        @if (recentBlogComments.Any())
        {
            <div class="card mb-4">
                <div class="card-header">
                    <strong><i class="fas fa-comment-dots me-2 text-primary"></i>Latest Blog Comments</strong>
                    <div class="text-muted small">Live feedback from readers</div>
                </div>
                <div class="card-body">
                    @foreach (var comment in recentBlogComments.Take(6))
                    {
                        var raw = comment.Comment ?? "";
                        var preview = System.Text.RegularExpressions.Regex.Replace(raw, "<.*?>", "");
                        if (preview.Length > 140) preview = preview.Substring(0, 140) + "...";

                        <div class="py-2 @(comment != recentBlogComments.Last() ? "border-bottom" : "")">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge bg-primary">@(comment.User?.UserName ?? "Guest")</span>
                                <small class="text-muted">@GetTimeAgo(comment.CreationDate)</small>
                            </div>
                            <div class="text-muted small mt-1">on <a href="/Blog/Details/@comment.BlogId">Blog #@comment.BlogId</a></div>
                            <div class="comment-content mt-1">@preview</div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (recentProductReviews.Any())
        {
            <div class="card mb-4">
                <div class="card-header">
                    <strong><i class="fas fa-star-half-alt me-2 text-primary"></i>Recent Product Reviews</strong>
                    <div class="text-muted small">Affiliate products rated by the community</div>
                </div>
                <div class="card-body">
                    @foreach (var review in recentProductReviews.Take(6))
                    {
                        var raw = review.Review ?? "";
                        var preview = System.Text.RegularExpressions.Regex.Replace(raw, "<.*?>", "");
                        if (preview.Length > 140) preview = preview.Substring(0, 140) + "...";

                        <div class="py-2 @(review != recentProductReviews.Last() ? "border-bottom" : "")">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge bg-success">@(review.User?.UserName ?? "Guest")</span>
                                <small class="text-muted">@GetTimeAgo(review.ReviewDate)</small>
                            </div>
                            <div class="text-muted small mt-1">Product #@review.BlogId</div>
                            <div class="comment-content mt-1">@preview</div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (featuredProducts.Any())
        {
            <div class="card mb-4">
                <div class="card-header">
                    <strong><i class="fas fa-shopping-bag me-2 text-primary"></i>Featured Products</strong>
                </div>
                <div class="card-body">
                    @foreach (var product in featuredProducts.Take(4))
                    {
                        <div class="py-2 @(product != featuredProducts.Last() ? "border-bottom" : "")">
                            <div class="fw-semibold">@(product.Title?.Length > 60 ? product.Title.Substring(0, 60) + "..." : product.Title)</div>
                            @if (!string.IsNullOrEmpty(product.BuyLink))
                            {
                                <a href="@product.BuyLink" target="_blank" rel="noopener" class="text-muted small">Open link</a>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header"><strong><i class="fas fa-info-circle me-2 text-primary"></i>About</strong></div>
            <div class="card-body">
                <p class="text-muted mb-0">GSMSharing is a community for mobile repair knowledge, discussions, and tools.</p>
            </div>
        </div>
    </aside>
</div>

@functions {
    private string GetTimeAgo(DateTime? date)
    {
        if (date == null) return "just now";

        var timeSpan = DateTime.UtcNow - date.Value;

        if (timeSpan.TotalSeconds < 60)
            return $"{(int)timeSpan.TotalSeconds}s ago";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalDays < 30)
            return $"{(int)timeSpan.TotalDays}d ago";
        if (timeSpan.TotalDays < 365)
            return $"{(int)(timeSpan.TotalDays / 30)}mo ago";

        return $"{(int)(timeSpan.TotalDays / 365)}y ago";
    }
}
