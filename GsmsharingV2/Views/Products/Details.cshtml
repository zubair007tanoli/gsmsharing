@model GsmsharingV2.Models.AffiliationProduct
@{
    ViewData["Title"] = Model.Title + " - GSMSharing Products";
    var productReviews = ViewBag.ProductReviews as IEnumerable<GsmsharingV2.Models.ProductReview> ?? new List<GsmsharingV2.Models.ProductReview>();
    var relatedProducts = ViewBag.RelatedProducts as IEnumerable<GsmsharingV2.Models.AffiliationProduct> ?? new List<GsmsharingV2.Models.AffiliationProduct>();
    var reviewCount = ViewBag.ReviewCount as int? ?? productReviews.Count();
}

<div class="container py-4">
    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- Product Header -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <nav aria-label="breadcrumb" class="mb-3">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                            <li class="breadcrumb-item"><a href="/Products">Products</a></li>
                            <li class="breadcrumb-item active">@(Model.Title?.Length > 30 ? Model.Title.Substring(0, 30) + "..." : Model.Title)</li>
                        </ol>
                    </nav>

                    <div class="row">
                        <!-- Product Image -->
                        <div class="col-md-5 mb-4 mb-md-0">
                            <div class="product-detail-image-wrapper">
                                @if (!string.IsNullOrEmpty(Model.ImageLink))
                                {
                                    <img src="@Model.ImageLink" alt="@Model.Title" class="product-detail-image img-fluid rounded" onerror="this.src='/images/placeholder-product.jpg'">
                                }
                                else
                                {
                                    <div class="product-image-placeholder-large">
                                        <i class="fas fa-image fa-5x text-muted"></i>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Product Info -->
                        <div class="col-md-7">
                            <h1 class="product-detail-title mb-3">@Model.Title</h1>
                            
                            @if (Model.Price.HasValue)
                            {
                                <div class="product-detail-price mb-3">
                                    <span class="price-label">Price:</span>
                                    <span class="price-value">$@Model.Price</span>
                                </div>
                            }

                            <div class="product-stats-modern mb-4">
                                <div class="stat-item">
                                    <i class="fas fa-eye text-primary"></i>
                                    <span>@(Model.Views ?? 0) Views</span>
                                </div>
                                <div class="stat-item">
                                    <i class="fas fa-thumbs-up text-success"></i>
                                    <span>@(Model.Likes ?? 0) Likes</span>
                                </div>
                                <div class="stat-item">
                                    <i class="fas fa-comments text-info"></i>
                                    <span>@reviewCount Reviews</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.BuyLink))
                            {
                                <a href="@Model.BuyLink" target="_blank" class="btn btn-primary btn-lg w-100 mb-3 product-buy-btn-large">
                                    <i class="fas fa-shopping-cart me-2"></i>Buy Now on Partner Site
                                </a>
                            }

                            <div class="product-meta-modern">
                                <div class="meta-item">
                                    <i class="fas fa-user text-muted me-2"></i>
                                    <span>Posted by <strong>@(Model.User?.UserName ?? "Anonymous")</strong></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-calendar text-muted me-2"></i>
                                    <span>@Model.CreationDate?.ToString("MMMM dd, yyyy")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Product Description -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle me-2 text-primary"></i>Product Description
                    </h5>
                </div>
                <div class="card-body">
                    <div class="product-description-content">
                        @if (!string.IsNullOrEmpty(Model.ProductDiscription))
                        {
                            <p class="lead">@Model.ProductDiscription</p>
                        }
                        @if (!string.IsNullOrEmpty(Model.Content))
                        {
                            <div class="mt-3">
                                @Html.Raw(Model.Content)
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Keywords))
                    {
                        <div class="mt-4 pt-4 border-top">
                            <h6 class="mb-2">Keywords:</h6>
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (var keyword in Model.Keywords.Split(',').Take(10))
                                {
                                    <span class="badge bg-secondary">#@keyword.Trim()</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Product Reviews -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-star me-2 text-warning"></i>Customer Reviews (@reviewCount)
                    </h5>
                </div>
                <div class="card-body">
                    @if (productReviews.Any())
                    {
                        @foreach (var review in productReviews)
                        {
                            <div class="review-card-modern mb-4 pb-4 @(review != productReviews.Last() ? "border-bottom" : "")">
                                <div class="d-flex gap-3">
                                    <div class="review-avatar-large">
                                        @(review.User?.UserName?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <strong>@(review.User?.UserName ?? "Guest")</strong>
                                                <div class="text-muted small">@review.ReviewDate?.ToString("MMMM dd, yyyy 'at' h:mm tt")</div>
                                            </div>
                                        </div>
                                        <p class="mb-0">@review.Review</p>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-comment-slash fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No reviews yet. Be the first to review this product!</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Related Products -->
            @if (relatedProducts.Any())
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="fas fa-th me-2 text-primary"></i>Related Products
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            @foreach (var related in relatedProducts)
                            {
                                <div class="col-md-6">
                                    <div class="related-product-card">
                                        <div class="d-flex gap-3">
                                            @if (!string.IsNullOrEmpty(related.ImageLink))
                                            {
                                                <img src="@related.ImageLink" alt="@related.Title" class="related-product-image" onerror="this.style.display='none'">
                                            }
                                            <div class="flex-grow-1">
                                                <h6 class="mb-1">
                                                    <a href="/Products/Details/@related.ProductId" class="text-decoration-none">
                                                        @(related.Title?.Length > 50 ? related.Title.Substring(0, 50) + "..." : related.Title)
                                                    </a>
                                                </h6>
                                                @if (related.Price.HasValue)
                                                {
                                                    <div class="text-primary fw-bold mb-2">$@related.Price</div>
                                                }
                                                <a href="/Products/Details/@related.ProductId" class="btn btn-sm btn-outline-primary">
                                                    View Details
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="sticky-top" style="top: 80px;">
                <!-- Quick Info -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle me-2"></i>Quick Info
                        </h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-3">
                                <i class="fas fa-user text-primary me-2"></i>
                                <strong>Author:</strong> @(Model.User?.UserName ?? "Anonymous")
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-calendar text-primary me-2"></i>
                                <strong>Posted:</strong> @Model.CreationDate?.ToString("MMM dd, yyyy")
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-eye text-primary me-2"></i>
                                <strong>Views:</strong> @(Model.Views ?? 0)
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-thumbs-up text-primary me-2"></i>
                                <strong>Likes:</strong> @(Model.Likes ?? 0)
                            </li>
                            <li>
                                <i class="fas fa-comments text-primary me-2"></i>
                                <strong>Reviews:</strong> @reviewCount
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Share Product -->
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="mb-3">Share this Product</h6>
                        <div class="d-flex gap-2 justify-content-center">
                            <button class="btn btn-sm btn-outline-primary" onclick="shareOnFacebook()">
                                <i class="fab fa-facebook"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-info" onclick="shareOnTwitter()">
                                <i class="fab fa-twitter"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="shareOnPinterest()">
                                <i class="fab fa-pinterest"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" onclick="copyLink()">
                                <i class="fas fa-link"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function shareOnFacebook() {
            window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(window.location.href), '_blank');
        }
        function shareOnTwitter() {
            window.open('https://twitter.com/intent/tweet?url=' + encodeURIComponent(window.location.href) + '&text=' + encodeURIComponent('@Model.Title'), '_blank');
        }
        function shareOnPinterest() {
            window.open('https://pinterest.com/pin/create/button/?url=' + encodeURIComponent(window.location.href), '_blank');
        }
        function copyLink() {
            navigator.clipboard.writeText(window.location.href).then(() => {
                alert('Link copied to clipboard!');
            });
        }
    </script>
}

