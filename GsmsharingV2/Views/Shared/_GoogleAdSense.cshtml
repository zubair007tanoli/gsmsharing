@* Google AdSense Partial View *@
@* Replace YOUR_PUBLISHER_ID with your actual AdSense Publisher ID *@

@{
    var publisherId = ViewBag.AdSensePublisherId ?? "ca-pub-YOUR_PUBLISHER_ID";
}

<!-- Google AdSense Auto Ads -->
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=@publisherId"
     crossorigin="anonymous"></script>

<!-- AdSense In-Article Ad -->
@if (ViewBag.ShowInArticleAd == true)
{
    <ins class="adsbygoogle"
         style="display:block; text-align:center;"
         data-ad-layout="in-article"
         data-ad-format="fluid"
         data-ad-client="@publisherId"
         data-ad-slot="@(ViewBag.AdSlot ?? "YOUR_AD_SLOT")"></ins>
    <script>
         (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
}

<!-- AdSense Display Ad (Sidebar) -->
@if (ViewBag.ShowSidebarAd == true)
{
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="@publisherId"
         data-ad-slot="@(ViewBag.SidebarAdSlot ?? "YOUR_SIDEBAR_AD_SLOT")"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>
         (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
}

<!-- AdSense Banner Ad (Top) -->
@if (ViewBag.ShowBannerAd == true)
{
    <div class="text-center mb-4">
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="@publisherId"
             data-ad-slot="@(ViewBag.BannerAdSlot ?? "YOUR_BANNER_AD_SLOT")"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
        <script>
             (adsbygoogle = window.adsbygoogle || []).push({});
        </script>
    </div>
}

