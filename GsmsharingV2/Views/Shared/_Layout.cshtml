<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GSMSharing</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/blog-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dark-mode.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GsmsharingV2.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="gs-header">
        <nav class="navbar navbar-expand-lg gs-navbar">
            <div class="container">
                <a class="navbar-brand gs-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="gs-brand-mark"><i class="fas fa-mobile-alt"></i></span>
                    <span class="gs-brand-text">GSMSharing</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#gsNavbar" aria-controls="gsNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="gsNavbar">
                    <ul class="navbar-nav me-auto gs-nav">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Posts" asp-action="Index">Posts</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Forum" asp-action="Index">Forums</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Blog" asp-action="Blogs">Blog</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index">Products</a></li>
                    </ul>

                    <form class="d-none d-lg-flex me-3 gs-search" asp-controller="Posts" asp-action="Index" method="get" role="search">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-transparent border-end-0"><i class="fas fa-search"></i></span>
                            <input name="search" class="form-control border-start-0" type="search" placeholder="Searchâ€¦" aria-label="Search" />
                        </div>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            @await Component.InvokeAsync("ThemeToggle")
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm" asp-controller="Content" asp-action="Create">
                                    <i class="fas fa-plus-circle me-1"></i>Create
                                </a>
                            </li>
                            <li class="nav-item position-relative">
                                <a class="nav-link" href="#" id="notificationBell" role="button">
                                    <i class="fas fa-bell"></i>
                                    <span class="badge bg-danger position-absolute top-0 start-100 translate-middle" id="notificationBadge" style="display: none;">0</span>
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-circle me-1"></i>@User.Identity!.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <form asp-controller="UserAccounts" asp-action="Logout" method="post" class="px-3 py-1">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                                <i class="fas fa-sign-out-alt me-1"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="UserAccounts" asp-action="Login">Login</a></li>
                            <li class="nav-item"><a class="btn btn-outline-primary btn-sm" asp-controller="UserAccounts" asp-action="Register">Sign up</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="gs-main">
        <div class="container py-4">
            <!-- AdSense Top Banner -->
            <div class="text-center mb-4" id="adsense-top">
                <!-- AdSense will be injected here -->
            </div>
            
            @RenderBody()
            
            <!-- AdSense Bottom Banner -->
            <div class="text-center mt-4" id="adsense-bottom">
                <!-- AdSense will be injected here -->
            </div>
        </div>
    </main>

    <footer class="gs-footer mt-5">
        <div class="container py-5">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="gs-brand-mark"><i class="fas fa-mobile-alt"></i></span>
                        <strong>GSMSharing</strong>
                    </div>
                    <p class="text-muted mb-0" style="max-width: 560px;">
                        Clean, modern UI for mobile repair knowledge and community discussions.
                    </p>
                </div>
                <div class="d-flex gap-3 flex-wrap">
                    <a class="text-decoration-none text-muted" asp-controller="Blog" asp-action="Blogs">Blog</a>
                    <a class="text-decoration-none text-muted" asp-controller="Forum" asp-action="Index">Forums</a>
                    <a class="text-decoration-none text-muted" asp-controller="Posts" asp-action="Index">Posts</a>
                    <a class="text-decoration-none text-muted" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </div>
            <hr class="my-4" />
            <div class="d-flex flex-column flex-md-row justify-content-between gap-2">
                <small class="text-muted">&copy; @DateTime.Now.Year GSMSharing</small>
                <small class="text-muted">Built for repair enthusiasts</small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- SignalR Connection Scripts -->
    <script>
        // SignalR Comment Hub Connection
        const commentConnection = new signalR.HubConnectionBuilder()
            .withUrl("/commentHub")
            .build();

        commentConnection.start().then(() => {
            console.log("Comment Hub connected");
        }).catch(err => console.error("Comment Hub connection error: ", err));

        // SignalR Notification Hub Connection
        const notificationConnection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        notificationConnection.start().then(() => {
            console.log("Notification Hub connected");
            @if (User.Identity?.IsAuthenticated == true)
            {
                <text>
                notificationConnection.invoke("JoinUserGroup", "@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value");
                </text>
            }
        }).catch(err => console.error("Notification Hub connection error: ", err));

        // Listen for notifications
        notificationConnection.on("ReceiveNotification", function (notification) {
            updateNotificationBadge();
            showNotificationToast(notification);
        });

        function updateNotificationBadge() {
            fetch('/Notifications/GetUnreadCount')
                .then(response => response.json())
                .then(data => {
                    const badge = document.getElementById('notificationBadge');
                    if (data.count > 0) {
                        badge.textContent = data.count;
                        badge.style.display = 'block';
                    } else {
                        badge.style.display = 'none';
                    }
                });
        }

        function showNotificationToast(notification) {
            // Create and show toast notification
            const toast = document.createElement('div');
            toast.className = 'toast align-items-center text-white bg-primary border-0';
            toast.setAttribute('role', 'alert');
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">${notification.title}: ${notification.content}</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            `;
            document.body.appendChild(toast);
            const bsToast = new bootstrap.Toast(toast);
            bsToast.show();
        }

        @if (User.Identity?.IsAuthenticated == true)
        {
            <text>
            // Load notification count on page load
            updateNotificationBadge();
            </text>
        }
    </script>

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-YOUR_PUBLISHER_ID"
            crossorigin="anonymous"></script>
    <script>
        // Inject AdSense ads
        function injectAdSense(containerId, adFormat) {
            const container = document.getElementById(containerId);
            if (container) {
                const adDiv = document.createElement('ins');
                adDiv.className = 'adsbygoogle';
                adDiv.style.display = 'block';
                adDiv.setAttribute('data-ad-client', 'ca-pub-YOUR_PUBLISHER_ID');
                adDiv.setAttribute('data-ad-slot', 'YOUR_AD_SLOT_ID');
                adDiv.setAttribute('data-ad-format', adFormat);
                container.appendChild(adDiv);
                try {
                    (adsbygoogle = window.adsbygoogle || []).push({});
                } catch (e) {
                    console.error('AdSense error:', e);
                }
            }
        }

        // Inject ads when page loads
        document.addEventListener('DOMContentLoaded', function() {
            injectAdSense('adsense-top', 'auto');
            injectAdSense('adsense-bottom', 'auto');
            injectAdSense('adsense-sidebar-layout', 'auto');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
