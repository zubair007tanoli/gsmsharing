@model GsmsharingV2.ViewComponents.EngagingSidebarViewModel

<div class="engaging-sidebar">
    <!-- Random Blog -->
    @if (Model.RandomBlog != null)
    {
        <div class="sidebar-widget mb-4">
            <div class="sidebar-widget-header">
                <h6 class="mb-0">
                    <i class="fas fa-random me-2 text-primary"></i>Random Blog
                </h6>
            </div>
            <div class="sidebar-widget-content">
                <a href="/Blog/GsmBlogDetails/@Model.RandomBlog.BlogId" class="sidebar-item-link">
                    <h6 class="sidebar-item-title">@(Model.RandomBlog.BlogTitle?.Length > 60 ? Model.RandomBlog.BlogTitle.Substring(0, 60) + "..." : Model.RandomBlog.BlogTitle)</h6>
                    <div class="sidebar-item-meta">
                        <span><i class="fas fa-eye"></i> @(Model.RandomBlog.BlogViews ?? 0)</span>
                        <span><i class="fas fa-user"></i> @(Model.RandomBlog.User?.UserName ?? "Anonymous")</span>
                    </div>
                </a>
            </div>
        </div>
    }

    <!-- Random Forum -->
    @if (Model.RandomForum != null)
    {
        <div class="sidebar-widget mb-4">
            <div class="sidebar-widget-header">
                <h6 class="mb-0">
                    <i class="fas fa-comments me-2 text-info"></i>Random Forum
                </h6>
            </div>
            <div class="sidebar-widget-content">
                <a href="/Forum/Details/@Model.RandomForum.UserFourmID" class="sidebar-item-link">
                    <h6 class="sidebar-item-title">@(Model.RandomForum.Title?.Length > 60 ? Model.RandomForum.Title.Substring(0, 60) + "..." : Model.RandomForum.Title)</h6>
                    <div class="sidebar-item-meta">
                        <span><i class="fas fa-eye"></i> @(Model.RandomForum.Views ?? 0)</span>
                        <span><i class="fas fa-user"></i> @(Model.RandomForum.User?.UserName ?? "Anonymous")</span>
                    </div>
                </a>
            </div>
        </div>
    }

    <!-- Random Product -->
    @if (Model.RandomProduct != null)
    {
        <div class="sidebar-widget mb-4">
            <div class="sidebar-widget-header">
                <h6 class="mb-0">
                    <i class="fas fa-shopping-bag me-2 text-success"></i>Featured Product
                </h6>
            </div>
            <div class="sidebar-widget-content">
                @if (!string.IsNullOrEmpty(Model.RandomProduct.ImageLink))
                {
                    <img src="@Model.RandomProduct.ImageLink" alt="@Model.RandomProduct.Title" class="sidebar-product-image mb-2">
                }
                <a href="/Products/Details/@Model.RandomProduct.ProductId" class="sidebar-item-link">
                    <h6 class="sidebar-item-title">@(Model.RandomProduct.Title?.Length > 50 ? Model.RandomProduct.Title.Substring(0, 50) + "..." : Model.RandomProduct.Title)</h6>
                    @if (Model.RandomProduct.Price.HasValue)
                    {
                        <div class="sidebar-product-price">$@Model.RandomProduct.Price</div>
                    }
                </a>
            </div>
        </div>
    }

    <!-- Recent Posts -->
    @if (Model.RecentPosts.Any())
    {
        <div class="sidebar-widget mb-4">
            <div class="sidebar-widget-header">
                <h6 class="mb-0">
                    <i class="fas fa-newspaper me-2 text-primary"></i>Recent Posts
                </h6>
            </div>
            <div class="sidebar-widget-content">
                @foreach (var post in Model.RecentPosts)
                {
                    <div class="sidebar-list-item">
                        <a href="/r/@(post.Community?.Slug ?? "gsmsharing")/posts/@post.Slug" class="sidebar-item-link">
                            <h6 class="sidebar-item-title">@(post.Title?.Length > 50 ? post.Title.Substring(0, 50) + "..." : post.Title)</h6>
                            <div class="sidebar-item-meta">
                                <span><i class="fas fa-users"></i> r/@(post.Community?.Name ?? "Community")</span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Trending Forums -->
    @if (Model.TrendingForums.Any())
    {
        <div class="sidebar-widget mb-4">
            <div class="sidebar-widget-header">
                <h6 class="mb-0">
                    <i class="fas fa-fire me-2 text-danger"></i>Trending Forums
                </h6>
            </div>
            <div class="sidebar-widget-content">
                @foreach (var forum in Model.TrendingForums)
                {
                    <div class="sidebar-list-item">
                        <a href="/Forum/Details/@forum.UserFourmID" class="sidebar-item-link">
                            <h6 class="sidebar-item-title">@(forum.Title?.Length > 50 ? forum.Title.Substring(0, 50) + "..." : forum.Title)</h6>
                            <div class="sidebar-item-meta">
                                <span><i class="fas fa-eye"></i> @(forum.Views ?? 0) views</span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Popular Blogs -->
    @if (Model.PopularBlogs.Any())
    {
        <div class="sidebar-widget mb-4">
            <div class="sidebar-widget-header">
                <h6 class="mb-0">
                    <i class="fas fa-star me-2 text-warning"></i>Popular Blogs
                </h6>
            </div>
            <div class="sidebar-widget-content">
                @foreach (var blog in Model.PopularBlogs)
                {
                    <div class="sidebar-list-item">
                        <a href="/Blog/GsmBlogDetails/@blog.BlogId" class="sidebar-item-link">
                            <h6 class="sidebar-item-title">@(blog.BlogTitle?.Length > 50 ? blog.BlogTitle.Substring(0, 50) + "..." : blog.BlogTitle)</h6>
                            <div class="sidebar-item-meta">
                                <span><i class="fas fa-eye"></i> @(blog.BlogViews ?? 0) views</span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    .engaging-sidebar {
        position: sticky;
        top: 100px;
    }

    .sidebar-widget {
        background: var(--bg-card, #fff);
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        overflow: hidden;
        border: 1px solid var(--border-color, #e0e0e0);
    }

    .sidebar-widget-header {
        padding: 1rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .sidebar-widget-header h6 {
        font-weight: 600;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .sidebar-widget-content {
        padding: 1rem;
    }

    .sidebar-item-link {
        text-decoration: none;
        color: inherit;
        display: block;
        transition: transform 0.2s ease;
    }

    .sidebar-item-link:hover {
        transform: translateX(5px);
        color: var(--primary, #667eea);
    }

    .sidebar-item-title {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        line-height: 1.4;
        color: var(--text-primary, #333);
    }

    .sidebar-item-meta {
        display: flex;
        gap: 1rem;
        font-size: 0.75rem;
        color: var(--text-muted, #666);
        margin-top: 0.5rem;
    }

    .sidebar-item-meta span {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .sidebar-list-item {
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--border-color, #e0e0e0);
    }

    .sidebar-list-item:last-child {
        border-bottom: none;
    }

    .sidebar-product-image {
        width: 100%;
        height: 120px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 0.75rem;
    }

    .sidebar-product-price {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--primary, #667eea);
        margin-top: 0.5rem;
    }

    @@media (max-width: 991px) {
        .engaging-sidebar {
            position: static;
            margin-top: 2rem;
        }
    }
</style>


