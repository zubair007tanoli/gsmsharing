@model GsmsharingV2.Models.Post
@{
    ViewData["Title"] = Model.Title + " - GSMSharing";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8">
            <article class="card shadow-modern fade-in-up">
                <div class="card-body p-5">
                    <!-- Post Header -->
                    <div class="mb-5">
                        <div class="d-flex gap-2 mb-3">
                            @if (Model.IsFeatured == true)
                            {
                                <span class="badge-modern badge-featured-modern">
                                    <i class="fas fa-star"></i>Featured
                                </span>
                            }
                            @if (Model.IsPromoted == true)
                            {
                                <span class="badge-modern badge-promoted-modern">
                                    <i class="fas fa-fire"></i>Promoted
                                </span>
                            }
                        </div>
                        <h1 class="mb-4" style="font-size: 2.5rem; font-weight: 800; line-height: 1.2;">@Model.Title</h1>
                        
                        <div class="d-flex flex-wrap gap-4 align-items-center text-muted">
                            <span>
                                <i class="fas fa-user text-primary me-2"></i>
                                <strong class="text-dark">@Model.User?.UserName</strong>
                            </span>
                            <span>
                                <i class="fas fa-users text-primary me-2"></i>
                                <a href="#" class="text-decoration-none text-dark">@Model.Community?.Name</a>
                            </span>
                            <span>
                                <i class="fas fa-calendar text-primary me-2"></i>
                                @Model.CreatedAt?.ToString("MMMM dd, yyyy")
                            </span>
                            <span>
                                <i class="fas fa-eye text-primary me-2"></i>
                                @(Model.ViewCount ?? 0) views
                            </span>
                        </div>
                    </div>

                    <!-- Featured Image -->
                    @if (!string.IsNullOrEmpty(Model.FeaturedImage))
                    {
                        <div class="mb-5">
                            <img src="@Model.FeaturedImage" class="img-fluid rounded-modern shadow-modern" alt="@Model.Title" style="max-height: 500px; object-fit: cover; width: 100%;">
                        </div>
                    }

                    <!-- Post Content -->
                    <div class="post-content mb-5" style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary);">
                        @Html.Raw(Model.Content)
                    </div>

                    <!-- Post Tags -->
                    @if (!string.IsNullOrEmpty(Model.Tags))
                    {
                        <div class="mb-5">
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (var tag in Model.Tags.Split(',').Take(5))
                                {
                                    <span class="post-tag-modern">#@tag.Trim()</span>
                                }
                            </div>
                        </div>
                    }

                    <!-- Post Actions -->
                    <div class="d-flex gap-3 mb-4 pb-4 border-bottom">
                        <button class="btn btn-outline-primary">
                            <i class="fas fa-thumbs-up me-2"></i>Like
                        </button>
                        <button class="btn btn-outline-primary">
                            <i class="fas fa-share me-2"></i>Share
                        </button>
                        <button class="btn btn-outline-primary">
                            <i class="fas fa-bookmark me-2"></i>Save
                        </button>
                    </div>

                    <!-- Edit/Delete Actions (for post owner) -->
                    @if (User.Identity?.IsAuthenticated == true && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.UserId)
                    {
                        <hr class="my-4">
                        <div class="d-flex gap-2">
                            <a href="/Posts/Edit/@Model.PostID" class="btn btn-warning">
                                <i class="fas fa-edit me-2"></i>Edit Post
                            </a>
                            <form asp-action="Delete" asp-route-id="@Model.PostID" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this post?')">
                                    <i class="fas fa-trash me-2"></i>Delete Post
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </article>

            <!-- Comments Section -->
            <div class="card shadow-modern mt-4 fade-in-up">
                <div class="card-body p-5">
                    <h3 class="mb-4" style="font-weight: 700;">
                        <i class="fas fa-comments me-2 text-primary"></i>Comments
                    </h3>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="mb-4">
                            <form id="comment-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="PostID" value="@Model.PostID" />
                                <div class="mb-3">
                                    <textarea name="Content" class="form-control" rows="3" placeholder="Write a comment..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-paper-plane me-2"></i>Post Comment
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            <a href="/UserAccounts/Login" class="alert-link">Login</a> to join the discussion
                        </div>
                    }
                    <div id="comments-list" class="comments-list">
                        <p class="text-muted text-center py-4">Loading comments...</p>
                    </div>
                    <div id="comment-count" style="display: none;">0</div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card shadow-custom mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">
                        <i class="fas fa-info-circle me-2"></i>About This Post
                    </h5>
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="fas fa-user text-primary me-2"></i>
                            <strong>Author:</strong> @Model.User?.UserName
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-users text-primary me-2"></i>
                            <strong>Community:</strong> @Model.Community?.Name
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-calendar text-primary me-2"></i>
                            <strong>Published:</strong> @Model.PublishedAt?.ToString("MMMM dd, yyyy")
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-eye text-primary me-2"></i>
                            <strong>Views:</strong> @(Model.ViewCount ?? 0)
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-custom mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">
                        <i class="fas fa-fire me-2"></i>Trending Posts
                    </h5>
                    <p class="text-muted">Coming soon...</p>
                </div>
            </div>

            <div class="card shadow-custom">
                <div class="card-body">
                    <h5 class="card-title mb-3">
                        <i class="fas fa-tags me-2"></i>Related Tags
                    </h5>
                    <div class="post-tags">
                        @if (!string.IsNullOrEmpty(Model.Tags))
                        {
                            @foreach (var tag in Model.Tags.Split(',').Take(10))
                            {
                                <span class="post-tag">#@tag.Trim()</span>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/comments.js" asp-append-version="true"></script>
    <script>
        // Load comments when page loads and initialize SignalR
        document.addEventListener('DOMContentLoaded', function() {
            const postId = @Model.PostID;
            if (postId) {
                loadComments(postId);
                initializeCommentHub(postId);
            }
        });
    </script>
}
