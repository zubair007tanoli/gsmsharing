@model GsmsharingV2.Models.Post
@{
    ViewData["Title"] = Model.Title + " - GSMSharing";
    var currentUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-9">
            <article class="card shadow-modern fade-in-up">
                <div class="card-body p-5">
                    <!-- Post Header -->
                    <div class="mb-4">
                        <div class="d-flex gap-2 mb-3">
                            @if (Model.IsFeatured == true)
                            {
                                <span class="badge bg-warning">
                                    <i class="fas fa-star"></i> Featured
                                </span>
                            }
                            @if (Model.IsPromoted == true)
                            {
                                <span class="badge bg-danger">
                                    <i class="fas fa-fire"></i> Promoted
                                </span>
                            }
                            @if (Model.IsPinned)
                            {
                                <span class="badge bg-info">
                                    <i class="fas fa-thumbtack"></i> Pinned
                                </span>
                            }
                        </div>
                        <h1 class="mb-3" style="font-size: 2.5rem; font-weight: 800; line-height: 1.2;">@Model.Title</h1>
                        
                        <div class="d-flex flex-wrap gap-4 align-items-center text-muted mb-3">
                            <span>
                                <i class="fas fa-user text-primary me-2"></i>
                                <a href="/Profile/@Model.UserId" class="text-decoration-none">
                                    <strong>@Model.User?.UserName</strong>
                                </a>
                            </span>
                            <span>
                                <i class="fas fa-users text-primary me-2"></i>
                                <a href="/r/@Model.Community?.Slug" class="text-decoration-none">r/@Model.Community?.Name</a>
                            </span>
                            <span>
                                <i class="fas fa-calendar text-primary me-2"></i>
                                @Model.CreatedAt?.ToString("MMMM dd, yyyy")
                            </span>
                            <span>
                                <i class="fas fa-eye text-primary me-2"></i>
                                @(Model.ViewCount ?? 0) views
                            </span>
                        </div>
                    </div>

                    <!-- Voting and Actions Sidebar (Left) -->
                    <div class="d-flex gap-4">
                        <div class="vote-section">
                            @await Component.InvokeAsync("VoteButtons", new { 
                                contentType = "post", 
                                contentId = Model.PostID,
                                upvotes = Model.UpvoteCount,
                                downvotes = Model.DownvoteCount
                            })
                        </div>

                        <div class="flex-grow-1">
                            <!-- Featured Image -->
                            @if (!string.IsNullOrEmpty(Model.FeaturedImage))
                            {
                                <div class="mb-4">
                                    <img src="@Model.FeaturedImage" class="img-fluid rounded" alt="@Model.Title" style="max-height: 500px; object-fit: cover; width: 100%;">
                                </div>
                            }

                            <!-- Post Content -->
                            <div class="post-content mb-4" style="font-size: 1.125rem; line-height: 1.8;">
                                @Html.Raw(Model.Content)
                            </div>

                            <!-- Post Tags -->
                            @if (!string.IsNullOrEmpty(Model.Tags))
                            {
                                <div class="mb-4">
                                    <div class="d-flex gap-2 flex-wrap">
                                        @foreach (var tag in Model.Tags.Split(',').Take(10))
                                        {
                                            <a href="/Posts?tag=@Uri.EscapeDataString(tag.Trim())" class="badge bg-secondary text-decoration-none">#@tag.Trim()</a>
                                        }
                                    </div>
                                </div>
                            }

                            <!-- Social Sharing -->
                            <div class="mb-4">
                                @await Component.InvokeAsync("SocialShare", new { 
                                    contentType = "post", 
                                    contentId = Model.PostID, 
                                    title = Model.Title,
                                    url = currentUrl
                                })
                            </div>

                            <!-- Post Actions -->
                            <div class="d-flex gap-2 flex-wrap mb-4 pb-4 border-bottom">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <button class="btn btn-outline-primary btn-sm" id="savePostBtn" data-post-id="@Model.PostID">
                                        <i class="fas fa-bookmark me-2"></i>Save
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#reportModal">
                                        <i class="fas fa-flag me-2"></i>Report
                                    </button>
                                }
                                
                                <!-- Edit/Delete Actions (for post owner) -->
                                @if (User.Identity?.IsAuthenticated == true && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.UserId)
                                {
                                    <a href="/Posts/Edit/@Model.PostID" class="btn btn-warning btn-sm">
                                        <i class="fas fa-edit me-2"></i>Edit
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@Model.PostID" method="post" class="d-inline" onsubmit="return confirm('Are you sure?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="fas fa-trash me-2"></i>Delete
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- AdSense In-Content Ad -->
                    @await Component.InvokeAsync("AdSense", new { position = "incontent" })
                </div>
            </article>

            <!-- Comments Section -->
            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-comments me-2"></i>
                        Comments (@Model.CommentCount)
                    </h5>
                </div>
                <div class="card-body">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <!-- Comment Form -->
                        <form id="commentForm" class="mb-4">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="PostID" value="@Model.PostID" />
                            <div class="mb-3">
                                <textarea name="Content" class="form-control" rows="3" placeholder="Write a comment..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-2"></i>Post Comment
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <a href="/UserAccounts/Login">Login</a> to post a comment.
                        </div>
                    }

                    <!-- Comments List -->
                    <div id="commentsContainer">
                        <!-- Comments will be loaded here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-3">
            <!-- Author Info -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-user me-2"></i>Author</h6>
                </div>
                <div class="card-body text-center">
                    <img src="@(Model.User?.AvatarPath ?? "/images/default-avatar.png")" class="rounded-circle mb-2" width="80" height="80" alt="Avatar">
                    <h6>@Model.User?.UserName</h6>
                    <p class="text-muted small mb-2">Joined @Model.User?.CreatedDate?.ToString("MMM yyyy")</p>
                    <a href="/Profile/@Model.UserId" class="btn btn-sm btn-outline-primary">View Profile</a>
                </div>
            </div>

            <!-- Related Posts -->
            @await Component.InvokeAsync("EngagingSidebar")

            <!-- AdSense Sidebar -->
            @await Component.InvokeAsync("AdSense", new { position = "sidebar" })
        </div>
    </div>
</div>

<!-- Report Modal -->
<div class="modal fade" id="reportModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Report Post</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="reportForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PostID" value="@Model.PostID" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Reason</label>
                        <select name="Reason" class="form-select" required>
                            <option value="">Select a reason</option>
                            <option value="Spam">Spam</option>
                            <option value="Harassment">Harassment</option>
                            <option value="Inappropriate Content">Inappropriate Content</option>
                            <option value="Copyright Violation">Copyright Violation</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Details</label>
                        <textarea name="Details" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Submit Report</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Load comments
        async function loadComments() {
            try {
                const response = await fetch('/api/Comments/GetByPost/@Model.PostID');
                const comments = await response.json();
                const container = document.getElementById('commentsContainer');
                container.innerHTML = comments.map(c => renderComment(c)).join('');
            } catch (error) {
                console.error('Error loading comments:', error);
            }
        }

        function renderComment(comment) {
            return `
                <div class="comment-item mb-3 pb-3 border-bottom" data-comment-id="${comment.commentID}">
                    <div class="d-flex gap-3">
                        <div class="vote-section-sm">
                            @await Component.InvokeAsync("VoteButtons", new { contentType = "comment", contentId = -1 })
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <strong>${comment.user?.userName || 'Anonymous'}</strong>
                                <span class="text-muted small">${new Date(comment.createdAt).toLocaleString()}</span>
                            </div>
                            <div class="comment-content">${comment.content}</div>
                        </div>
                    </div>
                </div>
            `;
        }

        // Submit comment
        document.getElementById('commentForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            
            try {
                const response = await fetch('/api/Comments/Create', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: formData
                });
                
                if (response.ok) {
                    this.reset();
                    loadComments();
                }
            } catch (error) {
                console.error('Error posting comment:', error);
            }
        });

        // Save post
        document.getElementById('savePostBtn')?.addEventListener('click', async function() {
            const postId = this.dataset.postId;
            try {
                const response = await fetch('/api/SavedPosts/Save', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({ postID: parseInt(postId) })
                });
                
                if (response.ok) {
                    const data = await response.json();
                    const icon = this.querySelector('i');
                    if (data.saved) {
                        icon.className = 'fas fa-bookmark me-2';
                        this.classList.remove('btn-outline-primary');
                        this.classList.add('btn-primary');
                    } else {
                        icon.className = 'far fa-bookmark me-2';
                        this.classList.remove('btn-primary');
                        this.classList.add('btn-outline-primary');
                    }
                }
            } catch (error) {
                console.error('Error saving post:', error);
            }
        });

        // Submit report
        document.getElementById('reportForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            
            try {
                const response = await fetch('/api/Reports/Post', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('#reportForm input[name="__RequestVerificationToken"]').value
                    },
                    body: formData
                });
                
                if (response.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('reportModal')).hide();
                    alert('Report submitted successfully');
                }
            } catch (error) {
                console.error('Error submitting report:', error);
            }
        });

        // Load comments on page load
        loadComments();
    </script>
}

