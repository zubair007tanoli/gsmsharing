@model GsmsharingV2.Models.Post
@{
    ViewData["Title"] = "Create Post - GSMSharing";
}

@section Styles {
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <style>
        .create-post-wrapper {
            background: #f5f7fa;
            min-height: 100vh;
            padding: 2rem 0;
        }

        .three-column-layout {
            display: grid;
            grid-template-columns: 1fr 2fr 1fr;
            gap: 1.5rem;
            max-width: 1600px;
            margin: 0 auto;
        }

        .column {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }

        .left-column {
            position: sticky;
            top: 2rem;
            height: fit-content;
        }

        .middle-column {
            min-height: 600px;
        }

        .right-column {
            position: sticky;
            top: 2rem;
            height: fit-content;
        }

        .section-header {
            font-size: 1.1rem;
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #e2e8f0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .section-header i {
            color: #667eea;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-label {
            font-weight: 500;
            color: #4a5568;
            margin-bottom: 0.5rem;
            display: block;
            font-size: 0.9rem;
        }

        .form-control, .form-select {
            border: 1px solid #cbd5e0;
            border-radius: 8px;
            padding: 0.75rem;
            transition: all 0.2s;
            width: 100%;
            font-size: 0.9rem;
        }
        
        .form-control[type="file"] {
            padding: 0.5rem;
            cursor: pointer;
        }

        .form-control:focus, .form-select:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
            outline: none;
        }

        .character-count {
            font-size: 0.75rem;
            color: #718096;
            text-align: right;
            margin-top: 0.25rem;
        }

        .character-count.warning {
            color: #ed8936;
        }

        .character-count.danger {
            color: #e53e3e;
        }

        #contentEditor {
            min-height: 400px;
            border: 1px solid #cbd5e0;
            border-radius: 8px;
        }

        .tag-input-container {
            border: 1px solid #cbd5e0;
            border-radius: 8px;
            padding: 0.5rem;
            min-height: 50px;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            align-items: center;
        }

        .tag {
            background: #667eea;
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.875rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .tag-remove {
            cursor: pointer;
            font-weight: bold;
            opacity: 0.8;
        }

        .tag-remove:hover {
            opacity: 1;
        }

        .image-preview-container {
            margin-top: 1rem;
            border-radius: 8px;
            overflow: hidden;
        }

        .image-preview {
            max-width: 100%;
            max-height: 300px;
            border-radius: 8px;
        }

        .switch-group {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem;
            border-radius: 8px;
            margin-bottom: 0.5rem;
            transition: background 0.2s;
        }

        .switch-group:hover {
            background: #f7fafc;
        }

        .form-switch {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 26px;
        }

        .form-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #cbd5e0;
            transition: 0.3s;
            border-radius: 26px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: 0.3s;
            border-radius: 50%;
        }

        input:checked + .slider {
            background-color: #667eea;
        }

        input:checked + .slider:before {
            transform: translateX(24px);
        }

        .seo-preview {
            background: #f7fafc;
            border-left: 4px solid #48bb78;
            padding: 1rem;
            border-radius: 8px;
            margin-top: 1rem;
        }

        .seo-preview-title {
            color: #1a0dab;
            font-size: 1.1rem;
            font-weight: 400;
            margin-bottom: 0.25rem;
            cursor: pointer;
        }

        .seo-preview-title:hover {
            text-decoration: underline;
        }

        .seo-preview-url {
            color: #006621;
            font-size: 0.875rem;
            margin-bottom: 0.25rem;
        }

        .seo-preview-description {
            color: #545454;
            font-size: 0.875rem;
            line-height: 1.4;
        }

        .action-buttons {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px solid #e2e8f0;
        }

        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-primary {
            background: #667eea;
            color: white;
        }

        .btn-primary:hover {
            background: #5568d3;
        }

        .btn-outline {
            background: white;
            color: #667eea;
            border: 1px solid #667eea;
        }

        .btn-outline:hover {
            background: #f7fafc;
        }

        .info-box {
            background: #edf2f7;
            border-left: 4px solid #4299e1;
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            font-size: 0.875rem;
        }

        .info-box i {
            color: #4299e1;
            margin-right: 0.5rem;
        }

        .text-danger {
            color: #e53e3e;
            font-size: 0.875rem;
            margin-top: 0.25rem;
            display: block;
        }
        
        .text-muted {
            color: #718096;
        }
        
        .d-block {
            display: block;
        }
        
        .me-1 {
            margin-right: 0.25rem;
        }
        
        .me-2 {
            margin-right: 0.5rem;
        }
        
        .mt-2 {
            margin-top: 0.5rem;
        }
        
        .btn-sm {
            padding: 0.5rem 1rem;
            font-size: 0.875rem;
        }
        
        .flex-grow-1 {
            flex-grow: 1;
        }
        
        .border-0 {
            border: 0;
        }

        @@media (max-width: 1200px) {
            .three-column-layout {
                grid-template-columns: 1fr;
            }
            .left-column, .right-column {
                position: static;
            }
        }
    </style>
}

<div class="create-post-wrapper">
    <div class="container-fluid px-4">
        <!-- Page Header -->
        <div style="margin-bottom: 2rem; text-align: center;">
            <h1 style="font-size: 2rem; font-weight: 700; color: #2d3748; margin-bottom: 0.5rem;">
                <i class="fas fa-plus-circle" style="color: #667eea; margin-right: 0.5rem;"></i>Create New Post
            </h1>
            <p style="color: #718096; font-size: 1rem;">Fill out the form below to create your post</p>
        </div>
        
        <form asp-action="Create" method="post" enctype="multipart/form-data" id="createPostForm">
            @Html.AntiForgeryToken()
            
            <div class="three-column-layout">
                <!-- LEFT COLUMN: Basic Info & Community -->
                <div class="column left-column">
                    <div class="section-header">
                        <i class="fas fa-info-circle"></i>
                        Basic Information
                    </div>

                    <div class="form-group">
                        <label asp-for="Title" class="form-label">Title *</label>
                        <input name="Title" class="form-control" placeholder="Enter post title..." required id="postTitle" value="@Model?.Title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                        <div class="character-count" id="titleCount">0 / 500</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="CommunityID" class="form-label">Community *</label>
                        <select name="CommunityID" class="form-select" asp-items="@(new SelectList(ViewBag.Communities ?? new List<GsmsharingV2.Models.Community>(), "CommunityID", "Name", Model?.CommunityID))" required>
                            <option value="">Select a community</option>
                        </select>
                        <span asp-validation-for="CommunityID" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Excerpt" class="form-label">Excerpt</label>
                        <textarea name="Excerpt" class="form-control" rows="3" placeholder="Brief summary..." maxlength="1000" id="excerptInput">@Model?.Excerpt</textarea>
                        <div class="character-count" id="excerptCount">0 / 1000</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Slug" class="form-label">URL Slug (SEO-Friendly)</label>
                        <input name="Slug" class="form-control" placeholder="auto-generated-from-title" id="slugInput" pattern="[a-z0-9-]+" value="@Model?.Slug" />
                        <button type="button" class="btn btn-outline btn-sm mt-2" id="generateSlugBtn" style="width: 100%;">
                            <i class="fas fa-magic me-2"></i>Generate SEO-Friendly Slug
                        </button>
                        <small class="text-muted d-block" style="font-size: 0.75rem; margin-top: 0.5rem;">
                            SEO-friendly URL. Auto-generated from title. Use lowercase letters, numbers, and hyphens only.
                        </small>
                        <span asp-validation-for="Slug" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Tags</label>
                        <div class="tag-input-container" id="tagContainer">
                            <input type="text" id="tagInput" class="border-0 flex-grow-1" placeholder="Type and press Enter..." />
                        </div>
                        <input type="hidden" name="Tags" id="tagsHidden" value="@Model?.Tags" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Featured Image</label>
                        <input type="file" id="imageUpload" name="imageFile" accept="image/*" class="form-control mb-2" />
                        <input name="FeaturedImage" type="text" class="form-control mt-2" placeholder="Or enter image URL..." value="@Model?.FeaturedImage" />
                        <div class="image-preview-container" id="imagePreviewContainer" style="display:none;">
                            <img id="previewImg" class="image-preview" alt="Preview" />
                            <button type="button" class="btn btn-outline btn-sm mt-2" onclick="clearImagePreview()">
                                <i class="fas fa-times me-1"></i>Remove
                            </button>
                        </div>
                        <small class="text-muted d-block" style="font-size: 0.75rem; margin-top: 0.5rem;">Upload an image file or provide a URL</small>
                    </div>
                </div>

                <!-- MIDDLE COLUMN: Content Editor -->
                <div class="column middle-column">
                    <div class="section-header">
                        <i class="fas fa-edit"></i>
                        Content Editor
                    </div>

                    <div class="form-group">
                        <label asp-for="Content" class="form-label">Content *</label>
                        <div id="contentEditor"></div>
                        <textarea name="Content" style="display: none;" required id="contentTextarea">@Model?.Content</textarea>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <div class="editor-stats">
                                <span id="wordCount" class="text-muted small">0 words</span>
                                <span class="text-muted mx-2">•</span>
                                <span id="charCount" class="text-muted small">0 characters</span>
                            </div>
                            <div class="editor-shortcuts text-muted small">
                                <span><kbd>Ctrl+B</kbd> Bold</span>
                                <span class="mx-1">•</span>
                                <span><kbd>Ctrl+I</kbd> Italic</span>
                                <span class="mx-1">•</span>
                                <span><kbd>Ctrl+K</kbd> Link</span>
                            </div>
                        </div>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>
                </div>

                <!-- RIGHT COLUMN: SEO & Settings -->
                <div class="column right-column">
                    <div class="section-header">
                        <i class="fas fa-cog"></i>
                        SEO & Settings
                    </div>

                    <!-- SEO Fields -->
                    <div class="form-group">
                        <label asp-for="FocusKeyword" class="form-label">Focus Keyword</label>
                        <input name="FocusKeyword" class="form-control" placeholder="Main keyword..." value="@Model?.FocusKeyword" />
                    </div>

                    <div class="form-group">
                        <label asp-for="MetaTitle" class="form-label">Meta Title</label>
                        <input name="MetaTitle" class="form-control" placeholder="SEO title..." maxlength="255" id="metaTitleInput" value="@Model?.MetaTitle" />
                        <div class="character-count" id="metaTitleCount">0 / 255</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="MetaDescription" class="form-label">Meta Description</label>
                        <textarea name="MetaDescription" class="form-control" rows="3" placeholder="SEO description..." maxlength="500" id="metaDescInput">@Model?.MetaDescription</textarea>
                        <div class="character-count" id="metaDescCount">0 / 500</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="OgTitle" class="form-label">OG Title</label>
                        <input name="OgTitle" class="form-control" placeholder="Open Graph title..." maxlength="255" value="@Model?.OgTitle" />
                    </div>

                    <div class="form-group">
                        <label asp-for="OgDescription" class="form-label">OG Description</label>
                        <textarea name="OgDescription" class="form-control" rows="2" placeholder="Open Graph description..." maxlength="500">@Model?.OgDescription</textarea>
                    </div>

                    <div class="form-group">
                        <label asp-for="OgImage" class="form-label">OG Image URL</label>
                        <input name="OgImage" class="form-control" type="url" placeholder="https://..." value="@Model?.OgImage" />
                    </div>

                    <div class="form-group">
                        <label asp-for="CanonicalUrl" class="form-label">Canonical URL</label>
                        <input name="CanonicalUrl" class="form-control" type="url" placeholder="https://..." value="@Model?.CanonicalUrl" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Slug" class="form-label">URL Slug (SEO-Friendly)</label>
                        <input name="Slug" class="form-control" placeholder="auto-generated-from-title" id="slugInput" pattern="[a-z0-9-]+" value="@Model?.Slug" />
                        <button type="button" class="btn btn-outline btn-sm mt-2" id="generateSlugBtn" style="width: 100%;">
                            <i class="fas fa-magic me-2"></i>Generate SEO-Friendly Slug
                        </button>
                        <small class="text-muted d-block" style="font-size: 0.75rem; margin-top: 0.5rem;">
                            SEO-friendly URL. Auto-generated from title. Use lowercase letters, numbers, and hyphens only.
                        </small>
                        <span asp-validation-for="Slug" class="text-danger"></span>
                    </div>

                    <!-- SEO Preview -->
                    <div class="seo-preview" id="seoPreview">
                        <div class="seo-preview-title" id="previewTitle">Enter a title to see preview</div>
                        <div class="seo-preview-url" id="previewUrl">https://gsmsharing.com/r/community/your-post-slug</div>
                        <div class="seo-preview-description" id="previewDescription">Enter a meta description to see preview</div>
                    </div>

                    <!-- Post Settings -->
                    <div class="section-header" style="margin-top: 2rem;">
                        <i class="fas fa-sliders-h"></i>
                        Post Settings
                    </div>

                    <div class="form-group">
                        <label asp-for="PostStatus" class="form-label">Status</label>
                        <select name="PostStatus" class="form-select" id="postStatusSelect">
                            @if (Model?.PostStatus == "draft")
                            {
                                <option value="draft" selected>Draft</option>
                                <option value="published">Published</option>
                                <option value="archived">Archived</option>
                            }
                            else if (Model?.PostStatus == "archived")
                            {
                                <option value="draft">Draft</option>
                                <option value="published">Published</option>
                                <option value="archived" selected>Archived</option>
                            }
                            else
                            {
                                <option value="draft">Draft</option>
                                <option value="published" selected>Published</option>
                                <option value="archived">Archived</option>
                            }
                        </select>
                    </div>

                    <div class="switch-group">
                        <div>
                            <label class="form-label" style="margin: 0;">Allow Comments</label>
                            <small class="text-muted d-block" style="font-size: 0.75rem;">Users can comment</small>
                        </div>
                        <label class="form-switch">
                            <input type="checkbox" name="AllowComments" value="true" @(Model?.AllowComments == true ? "checked" : "") />
                            <input type="hidden" name="AllowComments" value="false" />
                            <span class="slider"></span>
                        </label>
                    </div>

                    <div class="switch-group">
                        <div>
                            <label class="form-label" style="margin: 0;">Feature Post</label>
                            <small class="text-muted d-block" style="font-size: 0.75rem;">Show in featured</small>
                        </div>
                        <label class="form-switch">
                            <input type="checkbox" name="IsFeatured" value="true" @(Model?.IsFeatured == true ? "checked" : "") />
                            <input type="hidden" name="IsFeatured" value="false" />
                            <span class="slider"></span>
                        </label>
                    </div>

                    <div class="switch-group">
                        <div>
                            <label class="form-label" style="margin: 0;">Promote Post</label>
                            <small class="text-muted d-block" style="font-size: 0.75rem;">Boost visibility</small>
                        </div>
                        <label class="form-switch">
                            <input type="checkbox" name="IsPromoted" value="true" @(Model?.IsPromoted == true ? "checked" : "") />
                            <input type="hidden" name="IsPromoted" value="false" />
                            <span class="slider"></span>
                        </label>
                    </div>

                    <div class="switch-group">
                        <div>
                            <label class="form-label" style="margin: 0;">Pin Post</label>
                            <small class="text-muted d-block" style="font-size: 0.75rem;">Pin to top</small>
                        </div>
                        <label class="form-switch">
                            <input type="checkbox" name="IsPinned" value="true" @(Model?.IsPinned == true ? "checked" : "") />
                            <input type="hidden" name="IsPinned" value="false" />
                            <span class="slider"></span>
                        </label>
                    </div>

                    <div class="switch-group">
                        <div>
                            <label class="form-label" style="margin: 0;">Lock Post</label>
                            <small class="text-muted d-block" style="font-size: 0.75rem;">Disable comments</small>
                        </div>
                        <label class="form-switch">
                            <input type="checkbox" name="IsLocked" value="true" @(Model?.IsLocked == true ? "checked" : "") />
                            <input type="hidden" name="IsLocked" value="false" />
                            <span class="slider"></span>
                        </label>
                    </div>

                    <div class="info-box">
                        <i class="fas fa-info-circle"></i>
                        <strong>Note:</strong> Featured and Promoted posts may require admin approval.
                    </div>

                    <!-- Action Buttons -->
                    <div class="action-buttons">
                        <a href="/Posts" class="btn btn-outline" style="flex: 1;">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                        <button type="submit" name="action" value="draft" class="btn btn-outline" style="flex: 1;">
                            <i class="fas fa-save me-2"></i>Draft
                        </button>
                        <button type="submit" name="action" value="publish" class="btn btn-primary" style="flex: 1;">
                            <i class="fas fa-paper-plane me-2"></i>Publish
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        // Initialize Quill Editor
        var quill = new Quill('#contentEditor', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, 4, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'color': [] }, { 'background': [] }],
                    [{ 'align': [] }],
                    ['link', 'image', 'video', 'code-block'],
                    ['blockquote', 'clean']
                ]
            },
            placeholder: 'Write your post content here...'
        });

        quill.on('text-change', function() {
            document.getElementById('contentTextarea').value = quill.root.innerHTML;
        });

        // Character Counters
        function updateCounter(inputId, counterId, maxLength) {
            const input = document.getElementById(inputId);
            const counter = document.getElementById(counterId);
            if (!input || !counter) return;
            
            input.addEventListener('input', function() {
                const length = this.value.length;
                counter.textContent = length + ' / ' + maxLength;
                counter.className = 'character-count';
                if (length > maxLength * 0.9) counter.classList.add('warning');
                if (length > maxLength) counter.classList.add('danger');
            });
        }

        updateCounter('postTitle', 'titleCount', 500);
        updateCounter('excerptInput', 'excerptCount', 1000);
        updateCounter('metaTitleInput', 'metaTitleCount', 255);
        updateCounter('metaDescInput', 'metaDescCount', 500);

        // Generate SEO-friendly slug from text
        function generateSlug(text) {
            if (!text) return '';
            return text
                .toLowerCase()
                .trim()
                .replace(/[^\w\s-]/g, '') // Remove special characters
                .replace(/[\s_]+/g, '-') // Replace spaces and underscores with hyphens
                .replace(/-+/g, '-') // Replace multiple hyphens with single hyphen
                .replace(/^-+|-+$/g, ''); // Remove leading/trailing hyphens
        }

        // Manual slug generation button
        document.getElementById('generateSlugBtn')?.addEventListener('click', function() {
            const title = document.getElementById('postTitle')?.value;
            const slugInput = document.getElementById('slugInput');
            if (title && slugInput) {
                slugInput.value = generateSlug(title);
                updateSEOPreview();
            }
        });

        // Auto-fill meta title and slug from title
        document.getElementById('postTitle')?.addEventListener('input', function() {
            const metaTitle = document.getElementById('metaTitleInput');
            if (metaTitle && !metaTitle.value) {
                metaTitle.value = this.value.substring(0, 255);
            }
            
            // Auto-generate slug from title (only if slug is empty)
            const slugInput = document.getElementById('slugInput');
            if (slugInput && !slugInput.value) {
                const slug = generateSlug(this.value);
                slugInput.value = slug;
            }
            
            updateSEOPreview();
        });

        // Update slug preview when slug changes
        document.getElementById('slugInput')?.addEventListener('input', function() {
            // Clean the slug as user types
            const cleaned = generateSlug(this.value);
            if (cleaned !== this.value) {
                this.value = cleaned;
            }
            updateSEOPreview();
        });

        // Update community preview when community changes
        document.getElementById('CommunityID')?.addEventListener('change', function() {
            updateSEOPreview();
        });

        // Update SEO Preview
        function updateSEOPreview() {
            const title = document.getElementById('metaTitleInput')?.value || document.getElementById('postTitle')?.value || 'Enter a title';
            const description = document.getElementById('metaDescInput')?.value || 'Enter a meta description';
            const slug = document.getElementById('slugInput')?.value || 'your-post-slug';
            const communitySelect = document.getElementById('CommunityID');
            const communityName = communitySelect?.options[communitySelect.selectedIndex]?.text?.toLowerCase().replace(/\s+/g, '-') || 'community';
            
            const previewTitle = document.getElementById('previewTitle');
            const previewDesc = document.getElementById('previewDescription');
            const previewUrl = document.getElementById('previewUrl');
            const previewSlug = document.getElementById('previewSlug');
            
            if (previewTitle) previewTitle.textContent = title.substring(0, 60);
            if (previewDesc) previewDesc.textContent = description.substring(0, 160);
            if (previewUrl) {
                const baseUrl = window.location.origin;
                const seoUrl = `${baseUrl}/r/${communityName}/${slug || 'your-post-slug'}`;
                previewUrl.textContent = seoUrl;
            }
        }

        
        // Update slug preview when slug changes
        const slugInput = document.getElementById('slugInput');
        if (slugInput) {
            slugInput.addEventListener('input', function() {
                // Clean the slug as user types
                const cleaned = generateSlug(this.value);
                if (cleaned !== this.value) {
                    this.value = cleaned;
                }
                updateSEOPreview();
            });
        }

        document.getElementById('metaTitleInput')?.addEventListener('input', updateSEOPreview);
        document.getElementById('metaDescInput')?.addEventListener('input', updateSEOPreview);
        document.getElementById('slugInput')?.addEventListener('input', function() {
            // Clean the slug as user types
            const cleaned = generateSlug(this.value);
            if (cleaned !== this.value) {
                this.value = cleaned;
            }
            updateSEOPreview();
        });
        
        // Update preview when community changes
        const communitySelect = document.getElementById('CommunityID');
        if (communitySelect) {
            communitySelect.addEventListener('change', updateSEOPreview);
        }

        // Tag Management
        const tags = [];
        const tagInput = document.getElementById('tagInput');
        const tagContainer = document.getElementById('tagContainer');
        const tagsHidden = document.getElementById('tagsHidden');

        tagInput?.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                const tag = this.value.trim();
                if (tag && !tags.includes(tag) && tags.length < 20) {
                    tags.push(tag);
                    this.value = '';
                    updateTags();
                }
            }
        });

        function updateTags() {
            const tagsHtml = tags.map(tag => 
                `<span class="tag">${tag} <span class="tag-remove" data-tag="${tag}">×</span></span>`
            ).join('');
            tagContainer.innerHTML = tagsHtml + '<input type="text" id="tagInput" class="border-0 flex-grow-1" placeholder="Type and press Enter..." />';
            if (tagsHidden) tagsHidden.value = tags.join(',');
            
            document.querySelectorAll('.tag-remove').forEach(btn => {
                btn.addEventListener('click', function() {
                    const tagToRemove = this.dataset.tag;
                    const index = tags.indexOf(tagToRemove);
                    if (index > -1) {
                        tags.splice(index, 1);
                        updateTags();
                    }
                });
            });
            
            document.getElementById('tagInput')?.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    const tag = this.value.trim();
                    if (tag && !tags.includes(tag) && tags.length < 20) {
                        tags.push(tag);
                        this.value = '';
                        updateTags();
                    }
                }
            });
        }

        // Image Preview
        document.getElementById('imageUpload')?.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('imagePreviewContainer').style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });

        function clearImagePreview() {
            document.getElementById('imageUpload').value = '';
            document.getElementById('imagePreviewContainer').style.display = 'none';
            document.getElementById('previewImg').src = '';
        }

        // Form Submission
        document.getElementById('createPostForm')?.addEventListener('submit', function(e) {
            document.getElementById('contentTextarea').value = quill.root.innerHTML;
            if (tagsHidden) tagsHidden.value = tags.join(',');
        });
    </script>
}
