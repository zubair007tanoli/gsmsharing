@model GsmsharingV2.Models.Post
@{
    ViewData["Title"] = "Create Post - GSMSharing";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-modern fade-in-up">
                <div class="card-header" style="background: var(--primary-gradient); color: white;">
                    <h3 class="mb-0" style="font-weight: 700;">
                        <i class="fas fa-plus-circle me-2"></i>Create New Post
                    </h3>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-4">
                            <label asp-for="Title" class="form-label">
                                <i class="fas fa-heading me-2"></i>Title
                            </label>
                            <input asp-for="Title" class="form-control form-control-lg" placeholder="Enter a descriptive title..." required />
                            <span asp-validation-for="Title" class="text-danger"></span>
                            <small class="form-text text-muted">Make it clear and engaging</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CommunityID" class="form-label">
                                <i class="fas fa-users me-2"></i>Community
                            </label>
                            <select asp-for="CommunityID" class="form-select form-select-lg" asp-items="@(new SelectList(ViewBag.Communities, "CommunityID", "Name"))">
                                <option value="">Select a community</option>
                            </select>
                            <span asp-validation-for="CommunityID" class="text-danger"></span>
                            <small class="form-text text-muted">Choose the most relevant community</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Content" class="form-label">
                                <i class="fas fa-align-left me-2"></i>Content
                            </label>
                            <div id="contentEditor" style="min-height: 400px; background: white; border-radius: var(--border-radius);"></div>
                            <textarea asp-for="Content" style="display: none;" required></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                            <small class="form-text text-muted">Rich text editor with formatting options</small>
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label">
                                <i class="fas fa-image me-2"></i>Featured Image
                            </label>
                            <div class="image-upload-container">
                                <input type="file" id="imageUpload" accept="image/*" class="form-control mb-2" />
                                <div id="imagePreview" class="mb-2" style="display: none;">
                                    <img id="previewImg" src="" alt="Preview" class="img-fluid rounded-modern" style="max-height: 300px; object-fit: cover;">
                                    <button type="button" class="btn btn-sm btn-danger mt-2" onclick="clearImagePreview()">
                                        <i class="fas fa-times me-1"></i>Remove
                                    </button>
                                </div>
                                <input asp-for="FeaturedImage" type="text" class="form-control" placeholder="Or enter image URL..." />
                                <span asp-validation-for="FeaturedImage" class="text-danger"></span>
                                <small class="form-text text-muted">Upload an image or provide a URL</small>
                            </div>
                        </div>


                        <div class="mb-4">
                            <label asp-for="Tags" class="form-label">
                                <i class="fas fa-tags me-2"></i>Tags
                            </label>
                            <input asp-for="Tags" class="form-control" placeholder="repair, tutorial, guide (comma separated)" />
                            <span asp-validation-for="Tags" class="text-danger"></span>
                            <small class="form-text text-muted">Separate tags with commas</small>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="AllowComments" checked>
                                    <label class="form-check-label" asp-for="AllowComments">
                                        Allow Comments
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="IsPromoted">
                                    <label class="form-check-label" asp-for="IsPromoted">
                                        Promote Post
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                                <i class="fas fa-paper-plane me-2"></i>Publish Post
                            </button>
                            <a href="/Posts" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Help Card -->
            <div class="card shadow-modern mt-4 fade-in-up">
                <div class="card-body">
                    <h5 class="card-title" style="font-weight: 600;">
                        <i class="fas fa-lightbulb me-2 text-warning"></i>Tips for Great Posts
                    </h5>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Use clear, descriptive titles</li>
                        <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Include step-by-step instructions</li>
                        <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Add images to illustrate your points</li>
                        <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Use relevant tags for discoverability</li>
                        <li><i class="fas fa-check-circle text-success me-2"></i>Engage with comments and questions</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <!-- Quill Rich Text Editor -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        var quill = new Quill('#contentEditor', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'color': [] }, { 'background': [] }],
                    ['link', 'image', 'code-block'],
                    ['clean']
                ]
            },
            placeholder: 'Write your post content here...'
        });
        
        // Sync Quill content to textarea before form submit
        document.querySelector('form').addEventListener('submit', function() {
            var content = document.querySelector('.ql-editor').innerHTML;
            document.querySelector('textarea[name="Content"]').value = content;
        });
        
        // Image upload preview
        document.getElementById('imageUpload').addEventListener('change', function(e) {
            var file = e.target.files[0];
            if (file) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('imagePreview').style.display = 'block';
                    // For now, we'll need to implement actual upload later
                    // This is just preview functionality
                };
                reader.readAsDataURL(file);
            }
        });
        
        function clearImagePreview() {
            document.getElementById('imageUpload').value = '';
            document.getElementById('imagePreview').style.display = 'none';
            document.getElementById('previewImg').src = '';
        }
    </script>
}
