@model IEnumerable<GsmsharingV2.Models.Post>
@{
    ViewData["Title"] = "All Posts - GSMSharing";
}

<div class="container mt-4">
    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="mb-2 text-gradient">
                        <i class="fas fa-newspaper me-2"></i>All Posts
                    </h1>
                    <p class="text-muted mb-0">Browse all posts from our community</p>
                </div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Posts/Create" class="btn btn-primary">
                        <i class="fas fa-plus-circle me-2"></i>Create Post
                    </a>
                }
            </div>

            @if (Model != null && Model.Any())
            {
                @foreach (var post in Model)
                {
                    <div class="modern-post-card fade-in-up">
                        <div class="post-header-modern">
                            <span class="community-badge-modern">
                                <i class="fas fa-users"></i>
                                r/@post.Community?.Name
                            </span>
                            <span class="text-muted small">
                                by <strong>u/@post.User?.UserName</strong>
                                <span class="ms-2">@GetTimeAgo(post.CreatedAt)</span>
                            </span>
                        </div>
                        <h4 class="post-title-modern">
                            <a href="/r/@(post.Community?.Slug ?? "gsmsharing")/posts/@post.Slug">
                                @post.Title
                            </a>
                        </h4>
                        @if (!string.IsNullOrEmpty(post.FeaturedImage))
                        {
                            <div class="mb-3">
                                <img src="@post.FeaturedImage" alt="@post.Title" class="img-fluid rounded-modern" style="max-height: 300px; object-fit: cover; width: 100%;">
                            </div>
                        }
                        <p class="post-excerpt-modern">
                            @(post.Content?.Length > 200 ? post.Content.Substring(0, 200) + "..." : post.Content)
                        </p>
                        <div class="post-footer-modern">
                            <button class="post-action-modern">
                                <i class="fas fa-comment"></i>
                                <span>@(post.Comments?.Count ?? 0)</span>
                            </button>
                            <button class="post-action-modern">
                                <i class="fas fa-share"></i>
                                <span>Share</span>
                            </button>
                            <button class="post-action-modern">
                                <i class="fas fa-bookmark"></i>
                                <span>Save</span>
                            </button>
                            @if (post.IsFeatured == true)
                            {
                                <span class="badge-modern badge-featured-modern ms-auto">
                                    <i class="fas fa-star"></i>Featured
                                </span>
                            }
                        </div>
                    </div>
                }

                    <!-- Pagination -->
                    @if (ViewBag.TotalCount > ViewBag.PageSize)
                    {
                        <div class="pagination-wrapper mt-4">
                            <nav aria-label="Page navigation">
                                <ul class="pagination justify-content-center">
                                    @if (ViewBag.CurrentPage > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="?page=@(ViewBag.CurrentPage - 1)">Previous</a>
                                        </li>
                                    }
                                    @for (int i = 1; i <= Math.Ceiling((double)ViewBag.TotalCount / ViewBag.PageSize); i++)
                                    {
                                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                            <a class="page-link" href="?page=@i">@i</a>
                                        </li>
                                    }
                                    @if (ViewBag.CurrentPage < Math.Ceiling((double)ViewBag.TotalCount / ViewBag.PageSize))
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="?page=@(ViewBag.CurrentPage + 1)">Next</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="mb-4">
                            <i class="fas fa-newspaper fa-4x text-muted mb-3"></i>
                        </div>
                        <h3 class="mb-3">No posts found</h3>
                        <p class="text-muted mb-4">Be the first to share your knowledge with the community!</p>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a href="/Posts/Create" class="btn btn-primary btn-lg">
                                <i class="fas fa-plus-circle me-2"></i>Create Your First Post
                            </a>
                        }
                        else
                        {
                            <a href="/UserAccounts/Register" class="btn btn-primary btn-lg me-2">
                                <i class="fas fa-user-plus me-2"></i>Sign Up
                            </a>
                            <a href="/UserAccounts/Login" class="btn btn-outline-primary btn-lg">
                                <i class="fas fa-sign-in-alt me-2"></i>Login
                            </a>
                        }
                    </div>
                }
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="sticky-top sidebar-container" style="top: 100px;">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="card mb-4 shadow-sm">
                            <div class="card-body text-center">
                                <a href="/Posts/Create" class="btn btn-primary w-100">
                                    <i class="fas fa-plus-circle me-2"></i>Create Post
                                </a>
                            </div>
                        </div>
                    }
                    @await Component.InvokeAsync("EngagingSidebar")
                </div>
            </div>
        </div>
    </div>

<style>
    @@media (max-width: 991px) {
        .sidebar-container {
            position: static !important;
            margin-top: 2rem;
        }
    }
</style>
        </div>
    </div>
</div>

@functions {
    private string GetTimeAgo(DateTime? date)
    {
        if (date == null) return "just now";
        
        var timeSpan = DateTime.UtcNow - date.Value;
        
        if (timeSpan.TotalSeconds < 60)
            return $"{(int)timeSpan.TotalSeconds}s ago";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalDays < 30)
            return $"{(int)timeSpan.TotalDays}d ago";
        if (timeSpan.TotalDays < 365)
            return $"{(int)(timeSpan.TotalDays / 30)}mo ago";
        
        return $"{(int)(timeSpan.TotalDays / 365)}y ago";
    }
}
