@model GsmsharingV2.Models.ApplicationUser
@{
    ViewData["Title"] = "Dashboard - GSMSharing";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="fas fa-chart-line me-2 text-primary"></i>Dashboard
        </h1>
        <a href="/Posts/Create" class="btn btn-primary">
            <i class="fas fa-plus-circle me-2"></i>Create Post
        </a>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Total Posts</h6>
                            <h3 class="mb-0">@ViewBag.PostCount</h3>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-newspaper fa-2x text-primary"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <small class="text-muted">
                            <span class="text-success">@ViewBag.PublishedPostCount</span> published,
                            <span class="text-warning">@ViewBag.DraftPostCount</span> drafts
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Total Comments</h6>
                            <h3 class="mb-0">@ViewBag.CommentCount</h3>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-comments fa-2x text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Total Views</h6>
                            <h3 class="mb-0">@ViewBag.TotalViews</h3>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-eye fa-2x text-info"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Karma</h6>
                            <h3 class="mb-0">@(ViewBag.Upvotes - ViewBag.Downvotes)</h3>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-fire fa-2x text-warning"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <small class="text-muted">
                            <span class="text-success">+@ViewBag.Upvotes</span> /
                            <span class="text-danger">-@ViewBag.Downvotes</span>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Recent Posts -->
        <div class="col-lg-8 mb-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-newspaper me-2"></i>Recent Posts
                    </h5>
                    <a href="/UserAccounts/Profile" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body">
                    @if (ViewBag.RecentPosts != null && ((IEnumerable<dynamic>)ViewBag.RecentPosts).Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var post in ViewBag.RecentPosts)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <h6 class="mb-1">
                                                <a href="/Posts/Details/@post.PostID" class="text-decoration-none">
                                                    @post.Title
                                                </a>
                                            </h6>
                                            <small class="text-muted">
                                                <i class="fas fa-calendar me-1"></i>@post.CreatedAt.ToString("MMM dd, yyyy")
                                                <span class="mx-2">•</span>
                                                <i class="fas fa-eye me-1"></i>@(post.ViewCount ?? 0) views
                                                <span class="mx-2">•</span>
                                                <i class="fas fa-arrow-up me-1 text-success"></i>@post.UpvoteCount
                                                <span class="mx-1">•</span>
                                                <i class="fas fa-arrow-down me-1 text-danger"></i>@post.DownvoteCount
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4">No posts yet. <a href="/Posts/Create">Create your first post!</a></p>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Comments -->
        <div class="col-lg-4 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-comments me-2"></i>Recent Comments
                    </h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.RecentComments != null && ((IEnumerable<dynamic>)ViewBag.RecentComments).Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var comment in ViewBag.RecentComments)
                            {
                                <div class="list-group-item">
                                    <p class="mb-1 small">@(comment.Content.Length > 100 ? comment.Content.Substring(0, 100) + "..." : comment.Content)</p>
                                    <small class="text-muted">
                                        <i class="fas fa-calendar me-1"></i>@comment.CreatedAt.ToString("MMM dd")
                                        <span class="mx-2">•</span>
                                        <i class="fas fa-arrow-up me-1 text-success"></i>@comment.UpvoteCount
                                    </small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 small">No comments yet</p>
                    }
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-bolt me-2"></i>Quick Actions
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="/Posts/Create" class="btn btn-primary">
                            <i class="fas fa-plus-circle me-2"></i>Create Post
                        </a>
                        <a href="/UserAccounts/Profile" class="btn btn-outline-primary">
                            <i class="fas fa-user me-2"></i>View Profile
                        </a>
                        <a href="/Posts" class="btn btn-outline-secondary">
                            <i class="fas fa-list me-2"></i>Browse Posts
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .stat-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            border: 1px solid var(--gs-border);
        }
        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        }
        .stat-icon {
            opacity: 0.3;
        }
    </style>
}
