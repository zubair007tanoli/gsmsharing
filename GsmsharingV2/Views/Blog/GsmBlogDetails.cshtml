@model GsmsharingV2.Models.GsmBlog
@{
    ViewData["Title"] = Model.BlogTitle + " - GSMSharing";
    var blogSEO = ViewBag.BlogSEO as GsmsharingV2.Models.BlogSEO;
}

<div class="container py-4">
    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <article class="blog-detail-card mb-4">
                <!-- Featured Image -->
                @if (!string.IsNullOrEmpty(Model.ThumbNailLink))
                {
                    <div class="blog-detail-image-wrapper mb-4">
                        <img src="@Model.ThumbNailLink" alt="@Model.BlogTitle" class="blog-detail-image img-fluid rounded-3 shadow-sm" onerror="this.src='/images/placeholder-blog.jpg'">
                    </div>
                }
                
                <div class="blog-detail-content">
                    <!-- Breadcrumb -->
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                            <li class="breadcrumb-item"><a href="/Blog/Blogs">Blog</a></li>
                            <li class="breadcrumb-item active">@(Model.BlogTitle?.Length > 30 ? Model.BlogTitle.Substring(0, 30) + "..." : Model.BlogTitle)</li>
                        </ol>
                    </nav>

                    <!-- Title -->
                    <h1 class="blog-detail-title mb-4">@Model.BlogTitle</h1>
                    
                    <!-- Meta Information -->
                    <div class="blog-detail-meta mb-4 pb-4 border-bottom">
                        <div class="d-flex flex-wrap gap-4 align-items-center">
                            <div class="blog-author-large">
                                <div class="author-avatar-large">
                                    @(Model.User?.UserName?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <div>
                                    <div class="fw-bold">@(Model.User?.UserName ?? "Anonymous")</div>
                                    <small class="text-muted">Author</small>
                                </div>
                            </div>
                            <div class="blog-meta-stats">
                                <div class="meta-stat-item">
                                    <i class="fas fa-calendar text-primary"></i>
                                    <span>@Model.PublishDate?.ToString("MMMM dd, yyyy")</span>
                                </div>
                                <div class="meta-stat-item">
                                    <i class="fas fa-eye text-info"></i>
                                    <span>@(Model.BlogViews ?? 0) views</span>
                                </div>
                                <div class="meta-stat-item">
                                    <i class="fas fa-thumbs-up text-success"></i>
                                    <span>@(Model.BlogLikes ?? 0) likes</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Description -->
                    @if (!string.IsNullOrEmpty(Model.BlogDiscription))
                    {
                        <div class="lead mb-4 text-muted">
                            @Model.BlogDiscription
                        </div>
                    }

                    <!-- Content -->
                    <div class="blog-content-modern">
                        @Html.Raw(Model.BlogContent)
                    </div>

                    <!-- Keywords -->
                    @if (!string.IsNullOrEmpty(Model.BlogKeywords))
                    {
                        <div class="mt-4 pt-4 border-top">
                            <h6 class="mb-2">Keywords:</h6>
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (var keyword in Model.BlogKeywords.Split(',').Take(10))
                                {
                                    <span class="badge bg-secondary">#@keyword.Trim()</span>
                                }
                            </div>
                        </div>
                    }

                    <!-- SEO Info -->
                    @if (blogSEO != null)
                    {
                        <div class="mt-4 pt-4 border-top">
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                SEO: @(blogSEO.BlogDiscription?.Length > 100 ? blogSEO.BlogDiscription.Substring(0, 100) + "..." : blogSEO.BlogDiscription)
                            </small>
                        </div>
                    }
                </div>
            </article>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="sticky-top" style="top: 80px;">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle me-2"></i>Article Info
                        </h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-3">
                                <i class="fas fa-user text-primary me-2"></i>
                                <strong>Author:</strong> @(Model.User?.UserName ?? "Anonymous")
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-calendar text-primary me-2"></i>
                                <strong>Published:</strong> @Model.PublishDate?.ToString("MMM dd, yyyy")
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-eye text-primary me-2"></i>
                                <strong>Views:</strong> @(Model.BlogViews ?? 0)
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-thumbs-up text-primary me-2"></i>
                                <strong>Likes:</strong> @(Model.BlogLikes ?? 0)
                            </li>
                            <li>
                                <i class="fas fa-thumbs-down text-primary me-2"></i>
                                <strong>Dislikes:</strong> @(Model.BlogDisLikes ?? 0)
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Share Article -->
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        <h6 class="mb-3">Share this Article</h6>
                        <div class="d-flex gap-2 justify-content-center">
                            <button class="btn btn-sm btn-outline-primary" onclick="shareOnFacebook()">
                                <i class="fab fa-facebook"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-info" onclick="shareOnTwitter()">
                                <i class="fab fa-twitter"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="shareOnPinterest()">
                                <i class="fab fa-pinterest"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" onclick="copyLink()">
                                <i class="fas fa-link"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function shareOnFacebook() {
            window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(window.location.href), '_blank');
        }
        function shareOnTwitter() {
            window.open('https://twitter.com/intent/tweet?url=' + encodeURIComponent(window.location.href) + '&text=' + encodeURIComponent('@Model.BlogTitle'), '_blank');
        }
        function shareOnPinterest() {
            window.open('https://pinterest.com/pin/create/button/?url=' + encodeURIComponent(window.location.href), '_blank');
        }
        function copyLink() {
            navigator.clipboard.writeText(window.location.href).then(() => {
                alert('Link copied to clipboard!');
            });
        }
    </script>
}

