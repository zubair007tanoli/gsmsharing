@model GsmsharingV2.Models.MobilePost
@{
    ViewData["Title"] = Model.Title + " - GSMSharing";
    var relatedBlogs = ViewBag.RelatedBlogs as IEnumerable<GsmsharingV2.Models.MobilePost> ?? new List<GsmsharingV2.Models.MobilePost>();
    var blogComments = ViewBag.BlogComments as IEnumerable<GsmsharingV2.Models.BlogComment> ?? new List<GsmsharingV2.Models.BlogComment>();
    var blogSpecContainers = ViewBag.BlogSpecContainers as IEnumerable<GsmsharingV2.Models.BlogSpecContainer> ?? new List<GsmsharingV2.Models.BlogSpecContainer>();
    var commentCount = ViewBag.CommentCount as int? ?? blogComments.Count();
}

<div class="blog-container mt-4">
    <div class="blog-main-content">
        <!-- Main Content -->
        <div>
            <article class="blog-detail-card mb-4">
                <!-- Featured Image -->
                @if (!string.IsNullOrEmpty(Model.WebLinks))
                {
                    <div class="blog-detail-image-wrapper mb-4">
                        <img src="@Model.WebLinks" alt="@Model.Title" class="blog-detail-image img-fluid rounded-3 shadow-sm" onerror="this.src='/images/placeholder-blog.jpg'">
                    </div>
                }
                
                <div class="blog-detail-content">
                    <!-- Breadcrumb -->
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                            <li class="breadcrumb-item"><a href="/Blog/Blogs">Blog</a></li>
                            <li class="breadcrumb-item active">@(Model.Title?.Length > 30 ? Model.Title.Substring(0, 30) + "..." : Model.Title)</li>
                        </ol>
                    </nav>

                    <!-- Category Badge -->
                    <div class="mb-3">
                        <span class="badge bg-primary px-3 py-2">
                            <i class="fas fa-mobile-alt me-2"></i>Mobile Blog
                        </span>
                    </div>

                    <!-- Title -->
                    <h1 class="blog-detail-title mb-4">@Model.Title</h1>
                    
                    <!-- Meta Information -->
                    <div class="blog-detail-meta mb-4 pb-4 border-bottom">
                        <div class="d-flex flex-wrap gap-4 align-items-center">
                            <div class="blog-author-large">
                                <div class="author-avatar-large">
                                    @(Model.User?.UserName?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <div>
                                    <div class="fw-bold">@(Model.User?.UserName ?? "Anonymous")</div>
                                    <small class="text-muted">Author</small>
                                </div>
                            </div>
                            <div class="blog-meta-stats">
                                <div class="meta-stat-item">
                                    <i class="fas fa-calendar text-primary"></i>
                                    <span>@Model.CreationDate?.ToString("MMMM dd, yyyy")</span>
                                </div>
                                <div class="meta-stat-item">
                                    <i class="fas fa-eye text-info"></i>
                                    <span>@(Model.views ?? 0) views</span>
                                </div>
                                <div class="meta-stat-item">
                                    <i class="fas fa-thumbs-up text-success"></i>
                                    <span>@(Model.likes ?? 0) likes</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="blog-content-modern">
                        @Html.Raw(Model.Content)
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Tags))
                    {
                        <div class="mt-4 pt-4 border-top">
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (var tag in Model.Tags.Split(',').Take(10))
                                {
                                    <span class="badge bg-primary">#@tag.Trim()</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </article>

            <!-- Linked Specs -->
            @if (blogSpecContainers.Any())
            {
                <div class="card shadow-blog rounded-blog mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">
                            <i class="fas fa-microchip me-2 text-primary"></i>Device Specs Linked to this Blog
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Model</th>
                                        <th>Processor</th>
                                        <th>Memory</th>
                                        <th>Display</th>
                                        <th>Battery</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var link in blogSpecContainers)
                                    {
                                        <tr>
                                            <td>@link.MobileSpecs?.ModelName</td>
                                            <td>@link.MobileSpecs?.Processor</td>
                                            <td>@link.MobileSpecs?.Memory</td>
                                            <td>@link.MobileSpecs?.Display</td>
                                            <td>@link.MobileSpecs?.Battery</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- Blog Comments -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-comments me-2 text-primary"></i>Comments (@commentCount)
                    </h5>
                </div>
                <div class="card-body">
                    @if (blogComments.Any())
                    {
                        @foreach (var comment in blogComments)
                        {
                            <div class="review-card-modern mb-3 pb-3 @(comment != blogComments.Last() ? "border-bottom" : "")">
                                <div class="d-flex gap-3">
                                    <div class="review-avatar-large">
                                        @(comment.User?.UserName?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <strong>@(comment.User?.UserName ?? "Guest")</strong>
                                                <div class="text-muted small">@comment.CreationDate?.ToString("MMMM dd, yyyy 'at' h:mm tt")</div>
                                            </div>
                                        </div>
                                        <p class="mb-0">@comment.Comment</p>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-comment-slash fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No comments yet. Be the first to share your thoughts!</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Related Blogs -->
            @if (relatedBlogs.Any())
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="fas fa-book-open me-2 text-primary"></i>Related Articles
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            @foreach (var related in relatedBlogs)
                            {
                                <div class="col-md-6">
                                    <div class="related-product-card">
                                        <div class="d-flex gap-3">
                                            @if (!string.IsNullOrEmpty(related.WebLinks))
                                            {
                                                <img src="@related.WebLinks" alt="@related.Title" class="related-product-image" onerror="this.style.display='none'">
                                            }
                                            else
                                            {
                                                <div class="related-product-image" style="background: var(--gray-100); display: flex; align-items: center; justify-content: center;">
                                                    <i class="fas fa-blog text-muted"></i>
                                                </div>
                                            }
                                            <div class="flex-grow-1">
                                                <h6 class="mb-2">
                                                    <a href="/Blog/Details/@related.BlogId" class="text-decoration-none">
                                                        @(related.Title?.Length > 50 ? related.Title.Substring(0, 50) + "..." : related.Title)
                                                    </a>
                                                </h6>
                                                <div class="d-flex gap-3 align-items-center mb-2">
                                                    <small class="text-muted">
                                                        <i class="fas fa-eye me-1"></i>@(related.views ?? 0)
                                                    </small>
                                                    <small class="text-muted">
                                                        <i class="fas fa-thumbs-up me-1"></i>@(related.likes ?? 0)
                                                    </small>
                                                </div>
                                                <a href="/Blog/Details/@related.BlogId" class="btn btn-sm btn-outline-primary">
                                                    Read More
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="blog-sidebar">
            <div class="card shadow-blog rounded-blog mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">
                        <i class="fas fa-info-circle me-2 text-primary"></i>Article Info
                    </h5>
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="fas fa-user text-primary me-2"></i>
                            <strong>Author:</strong> @(Model.User?.UserName ?? "Anonymous")
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-calendar text-primary me-2"></i>
                            <strong>Published:</strong> @Model.CreationDate?.ToString("MMMM dd, yyyy")
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-eye text-primary me-2"></i>
                            <strong>Views:</strong> @(Model.views ?? 0)
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-thumbs-up text-primary me-2"></i>
                            <strong>Likes:</strong> @(Model.likes ?? 0)
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

