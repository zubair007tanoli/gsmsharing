@{
    ViewData["Title"] = "Home";
    ViewData["FullWidth"] = false;
}

<!-- Welcome Section -->
<div class="card mb-4">
    <div class="card-body text-center py-5">
        <h1 class="display-4 fw-bold mb-3">Welcome to DiscussionSpot</h1>
        <p class="lead mb-4">Join millions of people sharing knowledge, asking questions, and engaging in meaningful discussions across thousands of communities.</p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
            <a href="#" class="btn btn-primary btn-lg">
                <i class="fas fa-plus me-2"></i>Start a Discussion
            </a>
            <a href="#" class="btn btn-outline-primary btn-lg">
                <i class="fas fa-compass me-2"></i>Explore Communities
            </a>
        </div>
    </div>
</div>

<!-- Quick Stats -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <i class="fas fa-users fa-2x text-primary mb-3"></i>
                <h3 class="fw-bold">2.5M+</h3>
                <p class="text-muted mb-0">Active Members</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <i class="fas fa-layer-group fa-2x text-success mb-3"></i>
                <h3 class="fw-bold">10K+</h3>
                <p class="text-muted mb-0">Communities</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <i class="fas fa-comments fa-2x text-warning mb-3"></i>
                <h3 class="fw-bold">50M+</h3>
                <p class="text-muted mb-0">Discussions</p>
            </div>
        </div>
    </div>
</div>

<!-- Trending Topics -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center">
        <i class="fas fa-fire me-2 text-danger"></i>
        <span class="fw-semibold">Trending Topics</span>
    </div>
    <div class="card-body">
        <div class="d-flex flex-wrap gap-2">
            <span class="badge bg-primary">#AI Revolution</span>
            <span class="badge bg-secondary">#Climate Action</span>
            <span class="badge bg-success">#Web3 Future</span>
            <span class="badge bg-info">#Space Exploration</span>
            <span class="badge bg-warning">#Quantum Computing</span>
            <span class="badge bg-danger">#Sustainable Tech</span>
            <span class="badge bg-dark">#Remote Work</span>
        </div>
    </div>
</div>

<!-- Sample Posts -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center">
            <i class="fas fa-rocket me-2 text-primary"></i>
            <span class="fw-semibold">Popular Discussions</span>
        </div>
        <div class="btn-group btn-group-sm" role="group">
            <button type="button" class="btn btn-outline-primary active">Best</button>
            <button type="button" class="btn btn-outline-primary">Hot</button>
            <button type="button" class="btn btn-outline-primary">New</button>
        </div>
    </div>
    <div class="card-body p-0">
        <!-- Sample Post 1 -->
        <div class="border-bottom p-3">
            <div class="d-flex">
                <div class="flex-shrink-0 me-3">
                    <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fas fa-user text-white"></i>
                    </div>
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center mb-2">
                        <span class="fw-semibold me-2">r/technology</span>
                        <span class="text-muted small">• Posted by u/techguru • 2 hours ago</span>
                    </div>
                    <h5 class="mb-2">The Future of AI: What to Expect in 2025</h5>
                    <p class="text-muted mb-3">Artificial Intelligence continues to evolve at an unprecedented pace. Here's what experts predict for the coming year...</p>
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-arrow-up me-1"></i> 1.2k
                        </button>
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-arrow-down me-1"></i>
                        </button>
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-comment me-1"></i> 156
                        </button>
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-share me-1"></i> Share
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sample Post 2 -->
        <div class="border-bottom p-3">
            <div class="d-flex">
                <div class="flex-shrink-0 me-3">
                    <div class="bg-success rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fas fa-user text-white"></i>
                    </div>
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center mb-2">
                        <span class="fw-semibold me-2">r/programming</span>
                        <span class="text-muted small">• Posted by u/coder123 • 4 hours ago</span>
                    </div>
                    <h5 class="mb-2">Best Practices for Clean Code in 2025</h5>
                    <p class="text-muted mb-3">After years of experience, here are the essential principles that every developer should follow...</p>
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-arrow-up me-1"></i> 856
                        </button>
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-arrow-down me-1"></i>
                        </button>
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-comment me-1"></i> 89
                        </button>
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-share me-1"></i> Share
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sample Post 3 -->
        <div class="p-3">
            <div class="d-flex">
                <div class="flex-shrink-0 me-3">
                    <div class="bg-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fas fa-user text-white"></i>
                    </div>
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center mb-2">
                        <span class="fw-semibold me-2">r/science</span>
                        <span class="text-muted small">• Posted by u/researcher • 6 hours ago</span>
                    </div>
                    <h5 class="mb-2">Breakthrough in Quantum Computing Research</h5>
                    <p class="text-muted mb-3">Scientists have made significant progress in quantum error correction, bringing us closer to practical quantum computers...</p>
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-arrow-up me-1"></i> 2.1k
                        </button>
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-arrow-down me-1"></i>
                        </button>
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-comment me-1"></i> 234
                        </button>
                        <button class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-share me-1"></i> Share
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Call to Action -->
<div class="card bg-primary text-white">
    <div class="card-body text-center py-5">
        <h3 class="fw-bold mb-3">Ready to Join the Discussion?</h3>
        <p class="mb-4">Create an account today and start participating in meaningful conversations with our global community.</p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
            <a href="#" class="btn btn-light btn-lg">
                <i class="fas fa-user-plus me-2"></i>Sign Up Now
            </a>
            <a href="#" class="btn btn-outline-light btn-lg">
                <i class="fas fa-info-circle me-2"></i>Learn More
            </a>
        </div>
    </div>
</div>
