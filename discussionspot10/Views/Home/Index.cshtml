@{
    ViewData["Title"] = "DiscussionSpot — Join the conversation";
    ViewData["FullWidth"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
}

<section class="landing-hero py-7 py-lg-8">
    <div class="container-xxl">
        <div class="row align-items-center g-4">
            <div class="col-lg-6">
                <span class="hero-badge"><i class="fas fa-bolt"></i> Built for meaningful conversations</span>
                <h1 class="display-4 hero-title mt-3">Join communities that inspire, teach, and move you forward</h1>
                <p class="hero-subtitle mt-2">Ask questions, share knowledge, and connect with curious minds across thousands of active communities. Your next idea starts here.</p>
                <div class="hero-cta mt-3">
                    <a class="btn btn-landing-primary" asp-controller="Account" asp-action="Register"><i class="fas fa-user-plus me-2"></i>Create your free account</a>
                    <a class="btn btn-landing-outline" asp-controller="Community" asp-action="Index"><i class="fas fa-layer-group me-2"></i>Explore communities</a>
                </div>
                <div class="stat-badges mt-4">
                    <div class="stat-badge"><div class="num">2.5M+</div><div class="label">Members</div></div>
                    <div class="stat-badge"><div class="num">10K+</div><div class="label">Communities</div></div>
                    <div class="stat-badge"><div class="num">50M+</div><div class="label">Discussions</div></div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <div class="hero-card">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="fw-bold">Live now</div>
                            <div class="text-muted small">Trending conversations</div>
                        </div>
                        <span class="badge bg-primary-subtle text-primary"><i class="fas fa-signal me-1"></i>Active</span>
                    </div>
                    <hr />
                    <div class="mini">
                        <div class="hero-metric">
                            <div class="value"><i class="fas fa-fire me-2 text-danger"></i>Hot posts</div>
                            <div class="desc">Most engaged in the last hour</div>
                        </div>
                        <div class="hero-metric">
                            <div class="value"><i class="fas fa-arrow-trend-up me-2 text-success"></i>Rising topics</div>
                            <div class="desc">Communities on the move</div>
                        </div>
                        <div class="hero-metric">
                            <div class="value"><i class="fas fa-microphone me-2 text-primary"></i>Live talks</div>
                            <div class="desc">Join real-time discussions</div>
                        </div>
                        <div class="hero-metric">
                            <div class="value"><i class="fas fa-trophy me-2 text-warning"></i>Top awards</div>
                            <div class="desc">Best contributions today</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container-xxl">
        <div class="text-center section-head mb-4">
            <h2 class="h1">Everything you need to start a great discussion</h2>
            <p>From quick questions to deep dives, discover tools that make sharing and learning effortless.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <span class="feature-icon blue mb-2"><i class="fas fa-pen"></i></span>
                    <div class="feature-title h5">Create with ease</div>
                    <div class="feature-desc">Post text, images, videos, polls, or links—beautifully formatted.</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <span class="feature-icon purple mb-2"><i class="fas fa-compass"></i></span>
                    <div class="feature-title h5">Discover communities</div>
                    <div class="feature-desc">Follow topics you care about and find your people.</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <span class="feature-icon green mb-2"><i class="fas fa-shield-heart"></i></span>
                    <div class="feature-title h5">Thoughtful moderation</div>
                    <div class="feature-desc">Healthy conversation by design with smart tools and reporting.</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <span class="feature-icon orange mb-2"><i class="fas fa-chart-line"></i></span>
                    <div class="feature-title h5">Grow your impact</div>
                    <div class="feature-desc">Earn reputation with awards, badges, and top rankings.</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-body-tertiary">
    <div class="container-xxl">
        <div class="text-center section-head mb-4">
            <h2 class="h1">How it works</h2>
            <p>Three simple steps to get started.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-num mb-2">1</div>
                    <div class="fw-bold mb-1">Create your profile</div>
                    <div class="text-muted">Personalize your feed and show what you’re into.</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-num mb-2">2</div>
                    <div class="fw-bold mb-1">Join communities</div>
                    <div class="text-muted">Follow topics that matter—tech, design, science, and more.</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-num mb-2">3</div>
                    <div class="fw-bold mb-1">Start a conversation</div>
                    <div class="text-muted">Ask, answer, and connect with people like you.</div>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a class="btn btn-landing-primary" asp-controller="Account" asp-action="Register"><i class="fas fa-user-plus me-2"></i>Get started free</a>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container-xxl">
        <div class="text-center section-head mb-4">
            <h2 class="h1">What people are saying</h2>
            <p>Real feedback from community builders and curious minds.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="testimonial-card h-100">
                    <div class="testimonial-quote mb-2">“The best place on the internet to learn something new every day.”</div>
                    <div class="testimonial-author">— Alex, Developer</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="testimonial-card h-100">
                    <div class="testimonial-quote mb-2">“Thoughtful discussions, great moderation, and amazing communities.”</div>
                    <div class="testimonial-author">— Priya, Designer</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="testimonial-card h-100">
                    <div class="testimonial-quote mb-2">“I found collaborators and friends. Highly recommended.”</div>
                    <div class="testimonial-author">— Sam, Researcher</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container-xxl">
        <div class="cta-band p-4 p-md-5">
            <div class="row align-items-center g-3">
                <div class="col-lg-8">
                    <h3 class="mb-1">Ready to join the conversation?</h3>
                    <div class="opacity-75">It takes less than a minute to get started.</div>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a class="btn btn-light me-2" asp-controller="Community" asp-action="Index"><i class="fas fa-compass me-1"></i> Explore</a>
                    <a class="btn btn-outline-light" asp-controller="Account" asp-action="Register"><i class="fas fa-user-plus me-1"></i> Create account</a>
                </div>
            </div>
        </div>
    </div>
</section>
