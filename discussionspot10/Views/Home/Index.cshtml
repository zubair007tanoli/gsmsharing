@{
    ViewData["Title"] = "Home";
    ViewData["FullWidth"] = true;
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/DesignFolder/styles.css" />
    <link rel="stylesheet" href="~/css/enhanced-styles.css" />
}

<div class="hero-section">
    <div class="container">
        <div class="row align-items-center min-vh-75">
            <div class="col-lg-8">
                <div class="hero-content">
                    <div class="hero-badge">
                        <i class="fas fa-star"></i>
                        <span>Trusted by 2.5M+ users worldwide</span>
                    </div>
                    <h1 class="hero-title">Where Knowledge Meets <span class="gradient-text">Community</span></h1>
                    <p class="hero-subtitle">Join the world's most vibrant discussion platform. Connect with experts, share insights, and discover communities that match your interests. Your voice matters here.</p>
                    <div class="hero-cta">
                        <a href="#" class="btn btn-hero-primary">
                            <i class="fas fa-rocket me-2"></i>
                            Get Started Free
                        </a>
                        <a href="#" class="btn btn-hero-secondary">
                            <i class="fas fa-play-circle me-2"></i>
                            Watch Demo
                        </a>
                    </div>
                    <div class="hero-stats">
                        <div class="stat-item">
                            <div class="stat-icon">
                                <i class="fas fa-users"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-number">2.5M+</div>
                                <div class="stat-label">Active Members</div>
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-icon">
                                <i class="fas fa-layer-group"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-number">10K+</div>
                                <div class="stat-label">Communities</div>
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-icon">
                                <i class="fas fa-comments"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-number">50M+</div>
                                <div class="stat-label">Discussions</div>
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-icon">
                                <i class="fas fa-trophy"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-number">99.9%</div>
                                <div class="stat-label">Uptime</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 d-none d-lg-block">
                <div class="hero-visual">
                    <div class="floating-cards">
                        <div class="floating-card card-1">
                            <div class="card-icon">
                                <i class="fas fa-users"></i>
                            </div>
                            <div class="card-content">
                                <h5>Active Communities</h5>
                                <p>Join 10K+ thriving communities</p>
                            </div>
                        </div>
                        <div class="floating-card card-2">
                            <div class="card-icon">
                                <i class="fas fa-lightbulb"></i>
                            </div>
                            <div class="card-content">
                                <h5>Expert Insights</h5>
                                <p>Get answers from industry leaders</p>
                            </div>
                        </div>
                        <div class="floating-card card-3">
                            <div class="card-icon">
                                <i class="fas fa-trophy"></i>
                            </div>
                            <div class="card-content">
                                <h5>Build Reputation</h5>
                                <p>Earn recognition for contributions</p>
                            </div>
                        </div>
                    </div>
                    <div class="hero-background-shapes">
                        <div class="shape shape-1"></div>
                        <div class="shape shape-2"></div>
                        <div class="shape shape-3"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="trending-banner">
    <div class="container">
        <div class="trending-content">
            <i class="fas fa-fire-alt"></i>
            <span class="trending-label">Trending Now:</span>
            <div class="trending-topics-scroll">
                <a href="#" class="trending-topic">#AI Revolution</a>
                <a href="#" class="trending-topic">#Climate Action</a>
                <a href="#" class="trending-topic">#Web3 Future</a>
                <a href="#" class="trending-topic">#Space Exploration</a>
                <a href="#" class="trending-topic">#Quantum Computing</a>
            </div>
        </div>
    </div>
</div>

<div class="quick-actions-bar">
    <div class="container">
        <div class="quick-actions-grid">
            <button class="quick-action-btn" data-bs-toggle="modal" data-bs-target="#createPostModal" data-post-type="poll">
                <i class="fas fa-poll"></i>
                <span>Create Poll</span>
            </button>
            <button class="quick-action-btn" data-bs-toggle="modal" data-bs-target="#createPostModal">
                <i class="fas fa-pen"></i>
                <span>Start Discussion</span>
            </button>
            <button class="quick-action-btn">
                <i class="fas fa-users"></i>
                <span>Find Communities</span>
            </button>
            <button class="quick-action-btn">
                <i class="fas fa-microphone"></i>
                <span>Join Live Talk</span>
            </button>
            <button class="quick-action-btn" data-bs-toggle="modal" data-bs-target="#createPostModal" data-post-type="image">
                <i class="fas fa-image"></i>
                <span>Share Media</span>
            </button>
            <button class="quick-action-btn">
                <i class="fas fa-calendar-alt"></i>
                <span>View Events</span>
            </button>
        </div>
    </div>
</div>

<div class="featured-section">
    <div class="container">
        <div class="section-header">
            <div class="section-title-wrapper">
                <div class="section-icon">
                    <i class="fas fa-star"></i>
                </div>
                <div>
                    <h3 class="section-title">Featured Communities</h3>
                    <p class="section-subtitle">Discover thriving communities that match your interests</p>
                </div>
            </div>
            <a href="#" class="view-all-link">
                <span>Explore All</span>
                <i class="fas fa-arrow-right"></i>
            </a>
        </div>
        <div class="featured-communities-carousel" id="featured-communities">
            <!-- Generated by script.js -->
        </div>
    </div>
</div>

<div class="highlights-section">
    <div class="container">
        <div class="section-header">
            <div class="section-title-wrapper">
                <div class="section-icon highlights-icon">
                    <i class="fas fa-bolt"></i>
                </div>
                <div>
                    <h3 class="section-title">Today's Highlights</h3>
                    <p class="section-subtitle">Don't miss these trending discussions and events</p>
                </div>
            </div>
        </div>
        <div class="highlights-grid" id="highlights-grid">
            <!-- Generated by script.js -->
        </div>
    </div>
</div>

<div class="main-container">
    <div class="container">
        <div class="row">
            <div class="col-lg-3 left-sidebar">
                <div class="sidebar">
                    <div class="sidebar-card navigation-card">
                        <div class="sidebar-header">
                            <i class="fas fa-compass"></i>
                            <span>Explore</span>
                        </div>
                        <div class="sidebar-content">
                            <div class="nav-links">
                                <a href="#" class="nav-link-item active">
                                    <div class="nav-icon">
                                        <i class="fas fa-fire"></i>
                                    </div>
                                    <div class="nav-content">
                                        <span class="nav-title">Popular</span>
                                        <span class="nav-desc">Trending discussions</span>
                                    </div>
                                    <div class="nav-badge">Hot</div>
                                </a>
                                <a href="#" class="nav-link-item">
                                    <div class="nav-icon">
                                        <i class="fas fa-arrow-trend-up"></i>
                                    </div>
                                    <div class="nav-content">
                                        <span class="nav-title">Rising</span>
                                        <span class="nav-desc">Growing fast</span>
                                    </div>
                                </a>
                                <a href="#" class="nav-link-item">
                                    <div class="nav-icon">
                                        <i class="fas fa-certificate"></i>
                                    </div>
                                    <div class="nav-content">
                                        <span class="nav-title">Fresh</span>
                                        <span class="nav-desc">Latest posts</span>
                                    </div>
                                </a>
                                <a href="#" class="nav-link-item">
                                    <div class="nav-icon">
                                        <i class="fas fa-comments"></i>
                                    </div>
                                    <div class="nav-content">
                                        <span class="nav-title">Active</span>
                                        <span class="nav-desc">Most engaged</span>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="sidebar-card">
                        <div class="sidebar-header">Your Communities</div>
                        <div class="sidebar-content" id="your-communities"></div>
                    </div>

                    <div class="sidebar-card">
                        <div class="sidebar-header">Browse Categories</div>
                        <div class="sidebar-content" id="categories-list"></div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 col-md-8">
                <div class="content-container">
                    <div class="create-post-card">
                        <img src="https://i.pravatar.cc/150?img=12" alt="User" class="user-avatar">
                        <div class="create-post-input" data-bs-toggle="modal" data-bs-target="#createPostModal">What's on your mind? Ask a question...</div>
                        <div class="create-post-actions">
                            <button class="create-post-action" data-bs-toggle="modal" data-bs-target="#createPostModal" data-post-type="image" title="Add Image">
                                <i class="far fa-image"></i>
                            </button>
                            <button class="create-post-action" data-bs-toggle="modal" data-bs-target="#createPostModal" data-post-type="link" title="Add Link">
                                <i class="fas fa-link"></i>
                            </button>
                        </div>
                    </div>

                    <div class="filter-tabs">
                        <button class="filter-tab active" data-filter="best">
                            <i class="fas fa-rocket"></i>
                            Best
                        </button>
                        <button class="filter-tab" data-filter="hot">
                            <i class="fas fa-fire"></i>
                            Hot
                        </button>
                        <button class="filter-tab" data-filter="new">
                            <i class="fas fa-certificate"></i>
                            New
                        </button>
                        <button class="filter-tab" data-filter="rising">
                            <i class="fas fa-arrow-trend-up"></i>
                            Rising
                        </button>
                        <button class="filter-tab" data-filter="top">
                            <i class="fas fa-chart-line"></i>
                            Top
                        </button>
                    </div>

                    <div id="posts-container"><!-- Generated by script.js --></div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 right-sidebar">
                <div class="sidebar">
                    <div class="sidebar-card live-talks-card">
                        <div class="sidebar-header">
                            <i class="fas fa-microphone live-indicator"></i>
                            Live Talks
                        </div>
                        <div class="sidebar-content" id="live-talks"></div>
                    </div>

                    <div class="sidebar-card">
                        <div class="sidebar-header">
                            <i class="fas fa-fire"></i>
                            Active Right Now
                        </div>
                        <div class="sidebar-content" id="active-discussions"></div>
                    </div>

                    <div class="sidebar-card">
                        <div class="sidebar-header">Top Growing Communities</div>
                        <div class="sidebar-content" id="top-communities"></div>
                    </div>

                    <div class="sidebar-card community-spotlight">
                        <div class="sidebar-header">
                            <i class="fas fa-trophy"></i>
                            Community Spotlight
                        </div>
                        <div class="sidebar-content" id="community-spotlight"></div>
                    </div>

                    <div class="sidebar-card ad-card">
                        <div class="ad-label">Sponsored</div>
                        <div class="sidebar-content">
                            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=400" alt="Ad" class="ad-image">
                            <div class="ad-content">
                                <h4>Boost Your Business</h4>
                                <p>Reach millions of engaged users. Start advertising today.</p>
                                <button class="btn btn-primary sidebar-button">Learn More</button>
                            </div>
                        </div>
                    </div>

                    <div class="sidebar-card">
                        <div class="sidebar-header">Community Guidelines</div>
                        <div class="sidebar-content">
                            <ul class="guidelines-list">
                                <li>Be respectful and civil</li>
                                <li>No spam or self-promotion</li>
                                <li>Stay on topic</li>
                                <li>Cite your sources</li>
                                <li>Report rule violations</li>
                            </ul>
                        </div>
                    </div>

                    <div class="sidebar-card">
                        <div class="sidebar-header">Trending Today</div>
                        <div class="sidebar-content" id="trending-topics"></div>
                    </div>

                    <div class="sidebar-card">
                        <div class="sidebar-header">Daily Digest</div>
                        <div class="sidebar-content">
                            <p>Get the top posts from your favorite communities delivered to your inbox.</p>
                            <form class="newsletter-form">
                                <input type="email" class="form-control newsletter-input" placeholder="Your email address">
                                <button type="submit" class="btn btn-primary sidebar-button">Subscribe</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Post Modal -->
<div class="modal fade" id="createPostModal" tabindex="-1" aria-labelledby="createPostModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createPostModalLabel">Create a Post</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="post-type-selector">
                    <button class="post-type-option active" data-post-type="text"><i class="fas fa-font"></i>Text</button>
                    <button class="post-type-option" data-post-type="image"><i class="far fa-image"></i>Image</button>
                    <button class="post-type-option" data-post-type="link"><i class="fas fa-link"></i>Link</button>
                    <button class="post-type-option" data-post-type="video"><i class="fas fa-video"></i>Video</button>
                    <button class="post-type-option" data-post-type="poll"><i class="fas fa-poll"></i>Poll</button>
                </div>

                <div class="community-selector">
                    <label for="community-select" class="post-form-label">Choose a community</label>
                    <select id="community-select" class="post-form-input">
                        <option value="technology">r/technology</option>
                        <option value="programming">r/programming</option>
                        <option value="gaming">r/gaming</option>
                        <option value="movies">r/movies</option>
                        <option value="science">r/science</option>
                    </select>
                </div>

                <div id="post-form-container">
                    <label for="post-title" class="post-form-label">Title</label>
                    <input type="text" id="post-title" class="post-form-input" placeholder="Title">

                    <div id="text-post-content">
                        <label for="post-text" class="post-form-label">Text (optional)</label>
                        <textarea id="post-text" class="post-form-input post-form-textarea" placeholder="Text (optional)"></textarea>
                    </div>

                    <div id="image-post-content" style="display: none;">
                        <div class="file-upload-container">
                            <div class="file-upload-icon"><i class="far fa-image"></i></div>
                            <div class="file-upload-text">Drag and drop images or</div>
                            <button class="btn btn-outline-primary">Upload</button>
                            <input type="file" id="image-upload" style="display: none;" accept="image/*">
                            <div class="file-upload-subtext">Supported formats: JPG, PNG, GIF</div>
                        </div>
                    </div>

                    <div id="link-post-content" style="display: none;">
                        <label for="post-link" class="post-form-label">URL</label>
                        <input type="url" id="post-link" class="post-form-input" placeholder="URL">
                    </div>

                    <div id="video-post-content" style="display: none;">
                        <div class="file-upload-container">
                            <div class="file-upload-icon"><i class="fas fa-video"></i></div>
                            <div class="file-upload-text">Drag and drop video or</div>
                            <button class="btn btn-outline-primary">Upload</button>
                            <input type="file" id="video-upload" style="display: none;" accept="video/*">
                            <div class="file-upload-subtext">Supported formats: MP4, MOV, AVI (max 100MB)</div>
                        </div>
                    </div>

                    <div id="poll-post-content" style="display: none;">
                        <label for="poll-option-1" class="post-form-label">Poll Options</label>
                        <input type="text" id="poll-option-1" class="post-form-input mb-2" placeholder="Option 1">
                        <input type="text" id="poll-option-2" class="post-form-input mb-2" placeholder="Option 2">
                        <input type="text" id="poll-option-3" class="post-form-input mb-2" placeholder="Option 3 (optional)">
                        <input type="text" id="poll-option-4" class="post-form-input mb-2" placeholder="Option 4 (optional)">
                        <div class="poll-settings mt-3">
                            <label class="post-form-label">Poll Duration</label>
                            <select class="post-form-input">
                                <option>1 Day</option>
                                <option>3 Days</option>
                                <option selected>7 Days</option>
                                <option>14 Days</option>
                            </select>
                        </div>
                    </div>

                    <label for="post-tags" class="post-form-label">Tags (optional)</label>
                    <input type="text" id="post-tags" class="post-form-input" placeholder="Add up to 5 tags, separated by commas">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="post-cancel-btn" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="post-submit-btn">Post</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/DesignFolder/script.js"></script>
}
