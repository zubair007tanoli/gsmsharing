<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - discussionspot10</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/discussionspot10.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <style>
        /* Minimal tweaks if CSS isolation fails to load in some hosts */
        body { background-color: #f6f7f8; }
    </style>
    <meta name="color-scheme" content="light dark">
    <meta name="theme-color" content="#ffffff">
    <link rel="icon" href="~/favicon.ico" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        html, body { font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji"; }
    </style>
    <!-- Simple search route defaults to Search/Index?query=... -->
</head>
<body>
    @{
        var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
        var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();
        Func<string, string, string> activeClass = (controller, action) =>
        {
            controller = (controller ?? "").ToLowerInvariant();
            action = (action ?? "").ToLowerInvariant();
            if (currentController == controller && (action == "*" || currentAction == action)) return "active";
            return string.Empty;
        };
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
            <div class="container-fluid px-3 px-lg-5">
                <!-- Brand -->
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <svg width="36" height="36" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="me-2">
                        <circle cx="16" cy="16" r="16" fill="url(#gradient)"/>
                        <path d="M8 12h16v2H8v-2zm0 4h16v2H8v-2zm0 4h12v2H8v-2z" fill="white"/>
                        <defs>
                            <linearGradient id="gradient" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#4F46E5"/>
                                <stop offset="1" stop-color="#7C3AED"/>
                            </linearGradient>
                        </defs>
                    </svg>
                    <span class="fw-bold fs-5 text-dark">DiscussHub</span>
                </a>

                <!-- Mobile Toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <!-- Main Navigation -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @activeClass("Home","Index")" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @activeClass("Community","*")" asp-controller="Community" asp-action="Index">
                                <i class="bi bi-compass me-1"></i>Explore
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @activeClass("Category","*")" asp-controller="Category" asp-action="Index">
                                <i class="bi bi-tags me-1"></i>Topics
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @activeClass("Post","*")" asp-controller="Post" asp-action="Index">
                                <i class="bi bi-fire me-1"></i>Trending
                            </a>
                        </li>
                    </ul>

                    <!-- Search Bar -->
                    <form class="d-flex me-3 flex-grow-1" style="max-width: 500px;" asp-controller="Search" asp-action="Index" method="get">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input class="form-control border-start-0 ps-0" type="search" placeholder="Search discussions..." name="query">
                        </div>
                    </form>

                    <!-- Right Side Actions -->
                    <div class="d-flex align-items-center gap-2">
                        <!-- Create Button -->
                        <a class="btn btn-primary d-flex align-items-center" asp-controller="Post" asp-action="Index">
                            <i class="bi bi-plus-circle me-2"></i>
                            <span class="d-none d-lg-inline">Create</span>
                        </a>

                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <!-- Notifications Dropdown -->
                            <div class="dropdown">
                                <button class="btn btn-light position-relative" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-bell fs-5"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                        3
                                    </span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow" style="min-width: 320px;">
                                    <li class="dropdown-header d-flex justify-content-between align-items-center">
                                        <span class="fw-bold">Notifications</span>
                                        <a href="javascript:void(0)" class="text-primary text-decoration-none small">Mark all read</a>
                                    </li>
                                    <li><hr class="dropdown-divider my-0" /></li>
                                    <li>
                                        <a class="dropdown-item py-3" href="javascript:void(0)">
                                            <div class="d-flex">
                                                <img src="https://i.pravatar.cc/150?img=1" class="rounded-circle me-3" width="40" height="40" alt="User">
                                                <div class="flex-grow-1">
                                                    <p class="mb-1 small"><strong>John Doe</strong> commented on your post</p>
                                                    <span class="text-muted small">2 minutes ago</span>
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-0" /></li>
                                    <li>
                                        <a class="dropdown-item py-3" href="javascript:void(0)">
                                            <div class="d-flex">
                                                <img src="https://i.pravatar.cc/150?img=2" class="rounded-circle me-3" width="40" height="40" alt="User">
                                                <div class="flex-grow-1">
                                                    <p class="mb-1 small"><strong>Jane Smith</strong> liked your comment</p>
                                                    <span class="text-muted small">1 hour ago</span>
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-0" /></li>
                                    <li>
                                        <a class="dropdown-item py-3" href="javascript:void(0)">
                                            <div class="d-flex">
                                                <img src="https://i.pravatar.cc/150?img=3" class="rounded-circle me-3" width="40" height="40" alt="User">
                                                <div class="flex-grow-1">
                                                    <p class="mb-1 small"><strong>Mike Johnson</strong> started following you</p>
                                                    <span class="text-muted small">3 hours ago</span>
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-0" /></li>
                                    <li>
                                        <a class="dropdown-item text-center py-2 text-primary" asp-controller="Notifications" asp-action="Index">
                                            View all notifications
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <!-- Messages Dropdown -->
                            <div class="dropdown">
                                <button class="btn btn-light position-relative" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-chat-dots fs-5"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-success">
                                        2
                                    </span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow" style="min-width: 320px;">
                                    <li class="dropdown-header d-flex justify-content-between align-items-center">
                                        <span class="fw-bold">Messages</span>
                                        <a href="javascript:void(0)" class="text-primary text-decoration-none small">New message</a>
                                    </li>
                                    <li><hr class="dropdown-divider my-0" /></li>
                                    <li>
                                        <a class="dropdown-item py-3" href="javascript:void(0)">
                                            <div class="d-flex">
                                                <div class="position-relative">
                                                    <img src="https://i.pravatar.cc/150?img=4" class="rounded-circle me-3" width="40" height="40" alt="User">
                                                    <span class="position-absolute bottom-0 end-0 translate-middle p-1 bg-success border border-light rounded-circle"></span>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <div class="d-flex justify-content-between align-items-start">
                                                        <strong class="small">Sarah Wilson</strong>
                                                        <span class="text-muted small">5m</span>
                                                    </div>
                                                    <p class="mb-0 text-muted small text-truncate">Hey! Did you see the latest update?</p>
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-0" /></li>
                                    <li>
                                        <a class="dropdown-item py-3" href="javascript:void(0)">
                                            <div class="d-flex">
                                                <div class="position-relative">
                                                    <img src="https://i.pravatar.cc/150?img=5" class="rounded-circle me-3" width="40" height="40" alt="User">
                                                    <span class="position-absolute bottom-0 end-0 translate-middle p-1 bg-secondary border border-light rounded-circle"></span>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <div class="d-flex justify-content-between align-items-start">
                                                        <strong class="small">Alex Brown</strong>
                                                        <span class="text-muted small">2h</span>
                                                    </div>
                                                    <p class="mb-0 text-muted small text-truncate">Thanks for your help earlier!</p>
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-0" /></li>
                                    <li>
                                        <a class="dropdown-item text-center py-2 text-primary" asp-controller="Messages" asp-action="Index">
                                            View all messages
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <!-- User Dropdown -->
                            <div class="dropdown">
                                <button class="btn btn-light d-flex align-items-center" type="button" data-bs-toggle="dropdown">
                                    <img src="https://i.pravatar.cc/150?img=12" class="rounded-circle me-2" width="32" height="32" alt="User">
                                    <span class="d-none d-lg-inline me-1">@User.Identity.Name</span>
                                    <i class="bi bi-chevron-down"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li class="dropdown-header">
                                        <div class="d-flex align-items-center">
                                            <img src="https://i.pravatar.cc/150?img=12" class="rounded-circle me-2" width="48" height="48" alt="User">
                                            <div>
                                                <div class="fw-bold">@User.Identity.Name</div>
                                                <small class="text-muted">user@example.com</small>
                                            </div>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index"><i class="bi bi-person me-2"></i>My Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Index"><i class="bi bi-gear me-2"></i>Settings</a></li>
                                    <li><a class="dropdown-item" href="javascript:void(0)"><i class="bi bi-bookmark me-2"></i>Saved Posts</a></li>
                                    <li><a class="dropdown-item" href="javascript:void(0)"><i class="bi bi-clock-history me-2"></i>Activity</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" href="javascript:void(0)"><i class="bi bi-question-circle me-2"></i>Help Center</a></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
                            </a>
                            <a class="btn btn-primary" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus me-1"></i>Join Now
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @if ((ViewData["FullWidth"] as bool?) == true)
        {
            @RenderBody()
        }
        else
        {
            <div class="container-xxl py-3 bg-body-tertiary">
                <div class="row g-4">
                    <aside class="col-12 col-lg-3">
                        <div class="sticky-top" style="top: 88px;">
                            <div class="card mb-3">
                                <div class="card-header fw-semibold">Browse</div>
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Community" asp-action="Index">All Communities</a></li>
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Category" asp-action="Index">Categories</a></li>
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Post" asp-action="Index">All Posts</a></li>
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Search" asp-action="Index">Advanced Search</a></li>
                                </ul>
                            </div>
                        </div>
                    </aside>
                    <section class="col-12 col-lg-6">
                        @RenderBody()
                    </section>
                    <aside class="col-12 col-lg-3">
                        <div class="sticky-top" style="top: 88px;">
                            <div class="card mb-3">
                                <div class="card-header fw-semibold">Trending</div>
                                <ul class="list-group list-group-flush small">
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Post" asp-action="Index">Most upvoted today</a></li>
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Post" asp-action="Index">New this week</a></li>
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Community" asp-action="Index">Rising communities</a></li>
                                </ul>
                            </div>
                            <div class="card">
                                <div class="card-header fw-semibold">About</div>
                                <div class="card-body small text-muted">
                                    <div>&copy; 2025 - discussionspot10</div>
                                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        }
    </main>

    <footer class="footer">
        <div class="container-xxl">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="footer-brand">
                        <div class="footer-logo">
                            <i class="fas fa-comments"></i>
                            <span>DiscussHub</span>
                        </div>
                        <p class="footer-text">
                            The world's largest community platform where millions of people share knowledge, 
                            ask questions, and engage in meaningful conversations.
                        </p>
                        <div class="social-links">
                            <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                            <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                            <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                            <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                            <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <div class="footer-section">
                        <h4 class="footer-title">Platform</h4>
                        <ul class="footer-links">
                            <li><a href="#">Communities</a></li>
                            <li><a href="#">Categories</a></li>
                            <li><a href="#">Trending</a></li>
                            <li><a href="#">Search</a></li>
                            <li><a href="#">Mobile App</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <div class="footer-section">
                        <h4 class="footer-title">Community</h4>
                        <ul class="footer-links">
                            <li><a href="#">Guidelines</a></li>
                            <li><a href="#">Help Center</a></li>
                            <li><a href="#">Moderation</a></li>
                            <li><a href="#">Safety</a></li>
                            <li><a href="#">Report</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <div class="footer-section">
                        <h4 class="footer-title">Company</h4>
                        <ul class="footer-links">
                            <li><a href="#">About Us</a></li>
                            <li><a href="#">Careers</a></li>
                            <li><a href="#">Press</a></li>
                            <li><a href="#">Partners</a></li>
                            <li><a href="#">Contact</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <div class="footer-section">
                        <h4 class="footer-title">Legal</h4>
                        <ul class="footer-links">
                            <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                            <li><a href="#">Terms of Service</a></li>
                            <li><a href="#">Cookie Policy</a></li>
                            <li><a href="#">GDPR</a></li>
                            <li><a href="#">Accessibility</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p>&copy; 2025 DiscussHub. All rights reserved.</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div class="footer-bottom-links">
                            <a href="#">English</a>
                            <a href="#">Español</a>
                            <a href="#">Français</a>
                            <a href="#">Deutsch</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
