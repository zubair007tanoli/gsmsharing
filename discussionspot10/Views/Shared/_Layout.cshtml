<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - discussionspot10</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/discussionspot10.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <style>
        /* Minimal tweaks if CSS isolation fails to load in some hosts */
        body { background-color: #f6f7f8; }
    </style>
    <meta name="color-scheme" content="light dark">
    <meta name="theme-color" content="#ffffff">
    <link rel="icon" href="~/favicon.ico" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        html, body { font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji"; }
    </style>
    <!-- Simple search route defaults to Search/Index?query=... -->
</head>
<body>
    @{
        var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
        var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();
        Func<string, string, string> activeClass = (controller, action) =>
        {
            controller = (controller ?? "").ToLowerInvariant();
            action = (action ?? "").ToLowerInvariant();
            if (currentController == controller && (action == "*" || currentAction == action)) return "active";
            return string.Empty;
        };
    }
    <header>
        <nav class="navbar navbar-expand-md navbar-light bg-white border-bottom box-shadow sticky-top">
            <div class="container-xxl">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index" aria-label="DiscussHub home">
                    <i class="fas fa-comments text-primary"></i>
                    <span>DiscussHub</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topNavbar" aria-controls="topNavbar" aria-expanded="false" aria-label="Open menu">
                    <span class="navbar-toggler-icon" aria-hidden="true"></span>
                </button>

                <form class="search-form d-none d-md-flex mx-3 flex-grow-1" asp-controller="Search" asp-action="Index" method="get" role="search" aria-label="Site search">
                    <i class="fas fa-search search-icon" aria-hidden="true"></i>
                    <input class="form-control search-input" type="search" placeholder="Search posts, users, communities" aria-label="Search" name="query" />
                </form>

                <div class="d-flex align-items-center gap-2 ms-auto">
                    <button class="btn icon-btn d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#mobileSearch" aria-controls="mobileSearch" aria-expanded="false" aria-label="Toggle search">
                        <i class="fas fa-search"></i>
                    </button>
                    <a class="btn btn-ask-question d-none d-md-inline" asp-controller="Post" asp-action="Index" aria-label="Ask a question"><i class="fas fa-circle-question me-1" aria-hidden="true"></i> Ask Question</a>
                    <a class="btn icon-btn" asp-controller="Notifications" asp-action="Index" title="Notifications" aria-label="Notifications"><i class="far fa-bell" aria-hidden="true"></i></a>
                    <a class="btn icon-btn d-none d-md-inline" asp-controller="Messages" asp-action="Index" title="Messages" aria-label="Messages"><i class="far fa-envelope" aria-hidden="true"></i></a>
                    <ul class="navbar-nav mb-0 ms-1">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Account menu" id="accountMenu" aria-haspopup="true">
                                    <img src="https://i.pravatar.cc/150?img=12" alt="User" style="width:28px;height:28px;border-radius:50%;object-fit:cover;margin-right:8px;" />
                                    <span class="d-none d-lg-inline">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="accountMenu">
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index"><i class="fas fa-user me-2"></i>Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Index"><i class="fas fa-gear me-2"></i>Settings</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="px-3 py-1">
                                            <button type="submit" class="btn btn-link p-0 text-decoration-none">Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item d-none d-md-block"><a class="nav-link" asp-controller="Account" asp-action="Login"><i class="fas fa-right-to-bracket me-1" aria-hidden="true"></i>Login</a></li>
                            <li class="nav-item d-none d-md-block"><a class="nav-link" asp-controller="Account" asp-action="Register"><i class="fas fa-user-plus me-1" aria-hidden="true"></i>Sign up</a></li>
                        }
                    </ul>
                </div>

                <div class="collapse navbar-collapse" id="topNavbar">
                    <ul class="navbar-nav me-3 mb-2 mb-md-0">
                        <li class="nav-item"><a class="nav-link @activeClass("Home","Index")" asp-controller="Home" asp-action="Index"><i class="fas fa-home me-1" aria-hidden="true"></i>Home</a></li>
                        <li class="nav-item"><a class="nav-link @activeClass("Community","*")" asp-controller="Community" asp-action="Index"><i class="fas fa-layer-group me-1" aria-hidden="true"></i>Explore</a></li>
                        <li class="nav-item"><a class="nav-link @activeClass("Category","*")" asp-controller="Category" asp-action="Index"><i class="fas fa-tags me-1" aria-hidden="true"></i>Topics</a></li>
                        <li class="nav-item"><a class="nav-link @activeClass("Post","*")" asp-controller="Post" asp-action="Index"><i class="fas fa-fire me-1" aria-hidden="true"></i>Trending</a></li>
                    </ul>

                    @if (User?.Identity?.IsAuthenticated != true)
                    {
                        <hr class="d-md-none" />
                        <ul class="navbar-nav d-md-none mb-2">
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login"><i class="fas fa-right-to-bracket me-1"></i>Login</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register"><i class="fas fa-user-plus me-1"></i>Sign up</a></li>
                        </ul>
                    }
                </div>
            </div>
        </nav>

        <div class="container-xxl d-md-none">
            <div class="collapse" id="mobileSearch">
                <form class="search-form p-2" asp-controller="Search" asp-action="Index" method="get" role="search" aria-label="Mobile site search">
                    <i class="fas fa-search search-icon" aria-hidden="true"></i>
                    <input class="form-control search-input" type="search" placeholder="Search posts, users, communities" aria-label="Search" name="query" />
                </form>
            </div>
        </div>
    </header>

    <main>
        @if ((ViewData["FullWidth"] as bool?) == true)
        {
            @RenderBody()
        }
        else
        {
            <div class="container-xxl py-3 bg-body-tertiary">
                <div class="row g-4">
                    <aside class="col-12 col-lg-3">
                        <div class="sticky-top" style="top: 88px;">
                            <div class="card mb-3">
                                <div class="card-header fw-semibold">Browse</div>
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Community" asp-action="Index">All Communities</a></li>
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Category" asp-action="Index">Categories</a></li>
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Post" asp-action="Index">All Posts</a></li>
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Search" asp-action="Index">Advanced Search</a></li>
                                </ul>
                            </div>
                        </div>
                    </aside>
                    <section class="col-12 col-lg-6">
                        @RenderBody()
                    </section>
                    <aside class="col-12 col-lg-3">
                        <div class="sticky-top" style="top: 88px;">
                            <div class="card mb-3">
                                <div class="card-header fw-semibold">Trending</div>
                                <ul class="list-group list-group-flush small">
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Post" asp-action="Index">Most upvoted today</a></li>
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Post" asp-action="Index">New this week</a></li>
                                    <li class="list-group-item"><a class="text-decoration-none" asp-controller="Community" asp-action="Index">Rising communities</a></li>
                                </ul>
                            </div>
                            <div class="card">
                                <div class="card-header fw-semibold">About</div>
                                <div class="card-body small text-muted">
                                    <div>&copy; 2025 - discussionspot10</div>
                                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        }
    </main>

    <footer class="footer">
        <div class="container-xxl">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="footer-brand">
                        <div class="footer-logo">
                            <i class="fas fa-comments"></i>
                            <span>DiscussHub</span>
                        </div>
                        <p class="footer-text">
                            The world's largest community platform where millions of people share knowledge, 
                            ask questions, and engage in meaningful conversations.
                        </p>
                        <div class="social-links">
                            <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                            <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                            <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                            <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                            <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <div class="footer-section">
                        <h4 class="footer-title">Platform</h4>
                        <ul class="footer-links">
                            <li><a href="#">Communities</a></li>
                            <li><a href="#">Categories</a></li>
                            <li><a href="#">Trending</a></li>
                            <li><a href="#">Search</a></li>
                            <li><a href="#">Mobile App</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <div class="footer-section">
                        <h4 class="footer-title">Community</h4>
                        <ul class="footer-links">
                            <li><a href="#">Guidelines</a></li>
                            <li><a href="#">Help Center</a></li>
                            <li><a href="#">Moderation</a></li>
                            <li><a href="#">Safety</a></li>
                            <li><a href="#">Report</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <div class="footer-section">
                        <h4 class="footer-title">Company</h4>
                        <ul class="footer-links">
                            <li><a href="#">About Us</a></li>
                            <li><a href="#">Careers</a></li>
                            <li><a href="#">Press</a></li>
                            <li><a href="#">Partners</a></li>
                            <li><a href="#">Contact</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <div class="footer-section">
                        <h4 class="footer-title">Legal</h4>
                        <ul class="footer-links">
                            <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                            <li><a href="#">Terms of Service</a></li>
                            <li><a href="#">Cookie Policy</a></li>
                            <li><a href="#">GDPR</a></li>
                            <li><a href="#">Accessibility</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p>&copy; 2025 DiscussHub. All rights reserved.</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div class="footer-bottom-links">
                            <a href="#">English</a>
                            <a href="#">Español</a>
                            <a href="#">Français</a>
                            <a href="#">Deutsch</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
