<Window x:Class="BSS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BSS"
        mc:Ignorable="d"
        WindowState="Maximized"
        Title="Bss by Zubair">

    <Window.Resources>
        <!-- Menu Styles -->
        <Style TargetType="MenuItem" x:Key="TopMenuItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="20,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D94600"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="MenuItem" x:Key="SubMenuItem">
            <Setter Property="Foreground" Value="#1A1A1B"/>
            <Setter Property="Padding" Value="25,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F6F7F8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Separator" x:Key="MenuSeparator">
            <Setter Property="Background" Value="#EDEFF1"/>
            <Setter Property="Margin" Value="10,5"/>
        </Style>

        <!-- Original Styles -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Reddit-Style Menu Bar at Top -->
        <Menu DockPanel.Dock="Top" 
              Background="#FF5700" 
              Height="30" 
              Padding="10,0">

            <MenuItem Header="_File" Style="{StaticResource TopMenuItem}">
                <MenuItem Header="_New" Style="{StaticResource SubMenuItem}"/>
                <MenuItem Header="_Open" Style="{StaticResource SubMenuItem}"/>
                <Separator Style="{StaticResource MenuSeparator}"/>
                <MenuItem Header="_Exit" Style="{StaticResource SubMenuItem}"/>
            </MenuItem>

            <MenuItem Header="_Edit" Style="{StaticResource TopMenuItem}">
                <MenuItem Header="_Cut" Style="{StaticResource SubMenuItem}"/>
                <MenuItem Header="_Copy" Style="{StaticResource SubMenuItem}"/>
                <MenuItem Header="_Paste" Style="{StaticResource SubMenuItem}"/>
            </MenuItem>

            <MenuItem Header="_Help" Style="{StaticResource TopMenuItem}">
                <MenuItem Header="_About" Style="{StaticResource SubMenuItem}"/>
            </MenuItem>
        </Menu>

        <!-- Main Grid Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN - Navigation/List -->
            <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Records List" Style="{StaticResource HeaderTextStyle}"/>
                        <Button Content="+ Add New" Style="{StaticResource ButtonStyle}" 
                                Background="#4CAF50" Foreground="White" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- List View -->
                    <ListView Grid.Row="1" Margin="0,10,0,0" Name="RecordsListView">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Name" Width="150" DisplayMemberBinding="{Binding Name}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <!-- MIDDLE COLUMN - Main Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#D94600" Padding="10" Margin="10" CornerRadius="10">
                    <TextBlock Text="Exit Control List" HorizontalAlignment="Center" FontSize="24" FontWeight="Bold" Foreground="Black"/>
                </Border>

                <!-- Main Content Form -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20">
                        <TextBlock Text="Record Details" Style="{StaticResource HeaderTextStyle}" FontSize="18"/>

                        <!-- Form Fields in 2 Columns -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1: ID and Name -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="ID" Style="{StaticResource LabelStyle}"/>
                                <TextBox Name="IdTextBox" Style="{StaticResource TextBoxStyle}" 
                                         IsEnabled="False" Background="#F0F0F0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Name" Style="{StaticResource LabelStyle}"/>
                                <TextBox Name="NameTextBox" Style="{StaticResource TextBoxStyle}"/>
                            </StackPanel>

                            <!-- Row 2: Email and Phone -->
                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                                <TextBox Name="EmailTextBox" Style="{StaticResource TextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock Text="Phone" Style="{StaticResource LabelStyle}"/>
                                <TextBox Name="PhoneTextBox" Style="{StaticResource TextBoxStyle}"/>
                            </StackPanel>

                            <!-- Row 3: City and Country -->
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="City" Style="{StaticResource LabelStyle}"/>
                                <TextBox Name="CityTextBox" Style="{StaticResource TextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Country" Style="{StaticResource LabelStyle}"/>
                                <TextBox Name="CountryTextBox" Style="{StaticResource TextBoxStyle}"/>
                            </StackPanel>

                            <!-- Row 4: Date of Birth and Gender -->
                            <StackPanel Grid.Row="3" Grid.Column="0">
                                <TextBlock Text="Date of Birth" Style="{StaticResource LabelStyle}"/>
                                <DatePicker Name="DateOfBirthPicker" Height="35" 
                                           BorderBrush="#CCCCCC" BorderThickness="1"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="2">
                                <TextBlock Text="Gender" Style="{StaticResource LabelStyle}"/>
                                <ComboBox Name="GenderComboBox" Height="35" 
                                         BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13">
                                    <ComboBoxItem Content="Select Gender"/>
                                    <ComboBoxItem Content="Male"/>
                                    <ComboBoxItem Content="Female"/>
                                    <ComboBoxItem Content="Other"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Row 5: Address (Full Width) -->
                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Text="Address" Style="{StaticResource LabelStyle}"/>
                                <TextBox Name="AddressTextBox" Height="80" 
                                         TextWrapping="Wrap" AcceptsReturn="True" 
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="8" FontSize="13"
                                         BorderBrush="#CCCCCC" BorderThickness="1"/>
                            </StackPanel>
                        </Grid>

                        <!-- Additional Full Width Fields -->
                        <StackPanel Margin="0,0,0,0">
                            <TextBlock Text="Description" Style="{StaticResource LabelStyle}"/>
                            <TextBox Name="DescriptionTextBox" Height="100" 
                                     TextWrapping="Wrap" AcceptsReturn="True" 
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="8" FontSize="13"
                                     BorderBrush="#CCCCCC" BorderThickness="1"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,0">
                            <TextBlock Text="Notes" Style="{StaticResource LabelStyle}"/>
                            <TextBox Name="NotesTextBox" Height="80" 
                                     TextWrapping="Wrap" AcceptsReturn="True" 
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="8" FontSize="13"
                                     BorderBrush="#CCCCCC" BorderThickness="1"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2" Background="#EFEFEF" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Buttons -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Name="SaveButton" Content="💾 Save" Style="{StaticResource ButtonStyle}" 
                                    Background="#4CAF50" Foreground="White" Width="100"/>
                            <Button Name="UpdateButton" Content="✏️ Update" Style="{StaticResource ButtonStyle}" 
                                    Background="#2196F3" Foreground="White" Width="100"/>
                            <Button Name="DeleteButton" Content="🗑️ Delete" Style="{StaticResource ButtonStyle}" 
                                    Background="#F44336" Foreground="White" Width="100"/>
                            <Button Name="CancelButton" Content="❌ Cancel" Style="{StaticResource ButtonStyle}" 
                                    Background="#9E9E9E" Foreground="White" Width="100"/>
                        </StackPanel>

                        <!-- Date/Time Information -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <TextBlock Name="DateTextBlock" Text="Date: 10/09/2025" FontSize="11" Margin="10,0" FontWeight="SemiBold"/>
                            <TextBlock Text="•" FontSize="11" Margin="5,0"/>
                            <TextBlock Name="TimeTextBlock" Text="Time: 12:00:00 PM" FontSize="11" Margin="10,0" FontWeight="SemiBold"/>
                            <TextBlock Text="•" FontSize="11" Margin="5,0"/>
                            <TextBlock Name="StatusTextBlock" Text="Status: Ready" FontSize="11" Margin="10,0" Foreground="#4CAF50" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT COLUMN - Sponsors -->
            <Border Grid.Column="2" Background="#FAFAFA" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="Sponsors" Style="{StaticResource HeaderTextStyle}"/>

                        <!-- Sponsor 1 -->
                        <Border Background="White" Padding="10" Margin="0,0,0,15" 
                                BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5">
                            <StackPanel>
                                <Border Background="#E3F2FD" Height="80" CornerRadius="3" Margin="0,0,0,10">
                                    <TextBlock Text="SPONSOR LOGO" HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" FontWeight="Bold" Foreground="#2196F3"/>
                                </Border>
                                <TextBlock Text="Sponsor Company 1" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Premium Partner" FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Sponsor 2 -->
                        <Border Background="White" Padding="10" Margin="0,0,0,15" 
                                BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5">
                            <StackPanel>
                                <Border Background="#F3E5F5" Height="80" CornerRadius="3" Margin="0,0,0,10">
                                    <TextBlock Text="SPONSOR LOGO" HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" FontWeight="Bold" Foreground="#9C27B0"/>
                                </Border>
                                <TextBlock Text="Sponsor Company 2" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Gold Partner" FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Sponsor 3 -->
                        <Border Background="White" Padding="10" Margin="0,0,0,15" 
                                BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5">
                            <StackPanel>
                                <Border Background="#FFF3E0" Height="80" CornerRadius="3" Margin="0,0,0,10">
                                    <TextBlock Text="SPONSOR LOGO" HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF9800"/>
                                </Border>
                                <TextBlock Text="Sponsor Company 3" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Silver Partner" FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Sponsor 4 -->
                        <Border Background="White" Padding="10" Margin="0,0,0,15" 
                                BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5">
                            <StackPanel>
                                <Border Background="#E8F5E9" Height="80" CornerRadius="3" Margin="0,0,0,10">
                                    <TextBlock Text="SPONSOR LOGO" HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" FontWeight="Bold" Foreground="#4CAF50"/>
                                </Border>
                                <TextBlock Text="Sponsor Company 4" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Bronze Partner" FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Advertisement Section -->
                        <Border Background="#FFEBEE" Padding="15" Margin="0,10,0,0" 
                                BorderBrush="#FFCDD2" BorderThickness="1" CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="📢 Advertisement" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock Text="Your ad could be here! Contact us for sponsorship opportunities." 
                                          TextWrapping="Wrap" FontSize="10" Foreground="#555"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>