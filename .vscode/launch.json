{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
        // ===================================
        // C# / .NET CONFIGURATIONS
        // ===================================
        {
            "name": "C# - Launch discussionspot9 (Web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/discussionspot9/bin/Debug/net9.0/discussionspot9.dll",
            "args": [],
            "cwd": "${workspaceFolder}/discussionspot9",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5099"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/discussionspot9/Views"
            },
            "logging": {
                "moduleLoad": false
            }
        },
        {
            "name": "C# - Launch discussionspot (Web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/discussionspot/bin/Debug/net9.0/discussionspot.dll",
            "args": [],
            "cwd": "${workspaceFolder}/discussionspot",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/discussionspot/Views"
            }
        },
        {
            "name": "C# - Launch gsmsharing (Web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/gsmsharing/bin/Debug/net9.0/gsmsharing.dll",
            "args": [],
            "cwd": "${workspaceFolder}/gsmsharing",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/gsmsharing/Views"
            }
        },
        {
            "name": "C# - Attach to Process",
            "type": "coreclr",
            "request": "attach"
        },
        // ===================================
        // PYTHON CONFIGURATIONS
        // ===================================
        {
            "name": "Python - Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python - Django",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "runserver"
            ],
            "django": true,
            "justMyCode": true
        },
        {
            "name": "Python - Flask",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "app.py",
                "FLASK_DEBUG": "1"
            },
            "args": [
                "run",
                "--no-debugger",
                "--no-reload"
            ],
            "jinja": true,
            "justMyCode": true
        },
        {
            "name": "Python - FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": true
        },
        {
            "name": "Python - AI Service (discussionspot9)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/discussionspot9/Python_AI_Service/ai_service.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}/discussionspot9/Python_AI_Service"
        },
        {
            "name": "Python - Script with Args",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [],
            "justMyCode": false
        },
        // ===================================
        // JAVA CONFIGURATIONS
        // ===================================
        {
            "name": "Java - Current File",
            "type": "java",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "name": "Java - Debug (Launch)",
            "type": "java",
            "request": "launch",
            "mainClass": ""
        },
        {
            "name": "Java - Debug (Attach)",
            "type": "java",
            "request": "attach",
            "hostName": "localhost",
            "port": 5005
        },
        {
            "name": "Java - Spring Boot",
            "type": "java",
            "request": "launch",
            "mainClass": "<insert-main-class-name>",
            "projectName": "<insert-project-name>",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
