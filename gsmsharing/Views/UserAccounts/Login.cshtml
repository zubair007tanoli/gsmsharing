@model gsmsharing.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/css/Register_Login.css" rel="stylesheet" />
<style>
    .social-login {
        margin-top: 25px;
        text-align: center;
    }

        .social-login p {
            margin-bottom: 15px;
            color: #666;
            font-size: 14px;
        }

    .social-login-btn {
        width: 100%;
        margin-bottom: 10px;
        padding: 12px;
        border-radius: 5px;
        font-size: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .social-login-btn i {
            margin-right: 10px;
            font-size: 18px;
        }

    .btn-google {
        background-color: #db4437;
        color: white;
        border: 1px solid #db4437;
    }

    .btn-facebook {
        background-color: #1877f2;
        color: white;
        border: 1px solid #1877f2;
    }

    .btn-twitter {
        background-color: #1da1f2;
        color: white;
        border: 1px solid #1da1f2;
    }

    .btn-google:hover {
        background-color: #c23321;
        border-color: #c23321;
        transform: translateY(-2px);
    }

    .btn-facebook:hover {
        background-color: #165dbb;
        border-color: #165dbb;
        transform: translateY(-2px);
    }

    .btn-twitter:hover {
        background-color: #1991db;
        border-color: #1991db;
        transform: translateY(-2px);
    }

    .signup-link {
        text-align: center;
        margin-top: 20px;
        color: #666;
        font-size: 14px;
    }

        .signup-link a {
            color: #007bff;
            text-decoration: none;
            font-weight: 500;
        }

            .signup-link a:hover {
                text-decoration: underline;
            }

</style>
<div class="login-popup">
    <i class="fas fa-sign-in-alt fa-2x icon-circle"></i>
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="logo">
        <img src="https://via.placeholder.com/180x50.png?text=GSMSHARING+LOGO" alt="GSMSHARING Logo">
    </div>

    <h2 class="text-center mb-4">Welcome Back!</h2>
    <form asp-action="Login" asp-controller="UserAccounts" method="post" enctype="multipart/form-data">
        <div class="mb-3 form-floating">
            <input asp-for="Email" class="form-control" id="loginEmail" placeholder="name@example.com">
            <label for="loginEmail"><i class="fas fa-envelope"></i> Email address</label>
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="mb-3 form-floating">
            <input asp-for="Password" class="form-control" id="loginPassword" placeholder="Password">
            <label for="loginPassword"><i class="fas fa-lock"></i> Password</label>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="form-check mb-3">
            <input asp-for="RememberMe" class="form-check-input" type="checkbox">
            <label asp-for="RememberMe" class="form-check-label">
                Remember Me
            </label>
        </div>
        <button type="submit" class="btn btn-primary btn-block w-100 mb-3">Login</button>
    </form>

    <!-- Social Login Section -->
    <div class="social-login">
        <p class="mb-3">Or continue with social</p>
        <a href="#" class="btn btn-google social-login-btn">
            <i class="fab fa-google"></i>Google
        </a>
        <a href="#" class="btn btn-facebook social-login-btn">
            <i class="fab fa-facebook-f"></i>Facebook
        </a>
        <a href="#" class="btn btn-twitter social-login-btn">
            <i class="fab fa-twitter"></i>Twitter
        </a>
    </div>

    <!-- Sign Up Link -->
    <div class="signup-link">
        <p>New to Gsmsharing? <a href="#">Create an account</a></p>
    </div>

</div>

