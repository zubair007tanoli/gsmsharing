                            </tr>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="/placeholder.svg?height=32&width=32" alt="User" class="rounded-circle me-2">
                                        <span class="fw-medium">Mike Johnson</span>
                                    </div>
                                </td>
                                <td>mike.johnson@example.com</td>
                                <td><span class="badge bg-primary">Member</span></td>
                                <td>2025-02-26</td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="/placeholder.svg?height=32&width=32" alt="User" class="rounded-circle me-2">
                                        <span class="fw-medium">Sarah Williams</span>
                                    </div>
                                </td>
                                <td>sarah.williams@example.com</td>
