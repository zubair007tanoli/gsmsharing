@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["BreadcrumbSection"] = "Dashboard";
    ViewData["BreadcrumbPage"] = "Overview";
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Dashboard Overview</h1>
            <div>
                <button class="btn btn-primary">
                    <i class="fas fa-download me-2"></i> Export Report
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Stats Row -->
<div class="row">
    <div class="col-md-6 col-lg-3">
        <div class="admin-stat-card">
            <div class="admin-stat-icon bg-primary">
                <i class="fas fa-users"></i>
            </div>
            <div class="admin-stat-content">
                <h4 class="admin-stat-value">2,845</h4>
                <p class="admin-stat-label">Total Users</p>
                <div class="admin-stat-change positive">
                    <i class="fas fa-arrow-up"></i> 12.5% since last month
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="admin-stat-card">
            <div class="admin-stat-icon bg-success">
                <i class="fas fa-file-alt"></i>
            </div>
            <div class="admin-stat-content">
                <h4 class="admin-stat-value">1,253</h4>
                <p class="admin-stat-label">Total Posts</p>
                <div class="admin-stat-change positive">
                    <i class="fas fa-arrow-up"></i> 8.3% since last month
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="admin-stat-card">
            <div class="admin-stat-icon bg-warning">
                <i class="fas fa-users-cog"></i>
            </div>
            <div class="admin-stat-content">
                <h4 class="admin-stat-value">78</h4>
                <p class="admin-stat-label">Communities</p>
                <div class="admin-stat-change positive">
                    <i class="fas fa-arrow-up"></i> 5.2% since last month
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="admin-stat-card">
            <div class="admin-stat-icon bg-danger">
                <i class="fas fa-comments"></i>
            </div>
            <div class="admin-stat-content">
                <h4 class="admin-stat-value">4,521</h4>
                <p class="admin-stat-label">Comments</p>
                <div class="admin-stat-change negative">
                    <i class="fas fa-arrow-down"></i> 3.1% since last month
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row">
    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <h5 class="admin-card-title">User Growth</h5>
                <div class="btn-group">
                    <button type="button" class="btn btn-sm btn-outline-secondary active">Weekly</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary">Monthly</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary">Yearly</button>
                </div>
            </div>
            <div class="admin-card-body">
                <canvas id="userGrowthChart" height="300"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="admin-card">
            <div class="admin-card-header">
                <h5 class="admin-card-title">Content Distribution</h5>
            </div>
            <div class="admin-card-body">
                <canvas id="contentDistributionChart" height="300"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Ban Appeals Alert -->
@if (ViewBag.PendingAppealsCount > 0)
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <div class="d-flex align-items-center">
                    <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
                    <div class="flex-grow-1">
                        <h5 class="alert-heading mb-1">Pending Ban Appeals</h5>
                        <p class="mb-0">You have <strong>@ViewBag.PendingAppealsCount</strong> pending ban appeal(s) waiting for review.</p>
                    </div>
                    <a href="/Admin/BanAppeals" class="btn btn-warning">
                        <i class="fas fa-gavel me-2"></i>Review Appeals
                    </a>
                </div>
            </div>
        </div>
    </div>
}

<!-- Recent Activity -->
