                                <td>2025-02-28</td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="#" class="fw-medium text-dark">Top 10 Mobile Phones in 2025</a>
                                </td>
                                <td>Jane Smith</td>
                                <td><span class="badge bg-success">Published</span></td>
                                <td>2025-02-27</td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="#" class="fw-medium text-dark">The Future of 6G Technology</a>
