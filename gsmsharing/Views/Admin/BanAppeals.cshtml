@model IEnumerable<gsmsharing.Models.BanAppeal>
@{
    ViewData["Title"] = "Ban Appeals";
    ViewData["BreadcrumbSection"] = "User Management";
    ViewData["BreadcrumbPage"] = "Ban Appeals";
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Ban Appeals</h1>
            <div>
                <a href="/Admin/Users" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i> Back to Users
                </a>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="admin-card">
            <div class="admin-card-header">
                <h5 class="admin-card-title">Appeals List</h5>
                <div class="d-flex gap-2">
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-filter me-1"></i> Filter
                        </button>
                        <div class="dropdown-menu p-3" style="width: 200px;">
                            <h6 class="dropdown-header px-0 mb-2">Filter Appeals</h6>
                            <div class="mb-3">
                                <label class="form-label">Status</label>
                                <select class="form-select form-select-sm" id="statusFilter">
                                    <option value="">All Status</option>
                                    <option value="Pending">Pending</option>
                                    <option value="Approved">Approved</option>
                                    <option value="Rejected">Rejected</option>
                                </select>
                            </div>
                            <div class="d-grid">
                                <button class="btn btn-sm btn-primary" onclick="applyFilter()">Apply Filter</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="admin-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover datatable mb-0">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Appeal Message</th>
                                <th>Submitted At</th>
                                <th>Status</th>
                                <th>Reviewed By</th>
                                <th>Admin Response</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appeal in Model)
                            {
                                <tr data-status="@appeal.Status.ToString()">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div>
                                                <h6 class="mb-0">@appeal.User?.UserName</h6>
                                                <small class="text-muted">@appeal.User?.Email</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div style="max-width: 300px; overflow: hidden; text-overflow: ellipsis;">
                                            @appeal.AppealMessage
                                        </div>
                                    </td>
                                    <td>@appeal.SubmittedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        @if (appeal.Status == gsmsharing.Models.AppealStatus.Pending)
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                        else if (appeal.Status == gsmsharing.Models.AppealStatus.Approved)
                                        {
                                            <span class="badge bg-success">Approved</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Rejected</span>
                                        }
                                    </td>
                                    <td>
                                        @if (appeal.ReviewedBy != null)
                                        {
                                            <span>@appeal.ReviewedBy.UserName</span>
                                            <br />
                                            <small class="text-muted">@appeal.ReviewedAt?.ToString("yyyy-MM-dd HH:mm")</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(appeal.AdminResponse))
                                        {
                                            <div style="max-width: 200px; overflow: hidden; text-overflow: ellipsis;">
                                                @appeal.AdminResponse
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (appeal.Status == gsmsharing.Models.AppealStatus.Pending)
                                        {
                                            <div class="d-flex gap-1">
                                                <a href="/Admin/ReviewAppeal/@appeal.BanAppealId" class="btn btn-sm btn-outline-primary" data-bs-toggle="tooltip" title="Review">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <button class="btn btn-sm btn-outline-success" onclick="approveAppeal(@appeal.BanAppealId)" data-bs-toggle="tooltip" title="Approve">
                                                    <i class="fas fa-check"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" onclick="rejectAppeal(@appeal.BanAppealId)" data-bs-toggle="tooltip" title="Reject">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <a href="/Admin/ReviewAppeal/@appeal.BanAppealId" class="btn btn-sm btn-outline-primary" data-bs-toggle="tooltip" title="View Details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Approve Appeal Modal -->
<div class="modal fade" id="approveModal" tabindex="-1" aria-labelledby="approveModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="approveModalLabel">Approve Appeal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="approveForm" method="post">
                <div class="modal-body">
                    <input type="hidden" id="approveAppealId" name="id" />
                    <div class="mb-3">
                        <label for="approveResponse" class="form-label">Admin Response (Optional)</label>
                        <textarea class="form-control" id="approveResponse" name="adminResponse" rows="3" placeholder="Optional message to the user"></textarea>
                    </div>
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        This will unban the user and approve their appeal.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Approve Appeal</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Reject Appeal Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-labelledby="rejectModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="rejectModalLabel">Reject Appeal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="rejectForm" method="post">
                <div class="modal-body">
                    <input type="hidden" id="rejectAppealId" name="id" />
                    <div class="mb-3">
                        <label for="rejectResponse" class="form-label">Admin Response <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="rejectResponse" name="adminResponse" rows="3" placeholder="Reason for rejection" required></textarea>
                    </div>
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        The user will remain banned after rejection.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Reject Appeal</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function approveAppeal(id) {
            document.getElementById('approveAppealId').value = id;
            document.getElementById('approveForm').action = '/Admin/ApproveAppeal';
            var modal = new bootstrap.Modal(document.getElementById('approveModal'));
            modal.show();
        }

        function rejectAppeal(id) {
            document.getElementById('rejectAppealId').value = id;
            document.getElementById('rejectForm').action = '/Admin/RejectAppeal';
            var modal = new bootstrap.Modal(document.getElementById('rejectModal'));
            modal.show();
        }

        function applyFilter() {
            var status = document.getElementById('statusFilter').value;
            var rows = document.querySelectorAll('tbody tr');
            
            rows.forEach(function(row) {
                if (!status || row.getAttribute('data-status') === status) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        $(document).ready(function() {
            // Initialize DataTable
            $('.datatable').DataTable({
                responsive: true,
                paging: true,
                pageLength: 10,
                order: [[2, 'desc']] // Sort by submitted date descending
            });

            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });
        });
    </script>
}


