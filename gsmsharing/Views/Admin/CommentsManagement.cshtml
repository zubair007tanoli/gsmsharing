<!-- Add Comment Modal -->
<div class="modal fade" id="addCommentModal" tabindex="-1" aria-labelledby="addCommentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addCommentModalLabel">Add New Comment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label for="commentAuthor" class="form-label">Author</label>
                        <input type="text" class="form-control" id="commentAuthor" placeholder="Enter author name">
                    </div>
                    <div class="mb-3">
                        <label for="commentPost" class="form-label">Post</label>
                        <select class="form-select select2" id="commentPost">
                            <option value="">Select Post</option>
                            <option value="1">Getting Started with GSM Sharing</option>
                            <option value="2">Top 10 Mobile Phones in 2025</option>
                            <option value="3">The Future of 6G Technology</option>
                            <option value="4">How to Unlock Your Phone</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="commentContent" class="form-label">Comment</label>
                        <textarea class="form-control" id="commentContent" rows="4" placeholder="Enter comment"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="commentStatus" class="form-label">Status</label>
                        <select class="form-select" id="commentStatus">
                            <option value="approved">Approved</option>
                            <option value="pending">Pending</option>
                            <option value="flagged">Flagged</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary">Add Comment</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize DataTable
            $('.datatable').DataTable({
                responsive: true,
                paging: false,
                info: false,
                searching: false
            });

            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });

            // Initialize Select2
            $('.select2').select2({
                theme: 'bootstrap-5',
                dropdownParent: $('#addCommentModal')
            });

            // Select all checkbox
            $('#selectAll').on('change', function() {
                $('tbody .form-check-input').prop('checked', $(this).prop('checked'));
            });
        });
    </script>
}