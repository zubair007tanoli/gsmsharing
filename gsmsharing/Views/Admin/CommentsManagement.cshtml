@{
    ViewData["Title"] = "Comments Management";
    ViewData["BreadcrumbSection"] = "Content Management";
    ViewData["BreadcrumbPage"] = "Comments";
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Comments Management</h1>
            <div>
                <button class="btn btn-outline-secondary me-2">
                    <i class="fas fa-file-export me-2"></i> Export
                </button>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCommentModal">
                    <i class="fas fa-comment-dots me-2"></i> Add Comment
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Stats Row -->
<div class="row">
    <div class="col-md-6 col-lg-3">
        <div class="admin-stat-card">
            <div class="admin-stat-icon bg-primary">
                <i class="fas fa-comments"></i>
            </div>
            <div class="admin-stat-content">
                <h4 class="admin-stat-value">4,521</h4>
                <p class="admin-stat-label">Total Comments</p>
                <div class="admin-stat-change negative">
                    <i class="fas fa-arrow-down"></i> 3.1% since last month
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="admin-stat-card">
            <div class="admin-stat-icon bg-success">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="admin-stat-content">
                <h4 class="admin-stat-value">3,987</h4>
                <p class="admin-stat-label">Approved</p>
                <div class="admin-stat-change negative">
                    <i class="fas fa-arrow-down"></i> 2.5% since last month
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="admin-stat-card">
            <div class="admin-stat-icon bg-warning">
                <i class="fas fa-clock"></i>
            </div>
            <div class="admin-stat-content">
                <h4 class="admin-stat-value">245</h4>
                <p class="admin-stat-label">Pending</p>
                <div class="admin-stat-change positive">
                    <i class="fas fa-arrow-up"></i> 5.2% since last month
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="admin-stat-card">
            <div class="admin-stat-icon bg-danger">
                <i class="fas fa-flag"></i>
            </div>
            <div class="admin-stat-content">
                <h4 class="admin-stat-value">78</h4>
                <p class="admin-stat-label">Flagged</p>
                <div class="admin-stat-change positive">
                    <i class="fas fa-arrow-up"></i> 12.7% since last month
                </div>
            </div>
        </div>
    </div>
</div>

