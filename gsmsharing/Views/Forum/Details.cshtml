@model gsmsharing.Models.ForumThread
@{
    ViewData["Title"] = Model?.Title + " - GSMSharing Forums";
}

@section customStyle {
    <link rel="stylesheet" href="~/css/Enhanced.css" asp-append-version="true" />
}

<div class="mb-3">
    <a href="/Forum" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-2"></i>Back to Forums
    </a>
</div>

@if (Model != null)
{
    <div class="card modern-card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="flex-grow-1">
                    <h2 class="mb-2">@Model.Title</h2>
                    <div class="d-flex align-items-center text-muted small">
                        <span>Posted by <strong>@Model.User?.UserName</strong></span>
                        <span class="mx-2">•</span>
                        <span>@Model.CreationDate?.ToString("MMMM dd, yyyy 'at' HH:mm")</span>
                        <span class="mx-2">•</span>
                        <span><i class="fas fa-eye me-1"></i>@Model.Views views</span>
                    </div>
                </div>
                @if (User.Identity.IsAuthenticated && User.Identity.Name == Model.UserId)
                {
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Forum/Edit/@Model.UserFourmID"><i class="fas fa-edit me-2"></i>Edit</a></li>
                            <li>
                                <form asp-action="Delete" asp-controller="Forum" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@Model.UserFourmID" />
                                    <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Are you sure you want to delete this thread?')">
                                        <i class="fas fa-trash me-2"></i>Delete
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.Tags))
            {
                <div class="mb-3">
                    @foreach (var tag in Model.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <span class="badge bg-primary me-1">@tag.Trim()</span>
                    }
                </div>
            }

            <div class="post-content">
                @Html.Raw(Model.Content)
            </div>

            <div class="d-flex align-items-center justify-content-between mt-4 pt-3 border-top">
                <div class="d-flex gap-3">
                    <button class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-thumbs-up me-1"></i> @Model.Likes
                    </button>
                    <button class="btn btn-sm btn-outline-danger">
                        <i class="fas fa-thumbs-down me-1"></i> @Model.Dislikes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Replies Section -->
    <div class="card modern-card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="fas fa-comments me-2"></i>Replies (@(Model.Replies?.Count ?? 0))
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Replies != null && Model.Replies.Any())
            {
                @foreach (var reply in Model.Replies.OrderBy(r => r.PublishDate))
                {
                    <div class="reply-card border-bottom pb-3 mb-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <strong>@reply.User?.UserName</strong>
                                <span class="text-muted small ms-2">@reply.PublishDate?.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-thumbs-up"></i> @reply.Like
                                </button>
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-thumbs-down"></i> @reply.DisLike
                                </button>
                            </div>
                        </div>
                        <div class="reply-content">
                            @Html.Raw(reply.ForumContent)
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted text-center py-3">No replies yet. Be the first to reply!</p>
            }

            @if (User.Identity.IsAuthenticated)
            {
                <div class="mt-4">
                    <h6 class="mb-3">Post a Reply</h6>
                    <form asp-action="Reply" asp-controller="Forum" method="post">
                        <input type="hidden" name="threadId" value="@Model.UserFourmID" />
                        <div class="mb-3">
                            <textarea name="content" class="form-control" rows="5" required placeholder="Write your reply here..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-paper-plane me-2"></i>Post Reply
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <a href="/UserAccounts/Login" class="btn btn-primary btn-sm">Login</a> to post a reply
                </div>
            }
        </div>
    </div>
}

