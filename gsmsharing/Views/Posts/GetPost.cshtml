<style>
    /* Additions/Modifications for Reddit Style */
    .post-container {
        display: flex;
        gap: 24px;
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .main-content {
        flex: 1;
        max-width: 740px;
    }

    .sidebar {
        width: 312px;
        position: sticky;
        top: 2rem;
        align-self: flex-start;
    }

    .post-card {
        border: 1px solid var(--reddit-border);
        border-radius: 4px;
        background: white;
        margin-bottom: 16px;
    }

    .post-header {
        padding: 8px 16px;
        background: var(--reddit-light-gray);
        font-size: 12px;
        color: var(--text-muted);
        border-bottom: 1px solid var(--reddit-border);
    }

    .post-content {
        padding: 16px;
    }

    .post-title {
        font-size: 18px;
        font-weight: 500;
        margin-bottom: 8px;
        color: var(--reddit-text);
    }

    .post-actions {
        display: flex;
        gap: 8px;
        padding: 8px 16px;
        border-top: 1px solid var(--reddit-border);
        background: var(--reddit-light-gray);
    }

        .post-actions button {
            padding: 4px 8px;
            font-size: 12px;
            color: var(--text-muted);
            gap: 4px;
        }

    .comment-section {
        background: white;
        border: 1px solid var(--reddit-border);
        border-radius: 4px;
        margin-top: 16px;
    }

    .comment-card {
        padding: 16px;
        border-bottom: 1px solid var(--reddit-border);
        position: relative;
    }

    .nested-comment {
        margin-left: 24px;
        border-left: 2px solid var(--reddit-border);
        padding-left: 16px;
    }

    .sidebar-card {
        background: white;
        border: 1px solid var(--reddit-border);
        border-radius: 4px;
        padding: 12px;
        margin-bottom: 16px;
    }

    .post-image {
        max-width: 100%;
        height: auto;
        border-radius: 4px;
        margin-bottom: 16px;
    }

    .post-body img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 16px auto;
    }
</style>

<div class="post-container">
    <div class="main-content">
        <!-- Post Card -->
        <div class="post-card">
            <div class="post-header">
                <img src="https://i.pravatar.cc/32" class="user-avatar" alt="User">
                <a href="#" class="community-badge">r/@Model.CommunityName</a>
                <span>•</span>
                <span>Posted by u/@Model.AuthorName</span>
                <span>• 5h ago</span>
            </div>
            <div class="post-content">
                <h1 class="post-title">@Model.Title</h1>
                
                @* Debug: Show what's in FeaturedImage *@
                @if (ViewContext.HttpContext.Request.Host.Host.Contains("localhost"))
                {
                    <div class="alert alert-info">
                        <strong>Debug:</strong> FeaturedImage = "@Model.FeaturedImage"
                    </div>
                }
                
                <div class="post-body">
                    @if (!string.IsNullOrEmpty(Model.FeaturedImage))
                    {
                        var imagePath = Model.FeaturedImage;
                        // If it's a relative path, ensure it starts with /
                        if (!imagePath.StartsWith("http") && !imagePath.StartsWith("/"))
                        {
                            imagePath = "/" + imagePath;
                        }
                        <img src="@imagePath" alt="@Model.Title" class="post-image img-fluid mb-3" 
                             onerror="console.error('Image failed to load:', this.src); this.style.display='none';">
                    }
                    else
                    {
                        @if (ViewContext.HttpContext.Request.Host.Host.Contains("localhost"))
                        {
                            <div class="alert alert-warning">No featured image found for this post.</div>
                        }
                    }
                    @Html.Raw(Model.Content)
                </div>
                <div class="post-actions">
                    <button class="like-btn" onclick="handleReaction(this, 'like')">
                        <i class="far fa-thumbs-up"></i>
                        <span class="engagement-count">1.8k</span>
                    </button>
                    <button class="dislike-btn" onclick="handleReaction(this, 'dislike')">
                        <i class="far fa-thumbs-down"></i>
                        <span class="engagement-count">32</span>
                    </button>
                    <button>
                        <i class="far fa-comment-alt"></i>
                        <span>142 Comments</span>
                    </button>
                    <button>
                        <i class="fas fa-share"></i>
                        <span>Share</span>
                    </button>
                    <button>
                        <i class="far fa-bookmark"></i>
                        <span>Save</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Comment Form -->
        <div class="post-card mt-3">
            <div class="d-flex gap-3 p-3">
                <img src="https://i.pravatar.cc/32" class="user-avatar" alt="User">
                <div class="flex-grow-1">
                    <textarea class="form-control w-100" rows="2"
                              placeholder="What are your thoughts?"></textarea>
                    <div class="d-flex justify-content-end mt-2">
                        <button class="btn btn-primary px-3">Comment</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Comments -->
        <div class="comment-section">
            <div class="comment-card">
                <div class="d-flex gap-2 mb-2">
                    <img src="https://i.pravatar.cc/28" class="user-avatar" alt="User">
                    <div>
                        <span class="fw-bold">u/css_expert</span>
                        <span class="post-time">• 3h ago</span>
                    </div>
                </div>
                <p class="mb-2">Great overview! The container queries example is particularly useful.</p>
                <div class="comment-actions">
                    <button class="btn-action">
                        <i class="fas fa-arrow-up"></i>
                        <span>452</span>
                    </button>
                    <button class="btn-action">
                        <i class="fas fa-arrow-down"></i>
                    </button>
                    <button class="btn-action" onclick="toggleReply(this)">
                        Reply
                    </button>
                </div>

                <!-- Nested Comment -->
                <div class="nested-comment">
                    <div class="comment-card">
                        <div class="d-flex gap-2 mb-2">
                            <img src="https://i.pravatar.cc/28" class="user-avatar" alt="User">
                            <div>
                                <span class="fw-bold">u/design_system</span>
                                <span class="post-time">• 1h ago</span>
                            </div>
                        </div>
                        <p class="mb-2">Agreed! Combined with CSS nesting, it's revolutionized our component architecture.</p>
                        <div class="comment-actions">
                            <button class="btn-action">
                                <i class="fas fa-arrow-up"></i>
                                <span>156</span>
                            </button>
                            <button class="btn-action">
                                <i class="fas fa-arrow-down"></i>
                            </button>
                            <button class="btn-action" onclick="toggleReply(this)">
                                Reply
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-card">
            <div class="sidebar-title">About Community</div>
            <button class="sidebar-button">Join Community</button>
            <div class="sidebar-stat">
                <i class="fas fa-users"></i>
                <span>1.2M Members</span>
            </div>
            <div class="sidebar-stat">
                <i class="fas fa-chart-line"></i>
                <span>Top 1% Ranked</span>
            </div>
        </div>
    </div>
</div>