@model IEnumerable<gsmsharing.Models.Post>

@{
    ViewData["Title"] = "My Posts";
    var currentFilter = ViewBag.CurrentFilter as string ?? "all";
    var draftCount = ViewBag.DraftCount;
    var publishedCount = ViewBag.PublishedCount;
    var totalCount = ViewBag.TotalCount;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-file-alt me-2"></i> My Posts</h2>
                <a href="@Url.Action("Create")" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Create New Post
                </a>
            </div>

            <!-- Filter Tabs -->
            <ul class="nav nav-tabs mb-4">
                <li class="nav-item">
                    <a class="nav-link @(currentFilter == "all" ? "active" : "")" href="@Url.Action("MyPosts", new { status = "all" })">
                        <i class="fas fa-list"></i> All (@totalCount)
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentFilter == "published" ? "active" : "")" href="@Url.Action("MyPosts", new { status = "published" })">
                        <i class="fas fa-check-circle text-success"></i> Published (@publishedCount)
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentFilter == "draft" ? "active" : "")" href="@Url.Action("MyPosts", new { status = "draft" })">
                        <i class="fas fa-edit text-warning"></i> Drafts (@draftCount)
                    </a>
                </li>
            </ul>

            <!-- Posts List -->
            @if (Model != null && Model.Any())
            {
                <div class="list-group">
                    @foreach (var post in Model)
                    {
                        <div class="list-group-item list-group-item-action mb-3 border rounded">
                            <div class="row">
                                <div class="col-md-2">
                                    @if (!string.IsNullOrEmpty(post.FeaturedImage))
                                    {
                                        <img src="@post.FeaturedImage" alt="@post.Title" class="img-fluid rounded" style="max-height: 120px; object-fit: cover; width: 100%;">
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 120px;">
                                            <i class="fas fa-image fa-3x text-muted"></i>
                                        </div>
                                    }
                                </div>
                                <div class="col-md-7">
                                    <div class="d-flex align-items-center mb-2">
                                        <h5 class="mb-0 me-3">
                                            <a href="@Url.Action("Details", new { community = post.Community?.Slug ?? "gsmsharing", slug = post.Slug })" class="text-decoration-none text-dark">
                                                @post.Title
                                            </a>
                                        </h5>
                                        @if (post.PostStatus?.ToLower() == "draft")
                                        {
                                            <span class="badge bg-warning text-dark"><i class="fas fa-edit"></i> Draft</span>
                                        }
                                        else if (post.PostStatus?.ToLower() == "published")
                                        {
                                            <span class="badge bg-success"><i class="fas fa-check"></i> Published</span>
                                        }
                                        @if (post.IsPromoted == true)
                                        {
                                            <span class="badge bg-primary ms-2"><i class="fas fa-bullhorn"></i> Promoted</span>
                                        }
                                        @if (post.IsFeatured == true)
                                        {
                                            <span class="badge bg-info ms-2"><i class="fas fa-star"></i> Featured</span>
                                        }
                                    </div>
                                    <p class="text-muted mb-2">
                                        <i class="fas fa-folder"></i> r/@(post.Community?.Name ?? "Unknown") 
                                        <span class="mx-2">•</span>
                                        <i class="fas fa-calendar"></i> @post.CreatedAt?.ToString("MMM dd, yyyy")
                                        @if (post.UpdatedAt.HasValue && post.UpdatedAt != post.CreatedAt)
                                        {
                                            <span class="mx-2">•</span>
                                            <i class="fas fa-edit"></i><span> Updated: </span>@post.UpdatedAt?.ToString("MMM dd, yyyy")
                                        }
                                    </p>
                                    <p class="mb-0">
                                        <i class="fas fa-eye"></i> @(post.ViewCount ?? 0) views
                                    </p>
                                </div>
                                <div class="col-md-3 text-end">
                                    <div class="btn-group-vertical w-100" role="group">
                                        <a href="@Url.Action("Details", new { community = post.Community?.Slug ?? "gsmsharing", slug = post.Slug })" class="btn btn-sm btn-outline-primary mb-2">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = post.PostID })" class="btn btn-sm btn-outline-secondary mb-2">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>
                                        @{
                                            var safeTitle = post.Title?.Replace("'", "&#39;")?.Replace("\n", " ")?.Replace("\r", "");
                                        }
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deletePost(@post.PostID, '@safeTitle')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> 
                    @if (currentFilter == "draft")
                    {
                        <text>You don't have any drafts. <a href="@Url.Action("Create")">Create a new post</a> and save it as a draft.</text>
                    }
                    else if (currentFilter == "published")
                    {
                        <text>You don't have any published posts yet. <a href="@Url.Action("Create")">Create and publish your first post!</a></text>
                    }
                    else
                    {
                        <text>You haven't created any posts yet. <a href="@Url.Action("Create")">Create your first post!</a></text>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle"></i> Delete Post</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this post?</p>
                <p class="fw-bold" id="deletePostTitle"></p>
                <p class="text-danger"><i class="fas fa-info-circle"></i> This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDelete">
                    <i class="fas fa-trash"></i> Delete Post
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let postIdToDelete = null;

        function deletePost(postId, postTitle) {
            postIdToDelete = postId;
            document.getElementById('deletePostTitle').textContent = postTitle;
            const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }

        document.getElementById('confirmDelete').addEventListener('click', async function() {
            if (!postIdToDelete) return;

            const deleteBtn = this;
            const originalText = deleteBtn.innerHTML;
            deleteBtn.disabled = true;
            deleteBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting...';

            try {
                const response = await fetch('@Url.Action("Delete", "Posts")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify(postIdToDelete)
                });

                const result = await response.json();

                if (result.success) {
                    // Close modal
                    const modal = bootstrap.Modal.getInstance(document.getElementById('deleteModal'));
                    modal.hide();
                    
                    // Show success message and reload
                    alert('Post deleted successfully!');
                    window.location.reload();
                } else {
                    alert('Failed to delete post: ' + result.message);
                    deleteBtn.disabled = false;
                    deleteBtn.innerHTML = originalText;
                }
            } catch (error) {
                console.error('Error deleting post:', error);
                alert('An error occurred while deleting the post');
                deleteBtn.disabled = false;
                deleteBtn.innerHTML = originalText;
            }
        });
    </script>
}
