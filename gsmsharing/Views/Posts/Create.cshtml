@using gsmsharing.ViewModels

@model CreatePostAndCommunityViewModel

@{
    ViewData["Title"] = "Create";
}
@section Resources {
    <link rel="stylesheet" href="~/css/CreatePostCss.css" asp-append-version="true" />
    <style>
        /* Additional CSS for the Publishing Options section */
        .publishing-options-section {
            margin-bottom: 25px;
        }

        .publishing-toggle {
            width: 100%;
            padding: 12px 16px;
            border-radius: 4px;
            background: var(--reddit-light-gray);
            border: 1px solid var(--reddit-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-weight: 500;
            color: var(--reddit-text);
            transition: all 0.2s;
        }

            .publishing-toggle:hover {
                background: white;
                border-color: var(--reddit-blue);
            }

            .publishing-toggle i {
                color: var(--reddit-blue);
            }

        .publishing-fields {
            background: var(--reddit-light-gray);
            border-radius: 4px;
            padding: 20px;
            margin-top: 10px;
            border: 1px solid var(--reddit-border);
        }

        .form-check-input:checked {
            background-color: var(--reddit-blue);
            border-color: var(--reddit-blue);
        }

        .form-check.form-switch .form-check-input {
            width: 2.5em;
            height: 1.3em;
        }

        /* Improved action buttons styling */
        .action-buttons {
            display: flex;
            gap: 15px;
            width: 100%;
            justify-content: flex-end;
        }

        .btn-draft, .btn-publish {
            min-width: 150px;
            height: 44px;
            border-radius: 4px;
            font-weight: 500;
            font-size: 15px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-draft {
            background: white;
            color: var(--reddit-blue);
            border: 1px solid var(--reddit-blue);
        }

            .btn-draft:hover {
                background: rgba(0, 121, 211, 0.08);
            }

        .btn-publish {
            background: var(--reddit-orange);
            color: white;
            border: none;
        }

            .btn-publish:hover {
                background: #e03d00;
            }</style>
}
<div class="container-fluid">
    <div class="row justify-content-center g-0">
        <div class="col-md-12">
            <div class="create-post-card">
                <div class="post-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0 fw-bold">Create Post</h5>
                    <div class="tab-buttons">
                        <button class="tab-btn active" data-bs-toggle="modal" data-bs-target="#textPostModal">
                            <i class="fas fa-file-alt"></i>
                            <span>Post</span>
                        </button>
                        <button class="tab-btn" data-bs-toggle="modal" data-bs-target="#imagePostModal">
                            <i class="fas fa-image"></i>
                            <span>Image</span>
                        </button>
                        <button class="tab-btn" data-bs-toggle="modal" data-bs-target="#linkPostModal">
                            <i class="fas fa-link"></i>
                            <span>Link</span>
                        </button>
                    </div>
                </div>

                <form asp-controller="Posts" asp-action="Create" method="post" enctype="multipart/form-data">
                    <div class="post-editor">
                        <div class="mb-4">
                            <div class="community-selector">
                                <select asp-for="Post.CommunityID" class="community-dropdown" required>
                                    <option value="">Choose a community</option>
                                    @foreach (var community in Model.Post.Communities)
                                    {
                                        <option value="@community.Value">
                                            @community.Text
                                        </option>
                                    }
                                </select>
                                <button type="submit" class="create-community-btn" data-bs-toggle="modal" data-bs-target="#createCommunityModal">
                                    <i class="fas fa-plus"></i>
                                    <span>Create New</span>
                                </button>
                            </div>
                        </div>

                        <div class="mb-4">
                            <input type="text" asp-for="Post.Title" class="form-control mb-3" placeholder="Title" style="font-size: 18px; font-weight: 500;">
                            <span asp-validation-for="Post.Title" class="text-danger"></span>

                            <textarea asp-for="Post.MetaDescription" class="form-control mb-3" rows="2" placeholder="Post Description"></textarea>
                            <span asp-validation-for="Post.MetaDescription" class="text-danger"></span>

                            <partial name="_Editor" />
                            <input type="hidden" asp-for="Post.Content" />
                            <span asp-validation-for="Post.Content" class="text-danger"></span>

                            <div class="mt-3">
                                <label class="form-label">Featured Image</label>
                                <input type="file" asp-for="Post.FeaturedImage" class="form-control" accept="image/*">
                            </div>

                            <div class="mt-3">
                                <img id="imagePreviewPost" class="image-preview" alt="Image preview" style="display: none;">
                            </div>

                            <div class="tag-input-container">
                                <div class="tags-container" id="tags-container"></div>
                                <label class="form-label">Tags</label>
                                <input type="text" id="tag-input-field" class="form-control mb-3"
                                       placeholder="Type and press space or enter to add tags"
                                       style="font-size: 18px; font-weight: 500;">
                                <input type="hidden" id="tags-hidden" asp-for="Post.Tags">
                                <span asp-validation-for="Post.Tags" class="text-danger"></span>
                            </div>
                        </div>

                        <button class="seo-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#seoFields" aria-expanded="false" aria-controls="seoFields">
                            <div class="d-flex align-items-center gap-2">
                                <i class="fas fa-cog"></i>
                                <span>SEO Configuration</span>
                            </div>
                            <i class="fas fa-chevron-down"></i>
                        </button>

                        <div class="collapse" id="seoFields">
                            <div class="seo-fields">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Meta Title</label>
                                        <input type="text" asp-for="Post.MetaTitle" class="form-control" placeholder="Enter meta title">
                                        <span asp-validation-for="Post.MetaTitle" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">OG Title</label>
                                        <input type="text" asp-for="Post.OgTitle" class="form-control" placeholder="Enter OG title">
                                        <span asp-validation-for="Post.OgTitle" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Meta Description</label>
                                        <textarea asp-for="Post.MetaDescription" class="form-control" rows="3" placeholder="Enter meta description"></textarea>
                                        <span asp-validation-for="Post.MetaDescription" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">OG Description</label>
                                        <textarea asp-for="Post.OgDescription" class="form-control" rows="3" placeholder="Enter OG description"></textarea>
                                        <span asp-validation-for="Post.OgDescription" class="text-danger"></span>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">URL Slug</label>
                                        <input asp-for="Post.Slug" type="text" class="form-control" placeholder="Enter URL slug">
                                        <span asp-validation-for="Post.Slug" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Publishing Options Section -->
                        <div class="publishing-options-section mt-4">
                            <button class="publishing-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#publishingFields" aria-expanded="true" aria-controls="publishingFields">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-sliders-h"></i>
                                    <span>Publishing Options</span>
                                </div>
                                <i class="fas fa-chevron-down"></i>
                            </button>

                            <div class="collapse show" id="publishingFields">
                                <div class="publishing-fields">
                                    <div class="row g-3">
                                        <div class="col-md-8">
                                            <div class="mb-3">
                                                <label class="form-label" for="postStatus">Post Status</label>
                                                <select asp-for="Post.PostStatus" class="form-select" id="postStatus">
                                                    <option value="Draft">Draft - Save now, publish later</option>
                                                    <option value="Published">Published - Make visible to everyone immediately</option>
                                                    <option value="Scheduled">Scheduled - Publish at a future date</option>
                                                    <option value="Private">Private - Visible only to you</option>
                                                </select>
                                            </div>

                                            <div class="form-check form-switch mb-3">
                                                <input asp-for="Post.AllowComments" class="form-check-input" id="allowComments">
                                                <label class="form-check-label" for="allowComments">
                                                    <i class="fas fa-comments me-2"></i>Allow comments on this post
                                                </label>
                                            </div>
                                        </div>

                                        <div class="col-md-4">
                                            <di v class="card-post bg-light">
                                                <div class="card-body">
                                                    <h6 class="card-title mb-3">Visibility Settings</h6>

                                                    <div class="form-check mb-3">
                                                        <input type="checkbox" class="form-check-input" asp-for="Post.IsPromoted" />
                                                        <label class="form-check-label" for="isPromoted">
                                                            <i class="fas fa-bullhorn me-2"></i>Promote this post
                                                        </label>
                                                        <small class="form-text text-muted d-block mt-1">Makes your post more visible on the platform</small>
                                                    </div>

                                                    <div class="form-check">
                                                        <input asp-for="Post.IsFeatured" type="checkbox" class="form-check-input" id="isFeatured" />
                                                        <label class="form-check-label" for="isFeatured">
                                                            <i class="fas fa-star me-2"></i>Feature this post
                                                        </label>
                                                        <small class="form-text text-muted d-block mt-1">Displays your post in featured sections</small>
                                                    </div>
                                                </div>
                                            </di>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="post-actions">
                        <div class="action-buttons">
                            <button type="submit" class="btn-draft" name="Post.PostStatus" value="Draft">
                                <i class="fas fa-save"></i>
                                <span>Save Draft</span>
                            </button>
                            <button type="submit" class="btn-publish" name="Post.PostStatus" value="Published" onclick="submitComment()">
                                <i class="fas fa-paper-plane"></i>
                                <span>Publish Now</span>
                            </button>
                        </div>
                    </div>

                    <!-- Image Post Modal -->
                    <div class="modal fade" id="imagePostModal" tabindex="-1" aria-labelledby="imagePostModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="imagePostModalLabel">Create Image Post</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label for="imageTitle" class="form-label">Title</label>
                                        <input type="text" asp-for="Post.Title" class="form-control" id="imageTitle" placeholder="Enter post title">
                                    </div>
                                    <div class="mb-3">
                                        <label for="imageUpload" class="form-label">Upload Image</label>
                                        <input type="file" asp-for="Post.FeaturedImage" class="form-control" id="imageUpload" accept="image/*">
                                    </div>
                                    <div class="mb-3">
                                        <label for="imageAltText" class="form-label">Alt Text</label>
                                        <input type="text" class="form-control" id="imageAltText" placeholder="Enter alt text for the image">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Image Preview</label>
                                        <img id="imagePreview" class="image-preview" alt="Image preview" style="display: none;">
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    <button type="button" class="btn btn-primary">Create Post</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Link Post Modal -->
                    <div class="modal fade" id="linkPostModal" tabindex="-1" aria-labelledby="linkPostModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="linkPostModalLabel">Create Link Post</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label for="linkTitle" class="form-label">Title</label>
                                        <input type="text" asp-for="Post.Title" class="form-control" id="linkTitle" placeholder="Enter post title">
                                    </div>
                                    <div class="mb-3">
                                        <label for="linkUrl" class="form-label">URL</label>
                                        <input type="url" class="form-control" id="linkUrl" placeholder="Enter link URL">
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    <button type="button" class="btn btn-primary">Create Post</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Create Community Modal -->
<partial name="_CommunityModel" model="@Model.Community" />

@section Scripts {
    <script>
         $(document).ready(function() {
            const inputField = $('#tag-input-field');
            const tagsContainer = $('#tags-container');
            const hiddenInput = $('#tags-hidden');
            let tags = [];

            // Function to render tags
            function renderTags() {
                tagsContainer.empty();
                tags.forEach(function(tag, index) {
                    const tagElement = $('<div class="tag"></div>').text(tag).css('min-height', '40px');;
                    const closeButton = $('<span class="tag-close">×</span>');

                    closeButton.on('click', function() {
                        tags.splice(index, 1);
                        renderTags();
                        updateHiddenInput();
                    });

                    tagElement.append(closeButton);
                    tagsContainer.append(tagElement);
                });
            }

            // Function to update the hidden input with comma-separated tags
            function updateHiddenInput() {
                hiddenInput.val(tags.join(','));
            }

            // Handle keydown events (Space and Enter)
            inputField.on('keydown', function(e) {
                if (e.keyCode === 13) { // Space or Enter
                    e.preventDefault();

                    const value = inputField.val().trim();
                    if (value && !tags.includes(value)) {
                        tags.push(value);
                        renderTags();
                        updateHiddenInput();
                        inputField.val('');
                    }
                }
            });

            // Initialize if there are existing tags
            if (hiddenInput.val()) {
                tags = hiddenInput.val().split(',').map(tag => tag.trim()).filter(tag => tag);
                renderTags();
            }

            // Handle form submission
            $('form').on('submit', function() {
                // One final update to ensure the hidden input has the latest tags
                updateHiddenInput();
                return true;
            });
        });


        document.addEventListener('DOMContentLoaded', function() {
            const tabButtons = document.querySelectorAll('.tab-btn');
            tabButtons.forEach(button => {
                button.addEventListener('click', function() {
                    tabButtons.forEach(btn => btn.classList.remove('active'));
                    this.classList.add('active');
                });
            });

            const imageUpload = document.getElementById('Post_FeaturedImage');
            const imagePreview = document.getElementById('imagePreviewPost');

            if (!imageUpload || !imagePreview) {
                console.error('Image upload or preview element not found!');
                return;
            }

            imageUpload.addEventListener('change', function(event) {
                const file = event.target.files[0];

                if (file) {
                    const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
                    if (!allowedTypes.includes(file.type)) {
                        alert('Only JPG, PNG, GIF, and WebP images are allowed.');
                        imageUpload.value = '';
                        return;
                    }

                    const maxSize = 2 * 1024 * 1024;
                    if (file.size > maxSize) {
                        alert('File size must be less than 2MB.');
                        imageUpload.value = '';
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = function(e) {
                        imagePreview.src = e.target.result;
                        imagePreview.style.display = 'block';
                    };
                    reader.readAsDataURL(file);
                }
            });
        });
    </script>
}