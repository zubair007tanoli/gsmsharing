<!-- Chat Widget -->
<div class="chat-widget" id="chatWidget">
    <div class="chat-widget-header" id="chatWidgetHeader">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <i class="fas fa-comments me-2"></i>
                <span class="fw-bold">Messages</span>
                <span class="badge bg-danger ms-2" id="chatWidgetBadge" style="display: none;">0</span>
            </div>
            <div class="chat-widget-actions">
                <button class="btn-icon" id="minimizeChatBtn" title="Minimize">
                    <i class="fas fa-minus"></i>
                </button>
                <button class="btn-icon" id="closeChatBtn" title="Close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="chat-widget-body" id="chatWidgetBody">
        <!-- Chat List View -->
        <div class="chat-list-view" id="chatListView">
            <div class="chat-search">
                <input type="text" class="form-control" placeholder="Search conversations..." id="chatSearchInput">
            </div>

            <div class="chat-conversations" id="chatConversations">
                <!-- Empty State -->
                <div class="chat-empty-state" id="chatEmptyState">
                    <i class="fas fa-comments fa-3x text-muted mb-3"></i>
                    <h5>No conversations yet</h5>
                    <p class="text-muted">Start chatting with community members!</p>
                    <button class="btn btn-primary btn-sm" onclick="showNewChatModal()">
                        <i class="fas fa-plus me-1"></i>New Chat
                    </button>
                </div>

                <!-- Sample Conversations (will be populated dynamically) -->
                <!-- 
                <div class="chat-conversation-item" onclick="openChat('user123')">
                    <img src="https://ui-avatars.com/api/?name=John+Doe&background=667eea&color=fff" alt="User" class="chat-avatar">
                    <div class="chat-conversation-info">
                        <div class="d-flex justify-content-between align-items-start">
                            <h6 class="mb-0">John Doe</h6>
                            <span class="chat-time">2m</span>
                        </div>
                        <p class="chat-last-message mb-0">Hey, can you help me with...</p>
                    </div>
                    <div class="chat-unread-badge">3</div>
                </div>
                -->
            </div>
        </div>

        <!-- Individual Chat View -->
        <div class="chat-conversation-view" id="chatConversationView" style="display: none;">
            <div class="chat-conversation-header">
                <button class="btn-icon me-2" onclick="backToConversations()">
                    <i class="fas fa-arrow-left"></i>
                </button>
                <img src="https://ui-avatars.com/api/?name=User&background=667eea&color=fff" alt="User" class="chat-avatar-sm" id="chatCurrentUserAvatar">
                <div class="flex-grow-1">
                    <h6 class="mb-0" id="chatCurrentUserName">User</h6>
                    <small class="text-success" id="chatCurrentUserStatus">
                        <i class="fas fa-circle" style="font-size: 0.5rem;"></i> Online
                    </small>
                </div>
            </div>

            <div class="chat-messages" id="chatMessages">
                <!-- Messages will be dynamically added here -->
            </div>

            <div class="chat-input-container">
                <button class="btn-icon" title="Attach file">
                    <i class="fas fa-paperclip"></i>
                </button>
                <input type="text" class="form-control chat-message-input" placeholder="Type a message..." id="chatMessageInput">
                <button class="btn-icon" title="Send emoji">
                    <i class="far fa-smile"></i>
                </button>
                <button class="btn btn-primary btn-sm" onclick="sendMessage()">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Floating Chat Button -->
<button class="chat-float-btn" id="chatFloatBtn" onclick="toggleChatWidget()">
    <i class="fas fa-comments"></i>
    <span class="chat-float-badge" id="chatFloatBadge" style="display: none;">0</span>
</button>

<style>
    /* Chat Widget */
    .chat-widget {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 380px;
        max-width: calc(100vw - 2rem);
        height: 500px;
        background: white;
        border-radius: 16px;
        box-shadow: 0 12px 48px rgba(0, 0, 0, 0.2);
        display: none;
        flex-direction: column;
        overflow: hidden;
        z-index: 1000;
        animation: slideUp 0.3s ease-out;
    }

    .chat-widget.show {
        display: flex;
    }

    .chat-widget.minimized {
        height: 60px;
    }

    .chat-widget.minimized .chat-widget-body {
        display: none;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .chat-widget-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1rem;
        cursor: pointer;
        user-select: none;
    }

    .chat-widget-actions {
        display: flex;
        gap: 0.5rem;
    }

    .btn-icon {
        background: rgba(255, 255, 255, 0.2);
        border: none;
        color: white;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-icon:hover {
        background: rgba(255, 255, 255, 0.3);
    }

    .chat-widget-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    /* Chat List */
    .chat-list-view {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .chat-search {
        padding: 1rem;
        border-bottom: 1px solid #e9ecef;
    }

    .chat-search input {
        border-radius: 50px;
        background: #f8f9fa;
        border: none;
        padding: 0.5rem 1rem;
    }

    .chat-conversations {
        flex: 1;
        overflow-y: auto;
    }

    .chat-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        padding: 2rem;
        text-align: center;
    }

    .chat-conversation-item {
        display: flex;
        align-items: center;
        padding: 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        border-bottom: 1px solid #f0f0f0;
        position: relative;
    }

    .chat-conversation-item:hover {
        background: #f8f9fa;
    }

    .chat-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        margin-right: 1rem;
        object-fit: cover;
    }

    .chat-avatar-sm {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        margin-right: 0.75rem;
        object-fit: cover;
    }

    .chat-conversation-info {
        flex: 1;
        overflow: hidden;
    }

    .chat-conversation-info h6 {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
    }

    .chat-last-message {
        font-size: 0.85rem;
        color: #6c757d;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chat-time {
        font-size: 0.75rem;
        color: #6c757d;
    }

    .chat-unread-badge {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 12px;
        padding: 0.2rem 0.5rem;
        font-size: 0.75rem;
        font-weight: 600;
        min-width: 20px;
        text-align: center;
    }

    /* Individual Chat */
    .chat-conversation-view {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .chat-conversation-header {
        display: flex;
        align-items: center;
        padding: 1rem;
        border-bottom: 1px solid #e9ecef;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .chat-message {
        max-width: 75%;
        display: flex;
        flex-direction: column;
    }

    .chat-message.sent {
        align-self: flex-end;
        align-items: flex-end;
    }

    .chat-message.received {
        align-self: flex-start;
        align-items: flex-start;
    }

    .chat-message-bubble {
        padding: 0.75rem 1rem;
        border-radius: 16px;
        word-wrap: break-word;
    }

    .chat-message.sent .chat-message-bubble {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-bottom-right-radius: 4px;
    }

    .chat-message.received .chat-message-bubble {
        background: #f0f0f0;
        color: #1a1a2e;
        border-bottom-left-radius: 4px;
    }

    .chat-message-time {
        font-size: 0.7rem;
        color: #6c757d;
        margin-top: 0.25rem;
    }

    .chat-input-container {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 1rem;
        border-top: 1px solid #e9ecef;
        background: #f8f9fa;
    }

    .chat-message-input {
        flex: 1;
        border-radius: 50px;
        border: 1px solid #e9ecef;
        padding: 0.5rem 1rem;
        background: white;
    }

    /* Floating Chat Button */
    .chat-float-btn {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        box-shadow: 0 8px 24px rgba(102, 126, 234, 0.4);
        font-size: 1.5rem;
        cursor: pointer;
        transition: all 0.3s ease;
        z-index: 999;
        position: relative;
    }

    .chat-float-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 12px 32px rgba(102, 126, 234, 0.6);
    }

    .chat-float-badge {
        position: absolute;
        top: -5px;
        right: -5px;
        min-width: 22px;
        height: 22px;
        background: #f5576c;
        color: white;
        border-radius: 11px;
        font-size: 0.75rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid white;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    /* Mobile Responsive */
    @@media (max-width: 576px) {
        .chat-widget {
            width: 100%;
            height: 100%;
            bottom: 0;
            right: 0;
            border-radius: 0;
        }

        .chat-float-btn {
            bottom: 1rem;
            right: 1rem;
        }
    }
</style>

<script>
    // Chat Widget Functions
    function toggleChatWidget() {
        const widget = document.getElementById('chatWidget');
        const floatBtn = document.getElementById('chatFloatBtn');
        
        if (widget.classList.contains('show')) {
            widget.classList.remove('show');
            floatBtn.style.display = 'flex';
        } else {
            widget.classList.add('show');
            floatBtn.style.display = 'none';
            loadConversations();
        }
    }

    document.getElementById('minimizeChatBtn')?.addEventListener('click', function(e) {
        e.stopPropagation();
        document.getElementById('chatWidget').classList.toggle('minimized');
    });

    document.getElementById('closeChatBtn')?.addEventListener('click', function(e) {
        e.stopPropagation();
        toggleChatWidget();
    });

    document.getElementById('chatNavLink')?.addEventListener('click', function(e) {
        e.preventDefault();
        toggleChatWidget();
    });

    function loadConversations() {
        // TODO: Fetch conversations from API
        // For now, show empty state
        console.log('Loading conversations...');
    }

    function openChat(userId) {
        document.getElementById('chatListView').style.display = 'none';
        document.getElementById('chatConversationView').style.display = 'flex';
        // TODO: Load chat messages
    }

    function backToConversations() {
        document.getElementById('chatListView').style.display = 'flex';
        document.getElementById('chatConversationView').style.display = 'none';
    }

    function sendMessage() {
        const input = document.getElementById('chatMessageInput');
        const message = input.value.trim();
        
        if (message) {
            // Add message to UI
            addMessageToUI(message, true);
            input.value = '';
            
            // TODO: Send to server via SignalR
            console.log('Sending message:', message);
        }
    }

    function addMessageToUI(text, isSent) {
        const messagesContainer = document.getElementById('chatMessages');
        const messageDiv = document.createElement('div');
        messageDiv.className = `chat-message ${isSent ? 'sent' : 'received'}`;
        
        const now = new Date();
        const time = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        
        messageDiv.innerHTML = `
            <div class="chat-message-bubble">${text}</div>
            <div class="chat-message-time">${time}</div>
        `;
        
        messagesContainer.appendChild(messageDiv);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function showNewChatModal() {
        alert('New chat feature coming soon! This will allow you to start a conversation with any community member.');
    }

    // Enter key to send message
    document.getElementById('chatMessageInput')?.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            sendMessage();
        }
    });

    // Update badge count (demo)
    function updateChatBadge(count) {
        const badges = ['chatBadge', 'chatFloatBadge', 'chatWidgetBadge'];
        badges.forEach(id => {
            const badge = document.getElementById(id);
            if (badge) {
                if (count > 0) {
                    badge.textContent = count;
                    badge.style.display = 'flex';
                } else {
                    badge.style.display = 'none';
                }
            }
        });
    }

    // Demo: Simulate new message
    setTimeout(() => {
        updateChatBadge(3);
    }, 5000);
</script>

