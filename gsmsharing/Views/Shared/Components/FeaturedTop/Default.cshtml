<style>
    .featured-post {
        height: 400px;
    }

    .side-post {
        height: 120px;
        margin-bottom: 20px;
    }

    .bottom-post {
        height: 200px;
    }

    .post {
        background-size: cover;
        background-position: center;
        border-radius: 10px;
        position: relative;
        overflow: hidden;
    }

    .post-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 20px;
        background: linear-gradient(to top, rgba(0,0,0,0.8), rgba(0,0,0,0));
        color: white;
    }

    .post-title {
        font-weight: bold;
        margin-bottom: 5px;
    }

    .post-excerpt {
        font-size: 0.9em;
        margin-bottom: 5px;
    }

    .post-meta {
        font-size: 0.8em;
        opacity: 0.8;
    }
    /* News Ticker Styles */
    .news-ticker {
        background-color: #f8f9fa;
        overflow: hidden;
        padding: 10px 0;
        white-space: nowrap;
        position: relative;
    }

    .news-ticker-content {
        display: inline-block;
        padding-left: 100%;
        animation: ticker 30s linear infinite;
    }

    .news-ticker-item {
        display: inline-block;
        padding: 0 2rem;
    }
    @@keyframes ticker {
        0%{
        transform: translate3d(0, 0, 0);
    }
    100% {
        transform: translate3d(-100%, 0, 0);
    }

    }
</style>
<div class="news-ticker">
    <div class="news-ticker-content">
        <span class="news-ticker-item"><i class="fas fa-newspaper"></i> Breaking News: Major tech company announces new AI breakthrough</span>
        <span class="news-ticker-item"><i class="fas fa-globe"></i> Global climate summit to be held next month</span>
        <span class="news-ticker-item"><i class="fas fa-virus"></i> Health officials report decline in COVID-19 cases</span>
        <span class="news-ticker-item"><i class="fas fa-rocket"></i> SpaceX successfully launches another batch of satellites</span>
        <span class="news-ticker-item"><i class="fas fa-landmark"></i> New legislation aims to boost small businesses</span>
    </div>
</div>

