<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GSM Sharing Admin</title>
    <script type="importmap"></script>
    <!-- Bootstrap 5.x CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Chart.js -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.css">
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

    @* Resources *@
    <link rel="stylesheet" href="~/css/GsmMainStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Customs.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    
    @RenderSection("Resources", required: false)
    @RenderSection("customStyle", required: false)
    @* Favicon *@
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="~/apple-touch-icon.png">
    
</head>
<body class="admin-body">
    <div class="admin-wrapper">
        <!-- Admin Sidebar -->
        <aside class="admin-sidebar">
            <div class="admin-sidebar-header">
                <a href="/Admin" class="admin-logo">
                    <i class="fas fa-share-alt"></i>
                    <span>GSM Admin</span>
                </a>
                <button class="btn sidebar-toggle d-lg-none" id="sidebarToggle">
                    <i class="fas fa-bars"></i>
                </button>
            </div>

            <div class="admin-sidebar-content">
                <div class="admin-user-info">
                    <div class="admin-user-avatar">
                        <img src="/placeholder.svg?height=40&width=40" alt="Admin" class="rounded-circle">
                    </div>
                    <div class="admin-user-details">
                        <h6 class="mb-0">Admin User</h6>
                        <small class="text-muted">Administrator</small>
                    </div>
                </div>

                <nav class="admin-nav">
                    <div class="admin-nav-section">
                        <h6 class="admin-nav-title">Dashboard</h6>
                        <ul class="admin-nav-list">
                            <li class="admin-nav-item">
                                <a href="/Admin" class="admin-nav-link active">
                                    <i class="fas fa-tachometer-alt"></i>
                                    <span>Overview</span>
                                </a>
                            </li>
                            <li class="admin-nav-item">
                                <a href="/Admin/Analytics" class="admin-nav-link">
                                    <i class="fas fa-chart-line"></i>
                                    <span>Analytics</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="admin-nav-section">
                        <h6 class="admin-nav-title">User Management</h6>
                        <ul class="admin-nav-list">
                            <li class="admin-nav-item">
                                <a href="/Admin/Users" class="admin-nav-link">
                                    <i class="fas fa-users"></i>
                                    <span>Users</span>
                                </a>
                            </li>
                            <li class="admin-nav-item">
                                <a href="/Admin/Roles" class="admin-nav-link">
                                    <i class="fas fa-user-tag"></i>
                                    <span>Roles</span>
                                </a>
                            </li>
                            <li class="admin-nav-item">
                                <a href="/Admin/UserProfiles" class="admin-nav-link">
                                    <i class="fas fa-id-card"></i>
                                    <span>User Profiles</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="admin-nav-section">
                        <h6 class="admin-nav-title">Content Management</h6>
                        <ul class="admin-nav-list">
                            <li class="admin-nav-item">
                                <a href="/Admin/Categories" class="admin-nav-link">
                                    <i class="fas fa-folder"></i>
                                    <span>Categories</span>
                                </a>
                            </li>
                            <li class="admin-nav-item">
                                <a href="/Admin/Communities" class="admin-nav-link">
                                    <i class="fas fa-users-cog"></i>
                                    <span>Communities</span>
                                </a>
                            </li>
                            <li class="admin-nav-item">
                                <a href="/Admin/Posts" class="admin-nav-link">
                                    <i class="fas fa-file-alt"></i>
                                    <span>Posts</span>
                                </a>
                            </li>
                            <li class="admin-nav-item">
                                <a href="/Admin/Comments" class="admin-nav-link">
                                    <i class="fas fa-comments"></i>
                                    <span>Comments</span>
                                </a>
                            </li>
                            <li class="admin-nav-item">
                                <a href="/Admin/Reactions" class="admin-nav-link">
                                    <i class="fas fa-thumbs-up"></i>
                                    <span>Reactions</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="admin-nav-section">
                        <h6 class="admin-nav-title">Communication</h6>
                        <ul class="admin-nav-list">
                            <li class="admin-nav-item">
                                <a href="/Admin/ChatRooms" class="admin-nav-link">
                                    <i class="fas fa-comments-dollar"></i>
                                    <span>Chat Rooms</span>
                                </a>
                            </li>
                            <li class="admin-nav-item">
                                <a href="/Admin/ChatMessages" class="admin-nav-link">
                                    <i class="fas fa-comment-dots"></i>
                                    <span>Chat Messages</span>
                                </a>
                            </li>
                            <li class="admin-nav-item">
                                <a href="/Admin/Notifications" class="admin-nav-link">
                                    <i class="fas fa-bell"></i>
                                    <span>Notifications</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="admin-nav-section">
                        <h6 class="admin-nav-title">System</h6>
                        <ul class="admin-nav-list">
                            <li class="admin-nav-item">
                                <a href="/Admin/Settings" class="admin-nav-link">
                                    <i class="fas fa-cog"></i>
                                    <span>Settings</span>
                                </a>
                            </li>
                            <li class="admin-nav-item">
                                <a href="/Admin/Logs" class="admin-nav-link">
                                    <i class="fas fa-clipboard-list"></i>
                                    <span>Logs</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </nav>
            </div>

            <div class="admin-sidebar-footer">
                <a href="/" class="btn btn-outline-light btn-sm">
                    <i class="fas fa-external-link-alt"></i>
                    <span>View Site</span>
                </a>
                <form method="post" action="/Account/Logout" class="d-inline">
                    <button type="submit" class="btn btn-danger btn-sm">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- Main Content Wrapper -->
        <div class="admin-content-wrapper">
            <!-- Admin Header -->
            <header class="admin-header">
                <div class="admin-header-left">
                    <button class="btn sidebar-toggle d-none d-lg-block" id="sidebarToggleLg">
                        <i class="fas fa-bars"></i>
                    </button>
                    <div class="admin-breadcrumb">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item"><a href="/Admin">Dashboard</a></li>
                                @if (ViewData["BreadcrumbSection"] != null)
                                {
                                    <li class="breadcrumb-item">@ViewData["BreadcrumbSection"]</li>
                                }
                                @if (ViewData["BreadcrumbPage"] != null)
                                {
                                    <li class="breadcrumb-item active" aria-current="page">@ViewData["BreadcrumbPage"]</li>
                                }
                            </ol>
                        </nav>
                    </div>
                </div>

                <div class="admin-header-right">
                    <div class="admin-search">
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">
                                <i class="fas fa-search"></i>
                            </span>
                            <input type="text" class="form-control border-0 bg-light" placeholder="Search...">
                        </div>
                    </div>

                    <div class="admin-actions">
                        <div class="dropdown">
                            <button class="btn btn-light position-relative" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-bell"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    3
                                </span>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end notification-dropdown">
                                <div class="notification-header">
                                    <h6 class="mb-0">Notifications</h6>
                                    <a href="#" class="text-muted small">Mark all as read</a>
                                </div>
                                <div class="notification-list">
                                    <a href="#" class="dropdown-item notification-item">
                                        <div class="notification-icon bg-primary text-white">
                                            <i class="fas fa-user-plus"></i>
                                        </div>
                                        <div class="notification-content">
                                            <p class="mb-0">New user registered</p>
                                            <small class="text-muted">5 minutes ago</small>
                                        </div>
                                    </a>
                                    <a href="#" class="dropdown-item notification-item">
                                        <div class="notification-icon bg-warning text-white">
                                            <i class="fas fa-exclamation-triangle"></i>
                                        </div>
                                        <div class="notification-content">
                                            <p class="mb-0">Report generated</p>
                                            <small class="text-muted">2 hours ago</small>
                                        </div>
                                    </a>
                                    <a href="#" class="dropdown-item notification-item">
                                        <div class="notification-icon bg-success text-white">
                                            <i class="fas fa-check-circle"></i>
                                        </div>
                                        <div class="notification-content">
                                            <p class="mb-0">Task completed</p>
                                            <small class="text-muted">Yesterday</small>
                                        </div>
                                    </a>
                                </div>
                                <div class="notification-footer">
                                    <a href="/Admin/Notifications" class="btn btn-sm btn-primary w-100">View All</a>
                                </div>
                            </div>
                        </div>

                        <div class="dropdown">
                            <button class="btn btn-light" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-cog"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end">
                                <a class="dropdown-item" href="/Admin/Settings">
                                    <i class="fas fa-cog me-2"></i> Settings
                                </a>
                                <a class="dropdown-item" href="/Admin/Profile">
                                    <i class="fas fa-user me-2"></i> Profile
                                </a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="/Admin/Help">
                                    <i class="fas fa-question-circle me-2"></i> Help
                                </a>
                            </div>
                        </div>

                        <div class="dropdown">
                            <button class="btn admin-user-dropdown" type="button" data-bs-toggle="dropdown">
                                <img src="/placeholder.svg?height=32&width=32" alt="Admin" class="rounded-circle">
                                <span class="d-none d-md-inline-block ms-2">Admin User</span>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end">
                                <div class="dropdown-item-text">
                                    <div class="d-flex align-items-center">
                                        <img src="/placeholder.svg?height=48&width=48" alt="Admin" class="rounded-circle me-3">
                                        <div>
                                            <h6 class="mb-0">Admin User</h6>
                                            <small class="text-muted">admin@example.com</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="/Admin/Profile">
                                    <i class="fas fa-user me-2"></i> My Profile
                                </a>
                                <a class="dropdown-item" href="/Admin/Settings">
                                    <i class="fas fa-cog me-2"></i> Account Settings
                                </a>
                                <div class="dropdown-divider"></div>
                                <form method="post" action="/Account/Logout">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="fas fa-sign-out-alt me-2"></i> Logout
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Main Content Area -->
            <main class="admin-main">
                <div class="container-fluid p-4">
                    @RenderBody()
                </div>
            </main>

            <!-- Admin Footer -->
            <footer class="admin-footer">
                <div class="container-fluid">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            &copy; 2025 - GSM Sharing Admin Panel
                        </div>
                        <div>
                            <a href="/Admin/Privacy" class="text-muted me-3">Privacy</a>
                            <a href="/Admin/Terms" class="text-muted">Terms</a>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <!-- Select2 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-beta.1/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-beta.1/js/select2.min.js"></script>

    <script>
        $(document).ready(function() {
            // Initialize Select2
            $('.select2').select2();

            // Initialize DataTables
            $('.datatable').DataTable({
                responsive: true
            });

            // Sidebar Toggle
            $('#sidebarToggle, #sidebarToggleLg').on('click', function() {
                $('.admin-wrapper').toggleClass('sidebar-collapsed');
            });

            // Mobile sidebar close on menu item click
            $('.admin-nav-link').on('click', function() {
                if ($(window).width() < 992) {
                    $('.admin-wrapper').removeClass('sidebar-collapsed');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>