@using System.Security.Claims
<!-- Navbar -->
<nav class="navbar navbar-expand-lg sticky-top">
    <div class="container">
        <!-- Logo -->
        <a class="navbar-brand" href="/">
            <i class="fas fa-mobile-alt"></i>
            <span>GSMSharing</span>
        </a>

        <!-- Mobile Toggle -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
            <i class="fas fa-bars"></i>
        </button>

        <!-- Main Content -->
        <div class="collapse navbar-collapse" id="navbarContent">
            <!-- Navigation Links -->
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" href="/dashboard">
                        <i class="fas fa-home"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/tools">
                        <i class="fas fa-tools"></i>
                        <span>Tools</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/community">
                        <i class="fas fa-users"></i>
                        <span>Community</span>
                    </a>
                </li>
            </ul>

            <!-- Search Bar -->
            <div class="search-container">
                <i class="fas fa-search search-icon"></i>
                <input type="search" class="form-control search-input" placeholder="Search GSM solutions...">
            </div>

            <!-- Share Button -->
            <a href="/posts/create" class="btn share-btn">
                <i class="fas fa-plus"></i>
                <span>Share Solution</span>
            </a>

            <!-- User Actions -->
            <div class="user-actions">
                <!-- Notifications -->
                <div class="dropdown">
                    <button class="notification-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-bell"></i>
                        <span class="notification-badge">3</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end Nav_Dropdown" data-bs-popper="none">
                        <div class="d-flex justify-content-between align-items-center p-2">
                            <h6 class="mb-0">Notifications</h6>
                            <button class="btn btn-link btn-sm p-0 text-decoration-none">Mark all as read</button>
                        </div>
                        <div class="dropdown-divider"></div>
                        <a href="#" class="dropdown-item">
                            <img src="https://via.placeholder.com/32" alt="User" class="avatar">
                            <div>
                                <p class="mb-0"><strong>GSM Expert</strong> replied to your post</p>
                                <small class="text-muted">2 minutes ago</small>
                            </div>
                        </a>
                    </div>
                </div>

                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-action="Login" asp-controller="UserAccounts" class="btn user-btn" type="button" aria-expanded="false">
                        <span class="d-none d-lg-inline">Login</span>
                    </a>

                    <a asp-action="Register" asp-controller="UserAccounts" class="btn user-btn" type="button" aria-expanded="false">
                        <span class="d-none d-lg-inline">Register</span>
                    </a>
                }
                else
                {

                    var email = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Email)?.Value;
                    var firstName = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Name)?.Value;

                    <!-- User Profile -->
                    <div class="dropdown">
                        <button class="user-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="https://via.placeholder.com/32" alt="Profile" class="avatar">
                            <span class="d-none d-lg-inline">@firstName</span>
                            <i class="fas fa-chevron-down"></i>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end Nav_Dropdown">
                            <a class="dropdown-item" href="/UserAccount/Profile">
                                <i class="fas fa-user"></i>Profile
                            </a>
                            <a class="dropdown-item" href="/settings">
                                <i class="fas fa-cog"></i>Settings
                            </a>
                            <div class="dropdown-divider"></div>
                            <a asp-action="Logout" asp-controller="UserAccounts" class="dropdown-item">
                                <i class="fas fa-sign-out-alt"></i>Logout
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</nav>