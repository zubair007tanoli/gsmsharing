@model ErrorViewModel
@{
    var statusCode = Model?.StatusCode ?? 500;
    var errorMessage = Model?.ErrorMessage ?? "An error occurred while processing your request.";
    var requestId = Model?.RequestId;
    ViewData["Title"] = $"Error {statusCode}";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="error-template">
                <h1 class="display-1 text-danger">
                    @if (statusCode == 404)
                    {
                        <i class="fas fa-exclamation-triangle"></i>
                        @:404
                    }
                    else if (statusCode == 403)
                    {
                        <i class="fas fa-lock"></i>
                        @:403
                    }
                    else if (statusCode == 401)
                    {
                        <i class="fas fa-user-lock"></i>
                        @:401
                    }
                    else if (statusCode == 500)
                    {
                        <i class="fas fa-server"></i>
                        @:500
                    }
                    else
                    {
                        <i class="fas fa-exclamation-circle"></i>
                        @:Error
                    }
                </h1>
                
                <h2 class="mb-4">@errorMessage</h2>
                
                <div class="error-details mb-4">
                    <p class="text-muted">
                        @if (statusCode == 404)
                        {
                            @:The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
                        }
                        else if (statusCode == 403)
                        {
                            @:You don't have permission to access this resource. Please contact the administrator if you believe this is an error.
                        }
                        else if (statusCode == 401)
                        {
                            @:Please log in to access this resource.
                        }
                        else if (statusCode == 500)
                        {
                            @:We're sorry, but something went wrong on our end. Our team has been notified and is working to fix the issue.
                        }
                        else
                        {
                            @:We're sorry, but something unexpected happened. Please try again later.
                        }
                    </p>
                </div>

                @if (!string.IsNullOrEmpty(requestId))
                {
                    <div class="alert alert-info">
                        <strong>Request ID:</strong> <code>@requestId</code>
                        <br />
                        <small class="text-muted">Please reference this ID when contacting support.</small>
                    </div>
                }

                <div class="error-actions mt-4">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg">
                        <i class="fas fa-home"></i> Go to Homepage
                    </a>
                    
                    @if (statusCode == 401)
                    {
                        <a href="@Url.Action("Login", "UserAccounts")" class="btn btn-success btn-lg">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    }
                    
                    <a href="javascript:history.back()" class="btn btn-secondary btn-lg">
                        <i class="fas fa-arrow-left"></i> Go Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .error-template {
        padding: 40px 15px;
    }
    .error-actions {
        margin-top: 15px;
        margin-bottom: 15px;
    }
    .error-actions .btn {
        margin-right: 10px;
    }
</style>
