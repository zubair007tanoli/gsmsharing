<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - gsmsharing</title>
    <meta name="monetag" content="30676d5e8900908d4f346e12d291fbb6">
    <script type="importmap"></script>
    <!-- Bootstrap 5.x CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    @* Resources *@
    <link rel="stylesheet" href="~/css/GsmMainStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Customs.css" asp-append-version="true" />
 
    @RenderSection("Resources", required: false)
    @RenderSection("customStyle", required: false)
    @* Favicon *@
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="~/apple-touch-icon.png">
</head>
<body>
    <partial name="_Header.cshtml" />

    @* @await Component.InvokeAsync("FeaturedTop") *@
    <!-- Main Content -->
    <div class="container-fluid py-2 mt-2">
      
        <div class="row g-4">
            <!-- Left Sidebar -->
            <div class="col-lg-3 d-none d-lg-block">
                <!-- Quick Actions -->
                <div class="card mb-4">
                    <div class="card-body">
                        <h6 class="card-title mb-3">Quick Actions</h6>
                        <div class="d-grid gap-2">
                            <a href="/Posts/Create" class="btn btn-primary btn-sm">
                                <i class="fas fa-plus me-2"></i>Create Post
                            </a>
                            <a href="/Forum/Create" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-comments me-2"></i>Start Thread
                            </a>
                            <a href="/Marketplace/Create" class="btn btn-outline-success btn-sm">
                                <i class="fas fa-store me-2"></i>Sell Item
                            </a>
                            <a href="/Blog/Create" class="btn btn-outline-info btn-sm">
                                <i class="fas fa-blog me-2"></i>Write Blog
                            </a>
                            <a href="/Code/Create" class="btn btn-outline-warning btn-sm">
                                <i class="fas fa-code me-2"></i>Share Code
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Categories -->
                @await Component.InvokeAsync("LayoutSideCategoryCout")
               
            </div>

            <!-- Main Content Column -->
            <div class="col-lg-9">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>

            </div>

            <!-- Right Sidebar -->
            <div class="col-lg-3 d-none d-lg-block">
                <!-- Community Stats -->
                <div class="card mb-4">
                    <div class="card-body">
                        <h6 class="card-title">Community Stats</h6>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Online Users</span>
                            <strong>1,247</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>New Posts Today</span>
                            <strong>458</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Total Threads</span>
                            <strong>45.2k</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>Active Listings</span>
                            <strong>8.9k</strong>
                        </div>
                    </div>
                </div>

                <!-- Top Communities -->
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title">Top Communities</h6>
                        <div class="list-group list-group-flush">
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="fas fa-circle me-2 text-success"></i>
                                <span>iPhone Repairs</span>
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="fas fa-circle me-2 text-primary"></i>
                                <span>Samsung Solutions</span>
                            </a>
                            <a href="#" class="list-group-item list-group-item-action">
                                <i class="fas fa-circle me-2 text-warning"></i>
                                <span>Android Guides</span>
                            </a>
                            <a href="/Community" class="list-group-item list-group-item-action text-center">
                                View All <i class="fas fa-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - gsmsharing - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <!-- Then load Select2 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-beta.1/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-beta.1/js/select2.min.js"></script>
    <script>
                $(document).ready(function() {
            $('.category-select').select2({
                placeholder: 'Search categories and subcategories...',
                allowClear: true,
                width: '100%',
                templateResult: formatCategory,
                templateSelection: formatCategory,
                escapeMarkup: function(markup) {
                    return markup;
                }
            }).on('select2:select', function(e) {
                window.location.href = e.params.data.id;
            });
        });

        function formatCategory(category) {
            if (!category.id || !category.element) {
                return category.text;
            }

            var icon = $(category.element).data('icon') || 'fas fa-folder';
            var count = $(category.element).data('count');
            var isOptgroup = $(category.element).parent().is('optgroup');

            var $container = $('<div class="select2-category-option"></div>');
            var $icon = $('<i class="' + icon + '"></i>');
            var $text = $('<span class="category-option-text">' + category.text + '</span>');
            var $count = count ? $('<span class="category-option-count">' + count.toLocaleString() + '</span>') : '';

            if (isOptgroup) {
                $container.addClass('select2-subcategory-option');
                $icon.addClass('subcategory-icon');
            }

            return $container.append($icon).append($text).append($count);
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
