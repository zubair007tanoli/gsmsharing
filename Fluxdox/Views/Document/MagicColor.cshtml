@{
    ViewData["Title"] = "Magic Color Enhancement";
}

<h1 class="mb-4">@ViewData["Title"]</h1>
<p class="lead">Enhance photos of documents (e.g., lecture notes) by removing shadows and whitening backgrounds for cleaner results.</p>

<div class="alert alert-primary" role="alert">
    <strong>"Student Sam" persona focus:</strong> Ideal for quickly digitalizing lecture notes or whiteboard photos.
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-controller="Document" asp-action="UploadForMagicColor" method="post" enctype="multipart/form-data"
      hx-post="@Url.Action("UploadForMagicColor", "Document")" hx-target="#processingStatus" hx-swap="outerHTML" hx-encoding="multipart/form-data">
    <div class="mb-3">
        <label for="imageFile" class="form-label visually-hidden">Upload Image File</label>
        <div id="magicColorDropArea" class="file-drop-area mb-3">
            <i class="fas fa-palette icon-large"></i>
            <p class="drop-text">Drag and drop your document photo here, or click to browse</p>
            <input type="file" id="imageFile" name="file" class="form-control d-none" accept=".jpg,.jpeg,.png,.heic"
                   hx-indicator="#magicColorDropArea">
        </div>
    </div>

    <div class="d-grid gap-2 mb-4">
        <button type="submit" class="btn btn-primary btn-lg">
            <i class="fas fa-magic me-2"></i> Apply Magic Color
        </button>
    </div>
</form>

<div id="processingStatus" class="mt-4">
    <div class="card d-none htmx-indicator">
        <div class="card-body">
            <h5 class="card-title">Processing... <i class="fas fa-spinner fa-spin"></i></h5>
            <p class="mt-2">Applying magic color enhancement to your image.</p>
        </div>
    </div>
</div>

<h2 class="mt-5">Your Enhanced Images</h2>
<div class="row" id="enhancedResults">
    <div class="col-12">
        <p class="text-muted">No enhanced images yet. Upload a photo of a document to get started!</p>
    </div>
</div>