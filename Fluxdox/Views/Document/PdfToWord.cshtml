@{
    ViewData["Title"] = "High-Fidelity PDF to Word";
}

<h1 class="mb-4">@ViewData["Title"]</h1>
<p class="lead">Convert your PDF documents into editable .docx files, preserving layout using our hybrid engine.</p>

<div class="alert alert-info" role="alert">
    <strong>Note:</strong> Complex layouts may require significant processing time to ensure high fidelity.
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-controller="Document" asp-action="UploadForPdfToWord" method="post" enctype="multipart/form-data"
      hx-post="@Url.Action("UploadForPdfToWord", "Document")" hx-target="#processingStatus" hx-swap="outerHTML" hx-encoding="multipart/form-data">
    <div class="mb-3">
        <label for="pdfFile" class="form-label visually-hidden">Upload PDF File</label>
        <div id="pdfDropArea" class="file-drop-area mb-3">
            <i class="fas fa-file-pdf icon-large"></i>
            <p class="drop-text">Drag and drop your PDF file here, or click to browse</p>
            <input type="file" id="pdfFile" name="file" class="form-control d-none" accept=".pdf"
                   hx-indicator="#pdfDropArea">
        </div>
    </div>

    <div class="d-grid gap-2 mb-4">
        <button type="submit" class="btn btn-primary btn-lg">
            <i class="fas fa-file-word me-2"></i> Convert to Word
        </button>
    </div>
</form>

<div id="processingStatus" class="mt-4">
    <div class="card d-none htmx-indicator">
        <div class="card-body">
            <h5 class="card-title">Processing... <i class="fas fa-spinner fa-spin"></i></h5>
            <p class="mt-2">Your PDF is being converted into a Word document.</p>
        </div>
    </div>
</div>

<h2 class="mt-5">Your Converted Word Documents</h2>
<div class="row" id="convertedResults">
    <div class="col-12">
        <p class="text-muted">No converted Word documents yet. Upload a PDF to get started!</p>
    </div>
</div>