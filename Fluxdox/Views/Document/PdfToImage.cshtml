@{
    ViewData["Title"] = "PDF to Images";
}

<h1 class="mb-4">@ViewData["Title"]</h1>
<p class="lead">Extract PDF pages as individual image files (JPG/PNG). Selectable DPI for screen or print quality.</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-controller="Document" asp-action="UploadForPdfToImage" method="post" enctype="multipart/form-data"
      hx-post="@Url.Action("UploadForPdfToImage", "Document")" hx-target="#processingStatus" hx-swap="outerHTML" hx-encoding="multipart/form-data">
    <div class="mb-3">
        <label for="pdfFile" class="form-label visually-hidden">Upload PDF File</label>
        <div id="pdfDropArea" class="file-drop-area mb-3">
            <i class="fas fa-file-pdf icon-large"></i>
            <p class="drop-text">Drag and drop your PDF file here, or click to browse</p>
            <input type="file" id="pdfFile" name="file" class="form-control d-none" accept=".pdf"
                   hx-indicator="#pdfDropArea">
        </div>
    </div>

    <div class="mb-3">
        <label for="outputFormat" class="form-label">Output Format</label>
        <select class="form-select" id="outputFormat" name="outputFormat">
            <option value="JPG" selected>JPG</option>
            <option value="PNG">PNG</option>
        </select>
    </div>

    <div class="mb-3">
        <label for="dpi" class="form-label">DPI (Dots Per Inch)</label>
        <select class="form-select" id="dpi" name="dpi">
            <option value="72">72 DPI (Screen quality)</option>
            <option value="150">150 DPI (Balanced)</option>
            <option value="300" selected>300 DPI (Print quality)</option>
            <option value="600">600 DPI (High resolution)</option>
        </select>
        <small class="text-muted">Higher DPI results in larger, higher quality images.</small>
    </div>

    <div class="d-grid gap-2 mb-4">
        <button type="submit" class="btn btn-primary btn-lg">
            <i class="fas fa-file-image me-2"></i> Extract Images
        </button>
    </div>
</form>

<div id="processingStatus" class="mt-4">
    <div class="card d-none htmx-indicator">
        <div class="card-body">
            <h5 class="card-title">Processing... <i class="fas fa-spinner fa-spin"></i></h5>
            <p class="mt-2">Your PDF is being converted into images.</p>
        </div>
    </div>
</div>

<h2 class="mt-5">Your Extracted Images</h2>
<div class="row" id="extractedResults">
    <div class="col-12">
        <p class="text-muted">No extracted images yet. Upload a PDF to get started!</p>
    </div>
</div>