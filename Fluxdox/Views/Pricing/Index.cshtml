@{
    ViewData["Title"] = "FluxDoc Pricing Plans";
}

<h1 class="mb-4 text-center">Flexible Plans for Every Need</h1>
<p class="lead text-center mb-5">Choose the FluxDoc plan that best suits your document processing requirements.</p>

<div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
    <div class="col">
        <div class="pricing-card card h-100">
            <div class="card-header text-center py-3">
                <h4 class="my-0 fw-normal">Guest</h4>
            </div>
            <div class="card-body">
                <h1 class="card-title pricing-card-title text-center">$0<small class="text-muted fw-light">/month</small></h1>
                <ul class="list-unstyled mt-3 mb-4">
                    <li><i class="fas fa-clipboard-list text-success me-2"></i> 2 tasks / day</li>
                    <li><i class="fas fa-hdd text-success me-2"></i> 50MB file limit</li>
                    <li><i class="fas fa-hourglass-half text-danger me-2"></i> 1-hour retention</li>
                    <li><i class="fas fa-check text-success me-2"></i> Basic PDF Merge</li>
                    <li><i class="fas fa-times text-danger me-2"></i> No "Vault" storage</li>
                    <li><i class="fas fa-times text-danger me-2"></i> Limited OCR priority</li>
                </ul>
                <div class="d-grid">
                     <a href="#" class="btn btn-outline-primary">Browse Tools</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="pricing-card card h-100 border-primary shadow-sm">
            <div class="card-header text-center py-3 bg-primary text-white">
                <h4 class="my-0 fw-normal">Free Registered</h4>
            </div>
            <div class="card-body">
                <h1 class="card-title pricing-card-title text-center">$0<small class="text-muted fw-light">/month</small></h1>
                <ul class="list-unstyled mt-3 mb-4">
                    <li><i class="fas fa-clipboard-list text-success me-2"></i> 5 tasks / day</li>
                    <li><i class="fas fa-hdd text-success me-2"></i> 100MB file limit</li>
                    <li><i class="fas fa-hourglass-half text-warning me-2"></i> 24-hour retention</li>
                    <li><i class="fas fa-check text-success me-2"></i> All Core Tools</li>
                    <li><i class="fas fa-times text-danger me-2"></i> No "Vault" storage</li>
                    <li><i class="fas fa-exclamation-triangle text-warning me-2"></i> Basic OCR (Low Priority)</li>
                </ul>
                <div class="d-grid">
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary">Sign up for Free</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="pricing-card card h-100">
            <div class="card-header text-center py-3">
                <h4 class="my-0 fw-normal">Pro</h4>
            </div>
            <div class="card-body">
                <h1 class="card-title pricing-card-title text-center">$9<small class="text-muted fw-light">/month</small></h1>
                <ul class="list-unstyled mt-3 mb-4">
                    <li><i class="fas fa-check-double text-success me-2"></i> Unlimited tasks</li>
                    <li><i class="fas fa-hdd text-success me-2"></i> 2GB file limit</li>
                    <li><i class="fas fa-infinity text-success me-2"></i> Permanent "Vault" storage</li>
                    <li><i class="fas fa-check-double text-success me-2"></i> All Advanced Tools</li>
                    <li><i class="fas fa-check-double text-success me-2"></i> High Priority OCR</li>
                    <li><i class="fas fa-lock text-success me-2"></i> Enhanced Security</li>
                </ul>
                <div class="d-grid">
                    <a href="#" class="btn btn-primary">Get Pro</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="text-center mt-5">
    <h2>For Developers</h2>
    <p class="lead">Need to automate document workflows at scale?</p>
    <a asp-controller="Api" asp-action="Index" class="btn btn-info btn-lg mt-3"><i class="fas fa-code me-2"></i> Explore Developer API</a>
    <p class="mt-3">Pay-per-use model for API access.</p>
</div>