@using discussionspot.Models.ViewModels
@model PostCreateViewModel
@{
    ViewData["Title"] = "CreatePost";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!-- CSS styles (can be moved to a separate CSS file) -->
<style>
    /* Custom CSS for Create Post Page */
    .create-post-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    /* Add shadows to input fields */
    .form-control, .form-select, .input-group {
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.08);
        transition: all 0.2s ease;
    }

        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 0 0.25rem rgba(99, 102, 241, 0.25);
        }

    /* Add shadows to cards */
    .card {
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        border-radius: 8px;
    }

    .post-type-tab {
        cursor: pointer;
        padding: 12px 15px;
        border-radius: 4px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .post-type-tab:hover {
            background-color: rgba(99, 102, 241, 0.1);
        }

        .post-type-tab.active {
            background-color: var(--primary-color);
            color: white;
        }

        .post-type-tab i {
            font-size: 1.2rem;
        }

    .form-section {
        display: none;
    }

        .form-section.active {
            display: block;
        }

    .community-selector {
        position: relative;
    }

    .media-preview {
        max-width: 100%;
        max-height: 300px;
        margin-top: 10px;
        border-radius: 4px;
        display: none;
    }

    .poll-option {
        display: flex;
        align-items: center;
        margin-bottom: 10px;
    }

        .poll-option input {
            flex-grow: 1;
        }

        .poll-option button {
            margin-left: 10px;
        }

    .tag-input-container {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 8px;
        border: 1px solid var(--border-color);
        border-radius: 4px;
        min-height: 45px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.08);
    }

    .tag {
        background-color: rgba(99, 102, 241, 0.1);
        color: var(--primary-color);
        padding: 4px 8px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .tag i {
            cursor: pointer;
        }

    .tag-input {
        border: none;
        outline: none;
        background: transparent;
        flex-grow: 1;
        color: var(--text-color);
    }

    .formatting-toolbar {
        display: flex;
        gap: 5px;
        padding: 8px;
        border: 1px solid var(--border-color);
        border-radius: 4px 4px 0 0;
        background-color: var(--bg-dark);
    }

    .formatting-button {
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .formatting-button:hover {
            background-color: rgba(99, 102, 241, 0.1);
        }

    .content-textarea {
        border-radius: 0 0 4px 4px;
        border-top: none;
        min-height: 200px;
    }

    .nsfw-spoiler-options {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        margin-top: 15px;
    }

    .option-toggle {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
    }

    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 40px;
        height: 20px;
    }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: var(--bg-dark);
        transition: .4s;
        border-radius: 20px;
    }

        .toggle-slider:before {
            position: absolute;
            content: "";
            height: 16px;
            width: 16px;
            left: 2px;
            bottom: 2px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

    input:checked + .toggle-slider {
        background-color: var(--primary-color);
    }

        input:checked + .toggle-slider:before {
            transform: translateX(20px);
        }

    .post-preview {
        border: 1px dashed var(--border-color);
        border-radius: 4px;
        padding: 15px;
        margin-top: 20px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.08);
    }

    .preview-title {
        font-size: 1.2rem;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .preview-content {
        margin-bottom: 15px;
    }

    .preview-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        color: var(--text-light);
        font-size: 0.9rem;
    }

    .preview-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 10px;
    }

    .preview-tag {
        background-color: rgba(99, 102, 241, 0.1);
        color: var(--primary-color);
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.85rem;
    }

    .preview-community {
        font-weight: 500;
        color: var(--primary-color);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .preview-community-icon {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background-color: var(--primary-color);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 12px;
    }

    .error-feedback {
        color: #dc3545;
        font-size: 0.875em;
        margin-top: 0.25rem;
        display: none;
    }

    .validation-summary-errors {
        color: #dc3545;
        margin-bottom: 1rem;
    }

        .validation-summary-errors ul {
            margin-bottom: 0;
            padding-left: 1.5rem;
        }

    .field-validation-error {
        color: #dc3545;
        font-size: 0.875em;
        display: block;
        margin-top: 0.25rem;
    }

    .input-validation-error {
        border-color: #dc3545;
    }

        .input-validation-error:focus {
            border-color: #dc3545;
            box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25);
        }

    /* Responsive adjustments */
    @@media (max-width: 992px) {
        .right-sidebar

    {
        margin-top: 20px;
    }

    }

    @@media (max-width: 768px) {
        .left-sidebar

    {
        margin-bottom: 20px;
    }

    .post-type-tabs {
        flex-wrap: wrap;
    }

    .post-type-tab {
        flex: 1 0 auto;
        text-align: center;
        justify-content: center;
    }

    .nsfw-spoiler-options {
        flex-direction: column;
        gap: 10px;
    }

    }
</style>

<!-- Main Content -->
<main class="py-4">
    <div class="container create-post-container">
        <!-- Validation Summary -->
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <form asp-action="CreatePost" asp-controller="DiscussionPost" method="post" enctype="multipart/form-data" id="postForm">
            <div class="row">
                <!-- Left Sidebar - Community Selection & Rules -->
                <div class="col-lg-3 left-sidebar">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">Create a Post</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label asp-for="CommunityId" class="form-label">Choose a community <span class="text-danger">*</span></label>
                                <select asp-for="CommunityId" asp-items="Model.Communities" class="form-select" id="communitySelect">
                                    <option value="">-- Select a community --</option>
                                </select>
                                <span asp-validation-for="CommunityId" class="field-validation-error"></span>
                            </div>
                            <div class="d-grid">
                                <a asp-controller="Community" asp-action="Create" class="btn btn-outline-primary">
                                    <i class="fas fa-plus me-2"></i> Create Community
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="card rules-card">
                        <div class="card-header">
                            <h5 class="mb-0" id="communityRulesTitle">Community Rules</h5>
                        </div>
                        <div class="card-body p-0" id="communityRulesContainer">
                            <div class="text-center p-4" id="noCommunitySelected">
                                <i class="fas fa-users-slash fs-2 text-muted mb-3"></i>
                                <p>Select a community to see its rules</p>
                            </div>
                            <div id="communityRules" style="display: none;" class="p-0">
                                <!-- Rules will be populated dynamically -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Middle Column - Post Creation Form -->
                <div class="col-lg-6">
                    <!-- Post Type Tabs -->
                    <div class="card mb-3">
                        <div class="card-body p-2">
                            <div class="d-flex post-type-tabs">
                                @foreach (var postType in Model.PostTypes)
                                {
                                    <div class="post-type-tab @(postType.Value == Model.PostType ? "active" : "")" data-type="@postType.Value">
                                        <i class="fas @(postType.Value == "text" ? "fa-font" :
                                        postType.Value == "image" ? "fa-image" :
                                        postType.Value == "video" ? "fa-video" :
                                        postType.Value == "link" ? "fa-link" :
                                        "fa-poll")"></i>
                                        <span>@postType.Text</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Post Creation Form -->
                    <div class="card">
                        <div class="card-body">
                            <!-- Hidden field for post type -->
                            <input type="hidden" asp-for="PostType" id="postTypeInput">

                            <!-- Title (Common for all post types) -->
                            <div class="mb-3">
                                <label asp-for="Title" class="form-label">Title <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" asp-for="Title" placeholder="An interesting title" maxlength="300">
                                <span asp-validation-for="Title" class="field-validation-error"></span>
                                <div class="form-text text-end">
                                    <span id="titleCharCount">0</span>/300
                                </div>
                            </div>

                            <!-- Text Post Form -->
                            <div class="form-section @(Model.PostType == "text" ? "active" : "")" id="textPostForm">
                                <div class="mb-3">
                                    <label asp-for="Content" class="form-label">Content</label>
                                    <div class="formatting-toolbar">
                                        <div class="formatting-button" title="Bold" data-format="bold">
                                            <i class="fas fa-bold"></i>
                                        </div>
                                        <div class="formatting-button" title="Italic" data-format="italic">
                                            <i class="fas fa-italic"></i>
                                        </div>
                                        <div class="formatting-button" title="Link" data-format="link">
                                            <i class="fas fa-link"></i>
                                        </div>
                                        <div class="formatting-button" title="Bulleted List" data-format="ul">
                                            <i class="fas fa-list-ul"></i>
                                        </div>
                                        <div class="formatting-button" title="Numbered List" data-format="ol">
                                            <i class="fas fa-list-ol"></i>
                                        </div>
                                        <div class="formatting-button" title="Quote" data-format="quote">
                                            <i class="fas fa-quote-right"></i>
                                        </div>
                                        <div class="formatting-button" title="Code" data-format="code">
                                            <i class="fas fa-code"></i>
                                        </div>
                                        <div class="formatting-button" title="Heading" data-format="heading">
                                            <i class="fas fa-heading"></i>
                                        </div>
                                    </div>
                                    <textarea class="form-control content-textarea" asp-for="Content" id="contentTextarea" rows="10" placeholder="Share your thoughts..."></textarea>
                                    <span asp-validation-for="Content" class="field-validation-error"></span>
                                </div>
                            </div>

                            <!-- Image Post Form -->
                            <div class="form-section @(Model.PostType == "image" ? "active" : "")" id="imagePostForm">
                                <div class="mb-3">
                                    <label asp-for="ImageFiles" class="form-label">Upload Images <span class="text-danger">*</span></label>
                                    <input type="file" class="form-control" asp-for="ImageFiles" id="imageUpload" accept="image/*" multiple>
                                    <span asp-validation-for="ImageFiles" class="field-validation-error"></span>
                                    <div class="form-text">You can upload up to 20 images (10MB max per image)</div>
                                </div>
                                <div class="mb-3">
                                    <div id="imagePreviewContainer" class="d-flex flex-wrap gap-2 mt-2">
                                        <!-- Image previews will be inserted here -->
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="ImageCaption" class="form-label">Caption (optional)</label>
                                    <input type="text" class="form-control" asp-for="ImageCaption" placeholder="Add a caption to your image">
                                    <span asp-validation-for="ImageCaption" class="field-validation-error"></span>
                                </div>
                            </div>

                            <!-- Video Post Form -->
                            <div class="form-section @(Model.PostType == "video" ? "active" : "")" id="videoPostForm">
                                <div class="mb-3">
                                    <label asp-for="VideoFile" class="form-label">Upload Video <span class="text-danger">*</span></label>
                                    <input type="file" class="form-control" asp-for="VideoFile" id="videoUpload" accept="video/*">
                                    <span asp-validation-for="VideoFile" class="field-validation-error"></span>
                                    <div class="form-text">Maximum file size: 100MB</div>
                                </div>
                                <div class="mb-3">
                                    <video controls id="videoPreview" class="media-preview w-100 d-none"></video>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="VideoCaption" class="form-label">Caption (optional)</label>
                                    <input type="text" class="form-control" asp-for="VideoCaption" placeholder="Add a caption to your video">
                                    <span asp-validation-for="VideoCaption" class="field-validation-error"></span>
                                </div>
                            </div>

                            <!-- Link Post Form -->
                            <div class="form-section @(Model.PostType == "link" ? "active" : "")" id="linkPostForm">
                                <div class="mb-3">
                                    <label asp-for="Url" class="form-label">URL <span class="text-danger">*</span></label>
                                    <input type="url" class="form-control" asp-for="Url" id="linkUrl" placeholder="https://example.com">
                                    <span asp-validation-for="Url" class="field-validation-error"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Content" class="form-label">Description (optional)</label>
                                    <textarea class="form-control" asp-for="Content" id="linkDescription" rows="4" placeholder="Add context or description for this link"></textarea>
                                    <span asp-validation-for="Content" class="field-validation-error"></span>
                                </div>
                            </div>

                            <!-- Poll Post Form -->
                            <div class="form-section @(Model.PostType == "poll" ? "active" : "")" id="pollPostForm">
                                <input type="hidden" asp-for="HasPoll" id="hasPoll" value="true">

                                <div class="mb-3">
                                    <label class="form-label">Poll Options <span class="text-danger">*</span></label>
                                    <div id="pollOptionsContainer">
                                        @if (Model.PollOptions != null && Model.PollOptions.Any())
                                        {
                                            @for (int i = 0; i < Model.PollOptions.Count; i++)
                                            {
                                                <div class="poll-option">
                                                    <input asp-for="PollOptions[i]" class="form-control poll-option-input" placeholder="Option @(i+1)">
                                                    <button type="button" class="btn btn-sm btn-outline-danger remove-option" @(i < 2 ? "disabled" : "")>
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="poll-option">
                                                <input type="text" class="form-control poll-option-input" name="PollOptions[0]" placeholder="Option 1">
                                                <button type="button" class="btn btn-sm btn-outline-danger remove-option" disabled>
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </div>
                                            <div class="poll-option">
                                                <input type="text" class="form-control poll-option-input" name="PollOptions[1]" placeholder="Option 2">
                                                <button type="button" class="btn btn-sm btn-outline-danger remove-option" disabled>
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-primary mt-2" id="addPollOption">
                                        <i class="fas fa-plus me-1"></i> Add Option
                                    </button>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Poll Settings</label>
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" asp-for="AllowMultipleChoices" id="allowMultipleChoices">
                                        <label class="form-check-label" for="allowMultipleChoices">
                                            Allow users to select multiple options
                                        </label>
                                    </div>
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" asp-for="ShowResultsBeforeVoting" id="showResultsBeforeVoting">
                                        <label class="form-check-label" for="showResultsBeforeVoting">
                                            Show results before voting
                                        </label>
                                    </div>
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" id="pollExpiration">
                                        <label class="form-check-label" for="pollExpiration">
                                            Set poll expiration
                                        </label>
                                    </div>
                                    <div class="input-group mt-2" id="pollExpirationGroup" style="display: none;">
                                        <input type="datetime-local" class="form-control" asp-for="PollEndsAt" id="pollEndsAt">
                                        <span asp-validation-for="PollEndsAt" class="field-validation-error"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Tags (Common for all post types) -->
                            <div class="mb-3">
                                <label asp-for="TagsString" class="form-label">Tags</label>
                                <div class="tag-input-container" id="tagContainer">
                                    <input type="hidden" asp-for="TagsString" id="tagStringInput">
                                    <input type="text" class="tag-input" id="tagInput" placeholder="Add tags (press Enter to add)">
                                </div>
                                <div class="form-text">Add up to 5 tags to help categorize your post</div>
                                <span asp-validation-for="TagsString" class="field-validation-error"></span>
                            </div>

                            <!-- Post Options (Common for all post types) -->
                            <div class="nsfw-spoiler-options">
                                <label class="option-toggle">
                                    <span class="toggle-switch">
                                        <input type="checkbox" asp-for="IsNSFW" id="nsfwToggle">
                                        <span class="toggle-slider"></span>
                                    </span>
                                    <span>NSFW</span>
                                </label>
                                <label class="option-toggle">
                                    <span class="toggle-switch">
                                        <input type="checkbox" asp-for="IsSpoiler" id="spoilerToggle">
                                        <span class="toggle-slider"></span>
                                    </span>
                                    <span>Spoiler</span>
                                </label>
                                <label class="option-toggle">
                                    <span class="toggle-switch">
                                        <input type="checkbox" asp-for="IsPinned" id="pinToggle">
                                        <span class="toggle-slider"></span>
                                    </span>
                                    <span>Pin to Profile</span>
                                </label>
                                <label class="option-toggle">
                                    <span class="toggle-switch">
                                        <input type="checkbox" asp-for="IsCommentAllowed" id="allowCommentsToggle" checked>
                                        <span class="toggle-slider"></span>
                                    </span>
                                    <span>Allow Comments</span>
                                </label>
                            </div>

                            <!-- Post Preview -->
                            <div class="post-preview mt-4" id="postPreview">
                                <h6 class="text-muted mb-2">Post Preview</h6>
                                <div class="preview-community" id="previewCommunity">
                                    <div class="preview-community-icon" id="previewCommunityIcon">r/</div>
                                    <span id="previewCommunityName">Community</span>
                                </div>
                                <div class="preview-title" id="previewTitle">Your post title will appear here</div>
                                <div class="preview-tags" id="previewTags"></div>
                                <div class="preview-content" id="previewContent">Your post content will appear here</div>
                                <div class="preview-meta">
                                    <span><i class="fas fa-user me-1"></i> Posted by You</span>
                                    <span><i class="fas fa-comments me-1"></i> 0 comments</span>
                                    <span id="previewNSFW" style="display: none;"><i class="fas fa-exclamation-triangle me-1"></i> NSFW</span>
                                    <span id="previewSpoiler" style="display: none;"><i class="fas fa-eye-slash me-1"></i> Spoiler</span>
                                </div>
                            </div>

                            <!-- SEO Hidden Fields -->
                            <input type="hidden" asp-for="MetaTitle" id="metaTitleInput">
                            <input type="hidden" asp-for="MetaDescription" id="metaDescriptionInput">
                            <input type="hidden" asp-for="Keywords" id="keywordsInput">

                            <!-- Submit Buttons -->
                            <div class="d-flex justify-content-between mt-4">
                                <button type="button" class="btn btn-outline-secondary" id="saveAsDraftBtn">
                                    <i class="fas fa-save me-1"></i> Save as Draft
                                </button>
                                <div>
                                    <button type="button" class="btn btn-outline-primary me-2" id="previewBtn">
                                        <i class="fas fa-eye me-1"></i> Preview
                                    </button>
                                    <button type="submit" class="btn btn-primary" id="submitPostBtn">
                                        <i class="fas fa-paper-plane me-1"></i> Post
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Sidebar - SEO & Posting Tips -->
                <div class="col-lg-3 right-sidebar">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">SEO Settings</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="metaTitle" class="form-label">Meta Title</label>
                                <input type="text" class="form-control" id="metaTitle" placeholder="Custom title for search engines">
                                <div class="form-text">Leave blank to use post title</div>
                            </div>
                            <div class="mb-3">
                                <label for="metaDescription" class="form-label">Meta Description</label>
                                <textarea class="form-control" id="metaDescription" rows="3" placeholder="Brief description for search results"></textarea>
                                <div class="form-text">Recommended: 150-160 characters</div>
                            </div>
                            <div class="mb-3">
                                <label asp-for="OgImageFile" class="form-label">Social Media Image</label>
                                <input type="file" class="form-control" asp-for="OgImageFile" id="ogImage" accept="image/*">
                                <div class="form-text">Recommended size: 1200x630 pixels</div>
                            </div>
                            <div class="mb-3">
                                <label for="keywords" class="form-label">Keywords</label>
                                <input type="text" class="form-control" id="keywords" placeholder="Comma-separated keywords">
                            </div>
                        </div>
                    </div>

                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">Posting Tips</h5>
                        </div>
                        <div class="card-body">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Respond to comments to boost engagement
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Community Guidelines</h5>
                        </div>
                        <div class="card-body">
                            <p>Before posting, please ensure your content:</p>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-exclamation-circle text-warning me-2"></i>
                                    Follows community-specific rules
                                </li>
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-exclamation-circle text-warning me-2"></i>
                                    Doesn't contain personal information
                                </li>
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-exclamation-circle text-warning me-2"></i>
                                    Respects copyright and intellectual property
                                </li>
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-exclamation-circle text-warning me-2"></i>
                                    Is free from hate speech and harassment
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</main>

@section Scripts {
    <!-- jQuery Validation Scripts (required for validation) -->
    <partial name="_ValidationScriptsPartial" />

    <!-- Custom JavaScript for Post Creation -->
    <script>
        $(document).ready(function () {
            // Initialize tags array and post type
            let tags = [];

            // Initialize character counters
            updateCharCount('#Title', '#titleCharCount', 300);

            // Initialize post type from model
            const initialPostType = '@Model.PostType';
            $('#postTypeInput').val(initialPostType);

            // Handle post type tab clicks
            $('.post-type-tab').on('click', function() {
                // Remove active class from all tabs and sections
                $('.post-type-tab').removeClass('active');
                $('.form-section').removeClass('active');

                // Add active class to clicked tab and corresponding section
                $(this).addClass('active');
                const type = $(this).data('type');
                $('#' + type + 'PostForm').addClass('active');

                // Update hidden input
                $('#postTypeInput').val(type);

                // Update preview
                updatePreview();
            });

            // Character count for title field
            $('#Title').on('input', function() {
                updateCharCount('#Title', '#titleCharCount', 300);
                updatePreviewTitle();
            });

            // Content textarea handlers for text posts
            $('#contentTextarea').on('input', function() {
                updatePreviewContent();
            });

            // Formatting toolbar handlers
            $('.formatting-button').on('click', function() {
                const format = $(this).data('format');
                const textarea = document.getElementById('contentTextarea');
                const start = textarea.selectionStart;
                const end = textarea.selectionEnd;
                const selectedText = textarea.value.substring(start, end);
                let replacement = '';

                switch (format) {
                    case 'bold':
                        replacement = `**${selectedText}**`;
                        break;
                    case 'italic':
                        replacement = `*${selectedText}*`;
                        break;
                    case 'link':
                        replacement = selectedText ? `[${selectedText}](url)` : '[Link text](url)';
                        break;
                    case 'ul':
                        replacement = selectedText ? selectedText.split('\\n').map(line => `* ${line}`).join('\\n') : '* List item';
                        break;
                    case 'ol':
                        replacement = selectedText ? selectedText.split('\\n').map((line, i) => `${i+1}. ${line}`).join('\\n') : '1. List item';
                        break;
                    case 'quote':
                        replacement = selectedText ? selectedText.split('\\n').map(line => `> ${line}`).join('\\n') : '> Quote';
                        break;
                    case 'code':
                        replacement = selectedText ? `\`\`\`\\n${selectedText}\\n\`\`\`` : '```\\ncode\\n```';
                        break;
                    case 'heading':
                        replacement = selectedText ? `# ${selectedText}` : '# Heading';
                        break;
                }

                textarea.value = textarea.value.substring(0, start) + replacement + textarea.value.substring(end);
                textarea.focus();
                textarea.selectionStart = start + replacement.length;
                textarea.selectionEnd = start + replacement.length;

                // Update preview
                updatePreviewContent();
            });

            // Image upload handling
            $('#imageUpload').on('change', function(e) {
                const files = e.target.files;
                if (files.length > 0) {
                    $('#imagePreviewContainer').empty();

                    for (let i = 0; i < files.length; i++) {
                        const file = files[i];
                        const reader = new FileReader();

                        reader.onload = function(e) {
                            const imgWrap = $('<div>').addClass('position-relative mb-2');
                            const img = $('<img>')
                                .attr('src', e.target.result)
                                .addClass('img-fluid rounded')
                                .css('max-height', '200px')
                                .appendTo(imgWrap);

                            $('#imagePreviewContainer').append(imgWrap);
                        }

                        reader.readAsDataURL(file);
                    }

                    // Update preview
                    updatePreview();
                }
            });

            // Video upload handling
            $('#videoUpload').on('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const url = URL.createObjectURL(file);
                    $('#videoPreview')
                        .attr('src', url)
                        .removeClass('d-none');

                    // Update preview
                    updatePreview();
                }
            });

            // Poll option handling
            $('#addPollOption').on('click', function() {
                const optionCount = $('#pollOptionsContainer .poll-option').length + 1;
                const newOption = $('<div>').addClass('poll-option');

                newOption.html(`
                    <input type="text" class="form-control poll-option-input" name="PollOptions[${optionCount - 1}]" placeholder="Option ${optionCount}">
                    <button type="button" class="btn btn-sm btn-outline-danger remove-option">
                        <i class="fas fa-times"></i>
                    </button>
                `);

                $('#pollOptionsContainer').append(newOption);

                // Enable remove buttons if there are more than 2 options
                if ($('#pollOptionsContainer .poll-option').length > 2) {
                    $('.remove-option').prop('disabled', false);
                }

                // Update preview
                updatePreview();
            });

            // Remove poll option
            $('#pollOptionsContainer').on('click', '.remove-option', function() {
                // Only remove if there are more than 2 options
                if ($('#pollOptionsContainer .poll-option').length > 2) {
                    $(this).closest('.poll-option').remove();

                    // Update placeholders and names
                    $('#pollOptionsContainer .poll-option').each(function(index) {
                        $(this).find('input').attr('name', `PollOptions[${index}]`);
                        $(this).find('input').attr('placeholder', `Option ${index + 1}`);
                    });

                    // Disable remove buttons if only 2 options remain
                    if ($('#pollOptionsContainer .poll-option').length <= 2) {
                        $('.remove-option').prop('disabled', true);
                    }

                    // Update preview
                    updatePreview();
                }
            });

            // Poll expiration toggle
            $('#pollExpiration').on('change', function() {
                $('#pollExpirationGroup').toggle($(this).is(':checked'));
            });

            // Tags input
            $('#tagInput').on('keydown', function(e) {
                if (e.key === 'Enter' && $(this).val().trim() !== '') {
                    e.preventDefault();

                    // Only allow up to 5 tags
                    if (tags.length < 5) {
                        const tagText = $(this).val().trim();

                        // Check if tag already exists
                        if (!tags.includes(tagText)) {
                            tags.push(tagText);

                            const tagElement = $('<div>').addClass('tag').html(`
                                ${tagText}
                                <i class="fas fa-times" data-tag="${tagText}"></i>
                            `);

                            tagElement.insertBefore($(this));
                            $(this).val('');

                            // Update hidden field
                            updateTagsField();

                            // Update preview tags
                            updatePreviewTags();
                        }
                    }
                }
            });

            // Remove tag when clicked
            $('#tagContainer').on('click', '.tag i', function() {
                const tagToRemove = $(this).data('tag');
                tags = tags.filter(tag => tag !== tagToRemove);
                $(this).parent().remove();

                // Update hidden field
                updateTagsField();

                // Update preview tags
                updatePreviewTags();
            });

            // NSFW and Spoiler toggles
            $('#nsfwToggle').on('change', function() {
                $('#previewNSFW').toggle($(this).is(':checked'));
            });

            $('#spoilerToggle').on('change', function() {
                $('#previewSpoiler').toggle($(this).is(':checked'));
            });

            // Community select handling (fetching rules)
            $('#communitySelect').on('change', function() {
                const communityId = $(this).val();

                if (communityId) {
                    // Show loading indication
                    $('#communityRulesTitle').text('Loading community rules...');
                    $('#noCommunitySelected').hide();
                    $('#communityRules').html('<div class="p-3 text-center"><div class="spinner-border text-primary" role="status"></div></div>').show();

                    // In a real application, you would fetch rules from server
                    // For demo purposes, we'll simulate a server request
                    setTimeout(function() {
                        fetchCommunityRules(communityId);
                    }, 500);

                    // Update community preview
                    const communityName = $('#communitySelect option:selected').text();
                    $('#previewCommunityName').text(communityName);
                    $('#previewCommunityIcon').text(communityName.charAt(0));
                } else {
                    // Reset rules display
                    $('#communityRulesTitle').text('Community Rules');
                    $('#noCommunitySelected').show();
                    $('#communityRules').hide();

                    // Reset preview
                    $('#previewCommunityName').text('Community');
                    $('#previewCommunityIcon').text('r/');
                }
            });

            // Preview button
            $('#previewBtn').on('click', function() {
                updatePreview();
                $('#postPreview')[0].scrollIntoView({ behavior: 'smooth' });
            });

            // Save as draft
            $('#saveAsDraftBtn').on('click', function() {
                if ($('#Title').val().trim() === '') {
                    $('#Title').addClass('is-invalid');
                    alert('Please enter a title for your draft');
                    return;
                }

                // In a real application, you would save to localStorage or server
                // For demo purposes, we'll just show an alert
                alert('Post saved as draft');
            });

            // Form submission handling
            $('#postForm').on('submit', function(e) {
                // Pre-submission tasks

                // Update hidden SEO fields
                $('#metaTitleInput').val($('#metaTitle').val());
                $('#metaDescriptionInput').val($('#metaDescription').val());
                $('#keywordsInput').val($('#keywords').val());

                // Force-update tags field
                updateTagsField();

                // Validation is handled by jQuery Validation
            });

            // Helper functions
            function updateCharCount(inputSelector, countSelector, maxChars) {
                const length = $(inputSelector).val().length;
                $(countSelector).text(length);

                if (length > maxChars) {
                    $(countSelector).addClass('text-danger');
                } else {
                    $(countSelector).removeClass('text-danger');
                }
            }

            function updateTagsField() {
                $('#tagStringInput').val(tags.join(','));
            }

            function updatePreviewTitle() {
                const title = $('#Title').val();
                $('#previewTitle').text(title || 'Your post title will appear here');
            }

            function updatePreviewTags() {
                $('#previewTags').empty();

                tags.forEach(tag => {
                    const tagElement = $('<div>').addClass('preview-tag').text(tag);
                    $('#previewTags').append(tagElement);
                });
            }

            function updatePreviewContent() {
                const activeType = $('.post-type-tab.active').data('type');
                let content = '';

                switch (activeType) {
                    case 'text':
                        content = formatMarkdown($('#contentTextarea').val());
                        break;
                    case 'image':
                        if ($('#imagePreviewContainer img').length > 0) {
                            content = '<div class="d-flex flex-wrap gap-2">';
                            $('#imagePreviewContainer img').each(function() {
                                content += `<img src="${$(this).attr('src')}" class="img-fluid rounded" style="max-height: 150px;">`;
                            });
                            content += '</div>';

                            const caption = $('#ImageCaption').val();
                            if (caption) {
                                content += `<p class="mt-2">${caption}</p>`;
                            }
                        } else {
                            content = 'No images selected';
                        }
                        break;
                    case 'video':
                        if (!$('#videoPreview').hasClass('d-none')) {
                            content = `<video controls class="img-fluid rounded"><source src="${$('#videoPreview').attr('src')}"></video>`;

                            const caption = $('#VideoCaption').val();
                            if (caption) {
                                content += `<p class="mt-2">${caption}</p>`;
                            }
                        } else {
                            content = 'No video selected';
                        }
                        break;
                    case 'link':
                        const url = $('#linkUrl').val();
                        const description = $('#linkDescription').val();

                        if (url) {
                            content = `<div class="p-3 border rounded">
                                <a href="${url}" target="_blank" class="d-block mb-1 text-primary">${url}</a>`;

                            if (description) {
                                content += `<p class="mb-0 small">${description}</p>`;
                            }

                            content += '</div>';
                        } else {
                            content = 'No link provided';
                        }
                        break;
                    case 'poll':
                        content = '<div class="border rounded p-3">';
                        content += '<h6 class="mb-3">Poll</h6>';

                        $('#pollOptionsContainer .poll-option-input').each(function(index) {
                            const optionText = $(this).val() || `Option ${index + 1}`;
                            content += `
                                <div class="mb-2">
                                    <div class="d-flex align-items-center">
                                        <div class="form-check mb-0">
                                            <input class="form-check-input" type="${$('#allowMultipleChoices').is(':checked') ? 'checkbox' : 'radio'}"
                                                   id="pollPreview${index}" name="pollPreview" disabled>
                                            <label class="form-check-label" for="pollPreview${index}">
                                                ${optionText}
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            `;
                        });

                        content += '<button class="btn btn-primary btn-sm w-100 mt-2" disabled>Vote</button>';

                        if ($('#pollExpiration').is(':checked') && $('#pollEndsAt').val()) {
                            const date = new Date($('#pollEndsAt').val());
                            content += `<div class="small text-muted mt-2">Poll closes on ${date.toLocaleString()}</div>`;
                        }

                        content += '</div>';
                        break;
                }

                $('#previewContent').html(content || 'Your post content will appear here');
            }

            function formatMarkdown(text) {
                if (!text) return '';

                // Simple markdown formatting for preview
                return text
                    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                    .replace(/\*(.*?)\*/g, '<em>$1</em>')
                    .replace(/# (.*?)(\n|$)/g, '<h3>$1</h3>')
                    .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" target="_blank">$1</a>')
                    .replace(/> (.*?)(\n|$)/g, '<blockquote class="blockquote ps-3 border-start border-2">$1</blockquote>')
                    .replace(/```([\s\S]*?)```/g, '<pre><code>$1</code></pre>')
                    .replace(/`(.*?)`/g, '<code>$1</code>')
                    .replace(/\n/g, '<br>');
            }

            function updatePreview() {
                updatePreviewTitle();
                updatePreviewContent();
                updatePreviewTags();
            }

            function fetchCommunityRules(communityId) {
                // In a real application, you would fetch data from server
                // For demo purposes, we'll simulate community rules

                // Get community name
                const communityName = $('#communitySelect option:selected').text();

                // Update title
                $('#communityRulesTitle').text(`${communityName} Rules`);

                // Generate demo rules based on community ID
                const rules = [
                    { title: "Be respectful", description: "Treat others with respect. No personal attacks, harassment, or hate speech." },
                    { title: "Stay on topic", description: "Posts must be related to the community topic and contribute to discussion." },
                    { title: "No spam", description: "Don't spam the community with repetitive content or self-promotion." },
                    { title: "Credit sources", description: "Always provide credit for content that isn't yours." },
                    { title: "Follow site rules", description: "All Reddit content policy rules apply in this community." }
                ];

                // Render rules
                let rulesHtml = '';

                rules.forEach((rule, index) => {
                    rulesHtml += `
                        <div class="rule-item p-3">
                            <h6>${index + 1}. ${rule.title}</h6>
                            <p class="mb-0 small">${rule.description}</p>
                        </div>
                    `;
                });

                $('#communityRules').html(rulesHtml);
            }

            // Initialize preview on page load
            updatePreview();

            // Initialize community rules if a community is already selected
            if ($('#communitySelect').val()) {
                fetchCommunityRules($('#communitySelect').val());
            }
        });
    </script>
}






