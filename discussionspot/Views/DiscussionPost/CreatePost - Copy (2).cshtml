@model discussionspot.ViewModels.PostCreateViewModel
@{
    ViewData["Title"] = "CreatePost";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    /* Custom CSS for Create Post Page */
    .create-post-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    /* Add shadows to input fields */
    .form-control, .form-select, .input-group {
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.08);
        transition: all 0.2s ease;
    }

        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 0 0.25rem rgba(99, 102, 241, 0.25);
        }

    /* Add shadows to cards */
    .card {
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        border-radius: 8px;
    }

    .post-type-tab {
        cursor: pointer;
        padding: 12px 15px;
        border-radius: 4px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .post-type-tab:hover {
            background-color: rgba(99, 102, 241, 0.1);
        }

        .post-type-tab.active {
            background-color: var(--primary-color);
            color: white;
        }

        .post-type-tab i {
            font-size: 1.2rem;
        }

    .form-section {
        display: none;
    }

        .form-section.active {
            display: block;
        }

    .community-selector {
        position: relative;
    }

    .community-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        max-height: 300px;
        overflow-y: auto;
        border: 1px solid var(--border-color);
        border-radius: 4px;
        z-index: 1000;
        display: none;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    /* Fix for community dropdown background */
    body:not(.dark-mode) .community-dropdown {
        background-color: #ffffff;
    }

    body.dark-mode .community-dropdown {
        background-color: #1f2937;
    }

    .community-item {
        padding: 10px 15px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .community-item:hover {
            background-color: rgba(99, 102, 241, 0.1);
        }

    .community-icon {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background-color: var(--primary-color);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 12px;
    }

    .rules-card {
        position: sticky;
        top: 20px;
    }

    .rule-item {
        padding: 10px 0;
        border-bottom: 1px solid var(--border-color);
    }

        .rule-item:last-child {
            border-bottom: none;
        }

    .media-preview {
        max-width: 100%;
        max-height: 300px;
        margin-top: 10px;
        border-radius: 4px;
        display: none;
    }

    .poll-option {
        display: flex;
        align-items: center;
        margin-bottom: 10px;
    }

        .poll-option input {
            flex-grow: 1;
        }

        .poll-option button {
            margin-left: 10px;
        }

    .tag-input-container {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 8px;
        border: 1px solid var(--border-color);
        border-radius: 4px;
        min-height: 45px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.08);
    }

    .tag {
        background-color: rgba(99, 102, 241, 0.1);
        color: var(--primary-color);
        padding: 4px 8px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .tag i {
            cursor: pointer;
        }

    .tag-input {
        border: none;
        outline: none;
        background: transparent;
        flex-grow: 1;
        color: var(--text-color);
    }

    .formatting-toolbar {
        display: flex;
        gap: 5px;
        padding: 8px;
        border: 1px solid var(--border-color);
        border-radius: 4px 4px 0 0;
        background-color: var(--bg-dark);
    }

    .formatting-button {
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .formatting-button:hover {
            background-color: rgba(99, 102, 241, 0.1);
        }

    .content-textarea {
        border-radius: 0 0 4px 4px;
        border-top: none;
        min-height: 200px;
    }

    .nsfw-spoiler-options {
        display: flex;
        gap: 15px;
        margin-top: 15px;
    }

    .option-toggle {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
    }

    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 40px;
        height: 20px;
    }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: var(--bg-dark);
        transition: .4s;
        border-radius: 20px;
    }

        .toggle-slider:before {
            position: absolute;
            content: "";
            height: 16px;
            width: 16px;
            left: 2px;
            bottom: 2px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

    input:checked + .toggle-slider {
        background-color: var(--primary-color);
    }

        input:checked + .toggle-slider:before {
            transform: translateX(20px);
        }

    .post-preview {
        border: 1px dashed var(--border-color);
        border-radius: 4px;
        padding: 15px;
        margin-top: 20px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.08);
    }

    .preview-title {
        font-size: 1.2rem;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .preview-content {
        margin-bottom: 15px;
    }

    .preview-meta {
        display: flex;
        gap: 15px;
        color: var(--text-light);
        font-size: 0.9rem;
    }

    .preview-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 10px;
    }

    .preview-tag {
        background-color: rgba(99, 102, 241, 0.1);
        color: var(--primary-color);
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.85rem;
    }

    .preview-community {
        font-weight: 500;
        color: var(--primary-color);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .preview-community-icon {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background-color: var(--primary-color);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 12px;
    }

    .no-communities {
        text-align: center;
        padding: 20px;
    }

        .no-communities i {
            font-size: 3rem;
            color: var(--text-light);
            margin-bottom: 15px;
        }

    .error-feedback {
        color: #dc3545;
        font-size: 0.875em;
        margin-top: 0.25rem;
        display: none;
    }

    .is-invalid ~ .error-feedback {
        display: block;
    }

    .is-invalid {
        border-color: #dc3545;
    }

    @@media (max-width: 992px) {
        .right-sidebar {
            margin-top: 20px;
        }
    }

    @@media (max-width: 768px) {
        .left-sidebar {
            margin-bottom: 20px;
        }

        .post-type-tabs {
            flex-wrap: wrap;
        }

        .post-type-tab {
            flex: 1 0 auto;
            text-align: center;
            justify-content: center;
        }
    }
</style>

<!-- Main Content -->
<main class="py-4">
    <form asp-action="CreatePost" asp-controller="DiscussionPost" method="post" enctype="multipart/form-data">
        <div class="container create-post-container">
            <div class="row">
                <!-- Left Sidebar - Community Selection & Rules -->
                <div class="col-lg-3 left-sidebar">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">Create a Post</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label asp-for="CommunityId" class="form-label">Choose a community <span class="text-danger">*</span></label>
                                <div class="community-selector">
                                    <select asp-for="CommunityId" asp-items="Model.Communities" class="form-control" id="communitySelect" required>
                                        <option value="">-- Select a community --</option>
                                    </select>
                                    <div class="error-feedback">Please select a community</div>
                                    <div class="community-dropdown" id="communityDropdown">
                                        <!-- This will be populated by JavaScript -->
                                    </div>
                                </div>
                            </div>
                            <div class="d-grid">
                                <a href="create-community.html" class="btn btn-outline-primary" id="createCommunityBtn">
                                    <i class="fas fa-plus me-2"></i> Create Community
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="card rules-card">
                        <div class="card-header">
                            <h5 class="mb-0" id="communityRulesTitle">Community Rules</h5>
                        </div>
                        <div class="card-body p-0" id="communityRulesContainer">
                            <div class="no-communities" id="noCommunitySelected">
                                <i class="fas fa-users-slash"></i>
                                <p>Select a community to see its rules</p>
                            </div>
                            <div id="communityRules" style="display: none;">
                                <div class="rule-item p-3">
                                    <h6>1. Be respectful</h6>
                                    <p class="mb-0 small">Treat others with respect. No personal attacks, harassment, or hate speech.</p>
                                </div>
                                <div class="rule-item p-3">
                                    <h6>2. No spam</h6>
                                    <p class="mb-0 small">Don't spam the community with repetitive content or self-promotion.</p>
                                </div>
                                <div class="rule-item p-3">
                                    <h6>3. Stay on topic</h6>
                                    <p class="mb-0 small">Posts must be related to the community topic and contribute to discussion.</p>
                                </div>
                                <div class="rule-item p-3">
                                    <h6>4. No NSFW content</h6>
                                    <p class="mb-0 small">Keep content appropriate for all audiences unless the community allows it.</p>
                                </div>
                                <div class="rule-item p-3">
                                    <h6>5. No misinformation</h6>
                                    <p class="mb-0 small">Verify facts before posting. Don't spread false information.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Middle Column - Post Creation Form -->
                <div class="col-lg-6">
                    <!-- Post Type Tabs -->
                    <div class="card">
                        <div class="card-body p-2">
                            <div class="d-flex post-type-tabs">
                                @foreach (var postType in Model.PostTypes)
                                {
                                    <div class="post-type-tab @(postType.Value == Model.PostType ? "active" : "")" data-type="@postType.Value">
                                        <i class="fas @(postType.Value == "text" ? "fa-font" :
                                            postType.Value == "image" ? "fa-image" :
                                            postType.Value == "video" ? "fa-video" :
                                            postType.Value == "link" ? "fa-link" :
                                            "fa-poll")"></i>
                                        <span>@postType.Text</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Post Creation Form -->
                    <div class="card">
                        <div class="card-body">
                            <div id="postForm" novalidate>
                                <input type="hidden" asp-for="PostType" id="postType">

                                <!-- Title (Common for all post types) -->
                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label">Title <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" asp-for="Title" placeholder="Title" maxlength="300" required>
                                    <div class="error-feedback">Please enter a title (max 300 characters)</div>
                                    <div class="form-text text-end">
                                        <span id="titleCharCount">0</span>/300
                                    </div>
                                </div>

                                <!-- Text Post Form -->
                                <div class="form-section @(Model.PostType == "text" ? "active" : "")" id="textPostForm">
                                    <div class="mb-3">
                                        <label asp-for="Content" class="form-label">Content</label>
                                        <div class="formatting-toolbar">
                                            <div class="formatting-button" title="Bold" data-format="bold">
                                                <i class="fas fa-bold"></i>
                                            </div>
                                            <div class="formatting-button" title="Italic" data-format="italic">
                                                <i class="fas fa-italic"></i>
                                            </div>
                                            <div class="formatting-button" title="Link" data-format="link">
                                                <i class="fas fa-link"></i>
                                            </div>
                                            <div class="formatting-button" title="Bulleted List" data-format="ul">
                                                <i class="fas fa-list-ul"></i>
                                            </div>
                                            <div class="formatting-button" title="Numbered List" data-format="ol">
                                                <i class="fas fa-list-ol"></i>
                                            </div>
                                            <div class="formatting-button" title="Quote" data-format="quote">
                                                <i class="fas fa-quote-right"></i>
                                            </div>
                                            <div class="formatting-button" title="Code" data-format="code">
                                                <i class="fas fa-code"></i>
                                            </div>
                                            <div class="formatting-button" title="Heading" data-format="heading">
                                                <i class="fas fa-heading"></i>
                                            </div>
                                        </div>
                                        <textarea class="form-control content-textarea" asp-for="Content" rows="10" placeholder="Text (optional)"></textarea>
                                    </div>
                                </div>

                                <!-- Image Post Form -->
                                <div class="form-section @(Model.PostType == "image" ? "active" : "")" id="imagePostForm">
                                    <div class="mb-3">
                                        <label asp-for="ImageFiles" class="form-label">Upload Images <span class="text-danger">*</span></label>
                                        <input type="file" class="form-control" asp-for="ImageFiles" accept="image/*" multiple>
                                        <div class="error-feedback">Please upload at least one image</div>
                                        <div class="form-text">You can upload up to 20 images (10MB max per image)</div>
                                    </div>
                                    <div id="imagePreviewContainer">
                                        <img src="/placeholder.svg" id="imagePreview" class="media-preview">
                                    </div>
                                    <div class="mb-3 mt-3">
                                        <label asp-for="ImageCaption" class="form-label">Caption (optional)</label>
                                        <input type="text" class="form-control" asp-for="ImageCaption" placeholder="Add a caption to your image">
                                    </div>
                                    <div class="mb-3">
                                        <label for="imageAltText" class="form-label">Alt Text (for accessibility)</label>
                                        <input type="text" class="form-control" id="imageAltText" name="mediaAltText" placeholder="Describe your image for visually impaired users">
                                    </div>
                                </div>

                                <!-- Video Post Form -->
                                <div class="form-section @(Model.PostType == "video" ? "active" : "")" id="videoPostForm">
                                    <div class="mb-3">
                                        <label for="videoUpload" class="form-label">Upload Video <span class="text-danger">*</span></label>
                                        <input type="file" class="form-control" id="videoUpload" name="videoFile" accept="video/*">
                                        <div class="error-feedback">Please upload a video</div>
                                        <div class="form-text">Maximum file size: 100MB</div>
                                    </div>
                                    <div id="videoPreviewContainer">
                                        <video controls id="videoPreview" class="media-preview"></video>
                                    </div>
                                    <div class="mb-3 mt-3">
                                        <label for="videoCaption" class="form-label">Caption (optional)</label>
                                        <input type="text" class="form-control" id="videoCaption" name="videoCaption" placeholder="Add a caption to your video">
                                    </div>
                                </div>

                                <!-- Link Post Form -->
                                <div class="form-section @(Model.PostType == "link" ? "active" : "")" id="linkPostForm">
                                    <div class="mb-3">
                                        <label asp-for="Url" class="form-label">URL <span class="text-danger">*</span></label>
                                        <input type="url" class="form-control" asp-for="Url" placeholder="https://example.com">
                                        <div class="error-feedback">Please enter a valid URL</div>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Content" class="form-label">Description (optional)</label>
                                        <textarea class="form-control" asp-for="Content" rows="4" placeholder="Add context or description for this link"></textarea>
                                    </div>
                                </div>

                                <!-- Poll Post Form -->
                                <div class="form-section @(Model.PostType == "poll" ? "active" : "")" id="pollPostForm">
                                    <div class="mb-3">
                                        <label class="form-label">Poll Options <span class="text-danger">*</span></label>
                                        <div id="pollOptionsContainer">
                                            @if (Model.PollOptions != null && Model.PollOptions.Any())
                                            {@for (int i = 0; i < Model.PollOptions.Count; i++)
                                                {
                                                    <div class="poll-option">


                                                        <input asp-for="PollOptions[i]" class="form-control poll-option-input" placeholder="Option @(i+1)">


                                                        <span asp-validation-for="PollOptions[i]" class="text-danger"></span>


                                                        <button type="button" class="btn btn-sm btn-outline-danger remove-option" @(i < 2 ? "disabled" : "")>
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="poll-option">


                                                    <input type="text" class="form-control poll-option-input" name="PollOptions[0]" placeholder="Option 1">


                                                    <button type="button" class="btn btn-sm btn-outline-danger remove-option" disabled>
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                </div>


                                                <div class="poll-option">

                                                    <input type="text" class="form-control poll-option-input" name="PollOptions[1]" placeholder="Option 2">


                                                    <button type"button" class="btn btn-sm btn-outline-danger remove-option" disabled>

                                                        <i class="fas fa-times"></i>

                                                    </button>


                                                </div>

                                            }

                                        </div>
                                        <div class="error-feedback">Please enter at least 2 poll options</div>
                                        <button type="button" class="btn btn-sm btn-outline-primary mt-2" id="addPollOption">
                                            <i class="fas fa-plus me-1"></i> Add Option
                                        </button>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Poll Settings</label>
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox" asp-for="AllowMultipleChoices" id="allowMultipleChoices">
                                            <label class="form-check-label" for="allowMultipleChoices">
                                                Allow users to select multiple options
                                            </label>
                                        </div>
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox" asp-for="ShowResultsBeforeVoting" id="showResultsBeforeVoting">
                                            <label class="form-check-label" for="showResultsBeforeVoting">
                                                Show results before voting
                                            </label>
                                        </div>
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox" id="pollExpiration" name="hasPollExpiration">
                                            <label class="form-check-label" for="pollExpiration">
                                                Set poll expiration
                                            </label>
                                        </div>
                                        <div class="input-group mt-2" id="pollExpirationGroup" style="display: none;">
                                            <input type="datetime-local" class="form-control" asp-for="PollEndsAt" id="pollEndsAt">
                                        </div>
                                    </div>
                                </div>

                                <!-- Tags (Common for all post types) -->
                                <div class="mb-3">
                                    <label asp-for="TagsString" class="form-label">Tags</label>
                                    <div class="tag-input-container" id="tagContainer">
                                        <input type="text" class="tag-input" asp-for="TagsString" id="tagInput" placeholder="Add tags (press Enter to add)">
                                    </div>
                                    <div class="form-text">Add up to 5 tags to help categorize your post</div>
                                </div>

                                <!-- Post Options (Common for all post types) -->
                                <div class="nsfw-spoiler-options">
                                    <label class="option-toggle">
                                        <span class="toggle-switch">
                                            <input type="checkbox" asp-for="IsNSFW" id="nsfwToggle">
                                            <span class="toggle-slider"></span>
                                        </span>
                                        <span>NSFW</span>
                                    </label>
                                    <label class="option-toggle">
                                        <span class="toggle-switch">
                                            <input type="checkbox" asp-for="IsSpoiler" id="spoilerToggle">
                                            <span class="toggle-slider"></span>
                                        </span>
                                        <span>Spoiler</span>
                                    </label>
                                    <label class="option-toggle">
                                        <span class="toggle-switch">
                                            <input type="checkbox" asp-for="IsPined" id="pinToggle">
                                            <span class="toggle-slider"></span>
                                        </span>
                                        <span>Pin to Profile</span>
                                    </label>
                                    <label class="option-toggle">
                                        <span class="toggle-switch">
                                            <input type="checkbox" asp-for="IsCommentAllowed" id="disableCommentsToggle">
                                            <span class="toggle-slider"></span>
                                        </span>
                                        <span>Allow Comments</span>
                                    </label>
                                </div>

                                <!-- Post Preview -->
                                <div class="post-preview mt-4" id="postPreview">
                                    <h6 class="text-muted mb-2">Post Preview</h6>
                                    <div class="preview-community" id="previewCommunity">
                                        <div class="preview-community-icon" id="previewCommunityIcon">r/</div>
                                        <span id="previewCommunityName">Community</span>
                                    </div>
                                    <div class="preview-title" id="previewTitle">Your post title will appear here</div>
                                    <div class="preview-tags" id="previewTags"></div>
                                    <div class="preview-content" id="previewContent">Your post content will appear here</div>
                                    <div class="preview-meta">
                                        <span><i class="fas fa-user me-1"></i> Posted by TestUser</span>
                                        <span><i class="fas fa-comments me-1"></i> 0 comments</span>
                                        <span id="previewNSFW" style="display: none;"><i class="fas fa-exclamation-triangle me-1"></i> NSFW</span>
                                        <span id="previewSpoiler" style="display: none;"><i class="fas fa-eye-slash me-1"></i> Spoiler</span>
                                    </div>
                                </div>

                                <!-- Submit Buttons -->
                                <div class="d-flex justify-content-between mt-4">
                                    <button type="button" class="btn btn-outline-secondary" id="saveAsDraft">
                                        <i class="fas fa-save me-1"></i> Save as Draft
                                    </button>
                                    <div>
                                        <button type="button" class="btn btn-outline-primary me-2" id="previewBtn">
                                            <i class="fas fa-eye me-1"></i> Preview
                                        </button>
                                        <button type="submit" class="btn btn-primary" id="submitPost">
                                            <i class="fas fa-paper-plane me-1"></i> Post
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Sidebar - SEO & Posting Tips -->
                <div class="col-lg-3 right-sidebar">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">SEO Settings</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="metaTitle" class="form-label">Meta Title</label>
                                <input type="text" class="form-control" id="metaTitle" name="metaTitle" placeholder="Custom title for search engines">
                                <div class="form-text">Leave blank to use post title</div>
                            </div>
                            <div class="mb-3">
                                <label for="metaDescription" class="form-label">Meta Description</label>
                                <textarea class="form-control" id="metaDescription" name="metaDescription" rows="3" placeholder="Brief description for search results"></textarea>
                                <div class="form-text">Recommended: 150-160 characters</div>
                            </div>
                            <div class="mb-3">
                                <label for="ogImage" class="form-label">Social Media Image</label>
                                <input type="file" class="form-control" id="ogImage" name="ogImage" accept="image/*">
                                <div class="form-text">Recommended size: 1200x630 pixels</div>
                            </div>
                            <div class="mb-3">
                                <label for="keywords" class="form-label">Keywords</label>
                                <input type="text" class="form-control" name="keywords" placeholder="Comma-separated keywords">
                            </div>
                        </div>
                    </div>

                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">Posting Tips</h5>
                        </div>
                        <div class="card-body">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Use a clear, descriptive title
                                </li>
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Add relevant tags to increase visibility
                                </li>
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Include high-quality images or videos
                                </li>
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Format your text for readability
                                </li>
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Respond to comments to boost engagement
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Community Guidelines</h5>
                        </div>
                        <div class="card-body">
                            <p>Before posting, please ensure your content:</p>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-exclamation-circle text-warning me-2"></i>
                                    Follows community-specific rules
                                </li>
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-exclamation-circle text-warning me-2"></i>
                                    Doesn't contain personal information
                                </li>
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-exclamation-circle text-warning me-2"></i>
                                    Respects copyright and intellectual property
                                </li>
                                <li class="list-group-item bg-transparent">
                                    <i class="fas fa-exclamation-circle text-warning me-2"></i>
                                    Is free from hate speech and harassment
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</main>


@section Scripts {
    <!-- Custom JavaScript -->
    <script>
        // // Dark Mode Toggle
        // const darkModeToggle = document.getElementById('darkModeToggle');
        // const body = document.body;

        // // Check for saved theme preference or use preferred color scheme
        // const savedTheme = localStorage.getItem('theme');
        // if (savedTheme === 'dark' || (!savedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        //     body.classList.add('dark-mode');
        // }

        // if (darkModeToggle) {
        //     darkModeToggle.addEventListener('click', () => {
        //         body.classList.toggle('dark-mode');
        //         localStorage.setItem('theme', body.classList.contains('dark-mode') ? 'dark' : 'light');
        //     });
        // }

        // Community Selector
        const communitySelect = document.getElementById('communitySelect');
        const communityDropdown = document.getElementById('communityDropdown');
        const communityId = document.getElementById('communityId');

        communitySelect.addEventListener('focus', () => {
            communityDropdown.style.display = 'block';
        });

        communitySelect.addEventListener('input', () => {
            const searchTerm = communitySelect.value.toLowerCase();
            const communityItems = document.querySelectorAll('.community-item');

            communityItems.forEach(item => {
                const communityName = item.querySelector('div > div').textContent.toLowerCase();
                if (communityName.includes(searchTerm)) {
                    item.style.display = 'flex';
                } else {
                    item.style.display = 'none';
                }
            });

            communityDropdown.style.display = 'block';
        });

        document.addEventListener('click', (e) => {
            if (!communitySelect.contains(e.target) && !communityDropdown.contains(e.target)) {
                communityDropdown.style.display = 'none';
            }
        });

        // Select community when clicked
        const communityItems = document.querySelectorAll('.community-item');
        communityItems.forEach(item => {
            item.addEventListener('click', () => {
                const communityName = item.querySelector('div > div').textContent;
                const communityInitial = item.querySelector('.community-icon').textContent;
                communitySelect.value = communityName;
                communityDropdown.style.display = 'none';

                // Set community ID (in a real app, this would be the actual ID)
                communityId.value = communityName.replace('r/', '');

                // Update rules card with selected community
                document.querySelector('#communityRulesTitle').textContent = `${communityName} Rules`;
                document.getElementById('noCommunitySelected').style.display = 'none';
                document.getElementById('communityRules').style.display = 'block';

                // Update preview
                document.getElementById('previewCommunityName').textContent = communityName;
                document.getElementById('previewCommunityIcon').textContent = communityInitial;

                // Remove validation error if present
                communitySelect.classList.remove('is-invalid');
            });
        });

        // Post Type Tabs
        const postTypeTabs = document.querySelectorAll('.post-type-tab');
        const formSections = document.querySelectorAll('.form-section');
        const postTypeInput = document.getElementById('postType');

        postTypeTabs.forEach(tab => {
            tab.addEventListener('click', () => {
                // Remove active class from all tabs and sections
                postTypeTabs.forEach(t => t.classList.remove('active'));
                formSections.forEach(s => s.classList.remove('active'));

                // Add active class to clicked tab and corresponding section
                tab.classList.add('active');
                const type = tab.getAttribute('data-type');
                document.getElementById(`${type}PostForm`).classList.add('active');

                // Update hidden input
                postTypeInput.value = type;

                // Update preview based on post type
                updatePreview();
            });
        });

        // Title character count
        const postTitle = document.getElementById('Title');
        const titleCharCount = document.getElementById('titleCharCount');
        const slug = document.getElementById('slug');

        postTitle.addEventListener('input', () => {
            titleCharCount.textContent = postTitle.value.length;

            // Generate slug from title
            if (postTitle.value) {
                slug.value = postTitle.value
                    .toLowerCase()
                    .replace(/[^\w\s-]/g, '')
                    .replace(/\s+/g, '-')
                    .replace(/-+/g, '-')
                    .substring(0, 100);
            } else {
                slug.value = '';
            }

            // Update preview title
            document.getElementById('previewTitle').textContent = postTitle.value || 'Your post title will appear here';
        });

        // Text formatting
        const textContent = document.getElementById('textContent');
        const formattingButtons = document.querySelectorAll('.formatting-button');

        formattingButtons.forEach(button => {
            button.addEventListener('click', () => {
                const format = button.getAttribute('data-format');
                const textarea = textContent;
                const start = textarea.selectionStart;
                const end = textarea.selectionEnd;
                const selectedText = textarea.value.substring(start, end);
                let replacement = '';

                switch (format) {
                    case 'bold':
                        replacement = `**${selectedText}**`;
                        break;
                    case 'italic':
                        replacement = `*${selectedText}*`;
                        break;
                    case 'link':
                        replacement = selectedText ? `[${selectedText}](url)` : '[Link text](url)';
                        break;
                    case 'ul':
                        replacement = selectedText ? selectedText.split('\n').map(line => `* ${line}`).join('\n') : '* List item';
                        break;
                    case 'ol':
                        replacement = selectedText ? selectedText.split('\n').map((line, i) => `${i+1}. ${line}`).join('\n') : '1. List item';
                        break;
                    case 'quote':
                        replacement = selectedText ? selectedText.split('\n').map(line => `> ${line}`).join('\n') : '> Quote';
                        break;
                    case 'code':
                        replacement = selectedText ? `\`\`\`\n${selectedText}\n\`\`\`` : '\`\`\`\ncode\n\`\`\`';
                        break;
                    case 'heading':
                        replacement = selectedText ? `# ${selectedText}` : '# Heading';
                        break;
                }

                textarea.value = textarea.value.substring(0, start) + replacement + textarea.value.substring(end);
                textarea.focus();
                textarea.selectionStart = start + replacement.length;
                textarea.selectionEnd = start + replacement.length;

                // Update preview content
                updatePreviewContent();
            });
        });

        textContent.addEventListener('input', updatePreviewContent);

        function updatePreviewContent() {
            const content = textContent.value;
            let formattedContent = content;

            // Simple markdown-like formatting for preview
            formattedContent = formattedContent
                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                .replace(/\*(.*?)\*/g, '<em>$1</em>')
                .replace(/# (.*?)(\n|$)/g, '<h3>$1</h3>')
                .replace(/\[(.*?)\]$$(.*?)$$/g, '<a href="$2">$1</a>')
                .replace(/> (.*?)(\n|$)/g, '<blockquote>$1</blockquote>')
                .replace(/\`\`\`([\s\S]*?)\`\`\`/g, '<pre><code>$1</code></pre>')
                .replace(/`(.*?)`/g, '<code>$1</code>')
                .replace(/\n/g, '<br>');

            document.getElementById('previewContent').innerHTML = formattedContent || 'Your post content will appear here';
        }

        // Image preview
        const imageUpload = document.getElementById('imageUpload');
        const imagePreview = document.getElementById('imagePreview');

        imageUpload.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                const file = e.target.files[0];
                const url = URL.createObjectURL(file);
                imagePreview.src = url;
                imagePreview.style.display = 'block';
                imageUpload.classList.remove('is-invalid');

                // Update preview content
                updatePreview();
            }
        });

        // Video preview
        const videoUpload = document.getElementById('videoUpload');
        const videoPreview = document.getElementById('videoPreview');

        videoUpload.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                const file = e.target.files[0];
                const url = URL.createObjectURL(file);
                videoPreview.src = url;
                videoPreview.style.display = 'block';
                videoUpload.classList.remove('is-invalid');

                // Update preview content
                updatePreview();
            }
        });

        // Poll options
        const addPollOption = document.getElementById('addPollOption');
        const pollOptionsContainer = document.getElementById('pollOptionsContainer');

        addPollOption.addEventListener('click', () => {
            const optionCount = pollOptionsContainer.children.length + 1;
            const newOption = document.createElement('div');
            newOption.className = 'poll-option';
            newOption.innerHTML = `
                <input type="text" class="form-control poll-option-input" name="pollOptions[]" placeholder="Option ${optionCount}" required>
                <button type="button" class="btn btn-sm btn-outline-danger remove-option">
                    <i class="fas fa-times"></i>
                </button>
            `;
            pollOptionsContainer.appendChild(newOption);

            // Enable remove buttons if there are more than 2 options
            if (pollOptionsContainer.children.length > 2) {
                const removeButtons = document.querySelectorAll('.remove-option');
                removeButtons.forEach(btn => btn.disabled = false);
            }

            // Update preview
            updatePreview();
        });

        // Remove poll option
        pollOptionsContainer.addEventListener('click', (e) => {
            if (e.target.closest('.remove-option')) {
                const button = e.target.closest('.remove-option');
                const option = button.parentElement;

                // Only remove if there are more than 2 options
                if (pollOptionsContainer.children.length > 2) {
                    option.remove();

                    // Update placeholders
                    const options = pollOptionsContainer.querySelectorAll('.poll-option input');
                    options.forEach((input, index) => {
                        input.placeholder = `Option ${index + 1}`;
                    });

                    // Disable remove buttons if only 2 options remain
                    if (pollOptionsContainer.children.length <= 2) {
                        const removeButtons = document.querySelectorAll('.remove-option');
                        removeButtons.forEach(btn => btn.disabled = true);
                    }

                    // Update preview
                    updatePreview();
                }
            }
        });

        // Poll expiration toggle
        const pollExpiration = document.getElementById('pollExpiration');
        const pollExpirationGroup = document.getElementById('pollExpirationGroup');

        pollExpiration.addEventListener('change', () => {
            pollExpirationGroup.style.display = pollExpiration.checked ? 'flex' : 'none';
        });

        // Tags input
        const tagInput = document.getElementById('tag-input');
        const tagContainer = document.getElementById('tagContainer');
        const previewTags = document.getElementById('previewTags');
        let tags = [];

        tagInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && tagInput.value.trim() !== '') {
                e.preventDefault();

                // Only allow up to 5 tags
                if (tags.length < 5) {
                    const tagText = tagInput.value.trim();

                    // Check if tag already exists
                    if (!tags.includes(tagText)) {
                        tags.push(tagText);

                        const tagElement = document.createElement('div');
                        tagElement.className = 'tag';
                        tagElement.innerHTML = `
                            ${tagText}
                            <i class="fas fa-times" data-tag="${tagText}"></i>
                        `;

                        tagContainer.insertBefore(tagElement, tagInput);
                        tagInput.value = '';

                        // Update preview tags
                        updatePreviewTags();
                    }
                }
            }
        });

        // Remove tag when clicked
        tagContainer.addEventListener('click', (e) => {
            if (e.target.tagName === 'I') {
                const tagToRemove = e.target.getAttribute('data-tag');
                tags = tags.filter(tag => tag !== tagToRemove);
                e.target.parentElement.remove();

                // Update preview tags
                updatePreviewTags();
            }
        });

        function updatePreviewTags() {
            previewTags.innerHTML = '';

            tags.forEach(tag => {
                const tagElement = document.createElement('div');
                tagElement.className = 'preview-tag';
                tagElement.textContent = tag;
                previewTags.appendChild(tagElement);
            });
        }

        // NSFW and Spoiler toggles
        const nsfwToggle = document.getElementById('nsfwToggle');
        const spoilerToggle = document.getElementById('spoilerToggle');
        const previewNSFW = document.getElementById('previewNSFW');
        const previewSpoiler = document.getElementById('previewSpoiler');

        nsfwToggle.addEventListener('change', () => {
            previewNSFW.style.display = nsfwToggle.checked ? 'inline-block' : 'none';
        });

        spoilerToggle.addEventListener('change', () => {
            previewSpoiler.style.display = spoilerToggle.checked ? 'inline-block' : 'none';
        });

        // Post preview
        const previewBtn = document.getElementById('previewBtn');

        previewBtn.addEventListener('click', () => {
            updatePreview();

            // Scroll to preview
            document.getElementById('postPreview').scrollIntoView({ behavior: 'smooth' });
        });

        function updatePreview() {
            // Update title
            document.getElementById('previewTitle').textContent = postTitle.value || 'Your post title will appear here';

            // Get content based on active post type
            const activeType = document.querySelector('.post-type-tab.active').getAttribute('data-type');
            let content = '';

            switch (activeType) {
                case 'text':
                    updatePreviewContent();
                    break;
                case 'image':
                    if (imagePreview.style.display === 'block') {
                        const caption = document.getElementById('imageCaption').value;
                        content = `<img src="${imagePreview.src}" alt="Image Preview" style="max-width: 100%; border-radius: 4px; margin-bottom: 10px;">`;
                        if (caption) content += `<p>${caption}</p>`;
                    } else {
                        content = 'No image selected';
                    }
                    document.getElementById('previewContent').innerHTML = content;
                    break;
                case 'video':
                    if (videoPreview.style.display === 'block') {
                        const caption = document.getElementById('videoCaption').value;
                        content = `<video controls src="${videoPreview.src}" style="max-width: 100%; border-radius: 4px; margin-bottom: 10px;"></video>`;
                        if (caption) content += `<p>${caption}</p>`;
                    } else {
                        content = 'No video selected';
                    }
                    document.getElementById('previewContent').innerHTML = content;
                    break;
                case 'link':
                    const url = document.getElementById('linkUrl').value;
                    const description = document.getElementById('linkDescription').value;
                    content = url ? `<p><a href="${url}" target="_blank">${url}</a></p>` : 'No link provided';
                    if (description) content += `<p>${description}</p>`;
                    document.getElementById('previewContent').innerHTML = content;
                    break;
                case 'poll':
                    content = '<div style="border: 1px solid var(--border-color); padding: 10px; border-radius: 4px; margin-bottom: 10px;"><h6>Poll</h6>';
                    const options = pollOptionsContainer.querySelectorAll('.poll-option-input');
                    options.forEach((option, index) => {
                        if (option.value) {
                            content += `
                                <div style="margin-bottom: 8px;">
                                    <div style="display: flex; align-items: center;">
                                        <input type="radio" id="pollPreview${index}" name="pollPreview" style="margin-right: 8px;">
                                        <label for="pollPreview${index}">${option.value}</label>
                                    </div>
                                </div>
                            `;
                        }
                    });

                    const allowMultiple = document.getElementById('allowMultipleChoices').checked;
                    const showResults = document.getElementById('showResultsBeforeVoting').checked;
                    const hasExpiration = document.getElementById('pollExpiration').checked;

                    content += '<button style="width: 100%; padding: 6px; margin-top: 10px; background-color: var(--primary-color); color: white; border: none; border-radius: 4px;" disabled>Vote</button>';

                    if (hasExpiration) {
                        const duration = document.getElementById('pollDuration').value;
                        const durationType = document.getElementById('pollDurationType').value;
                        content += `<div style="margin-top: 8px; font-size: 0.85rem; color: var(--text-light);">Poll closes in ${duration} ${durationType}</div>`;
                    }

                    content += '</div>';
                    document.getElementById('previewContent').innerHTML = content;
                    break;
            }
        }

        // Form validation
        const postForm = document.getElementById('postForm');

        function validateForm() {
            let isValid = true;

            // Validate title
            if (!postTitle.value.trim()) {
                postTitle.classList.add('is-invalid');
                isValid = false;
            } else {
                postTitle.classList.remove('is-invalid');
            }

            // Validate community
            if (!communitySelect.value.trim()) {
                communitySelect.classList.add('is-invalid');
                isValid = false;
            } else {
                communitySelect.classList.remove('is-invalid');
            }

            // Get active post type
            const activeType = document.querySelector('.post-type-tab.active').getAttribute('data-type');

            // Validate based on post type
            switch (activeType) {
                case 'image':
                    if (!imageUpload.files.length) {
                        imageUpload.classList.add('is-invalid');
                        isValid = false;
                    } else {
                        imageUpload.classList.remove('is-invalid');
                    }
                    break;
                case 'video':
                    if (!videoUpload.files.length) {
                        videoUpload.classList.add('is-invalid');
                        isValid = false;
                    } else {
                        videoUpload.classList.remove('is-invalid');
                    }
                    break;
                case 'link':
                    const linkUrl = document.getElementById('linkUrl');
                    if (!linkUrl.value.trim() || !isValidUrl(linkUrl.value)) {
                        linkUrl.classList.add('is-invalid');
                        isValid = false;
                    } else {
                        linkUrl.classList.remove('is-invalid');
                    }
                    break;
                case 'poll':
                    const pollOptions = pollOptionsContainer.querySelectorAll('.poll-option-input');
                    let validOptions = 0;
                    pollOptions.forEach(option => {
                        if (option.value.trim()) validOptions++;
                        else option.classList.add('is-invalid');
                    });

                    if (validOptions < 2) {
                        pollOptionsContainer.classList.add('is-invalid');
                        isValid = false;
                    } else {
                        pollOptionsContainer.classList.remove('is-invalid');
                        pollOptions.forEach(option => {
                            if (option.value.trim()) option.classList.remove('is-invalid');
                        });
                    }
                    break;
            }

            return isValid;
        }

        function isValidUrl(string) {
            try {
                new URL(string);
                return true;
            } catch (_) {
                return false;
            }
        }

        // Form submission
        postForm.addEventListener('submit', (e) => {
            e.preventDefault();

            if (validateForm()) {
                // Get active post type
                const activeType = document.querySelector('.post-type-tab.active').getAttribute('data-type');

                // Prepare form data
                const formData = new FormData(postForm);
                formData.append('tags', JSON.stringify(tags));

                // Simulate form submission
                alert('Post submitted successfully!');

                // In a real application, you would send the data to the server here
                // For demonstration purposes, we'll just log the data
                console.log({
                    title: postTitle.value,
                    type: activeType,
                    community: communitySelect.value,
                    communityId: communityId.value,
                    slug: slug.value,
                    tags: tags,
                    nsfw: nsfwToggle.checked,
                    spoiler: spoilerToggle.checked,
                    pinToProfile: document.getElementById('pinToggle').checked,
                    disableComments: document.getElementById('disableCommentsToggle').checked,
                    // Additional data based on post type would be collected here
                });

                // Reset form
                postForm.reset();
                document.getElementById('previewTitle').textContent = 'Your post title will appear here';
                document.getElementById('previewContent').textContent = 'Your post content will appear here';
                imagePreview.style.display = 'none';
                videoPreview.style.display = 'none';
                previewTags.innerHTML = '';
                previewNSFW.style.display = 'none';
                previewSpoiler.style.display = 'none';
                tags = [];
                const tagElements = document.querySelectorAll('.tag');
                tagElements.forEach(tag => tag.remove());

                // Reset community rules
                document.getElementById('noCommunitySelected').style.display = 'block';
                document.getElementById('communityRules').style.display = 'none';
                document.querySelector('#communityRulesTitle').textContent = 'Community Rules';
                document.getElementById('previewCommunityName').textContent = 'Community';
                document.getElementById('previewCommunityIcon').textContent = 'r/';
            }
        });

        // Save as draft
        const saveAsDraft = document.getElementById('saveAsDraft');

        saveAsDraft.addEventListener('click', () => {
            // Validate minimal requirements for a draft
            if (!postTitle.value.trim()) {
                postTitle.classList.add('is-invalid');
                alert('Please enter a title for your draft');
                return;
            }

            // Get active post type
            const activeType = document.querySelector('.post-type-tab.active').getAttribute('data-type');

            // Prepare draft data
            const draftData = {
                title: postTitle.value,
                type: activeType,
                community: communitySelect.value,
                communityId: communityId.value,
                content: activeType === 'text' ? textContent.value : '',
                tags: tags,
                nsfw: nsfwToggle.checked,
                spoiler: spoilerToggle.checked,
                savedAt: new Date().toISOString()
            };

            // In a real application, you would save this to localStorage or server
            console.log('Draft saved:', draftData);

            // Show confirmation
            alert('Post saved as draft');
        });

        // Initialize preview on page load
        updatePreview();
    </script>

}






