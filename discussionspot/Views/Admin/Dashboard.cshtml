                        </a>
                        <a class="nav-link" id="users-tab" data-bs-toggle="pill" href="#users" role="tab">
                            <i class="fas fa-users"></i> Users
                        </a>
                        <a class="nav-link" id="communities-tab" data-bs-toggle="pill" href="#communities" role="tab">
                            <i class="fas fa-users-rectangle"></i> Communities
                        </a>
                        <a class="nav-link" id="posts-tab" data-bs-toggle="pill" href="#posts" role="tab">
                            <i class="fas fa-file-alt"></i> Posts
                        </a>
                        <a class="nav-link" id="comments-tab" data-bs-toggle="pill" href="#comments" role="tab">
                            <i class="fas fa-comments"></i> Comments
                        </a>
                        <a class="nav-link" id="categories-tab" data-bs-toggle="pill" href="#categories" role="tab">
                            <i class="fas fa-folder"></i> Categories
                        </a>
                        <a class="nav-link" id="tags-tab" data-bs-toggle="pill" href="#tags" role="tab">
                            <i class="fas fa-tags"></i> Tags
                        </a>
                        <a class="nav-link" id="media-tab" data-bs-toggle="pill" href="#media" role="tab">
                            <i class="fas fa-images"></i> Media
                        </a>
                        <a class="nav-link" id="reports-tab" data-bs-toggle="pill" href="#reports" role="tab">
                            <i class="fas fa-flag"></i> Reports
                        </a>
                        <a class="nav-link" id="settings-tab" data-bs-toggle="pill" href="#settings" role="tab">
                            <i class="fas fa-cog"></i> Settings
                        </a>
                    </div>
                </div>
            </div>
            
